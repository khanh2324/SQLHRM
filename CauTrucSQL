CREATE FUNCTION [dbo].[BHXH_TINHTRUNGBINHLUONG6T]
(
@NhanVienID int,
@Thang int,
@Nam int
)
RETURNS decimal(20,5)
BEGIN
	-- Nếu lastworkingdate vào ngày cuối tháng có ngày hiệu lực vào tháng sau thì 6 tháng liền kề là từ tháng lastworkingdate
-- Nếu  lastworkingdate và ngày hiệu lực nghỉ việc cùng tháng thì 6 tháng liền kề là từ tháng lastworkingdate -1

declare @SoTien decimal(20,5)
	declare @date date = convert(date,convert(nvarchar,@Thang)+'/1/'+convert(nvarchar,@Nam))
	declare @Lastworkingdate int =(select month(dateadd(day,-1,NgayHieuLuc)) from NS_NhanVien_NghiViec where NhanVienID = @NhanVienID)
	declare @Thanghieuluc int =(select month(NgayHieuLuc) from NS_NhanVien_NghiViec where NhanVienID = @NhanVienID)
	
	if (@Lastworkingdate != @Thanghieuluc)
	begin
	set @SoTien=(select sum(TrungBinh)/6.0 from(
	select (select max(GiaTri) from NS_QTDienBienLuongChiTiet 
	inner join NS_QTDienBienLuong on NS_QTDienBienLuongChiTiet.QTDienBienLuongID = NS_QTDienBienLuong.QTDienBienLuongID
	where NS_QTDienBienLuong.NhanVienID=@NhanVienID and NS_QTDienBienLuongChiTiet.LoaiLuongID = 1
	and NS_QTDienBienLuong.NgayHuong = (select max(NgayHuong) from NS_QTDienBienLuong as QT where QT.NhanVienID
	= @NhanVienID and convert(date,QT.NgayHuong)<=NS_BH_NgayThang.Ngay)) as TrungBinh
	from NS_BH_NgayThang where day(ngay)=15
	and ngay between dateadd(mm,-5,@date) and eomonth(@date)) as a)
	end
	else 
	set @SoTien=(select sum(TrungBinh)/6.0 from(
	select (select max(GiaTri) from NS_QTDienBienLuongChiTiet 
	inner join NS_QTDienBienLuong on NS_QTDienBienLuongChiTiet.QTDienBienLuongID = NS_QTDienBienLuong.QTDienBienLuongID
	where NS_QTDienBienLuong.NhanVienID=@NhanVienID and NS_QTDienBienLuongChiTiet.LoaiLuongID = 1
	and NS_QTDienBienLuong.NgayHuong = (select max(NgayHuong) from NS_QTDienBienLuong as QT where QT.NhanVienID
	= @NhanVienID and convert(date,QT.NgayHuong)<=NS_BH_NgayThang.Ngay)) as TrungBinh
	from NS_BH_NgayThang where day(ngay)=15
	and ngay between dateadd(mm,-6,@date) and dateadd(mm,-1,eomonth(@date)) ) as a)
	return isnull(@SoTien,0)
END
GO
