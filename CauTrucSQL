CREATE PROCEDURE [dbo].[XD_LayDSXetDuyet_OT]
@NhanVienID int,
@NguoiDungID int,
@MaLoaiQuyTrinh nvarchar(100),
@QuyTrinhID int,
@TrangThai int
AS
BEGIN
SELECT 
	NhanVien.MaNhanVien+' - '+NhanVien.Ho+' '+NhanVien.HoTen as NguoiTao,-- N'Name',
	Convert(nvarchar,NS_TL_DangKyOT.NgayDangKy,103) as NgayTao, --Date,
	PhongBan.Ten as Department,
    NS_DsChucVu.TenChucVu as ChucVu, --Position,
    WF_QuyTrinh_ThucHien.QuyTrinhThucHienID,
	CONVERT(NVARCHAR,BatDauLamThem,108) +' - '+ CONVERT(NVARCHAR,KetThucLamThem,108) AS  Register,
	ISNULL(NS_TL_DangKyOT.CanhBaoTangCa,'') as Notify,
	SYS_XetDuyet.TenXetDuyet,
	ISNULL(LyDo.TenLyDoTangCa,'')+' '+ISNULL(NS_TL_DangKyOT.LyDoTangCa,'') as Reason
FROM WF_QuyTrinh_ThucHien
    left join SYS_XetDuyet  ON SYS_XetDuyet.XetDuyetID=WF_QuyTrinh_ThucHien.XetDuyetID AND ObjectCode='NS_TL_DangKyOT'
    left join dbo.NS_TL_DangKyOT on NS_TL_DangKyOT.DangKyOTID=SYS_XetDuyet.ObjectID
	left join NhanVien on NhanVien.NhanVienID = NS_TL_DangKyOT.NhanVienID
	left join PhongBan on PhongBan.PhongBanID = NhanVien.PhongBanID
    left join NS_DsChucVu on NS_DsChucVu.ChucVuID = nhanvien.ChucVuID
	left join WF_QuyTrinh on WF_QuyTrinh.QuyTrinhID = SYS_XetDuyet.QuyTrinhID
	left join NS_DsLyDoTangCa as LyDo on LyDO.LyDoTangCaID = NS_TL_DangKyOT.LyDoTangCaID
WHERE ((SYS_XetDuyet.TrangThai=100) OR (SYS_XetDuyet.TrangThai=@TrangThai)) AND (WF_QuyTrinh_ThucHien.TrangThai=@TrangThai) 
    AND (WF_QuyTrinh_ThucHien.NguoiDungXetDuyetID=@NguoiDungID) AND (WF_QuyTrinh.QuyTrinhID=@QuyTrinhID)
	END
