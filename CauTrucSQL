create FUNCTION [dbo].[fnt_GetNgayGioKyCong](@CongTyID INT, @NgayChamCong DATE)  
RETURNS TABLE  
AS  
RETURN  
(  
    WITH ThongSoGiaTri AS (  
        SELECT  
            ts.MaSo,  
            GiaTri =   
                CASE   
                    WHEN gv.GiaTri IS NOT NULL THEN TRY_CAST(CAST(gv.GiaTri AS NVARCHAR(20)) AS INT)  
                    ELSE TRY_CAST(CAST(ts.GiaTri AS NVARCHAR(20)) AS INT)  
                END  
        FROM SYS_ThongSo ts  
        LEFT JOIN SYS_ThongSo_GiaTri gv ON gv.ThongSoID = ts.ThongSoID AND gv.CongTyID = @CongTyID  
        WHERE ts.MaSo IN ('NBDCC', 'NKTCC')  
    ),  
    Params AS (  
        SELECT  
            NBDCC = ISNULL(MAX(CASE WHEN MaSo = 'NBDCC' THEN GiaTri END), 0),  
            NKTCC = ISNULL(MAX(CASE WHEN MaSo = 'NKTCC' THEN GiaTri END), 0)  
        FROM ThongSoGiaTri  
    ),  
    Dates AS (  
        SELECT  
            NgayBD_CongThang =   
                CASE  
                    WHEN NBDCC IN (0, 1) THEN DATEFROMPARTS(YEAR(@NgayChamCong), MONTH(@NgayChamCong), 1)  
                    WHEN DAY(@NgayChamCong) >= NBDCC THEN DATEFROMPARTS(YEAR(@NgayChamCong), MONTH(@NgayChamCong), NBDCC)  
                    ELSE DATEFROMPARTS(YEAR(DATEADD(MONTH, -1, @NgayChamCong)), MONTH(DATEADD(MONTH, -1, @NgayChamCong)), NBDCC)  
                END,  
            NgayKT_CongThang =   
                CASE  
                    WHEN NBDCC IN (0, 1) THEN EOMONTH(@NgayChamCong)  
                    WHEN DAY(@NgayChamCong) >= NBDCC THEN DATEFROMPARTS(YEAR(DATEADD(MONTH, 1, @NgayChamCong)), MONTH(DATEADD(MONTH, 1, @NgayChamCong)), NKTCC)  
                    ELSE DATEFROMPARTS(YEAR(@NgayChamCong), MONTH(@NgayChamCong), NKTCC)  
                END  
        FROM Params  
    )  
    SELECT  
        NgayBD_CongThang = CAST(NgayBD_CongThang AS DATETIME),  
        NgayKT_CongThang = DATEADD(SECOND, 86399, CAST(NgayKT_CongThang AS DATETIME))  
    FROM Dates  
)  
  
/*  
CREATE NONCLUSTERED INDEX IX_SYS_ThongSo_MaSo  
ON SYS_ThongSo (MaSo)  
INCLUDE (ThongSoID, GiaTri);  
  
CREATE NONCLUSTERED INDEX IX_ThongSoGiaTri_ThongSoID_CongTyID  
ON SYS_ThongSo_GiaTri (ThongSoID, CongTyID)  
INCLUDE (GiaTri);  
  
  
  
*/
GO
