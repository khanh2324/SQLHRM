CREATE PROCEDURE [dbo].[DanhGiaLaiXe]
		@PhongBanID INT ,
		@DangNhapID INT ,
		@Nam INT,
		@Thang int
AS
BEGIN


DECLARE @DotTuyenDungID INT = 1;   -- đợt
DECLARE @VongThiID      INT = 5;   -- vòng (bắt buộc)

DECLARE @cols        NVARCHAR(MAX) = N'';  -- danh sách cột điểm: [DM_0001],[KN_0002],...
DECLARE @selScore    NVARCHAR(MAX) = N'';  -- select sp.[DM_0001], sp.[KN_0002],...
DECLARE @selName     NVARCHAR(MAX) = N'';  -- select np.[DM_0001] AS [DM_0001_Name], ...
DECLARE @sql         NVARCHAR(MAX);

-- 1) Lấy danh sách cột động theo người chấm của vòng
DECLARE @ColsTbl TABLE(ColName NVARCHAR(256), BaseName NVARCHAR(256));
WITH CteCols AS (
    SELECT DISTINCT
        QUOTENAME(mt.MaMonThi + '_' + ISNULL(nv.MaNhanVien, CONVERT(varchar(10), mtts.NguoiChamDiemID))) AS ColName,
        mt.MaMonThi + '_' + ISNULL(nv.MaNhanVien, CONVERT(varchar(10), mtts.NguoiChamDiemID))            AS BaseName
    FROM dbo.NS_TD_MonThi_ThiSinh              AS mtts
    INNER JOIN dbo.NS_TD_MonThi                AS mt   ON mt.MonThiID        = mtts.MonThiID
    INNER JOIN dbo.NS_TD_DotTuyenDung          AS dtd  ON dtd.DotTuyenDungID = mtts.DotTuyenDungID
    INNER JOIN dbo.NS_TD_VongThi               AS vt   ON vt.VongThiID       = mtts.VongThiID
    INNER JOIN dbo.NS_TD_VongThi_NguoiChamDiem AS vtn  ON vtn.VongThiID      = vt.VongThiID
                                                     AND vtn.NguoiChamDiemID = mtts.NguoiChamDiemID
    LEFT  JOIN dbo.NhanVien                    AS nv   ON nv.NhanVienID      = mtts.NguoiChamDiemID
    WHERE dtd.DotTuyenDungID = @DotTuyenDungID
      AND vt.VongThiID       = @VongThiID
      AND mt.MaMonThi IN ('SK','TC','KNGT','KN','KTL','KTTL','KTMM','KTAT','KNTN','DM','DY')
)
INSERT INTO @ColsTbl(ColName, BaseName)
SELECT ColName, BaseName FROM CteCols;

-- 2) Chuỗi cột cho PIVOT và SELECT
SELECT
  @cols = STUFF( (SELECT ',' + ColName FROM @ColsTbl FOR XML PATH(''), TYPE).value('.','nvarchar(max)'), 1, 1, ''),
  @selScore = STUFF( (SELECT ',' + 'sp.' + ColName FROM @ColsTbl FOR XML PATH(''), TYPE).value('.','nvarchar(max)'), 1, 1, ''),
  @selName = STUFF( (SELECT ',' + 'np.' + ColName + ' AS ' + QUOTENAME(BaseName + '_Name')
                     FROM @ColsTbl FOR XML PATH(''), TYPE).value('.','nvarchar(max)'), 1, 1, '');

-- 3) Nếu chưa có dữ liệu để pivot thì trả danh sách thí sinh
IF ISNULL(@cols, N'') = N''
BEGIN
    SELECT ts.ThiSinhID, ts.SoBaoDanh, ts.TenHo + N' ' + ts.Ten AS FullName
    FROM dbo.NS_TD_ThiSinh AS ts
    WHERE EXISTS (
        SELECT 1 FROM dbo.NS_TD_MonThi_ThiSinh AS m
        WHERE m.ThiSinhID = ts.ThiSinhID AND m.DotTuyenDungID = @DotTuyenDungID AND m.VongThiID = @VongThiID
    )
    ORDER BY ts.ThiSinhID;
    RETURN;
END;

-- 4) Ghép 2 pivot: điểm (sp) + tên giám khảo (np)
SET @sql = N'
SELECT
    ts.ThiSinhID,
    ts.SoBaoDanh,
    ts.TenHo + N'' '' + ts.Ten AS FullName, ' + @selScore + N', ' + @selName + N'
FROM (
    SELECT
        mtts.ThiSinhID,
        mt.MaMonThi + ''_'' + ISNULL(nv.MaNhanVien, CONVERT(varchar(10), mtts.NguoiChamDiemID)) AS Mon_Exam,
        CAST(mtts.DiemThi AS decimal(18,2)) AS Diem
    FROM dbo.NS_TD_MonThi_ThiSinh              AS mtts
    INNER JOIN dbo.NS_TD_MonThi                AS mt   ON mt.MonThiID        = mtts.MonThiID
    INNER JOIN dbo.NS_TD_DotTuyenDung          AS dtd  ON dtd.DotTuyenDungID = mtts.DotTuyenDungID
    INNER JOIN dbo.NS_TD_VongThi               AS vt   ON vt.VongThiID       = mtts.VongThiID
    INNER JOIN dbo.NS_TD_VongThi_NguoiChamDiem AS vtn  ON vtn.VongThiID      = vt.VongThiID
                                                      AND vtn.NguoiChamDiemID= mtts.NguoiChamDiemID
    LEFT  JOIN dbo.NhanVien                    AS nv   ON nv.NhanVienID      = mtts.NguoiChamDiemID
    WHERE dtd.DotTuyenDungID = @DotTuyenDungID
      AND vt.VongThiID       = @VongThiID
      AND mt.MaMonThi IN (''SK'',''TC'',''KNGT'',''KN'',''KTL'',''KTTL'',''KTMM'',''KTAT'',''KNTN'',''DM'',''DY'')
) AS src
PIVOT ( AVG(Diem) FOR Mon_Exam IN (' + @cols + N') ) AS sp
-- pivot tên giám khảo (text) theo cùng bộ cột
INNER JOIN (
    SELECT
        mtts.ThiSinhID,
        mt.MaMonThi + ''_'' + ISNULL(nv.MaNhanVien, CONVERT(varchar(10), mtts.NguoiChamDiemID)) AS Mon_Exam,
        nv.HoTen AS TenGiamKhao
    FROM dbo.NS_TD_MonThi_ThiSinh              AS mtts
    INNER JOIN dbo.NS_TD_MonThi                AS mt   ON mt.MonThiID        = mtts.MonThiID
    INNER JOIN dbo.NS_TD_DotTuyenDung          AS dtd  ON dtd.DotTuyenDungID = mtts.DotTuyenDungID
    INNER JOIN dbo.NS_TD_VongThi               AS vt   ON vt.VongThiID       = mtts.VongThiID
    INNER JOIN dbo.NS_TD_VongThi_NguoiChamDiem AS vtn  ON vtn.VongThiID      = vt.VongThiID
                                                      AND vtn.NguoiChamDiemID= mtts.NguoiChamDiemID
    LEFT  JOIN dbo.NhanVien                    AS nv   ON nv.NhanVienID      = mtts.NguoiChamDiemID
    WHERE dtd.DotTuyenDungID = @DotTuyenDungID
      AND vt.VongThiID       = @VongThiID
      AND mt.MaMonThi IN (''SK'',''TC'',''KNGT'',''KN'',''KTL'',''KTTL'',''KTMM'',''KTAT'',''KNTN'',''DM'',''DY'')
) AS src2
PIVOT ( MAX(TenGiamKhao) FOR Mon_Exam IN (' + @cols + N') ) AS np
    ON np.ThiSinhID = sp.ThiSinhID
INNER JOIN dbo.NS_TD_ThiSinh AS ts
    ON ts.ThiSinhID = sp.ThiSinhID
ORDER BY ts.ThiSinhID;';

EXEC sys.sp_executesql
    @sql,
    N'@DotTuyenDungID INT, @VongThiID INT',
    @DotTuyenDungID = @DotTuyenDungID,
    @VongThiID      = @VongThiID
END
GO
