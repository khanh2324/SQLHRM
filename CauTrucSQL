CREATE FUNCTION [dbo].[fn_LayNgayGioKyCong](@CongTyID  int, @NgayChamCong DATE)      
RETURNS @ReturnTable TABLE (NgayBD_CongThang datetime, NgayKT_CongThang datetime)      
AS      
BEGIN      
  DECLARE @NBDCC int = CONVERT(INT, ISNULL((SELECT GiaTri FROM SYS_ThongSo_GiaTri WHERE ThongSoID = (SELECT ThongSoID FROM  SYS_ThongSo where MaSo ='NBDCC' ) and CongTyID =@CongTyID),0))    
  DECLARE @NKTCC INT = CONVERT(INT,ISNULL((SELECT GiaTri FROM SYS_ThongSo_GiaTri WHERE ThongSoID = (SELECT ThongSoID FROM  SYS_ThongSo where MaSo ='NKTCC' ) and CongTyID =@CongTyID) ,0))    
      
  DECLARE @NgayBD_CongThang DATETIME ,   @NgayKT_CongThang DATETIME     
  DECLARE @NCC date = @NgayChamCong    
  IF(@NBDCC IN(0,1))    
  BEGIN    
   SET @NgayBD_CongThang=CONCAT(MONTH(@NgayChamCong),'/01/',YEAR(@NgayChamCong), ' 00:00:00')    
   SET @NgayKT_CongThang=CONCAT(EOMONTH(@NgayChamCong), ' 23:59:59')    
  END    
  ELSE IF(DAY(@NCC) >= @NBDCC)    
  BEGIN     
   SET @NgayBD_CongThang=CONCAT(MONTH(@NCC),'/',@NBDCC,'/',YEAR(@NCC), ' 00:00:00')    
   SET @NCC = DATEADD(MONTH, 1, @NCC)    
   SET @NgayKT_CongThang=CONCAT(MONTH(@NCC),'/',@NKTCC,'/',YEAR(@NCC), ' 23:59:59')    
  END    
  ELSE    
  BEGIN      
   SET @NgayKT_CongThang=CONCAT(MONTH(@NCC),'/',@NKTCC,'/',YEAR(@NCC), ' 23:59:59')    
   SET @NCC = DATEADD(MONTH, -1, @NCC)    
   SET @NgayBD_CongThang=CONCAT(MONTH(@NCC),'/',@NBDCC,'/',YEAR(@NCC), ' 00:00:00')    
  END    
    
    
    
 INSERT @ReturnTable        
 SELECT @NgayBD_CongThang NgayBD_CongThang, @NgayKT_CongThang NgayKT_CongThang    
 RETURN        
END      
      
    
    
GO
