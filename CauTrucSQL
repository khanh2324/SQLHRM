CREATE PROCEDURE [dbo].[ADD_BaoCaoThue051]    
(    
    @PhongBanID INT, @Nam INT, @NhanVienID INT , @DangNhapID INT   
)    
AS    
BEGIN    

--DECLARE @PhongBanID INT = 20,
--        @Nam        INT = 2025,
--        @NhanVienID INT = 0,      -- 0 hoặc -1001 = tất cả
--        @DangNhapID INT = 3115;

DECLARE @Date DATE = DATEFROMPARTS(@Nam, 12, 31);

;WITH HD AS (
    -- Tất cả HĐ của nhân viên trong năm quyết toán @Nam (hợp đồng có giao thoa với năm này)
    SELECT 
        hd.NhanVienID,
        hd.NgayBatDau,
        hd.NgayKetThuc,
        lhd.MaLoaiHD
    FROM NS_HopDong hd
    INNER JOIN NS_DsLoaiHopDong lhd 
        ON hd.LoaiHopDongID = lhd.LoaiHopDongID
    WHERE 
        -- Hợp đồng giao thoa với khoảng 01/01/@Nam - 31/12/@Nam
        hd.NgayBatDau <= DATEFROMPARTS(@Nam,12,31)
        AND ISNULL(hd.NgayKetThuc,'2099-12-31') >= DATEFROMPARTS(@Nam,1,1)
),
HDYear AS (
    -- Thông tin hợp đồng trong năm: chỉ cần biết có HĐTV không
    SELECT
        h.NhanVienID,
        CoHDTV  = MAX(CASE WHEN h.MaLoaiHD = N'HĐTV' THEN 1 ELSE 0 END)
        -- Nếu sau này cần, vẫn có thể thêm CoHDLD:
        -- ,CoHDLD  = MAX(CASE WHEN h.MaLoaiHD = N'HĐLĐ' THEN 1 ELSE 0 END)
    FROM HD h
    GROUP BY h.NhanVienID
)
SELECT
    qtn.HoVaTen                     AS HoVaTen,              -- Họ và tên (*)
    qtn.MaSoThue                    AS MaSoThue,             -- Mã số thuế

    -- Cá nhân uỷ quyền quyết toán thay: 1 = có bản ghi trong ADD_UyQuyenThue, 0 = không
    UyQuyenQuyetToanThay = CASE 
                  WHEN EXISTS (
                      SELECT 1 
                      FROM ADD_UyQuyenThue uy
                      WHERE uy.NhanVienID = qtn.NhanVienID
                        AND uy.Nam        = @Nam
                  ) THEN 1 
                  ELSE 0 
              END,

    -- Tổng số tiền thu nhập chịu thuế cả năm
    ISNULL(qtn.TongThuNhapChiuThueNam, 0) AS TongThuNhapChiuThue,
    ISNULL(qtn.BH_Tong_NLD, 0)      AS BaoHiemDuocTru,

    -- Số thuế TNCN đã khấu trừ trong năm
    ISNULL(qtn.TongThueDaKhauTruNam, 0)   AS ThueTNCNDaKhauTru

FROM dbo.ADD_QuyetToanThueNam qtn
    INNER JOIN dbo.NhanVien nv 
        ON nv.NhanVienID = qtn.NhanVienID

    -- Thông tin phòng ban tại thời điểm cuối năm
    CROSS APPLY dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1
    INNER JOIN dbo.PhongBan pb 
        ON pb.PhongBanID = pb1.PhongBanID

    -- Thông tin hợp đồng trong năm
    LEFT JOIN HDYear hdy
        ON hdy.NhanVienID = qtn.NhanVienID

WHERE 
    qtn.Nam = @Nam

    -- Chỉ lấy đối tượng là nhân viên (bỏ vãng lai nếu có cột LoaiDoiTuong)
    AND (qtn.LoaiDoiTuong IS NULL OR qtn.LoaiDoiTuong = N'NhanVien')

 
    AND ISNULL(hdy.CoHDTV, 0) = 0

    AND pb.PhongBanID IN (SELECT valu FROM dbo.GetPhongBanChild_WUser(@PhongBanID, @DangNhapID))

    AND (@NhanVienID = 0 OR @NhanVienID = -1001 OR qtn.NhanVienID = @NhanVienID)

ORDER BY pb.ThuTuSapXep, qtn.HoVaTen

END
GO
