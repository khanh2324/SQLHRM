, a2 nvarchar(100), a3 nvarchar(100), a4 nvarchar(100), a5 nvarchar(100), a6 nvarchar(100))
AS
 begin
 declare @phongbanid int
  declare @tbl table(phongbanid int)
declare @tbltam table(id int IDENTITY(1,1) NOT NULL,ten nvarchar(100))
declare @dem int 
declare @stop int set @stop = (select phongbanid from PhongBan where PhongBanChaID = 0)
set @dem = 1
declare @phongbanchaid int
insert into @tbl
select phongbanid from PhongBan where phongbanid !=2629
