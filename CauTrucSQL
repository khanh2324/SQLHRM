CREATE FUNCTION [dbo].[fns_XacDinhNgayNghiCuaNhanVien] (    @NhanVienID INT,      @NgayChamCong DATETIME) RETURNS BIT AS   
  
  
BEGIN  
--declare @NhanVienID   int  = (select nhanvienid from  nhanvien where manhanvien ='80660')    
--, @NgayChamCong date ='03/29/2025'  
  
	
	declare @GioBatDau2 time ='00:00:00'
	SELECT  @GioBatDau2 = GioBatDau2 FROM NS_CaLamViec where CaLamViecID=(select dbo.fns_LayCaLamViecNhanVien(@NhanVienID, @NgayChamCong))

    DECLARE @IsNgayNghi BIT = 0;  
    DECLARE @Thu INT = DATEPART(WEEKDAY, @NgayChamCong);  
  
    DECLARE @MaLoaiCongChuan NVARCHAR(50),        @IsNgayNghiLuanPhien BIT;  
  
    SELECT @MaLoaiCongChuan = ISNULL(LC.MaLoaiCongChuan, '48H'), @IsNgayNghiLuanPhien = ISNULL(NV.IsNgayNghiLuanPhien, 0)  
    FROM NhanVien NV    LEFT JOIN ADD_LoaiCongChuan LC ON NV.LoaiCongChuanID = LC.LoaiCongChuanID  
    WHERE NV.NhanVienID = @NhanVienID;  
  
    -- Quy tắc nghỉ cố định  
    IF @Thu = 1  
        SET @IsNgayNghi = 1;  
    ELSE IF @Thu = 7 AND ISNULL(@MaLoaiCongChuan, '') IN ('44H') and convert(time,@NgayChamCong)>=@GioBatDau2
        SET @IsNgayNghi = 1;  
    ELSE IF @Thu = 7 AND ISNULL(@MaLoaiCongChuan, '') NOT IN ('48H', '44H')  
        SET @IsNgayNghi = 1;  
  
    -- Quy tắc nghỉ luân phiên  
    IF @IsNgayNghiLuanPhien = 1  
    begin   
         IF   EXISTS (  
                SELECT 1   
                FROM NS_TL_DangKyCong   
                WHERE CONVERT(DATE, NgayChamCong) = CONVERT(DATE, @NgayChamCong)  
                  AND NhanVienID = @NhanVienID   
                  AND XetDuyetCLV = 1   
                  AND (ISNULL(IsNgayNghi, 0) = 1  OR CaLamViecID = 72)
            ) set @IsNgayNghi =1  
            else set @IsNgayNghi =0  
    end  
  
  
    RETURN @IsNgayNghi;  
END  
GO
