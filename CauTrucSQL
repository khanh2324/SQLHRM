CREATE PROCEDURE [dbo].[ADD_XD_CONGTAC]
(@BuocThucHienID int,@BuocTiepTheoID int,@NguoiTaoID int,@XetDuyetID int)
AS
BEGIN
	--DECLARE @XetDuyetID INT = 24201,@BuocTiepTheoID INT = 1047

	DECLARE @ID INT = (SELECT ObjectID FROM SYS_XetDuyet WHERE XetDuyetID=@XetDuyetID)
	DECLARE @NhanVienID INT = (SELECT NhanVienID FROM NS_QTCongTac WHERE QTCongTacID = @ID)
	DECLARE @QuanLyTrucTiepID INT = (SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienID = @NhanVienID)
	DECLARE @LyDoCongTacID INT = (SELECT LyDoCongTacID FROM dbo.NS_QTCongTac WHERE QTCongTacID = @ID)
	DECLARE @TruongBoPhanID INT = (SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanId = (SELECT PhongbanID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID))

	DECLARE @GiamDocTQId INT = (SELECT TOP 1 ChucVuID FROM dbo.NS_DsChucVu where TenChucVu = N'Giám đốc Toàn quốc')
	DECLARE @ChucVuId INT = (SELECT ChucVuId FROM dbo.NhanVien WHERE NhanVienId = @NhanVienID)
	DECLARE @PhongBanID INT = (SELECT PhongBanID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)
	DECLARE @IDCapPhong INT = (SELECT dbo.fns_LayPhongBanIDTheoCap(1010,@PhongBanId))
	DECLARE @IDCapBoPhan INT = (SELECT dbo.fns_LayPhongBanIDTheoCap(1011,@PhongBanId))

	declare @CapBacID int = (select CapBacID from nhanvien where NhanVienID=@NhanVienID)

	declare @NguoiDuyetID int = 0

	-- thiết lập để test cho dễ
	IF @NhanVienID = 40452
	BEGIN
	    set @NguoiDuyetID = (select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID)
	END
	ELSE
	BEGIN
		-- Nếu không có cấp bậc thì lên chị Thơm duyệt
		if isnull(@CapBacID,0) in (0,1014)
		begin
			set @NguoiDuyetID = 3297
		end
		else
		begin
			-- - Nhân viên có Cấp bậc O (O1, O2…), S (S1, S2…), P (P1, P2…)
			if exists (select 1 from NS_DsCapBac where CapBacID = @CapBacID and TenBac like N'[OSP]%')
			begin 
				-- Công tác trong nước
				if @LyDoCongTacID = 6
				begin
					-- Bước 1 lên quản lý trực tiếp duyệt
					if @BuocTiepTheoID = 1035
					begin
						set @NguoiDuyetID = @QuanLyTrucTiepID
					end
					-- Bước 2: 
					else if @BuocTiepTheoID = 1047
					begin 
						-- Phòng Kỹ thuật lên trưởng bộ phận duyệt
						if @PhongBanID in (select valu from GetPhongBanChilds(155))
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapBoPhan)))
						end
						-- Phòng Vận hành lên trưởng bộ phận duyệt, nếu là trưởng bộ phận thì lên trưởng phòng duyệt
						else if @PhongBanID in (select valu from GetPhongBanChilds(161))
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapBoPhan)))
							if @NguoiDuyetID = (select NguoiDungID from SYS_NguoiDung where NhanVienID=@NhanVienID)
							begin
								set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
										(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
										(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong)))
							end
						end
						else
						-- Còn lại trưởng phòng duyệt
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong)))
						end
					end
					-- Bước 3,4
					else 
					begin
						set @NguoiDuyetID = 0
					end
				end
				-- Công tác nước ngoài
				else if @LyDoCongTacID = 5
				begin
					-- Bước 1 lên quản lý trực tiếp duyệt
					if @BuocTiepTheoID = 1035
					begin
						set @NguoiDuyetID = @QuanLyTrucTiepID
					end
					-- Bước 2: 
					else if @BuocTiepTheoID = 1047
					begin 
						-- Phòng Kỹ thuật lên trưởng bộ phận duyệt
						if @PhongBanID in (select valu from GetPhongBanChilds(155))
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapBoPhan)))
						end
						-- Phòng Vận hành lên trưởng bộ phận duyệt, nếu là trưởng bộ phận thì lên trưởng phòng duyệt
						else if @PhongBanID in (select valu from GetPhongBanChilds(161))
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapBoPhan)))
							if @NguoiDuyetID = (select NguoiDungID from SYS_NguoiDung where NhanVienID=@NhanVienID)
							begin
								set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
										(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
										(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong)))
							end
						end
						else
						-- Còn lại trưởng phòng duyệt
						begin
							set @NguoiDuyetID = (SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
									(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
									(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong)))
						end
					end
					-- Bước 3: Mr.Tùng duyệt 
					else if @BuocTiepTheoID = 1091
					begin
						set @NguoiDuyetID = 3125
					end
					-- Bước 4: Mr.Tâm duyệt 
					else if @BuocTiepTheoID = 1092
					begin
						set @NguoiDuyetID = 3150
					end
				end
			end
			else if exists (select 1 from NS_DsCapBac where CapBacID = @CapBacID and TenBac like N'M%')
			begin 
				-- Công tác trong nước
				if @LyDoCongTacID = 6
				begin
					-- Bước 1 lên quản lý trực tiếp duyệt
					if @BuocTiepTheoID = 1035
					begin
						set @NguoiDuyetID = @QuanLyTrucTiepID
					end
					-- Bước 2: Mr.Tâm duyệt
					else if @BuocTiepTheoID = 1047
					begin 
						if @QuanLyTrucTiepID in (3125,3150)
						begin
							set @NguoiDuyetID = 0
						end
						else
						begin
							set @NguoiDuyetID = 3150
						end
					end
					-- Bước 3,4
					else 
					begin
						set @NguoiDuyetID = 0
					end
				end
				-- Công tác nước ngoài
				else if @LyDoCongTacID = 5
				begin
					-- Bước 1 lên quản lý trực tiếp duyệt
					if @BuocTiepTheoID = 1035
					begin
						set @NguoiDuyetID = @QuanLyTrucTiepID
					end
					-- Bước 2: Mr.Tâm duyệt
					else if @BuocTiepTheoID = 1047
					begin 
						set @NguoiDuyetID = 3150
					end
					-- Bước 3: Mr.Sanjay duyệt 
					else if @BuocTiepTheoID = 1091
					begin
						set @NguoiDuyetID = 3321
					end
					-- Bước 4: Mr.Tùng duyệt 
					else if @BuocTiepTheoID = 1092
					begin
						set @NguoiDuyetID = 0
					end
				end
			end


		end


	END
	select @NguoiDuyetID

END
