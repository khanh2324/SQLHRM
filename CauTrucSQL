create FUNCTION [dbo].[fnt_GetChucDanhNhanVienTaiThoiDiem](@NhanVienID int, @NgayKiemTra DATE)  
RETURNS TABLE  
AS  
RETURN  
WITH DL AS (  
    SELECT   
        NhanVienID,  
        NgayHieuLuc,  
        ChucDanhMoiID,  
        ChucDanhCuID,  
        ROW_NUMBER() OVER (PARTITION BY NhanVienID ORDER BY   
            CASE   
                WHEN NgayHieuLuc <= @NgayKiemTra THEN 1   
                ELSE 2   
            END,  
            ABS(DATEDIFF(DAY, NgayHieuLuc, @NgayKiemTra))  
        ) AS RowNum  
    FROM NS_QTChuyenCanBo  
    WHERE XetDuyet = 1 and NhanVienID = @NhanVienID  
),  
Chon AS (  
    SELECT   
        nv.NhanVienID,  
        ISNULL(  
            (SELECT   
                CASE   
                    WHEN NgayHieuLuc <= @NgayKiemTra THEN ChucDanhMoiID  
                    ELSE ChucDanhCuID  
                END  
             FROM DL  
             WHERE DL.NhanVienID = nv.NhanVienID AND RowNum = 1),  
            nv.ChucDanhID  
        ) AS ChucDanhId  
    FROM NhanVien nv  
    WHERE ISNULL(nv.IsDeleted, 0) = 0 and NhanVienID = @NhanVienID  
)  
SELECT NhanVienID, ChucDanhId FROM Chon;  
