CREATE  FUNCTION [dbo].[fnt_GetPhongBanCon] (    @PhongBanChaID INT) RETURNS TABLE  AS    
    
RETURN    
(    
    WITH cte AS (    
        SELECT CongTyID, PhongBanID, PhongBanChaID, Ten    
