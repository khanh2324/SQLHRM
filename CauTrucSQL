			,[DonViTinh],[Deadline],[CreatedByID],[CreatedDate],[SanPhamDauRa],[Muc1],[Muc2],[Muc3]
			,[Muc4],[SoLuongChiTieu],[DanChungKetQuaTHCV],[IsHighLevel],[GiaTriNhoNhat],[NhanXetGiuaKy]
			,[NhanXetQLGiuaKy])
			select @BoTieuChiCuoiNamID,CONVERT(NVARCHAR,@BoTieuChiCuoiNamID),[NhanVienID],@DotDanhGiaID,
			case when TieuChiChaID=0 then 0 else (case when TieuChiChaID=1108 then 1121 end) end,
