create FUNCTION [dbo].[IsThaiSan] 
(
	-- Add the parameters for the function here
	@NhanVienID int,
	@T int,
	@N int
)
RETURNS int
AS
BEGIN
declare @r int
set @r = (select case when @NhanVienID IN(
