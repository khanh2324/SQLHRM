CREATE PROCEDURE [dbo].[UpdateChamCong]
	@thang int,
	@nam int
AS
BEGIN

delete NS_TL_BangChamCong where month(ngaychamcong) = @thang and year(NgayChamCong) = @nam
declare @Tbl_NgayThang table (Ngay datetime)
insert into @Tbl_NgayThang
select Ngay from NS_BH_NgayThang where month(Ngay)=@thang and year(Ngay)=@nam
declare @Tbl_NhanVien table(NhanVienID int)
insert into @Tbl_NhanVien
select distinct NhanVienID from NhanVien where NgayBatDauLam<=dateadd(dd,-1,dateadd(mm,1,convert(date,convert(nvarchar,@thang)+'/1/'+convert(nvarchar,@nam))))
and (Isnull(NghiViec,0)=0 or (NghiViec = 1 and NgayNghiViec>convert(date,convert(nvarchar,@thang)+'/1/'+convert(nvarchar,@nam))))
declare @Dem int = (select count(*) from @Tbl_NhanVien)
declare @NVID int
declare @NgayCheck date,@NgayNghi date ,@NgayBD date,@NgayCT date, @NgayKT date
declare @NgayCuoi date = (select max(Ngay) from @Tbl_NgayThang)
declare @KyHieuID int
while (@Dem!=0)
	begin
		set @NVID = (select top 1 NhanVienID from @Tbl_NhanVien)
		set @NgayCheck = (select min(Ngay) from @Tbl_NgayThang)
		set @NgayBD = (Select min(convert(date,NgayBatDau)) from NS_QTNghiPhep where NhanVienID = @NVID and isnull(KyHieuChamCongID,0) not in (22,23) and XetDuyet = 1)
		set @NgayNghi = (Select min(convert(date,NgayKetThuc)) from NS_QTNghiPhep where NhanVienID = @NVID and isnull(KyHieuChamCongID,0) not in (22,23) and XetDuyet = 1 )
		set @NgayCT = (Select min(convert(date,NgayBatDau)) from NS_QTCongTac where NhanVienID = @NVID and XetDuyet = 1)
		set @NgayKT =(Select min(convert(date,NgayKetThuc)) from NS_QTCongTac where NhanVienID = @NVID and XetDuyet = 1)
		while(@NgayCheck < @NgayCuoi)
			begin
				if((@NgayCheck between @NgayBD and @NgayNghi) and DATEPART(dw,@NgayCheck) not in (1,7))
					begin
						set @KyHieuID = (select KyHieuChamCongID from NS_QTNghiPhep where NhanVienID=@NVID and convert(date,NgayBatDau) = @NgayBD)
						insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
						select @NVID,@KyHieuID,@NgayCheck,0
						set @NgayCheck = dateadd(dd,1,@NgayCheck)
					end
				else if(@NgayCheck < @NgayBD and @NgayCheck < @NgayCT and datepart(dw,@NgayCheck) not in (1,7) )
					begin
						insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
						select @NVID,1,@NgayCheck,0 from NhanVien
						where convert(date,NgayBatDauLam)<=convert(date,@NgayCheck)
						and NhanVienID = @NVID
						set @NgayCheck = dateadd(dd,1,@NgayCheck)
					end
				else if(@NgayCheck >@Ngaynghi and datepart(dw,@NgayCheck) not in (1,7) )
					begin
						set @NgayBD = (Select min(convert(date,NgayBatDau)) from NS_QTNghiPhep where NhanVienID = @NVID 
						and isnull(KyHieuChamCongID,0) not in (22,23) and XetDuyet = 1 and @NgayBD<convert(date,NgayBatDau))
						set @NgayNghi = (Select min(convert(date,NgayKetThuc)) from NS_QTNghiPhep where NhanVienID = @NVID 
						and isnull(KyHieuChamCongID,0) not in (22,23) and XetDuyet = 1 and @NgayNghi< convert(date,NgayKetThuc))
							if((@NgayCheck between @NgayBD and @NgayNghi) and DATEPART(dw,@NgayCheck) not in (1,7))
								begin
									set @KyHieuID = (select KyHieuChamCongID from NS_QTNghiPhep where NhanVienID=@NVID and convert(date,NgayBatDau) = @NgayBD)
									insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
									select @NVID,@KyHieuID,@NgayCheck,0
									set @NgayCheck = dateadd(dd,1,@NgayCheck)
								end
					end
				else if((@NgayCheck between @NgayCT and @NgayKT) )
					begin
						insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
						select @NVID,24,@NgayCheck,0
						set @NgayCheck = dateadd(dd,1,@NgayCheck)
					end
				else if(@NgayCheck >@NgayKT  )
					begin
						set @NgayCT = (Select min(convert(date,NgayBatDau)) from NS_QTCongTac where NhanVienID = @NVID 
						and XetDuyet = 1 and @NgayCT<convert(date,NgayBatDau))
						set @NgayKT = (Select min(convert(date,NgayKetThuc)) from NS_QTCongTac where NhanVienID = @NVID 
					    and XetDuyet = 1 and @NgayKT< convert(date,NgayKetThuc))
							if((@NgayCheck between @NgayCT and @NgayKT) and DATEPART(dw,@NgayCheck) not in (1,7))
								begin
									insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
									select @NVID,24,@NgayCheck,0
									set @NgayCheck = dateadd(dd,1,@NgayCheck)
								end
					end
				else if (datepart(dw,@NgayCheck) not in (1,7))
					begin
						insert into NS_TL_BangChamCong(NhanVienID,KyHieuChamCongID,NgayChamCong,Lock)
						select @NVID,1,@NgayCheck,0 from NhanVien
						where convert(date,NgayBatDauLam)<=convert(date,@NgayCheck)
						and NhanVienID = @NVID
						set @NgayCheck = dateadd(dd,1,@NgayCheck)
					end
				else
					begin
						set @NgayCheck = dateadd(dd,1,@NgayCheck)
					end
			end
		delete @Tbl_NhanVien where NhanVienID = @NVID
        set @Dem = (select count(*) from @Tbl_NhanVien)
	end
END
