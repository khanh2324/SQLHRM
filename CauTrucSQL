CREATE proc [dbo].[ADD_BCDB_TongOT]  
as  
  
-- (Tùy chọn) tham số lọc khoảng thời gian
-- DECLARE @FromDate DATE = '2025-01-01';
-- DECLARE @ToDate   DATE = '2025-12-31';

SELECT
    pb.PhongBanID,
	pb.MaPhongBan,
	pb.MaPhongBan + ' - ' + pb.Ten AS TenPhongBan,
    CONVERT(NVARCHAR,YEAR(cc.NgayChamCong))  AS Nam,
    N'Tháng ' + CONVERT(NVARCHAR,MONTH(cc.NgayChamCong)) AS Thang,

    -- Tổng OT tính tiền
    CONVERT(DECIMAL(10,1),SUM(CASE WHEN lcc.MaSo LIKE N'OT_TQD_%' THEN cc.SoGioLam ELSE 0 END)) AS TongGioOT_TinhTien,

    -- Tổng OT nghỉ bù
    CONVERT(DECIMAL(10,1),SUM(CASE WHEN lcc.MaSo LIKE N'NB_TQD_%' THEN cc.SoGioLam ELSE 0 END)) AS TongGioOT_NghiBu,

    -- Tổng cả 2 loại
    CONVERT(DECIMAL(10,1),SUM(CASE WHEN lcc.MaSo LIKE N'OT_TQD_%' OR lcc.MaSo LIKE N'NB_TQD_%'
             THEN cc.SoGioLam ELSE 0 END)) AS TongGioOT_All
FROM dbo.NS_TL_ChamCong AS cc
INNER JOIN dbo.NS_TL_LoaiChamCong AS lcc
    ON cc.LoaiChamCongID = lcc.LoaiChamCongID
INNER JOIN dbo.NhanVien AS nv
    ON nv.NhanVienID = cc.NhanVienID
INNER JOIN dbo.PhongBan AS pb
    ON pb.PhongBanID = nv.PhongBanID
WHERE lcc.MaSo IN (
    N'OT_TQD_NgayThuong', N'OT_TQD_NgayNghi', N'OT_TQD_NgayLe',
    N'OT_TQD_DemThuong', N'OT_TQD_DemNghi', N'OT_TQD_DemLe', N'OT_TQD_NgayDemThuong',
    N'NB_TQD_NgayThuong', N'NB_TQD_NgayNghi', N'NB_TQD_NgayLe',
    N'NB_TQD_DemThuong', N'NB_TQD_DemNghi', N'NB_TQD_DemLe', N'NB_TQD_NgayDemThuong'
)
-- (Tùy chọn) bật lọc thời gian nếu cần
