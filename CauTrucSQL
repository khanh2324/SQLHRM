Create PROCEDURE [dbo].[Job_ADCo_GuiMailQuanLy]


AS
BEGIN

declare @numbermail int =(select count(*) from dbo.NhanVien WHERE NgayBatDauLam <= GETDATE() AND ISNULL(NgayNghiViec,'2099-01-01') >= GETDATE()
AND Email <> '' AND Email IS NOT NULL AND ChucVuID IN (SELECT ChucVuLanhDaoID FROM dbo.PhongBan))

declare @date date=convert(date, dateadd(d,-1,getdate()))
declare @LaThuBay bit = (case  when  DATEPART (WEEKDAY, @date) = 7 then  1 else 0 end )
declare @LaChuNhat bit = (case  when  DATEPART (WEEKDAY, @date) = 1 then  1 else 0 end )
declare @LaNgayLe bit, @LoaiCongChuanID int, @IsGuiMail int

DECLARE @mail int = 1
DECLARE @EmailCC NVARCHAR(1000) = dbo.LayEmailCC()

while @mail <= @numbermail
BEGIN
DECLARE @NhanVienID INT = (
    SELECT NhanVienID
    FROM (
        SELECT ROW_NUMBER() OVER (ORDER BY NhanVienID) AS STT, NhanVienID
        FROM dbo.NhanVien
        WHERE NgayBatDauLam <= GETDATE()
            AND ISNULL(NgayNghiViec, '2099-01-01') >= GETDATE()
            AND Email IS NOT NULL AND Email <> ''
			AND ChucVuID IN (SELECT ChucVuLanhDaoID FROM dbo.PhongBan)
			AND ChucVuID NOT IN (801,805)
    ) AS nv
    WHERE STT = @mail
)

set @LaNgayLe = (select dbo.fns_XacDinhNgayLeCuaNhanVien(@NhanVienID, @date)) 
set @LoaiCongChuanID = (select isnull(LoaiCongChuanID,0) from NhanVien where NhanVienID=@NhanVienID)
set @IsGuiMail = case when isnull(@LoaiCongChuanID,0)=1 and isnull(@LaThuBay,0)=1 then 0 when isnull(@LoaiCongChuanID,0)=1 and isnull(@LaChuNhat,0)=1 then 0 when isnull(@LaNgayLe,0)=1  then 0 else 1 end

if @IsGuiMail = 1 
begin
	insert into EmailToSend(ContentID,Email,EmailProfileID,ParameterQuery,[Subject],[Status],CustomerID,CC)
	SELECT 2047,(select dbo.EmailNhanVien(@NhanVienID) )as Email,13,concat('DsChamCongPhong', ' ',CONVERT(NVARCHAR(50),@NhanVienID))
	,N'Danh sách chấm công / Time keeping report - '+CONVERT(NVARCHAR(100),GETDATE()-1,103),0,0,@EmailCC
end
    set @mail = @mail+1
END



END


