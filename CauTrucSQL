CREATE PROCEDURE [dbo].[QT_GetDSQuaTrinh]
@TuNgay DateTime,
@ToiNgay DateTime,
@PhongBanID int,
@NhanVienID int	
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;

	SELECT NS_BH_NguoiThamGia.HoVaTen as 'Nhân viên',
		   NgayBatDau as 'Từ ngày', NgayKetThuc as 'Tới ngày', DonViCongViecChucVu, SoNam as 'Số Năm',
		   SoThang as 'Số tháng', MucLuong as 'Mức lương'
	FROM NS_QTDongBHXH
	inner join NS_BH_NguoiThamGia on NS_BH_NguoiThamGia.NguoiThamGiaID = NS_QTDongBHXH.NguoiThamGiaID
	inner join NhanVien on NhanVien.NhanVienID = NS_QTDongBHXH.NhanVienID
	inner join PhongBan on PhongBan.PhongBanID = NhanVien.PhongBanID
	WHERE (1=1) 
	And ((NS_QTDongBHXH.NgayBatDau>@TuNgay) Or (Year(@TuNgay)=1900))
	And ((NS_QTDongBHXH.NgayKetThuc<@ToiNgay) Or (Year(@ToiNgay)=1900))
	AND (NS_QTDongBHXH.NhanVienID = @NhanVienID Or @NhanVienID=0)
	And (PhongBan.PhongBanID=@PhongBanID Or @PhongBanID=0)
	Order By NhanVien.MaNhanVien
END
GO
