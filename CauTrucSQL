CREATE PROCEDURE [dbo].[HS_LayParameters_BangLuong]
@phongbanid int,@thang int,@nam int
AS
BEGIN
--declare @phongbanid int=1,@thang int=1,@nam int=2022
DECLARE @LoaiLuong NVARCHAR(max), @PBID nvarchar(50),@thangt nvarchar(50),@namt nvarchar(50)
DECLARE @SQL NVARCHAR(MAX)
set @PBID=@phongbanid
set @thangt=@thang
set @namt=@nam
SELECT @loailuong   =COALESCE(@loailuong +',' + x1 + '',''+x1+'') 
   FROM  (
select '['+maso+']' as x1 from NS_TL_LoaiLuong) as a
--select @loailuong
SET @SQL=
N'select * from
(select 
nhanvien.manhanvien,nhanvien.ho+'' ''+nhanvien.hoten hoten,
phongban.ten tenpb,ns_dschucvu.tenchucvu,
NS_TL_LoaiLuong.maso,ns_tl_chitietluong.tienluong
from nhanvien
inner join ns_tl_bangluong on nhanvien.nhanvienid=ns_tl_bangluong.nhanvienid
inner join phongban on phongban.phongbanid=nhanvien.phongbanid
left join ns_dschucvu on ns_dschucvu.chucvuid=nhanvien.chucvuid
inner join ns_tl_chitietluong on ns_tl_chitietluong.bangluongid=ns_tl_bangluong.bangluongid
inner join NS_TL_LoaiLuong on NS_TL_LoaiLuong.loailuongid=ns_tl_chitietluong.loailuongid
