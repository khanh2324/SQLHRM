CREATE PROC [dbo].[DsChamCongPhong] @NhanVienID INT    
AS    
BEGIN 

--DECLARE @NhanVienID INT = 40364  

DECLARE @PhongBanId INT = (SELECT PhongBanID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)  
DECLARE @DangNhapID INT = (SELECT TOP 1 NguoiDungID FROM dbo.SYS_NguoiDung WHERE NhanVienID = @NhanVienID)  
DECLARE @Thongtin NVARCHAR(MAX)  
  
SELECT @Thongtin = COALESCE(@Thongtin, '') +   
    '<tr>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + ISNULL(nv.Ho, '') + ' ' + ISNULL(nv.HoTen, '') + '</td>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + ISNULL(CONVERT(NVARCHAR, nv.MaNhanVien), '') + '</td>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + ISNULL(CONVERT(NVARCHAR(50), thc.NgayChamCong, 103) + ' ' + CONVERT(NVARCHAR(5), thc.GioDen, 108), '') + '</td>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + CONVERT(NVARCHAR, CAST(ISNULL(thc.TGDiMuon, 0) AS INT)) + '</td>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + ISNULL(CONVERT(NVARCHAR(50), thc.NgayChamCong, 103) + ' ' + CONVERT(NVARCHAR(5), thc.GioVe, 108), '') + '</td>' +  
    '<td style="text-align: center; width: 550px; height: 35px; border: 0.5px solid #888; border-collapse: collapse;">' + CONVERT(NVARCHAR, CAST(ISNULL(thc.TGVeSom, 0) AS INT)) + '</td>' +  
    '</tr>'  
FROM dbo.NS_TL_CC_TongHopTheoNgay thc  
INNER JOIN dbo.NhanVien nv ON nv.NhanVienID = thc.NhanVienID  
WHERE nv.PhongBanID IN (  
    SELECT valu FROM dbo.GetPhongBanChild_WUser(@PhongBanId, @DangNhapID)  
)  
--AND ISNULL(thc.TGDiMuon, 0) + ISNULL(thc.TGVeSom, 0) > 0  
AND thc.NgayChamCong = CONVERT(DATE, GETDATE() - 1)  
order by nv.PhongBanID
  
SELECT @Thongtin AS HtmlOutput, CONVERT(NVARCHAR(100), GETDATE()-1, 103) Title  
  
END    
