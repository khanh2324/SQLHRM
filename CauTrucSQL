            , TenPhongBan AS PhongBan, TenChucVu AS ChucVu, HoVaTen, TuThang, @ToiThang AS ToiThang, 0 AS MucLuong, 'gh' AS GhiChu, N'Đóng quá trình do nghỉ việc' AS Nhom
            , @Types AS TrangThai, NULL AS NgayTraTheBHYT, CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVienCTE
        WHERE @Type1 IN (0, @Types);


/* @Type = 7 GIẢM DO NGHỈ KHÔNG LƯƠNG (LOẠI NGHỈ N'L_Nopay', N'ABS') */
SET @Types = 7;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        ;WITH NhanVien_NghiKhongLuongCTE AS (
            SELECT 
                nv.NhanVienID,        nv.MaNhanVien,        nv.HoVaTen,        nv.SoBHXH,        nv.PhongBanID,        nv.ChucVuID,        nv.QuocTichID,        pb_list.TenPhongBan,        cv.TenChucVu,        DATEADD(DAY, 1 - DAY(@ToDate1), @ToDate1) AS TuThang
            FROM @nv nv 
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            INNER JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID AND bh.Status <> 5
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN #BH bh_temp WITH (NOLOCK) ON nv.NhanVienID = bh_temp.NhanVienID AND bh_temp.[Type] = @Types
            WHERE bh_temp.NhanVienID IS NULL -- Loại bỏ nhân viên đang biến động nghỉ ko lương
            --AND dbo.BHXH_TinhSoNgayNghi(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            --AND dbo.BHXH_TinhSoNgayNghi_KL(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            AND dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            AND dbo.BHXH_TinhSoNgayNghi_KL_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
        )

        -- Kết quả cuối cùng
          INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
        SELECT @Todate1 AS ThangBaoCao, @Types AS type, NhanVienID, MaNhanVien, NULL AS MucLuongCu, NULL AS TyleCu, dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle, SoBHXH AS SoSo
        , TenPhongBan AS PhongBan, TenChucVu AS ChucVu, HoVaTen, TuThang, @ToiThang AS ToiThang, 0 AS MucLuong, 'kl' AS GhiChu, N'Đóng quá trình do nghỉ dài ngày' AS Nhom
        , @Types AS TrangThai, NULL AS NgayTraTheBHYT, CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVien_NghiKhongLuongCTE
        WHERE @Type1 IN (0, @Types);


/* @Type = 8 GIẢM DO NGHỈ ỐM DÀI NGÀY (LOẠI NGHỈ N'SL_SI',N'SL_Pres',N'SL_Nurse') */
SET @Types = 8;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        ;WITH NhanVien_OmDaiNgayCTE AS (
            SELECT 
                nv.NhanVienID,       nv.MaNhanVien,        nv.HoVaTen,        nv.SoBHXH,        nv.PhongBanID,        nv.ChucVuID,        nv.QuocTichID,        pb_list.TenPhongBan,        cv.TenChucVu,
                DATEADD(DAY, 1 - DAY(@ToDate1), @ToDate1) AS TuThang
            FROM @nv nv 
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            INNER JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID AND bh.Status <> 5
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN #BH bh_temp WITH (NOLOCK) ON nv.NhanVienID = bh_temp.NhanVienID AND bh_temp.[Type] = @Types
            WHERE bh_temp.NhanVienID IS NULL -- Loại bỏ nhân viên đang biến động nghỉ ốm
            --AND dbo.BHXH_TinhSoNgayNghi(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            --AND dbo.BHXH_TinhSoNgayNghi_O(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            AND dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
            AND dbo.BHXH_TinhSoNgayNghi_O_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
        )

        -- Kết quả cuối cùng
        
        INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
        SELECT 
            @Todate1 AS ThangBaoCao,    @Types AS type,    NhanVienID,    MaNhanVien,    NULL AS MucLuongCu,    NULL AS TyleCu,    dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle, SoBHXH AS SoSo
            ,    TenPhongBan AS PhongBan,    TenChucVu AS ChucVu,    HoVaTen,    TuThang,    @ToiThang AS ToiThang,    0 AS MucLuong,    'of' AS GhiChu,    N'Đóng quá trình do nghỉ dài ngày' AS Nhom,
            @Types AS TrangThai,            NULL AS NgayTraTheBHYT,
            CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVien_OmDaiNgayCTE
        WHERE @Type1 IN (0, @Types);


/* @Type = 3 TĂNG DO HẾT NGHỈ DÀI NGÀY */
SET @Types = 3;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        ;WITH NhanVien_HetNghiCTE AS (
            SELECT 
                nv.NhanVienID,        nv.MaNhanVien,        nv.HoVaTen,        nv.SoBHXH,        nv.PhongBanID,        nv.ChucVuID,        nv.QuocTichID,        pb_list.TenPhongBan,        cv.TenChucVu,
                DATEFROMPARTS(YEAR(@Todate1), MONTH(@Todate1), 1) AS TuThang,
                (
                    SELECT TOP 1 mucluong 
                    FROM NS_QTDongBHXH WITH (NOLOCK)
                    WHERE NhanVienID = nv.NhanVienID
                    AND mucluong > 0
                    ORDER BY ngaybatdau DESC
                ) AS MucLuong
            FROM @nv nv
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            INNER JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID AND bh.Status in (7,8)
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN #BH bh_temp WITH (NOLOCK) ON nv.NhanVienID = bh_temp.NhanVienID AND bh_temp.[Type] = @Types
            WHERE bh_temp.NhanVienID IS NULL -- Loại bỏ nhân viên đang biến động
            AND dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) < 14
        )

        -- Kết quả cuối cùng
        
        INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
        SELECT 
            @Todate1 AS ThangBaoCao,    @Types AS type,    NhanVienID,    MaNhanVien,    NULL AS MucLuongCu,    NULL AS TyleCu,    dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle,    SoBHXH AS SoSo,
            TenPhongBan AS PhongBan,    TenChucVu AS ChucVu,    HoVaTen,    TuThang,    @ToiThang AS ToiThang,    MucLuong,    'tkl' AS GhiChu,    N'Tăng lại - hết nghỉ dài ngày' AS Nhom,    @Types AS TrangThai
            ,    NULL AS NgayTraTheBHYT,    CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVien_HetNghiCTE
        WHERE @Type1 IN (0, @Types) AND MucLuong IS NOT NULL;



        /* @Type = 9 GIẢM DO NGHỈ THAI SẢN */
SET @Types = 9;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        WITH ThaiSanNhanVien AS (
            SELECT         NhanVienID,         NgayBatDau, NgayKetThuc,       ROW_NUMBER() OVER (PARTITION BY NhanVienID ORDER BY NgayBatDau DESC) AS RowNum
            FROM NS_QTThaiSan WITH (NOLOCK)
            WHERE NgayBatDau BETWEEN DATEADD(MONTH, -2, @Todate1) AND @Todate1
        ),
        NhanVienThaiSan AS (
            SELECT 
                nv.NhanVienID, nv.MaNhanVien, nv.HoVaTen, nv.SoBHXH, nv.PhongBanID, nv.ChucVuID, nv.QuocTichID, pb_list.TenPhongBan, cv.TenChucVu, ts.NgayBatDau,
                CASE 
                    WHEN dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) < 14
                    then DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(ts.NgayBatDau), ts.NgayBatDau))
                    else DATEADD(DAY, 1 - DAY(ts.NgayBatDau), ts.NgayBatDau)
                END AS TuThang, ts.NgayKetThuc DenThang,
                --(
                --    SELECT TOP 1 mucluong 
                --    FROM NS_QTDongBHXH WITH (NOLOCK)
                --    WHERE NhanVienID = nv.NhanVienID
                --    AND mucluong > 0
                --    ORDER BY ngaybatdau DESC
                --) AS MucLuong,
                0 AS MucLuong
            FROM @nv nv 
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            INNER JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID --AND bh.Status = 3
            INNER JOIN ThaiSanNhanVien ts ON nv.NhanVienID = ts.NhanVienID AND ts.RowNum = 1
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN #BH bh_temp WITH (NOLOCK) ON nv.NhanVienID = bh_temp.NhanVienID AND bh_temp.[Type] = @Types
            WHERE  bh_temp.NhanVienID IS NULL -- Loại bỏ nhân viên đang biến động thai sản
            --AND dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) >= 14
        )
        INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
        -- Kết quả cuối cùng
        SELECT 
            @Todate1 AS ThangBaoCao,    @Types AS type,    NhanVienID,    MaNhanVien,    NULL AS MucLuongCu,    NULL AS TyleCu,    dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle, SoBHXH AS SoSo
            ,    TenPhongBan AS PhongBan,    TenChucVu AS ChucVu,    HoVaTen,    TuThang,    DenThang AS ToiThang,    MucLuong            ,    'ts' AS GhiChu,    N'Đóng quá trình do nghỉ thai sản' AS Nhom
            ,    @Types AS TrangThai,    NULL AS NgayTraTheBHYT,    CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVienThaiSan
        WHERE @Type1 IN (0, @Types) AND MucLuong IS NOT NULL


/* @Type = 3 TĂNG SAU THAI SẢN */
SET @Types = 3;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        WITH ThaiSanNhanVien AS (
            SELECT 
                NhanVienID, 
                NgayBatDau,
                --ISNULL(NgayDiLamTroLai, NgayKetThuc) AS NgayKetThuc,
                NgayKetThuc,
                ROW_NUMBER() OVER (PARTITION BY NhanVienID ORDER BY NgayBatDau DESC) AS RowNum
            FROM NS_QTThaiSan WITH (NOLOCK)
            WHERE NgayKetThuc BETWEEN @Fromdate1 AND @Todate1
        ),
        NhanVien_ThaiSanCTE AS (
            SELECT 
                nv.NhanVienID,
                nv.MaNhanVien,
                nv.HoVaTen,
                nv.SoBHXH,
                nv.PhongBanID,
                nv.ChucVuID,
                nv.QuocTichID,
                pb_list.TenPhongBan,
                cv.TenChucVu,
                ts.NgayKetThuc,
                CASE 
                    WHEN dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(ts.NgayKetThuc), YEAR(ts.NgayKetThuc), nv.NhanVienID) < 14
                    THEN DATEADD(DAY, 1 - DAY(ts.NgayKetThuc), ts.NgayKetThuc)
                    ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(ts.NgayKetThuc), ts.NgayKetThuc))
                END AS TuThang,
                dbo.BHXH_LayMucLuongDongBHXH(nv.NhanVienID, ts.NgayKetThuc) AS MucLuong
            FROM @nv nv  
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            INNER JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID AND bh.Status in (9)
            INNER JOIN ThaiSanNhanVien ts ON nv.NhanVienID = ts.NhanVienID AND ts.RowNum = 1
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN #BH bh_temp WITH (NOLOCK) ON nv.NhanVienID = bh_temp.NhanVienID AND bh_temp.[Type] = @Types
            WHERE   bh_temp.NhanVienID IS NULL -- Loại bỏ nhân viên đang biến động thai sản
            --AND dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) < 14
        )

        -- Kết quả cuối cùng
        INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT
        )
        SELECT 
            @Todate1 AS ThangBaoCao,    @Types AS type,    NhanVienID,    MaNhanVien,    NULL AS MucLuongCu,    NULL AS TyleCu,    dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle,    SoBHXH AS SoSo,
            TenPhongBan AS PhongBan,    TenChucVu AS ChucVu,    HoVaTen,    TuThang,    @ToiThang AS ToiThang,    MucLuong,    'tts' AS GhiChu,    N'Tăng lại sau thai sản' AS Nhom,
            @Types AS TrangThai,    NULL AS NgayTraTheBHYT,    CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM NhanVien_ThaiSanCTE
        WHERE @Type1 IN (0, @Types) AND MucLuong IS NOT NULL;



        select * from  @tbl_BienDong


ENd   

end  
GO
/****** Object:  StoredProcedure [dbo].[BHXH_DS_THAYDOI_QTBHXH_2024]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

create  proc [dbo].[BHXH_DS_THAYDOI_QTBHXH_2024] @DonViID int, @CongTyID int, @Fromdate DateTime, @Todate DateTime, @Type int AS      
      
BEGIN      
      
        --DECLARE  @CongTyID int=1,@DonViID int =0,@FromDate datetime='2025-02-26 00:00:00',@ToDate datetime='2025-3-25 23:59:59',@Type int=0  
    
        SET NOCOUNT ON;      
        DECLARE @DonVi int, @CongTyID_ID int, @Fromdate1 DateTime, @Todate1 DateTime, @Type1 int, @Types int=-1  
        SET @DonVi= @DonViID set @CongTyID_ID = @CongTyID set @Fromdate1 = @Fromdate set @Todate1 = @Todate set @Type1 = @Type      
    
  BEGIN    
        DECLARE  @ToiThang datetime = '12/31/2099'      
        DECLARE  @LoaiLuongID int = (SELECT LoaiLuongID FROM  NS_TL_LoaiLuong where MaSo ='T_MucDongBH')  -- Loại lương ID để xác định loại lương đóng bảo hiểm      
      
  
    --DECLARE  @TyLe decimal(10,3)=ISNULL(( SELECT TOP 1 isnull(TyLeBHXH_CTY,0)+isnull(TyLeBHYT_CTY,0)+isnull(TyLeBHTN_CTY,0)+isnull(TyLeBHTNLD_BNN_CTY,0)      
    --+isnull(TyLeBHXH_NLD,0)+isnull(TyLeBHYT_NLD,0)+isnull(TyLeBHTN_NLD,0)  FROM  NS_BH_TyLeThamGiaBHXH WHERE NgayBatDau<=@Todate1 ORDER BY NgayBatDau DESC),32)      
      
      
        DECLARE @PB Table (PhongBanID int)      
        insert into @PB      
        SELECT PhongBanID FROM  PhongBan where CongTyID  =@CongTyID  
      
      
       DECLARE @dbl table (STTG int,NhanVienID int, NgayHuong date,  GiaTriMoi decimal)     
       INSERT INTO @dbl    
       SELECT STTG, NhanVienID, NgayHuong,  GiaTriMoi  FROM      
         (SELECT STTG, QTDienBienLuongID, NhanVienID, NgayHuong    
          FROM (SELECT ROW_NUMBER() OVER (PARTITION BY NhanVienID  ORDER BY ISNULL(NgayHuong, NgayQuyetDinh) DESC) AS [STTG], QTDienBienLuongID, NhanVienID, ISNULL( NgayHuong, NgayQuyetDinh)   NgayHuong    
           FROM  NS_QTDienBienLuong WHERE CONVERT(DATE, ISNULL(NgayHuong, NgayQuyetDinh)) <= @todate1) tbl_1 where STTG <=2) tbl_DBL    
        INNER JOIN    
         (SELECT QTDienBienLuongID, GiaTriMoi FROM  NS_QTDienBienLuongChiTiet WHERE LoaiLuongID = @LoaiLuongID ) tbl_CTL ON tbl_DBL.QTDienBienLuongID = tbl_CTL.QTDienBienLuongID    
  END    
  
  
 /*Chưa hiểu ý nghĩa*/      
   BEGIN       
     update ns_bh_nguoithamgia set Status = case NS_QTDongBHXH.Type when 5 then 5 when 7 then 3 when 8 then 3 else 4 end,      
     MucLuongDongBH = (select max(mucluong) from NS_QTDongBHXH where nhanvienid = NS_BH_NguoiThamGia.nhanvienid      
     and ngaybatdau = (select max(ngaybatdau) from ns_qtdongbhxh where nhanvienid = NS_BH_NguoiThamGia.nhanvienid and mucluong>0))      
     from NS_BH_NguoiThamGia      
     inner join NS_QTDongBHXH on NS_BH_NguoiThamGia.nhanvienid = NS_QTDongBHXH.NhanVienID      
     inner join (select nhanvienid,max(ngaybatdau) as ngaybatdau from NS_QTDongBHXH      
     group by nhanvienid) as a on NS_QTDongBHXH.NhanVienID = a.NhanVienID and NS_QTDongBHXH.NgayBatDau = a.ngaybatdau      
       
     update NS_QTDongBHXH set NgayKetthuc = ngaybatdau where type in (5,6,7,8) and mucluong=0      
     update ns_qtdongbhxh set ngayketthuc = dateadd(mm,5,ngaybatdau) where type = 9      
      
     update NS_QTDongBHXH set NgayKetthuc = (select dateadd(dd,-1,max(NgayBatDau)) from NS_QTDongBHXH as QT      
     where QT.NhanVienID = NS_QTDongBHXH.NhanVienID and QT.NgayBatDau = (select min(NgayBatDau) from NS_QTDongBHXH as QT1      
     where QT1.NhanVienID = NS_QTDongBHXH.NhanVienID and QT1.NgayBatDau>NS_QTDongBHXH.NgayBatDau))      
     where (select min(NgayBatDau) from NS_QTDongBHXH as QT1      
     where QT1.NhanVienID = NS_QTDongBHXH.NhanVienID and QT1.NgayBatDau>NS_QTDongBHXH.NgayBatDau) is not null      
      
     update NS_QTDongBHXH set ngayketthuc =  case when NgayKetThuc<NgayBatDau then   dateadd(dd,-1,dateadd(dd,1-day(NgayBatDau),dateadd(mm,1,NgayBatDau)))      
     else dateadd(dd,-1,dateadd(dd,1-day(ngayketthuc),dateadd(mm,1,ngayketthuc))) end      
      
     update NS_QTDongBHXH set LoaiBienDongID=type where isnull(Type,0)!=0      
      
     update NS_QTDongBHXH set SoThang = (select (datediff(mm,ngaybatdau,case when year(NgayKetThuc)=2099 then getdate() else NgayketThuc end)+1)%12)      
     update NS_QTDongBHXH set SoNam = (select (datediff(mm,ngaybatdau,case when year(NgayKetThuc)=2099 then getdate() else NgayketThuc end)+1)/12)    
     

   END      

    
  SELECT TOP 1 WITH TIES NhanVienID, [Type], NgayBatDau, NgayKetthuc, SoNam, SoThang, MucLuong, NguoiThamGiaID, TyleDong, ThangBaoCao   
  INTO #BH FROM NS_QTDongBHXH  WHERE NgayBatDau <= @Todate1  ORDER BY ROW_NUMBER() OVER (PARTITION BY  NhanVienID ORDER BY  NgayBatDau DESC)   
  
  /*Tạo bảng biến động để lưu từng loại biến động! check dữ liệu cho dễ*/    
  DECLARE @tbl_BienDong table (ThangBaoCao date, [type] int,  NhanVienID int, MaNhanVien Nvarchar(50), MucLuongCu decimal(18,2), TyleCu decimal(10,2), Tyle decimal(10,2)    
  , SoSo nvarchar(50), PhongBan nvarchar(250), ChucVu nvarchar(250), HoVaTen nvarchar(100),  TuThang Date, ToiThang date, MucLuong decimal(18,2)  
  , GhiChu Nvarchar(50), Nhom Nvarchar(100), TrangThai int,  NgayTraTheBHYT date,  KhongTraTheBHYT bit  )    
    
  
  /*@Type =1  TĂNG MỚI*/      
  SET @Types = 1  
  INSERT INTO  @tbl_BienDong(ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, TrangThai, NgayTraTheBHYT, KhongTraTheBHYT)  
  SELECT * FROM        
  (SELECT  @Todate1 as ThangBaoCao, @Types as type, tbl_NhanVien.NhanVienID, tbl_NhanVien.MaNhanVien,      
  null as MucLuongCu,   null as TyleCu,  dbo.BHXH_LayTyLe(QuocTichID, @Todate1)  as Tyle,      
  tbl_NhanVien.SoBHXH as SoSo,      
  tbl_PhongBan.TenPhongBan as PhongBan,  tbl_ChucVu.TenChucVu as ChucVu,      
  tbl_NhanVien.HoVaTen,     
     
   CASE WHEN DAY(NgayKyHD)<=15 then DATEADD(DD,1-day(NgayKyHD) , NgayKyHD) else DATEADD(MM,1,DATEADD(DD,1-DAY(NgayKyHD),NgayKyHD)) end     as TuThang,      
  @ToiThang as ToiThang, dbo.BHXH_LayMucLuongDongBHXH(tbl_NhanVien.NhanVienID , NgayKyHD) as MucLuong,      
      
  'tm' as GhiChu,  N'Tăng mới BHXH' as Nhom,  4 as TrangThai,   null as NgayTraTheBHYT,  convert(bit,0) as KhongTraTheBHYT      
      
   FROM       
   ( SELECT dbo.BHXH_LayHDDauTien(NhanVienID) NgayKyHD,  NhanVienID, MaNhanVien, CONCAT(HO, ' ', HoTen) HoVaTen, SoBHXH, PhongBanID, ChucDanhID, ChucVuID, ISNULL(NghiViec,0) NghiViec, NgayNghiViec, QuocTichID  FROM  NhanVien  X       
   WHERE X.PhongBanID IN(SELECT PhongBanID FROM  @PB) AND X.NgayBatDauLam <= @Todate1  AND ISNULL(X.IsDeleted,0) = 0       
   AND NhanVienID not in (SELECT NhanVienID from NS_BH_NguoiThamGia)       
   )  AS tbl_NhanVien   
     
  INNER JOIN      
   (SELECT PhongBanID,  MaPhongBan, Ten TenPhongBan FROM PhongBan where PhongBanID in (SELECT PhongBanID FROM  @PB) ) tbl_PhongBan on tbl_NhanVien.PhongBanID = tbl_PhongBan.PhongBanID      
  LEFT JOIN        
   (SELECT ChucVuID, TenChucVu FROM NS_DsChucVu ) tbl_ChucVu on tbl_NhanVien.ChucVuID = tbl_ChucVu.ChucVuID      
    
  WHERE  NgayKyHD is not null AND NgayKyHD <=@Todate1       
  AND (NghiViec=0  OR (NghiViec=1 and  (case when NgayKyHD between @Fromdate1 and @Todate1 then dateadd(mm,0,NgayNghiViec) else dateadd(mm,1,NgayNghiViec) end)>@Todate1))      
  AND @Type1 in (0,@Types)      
   )tbl_TangMoi  where MucLuong > 0      
      
  /*@Type =4 TĂNG DO TĂNG LƯƠNG*/      
  SET @Types = 4  
  INSERT INTO  @tbl_BienDong    
      (ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, TrangThai, NgayTraTheBHYT, KhongTraTheBHYT)  
  SELECT * FROM  (    
  SELECT  @Todate1 as ThangBaoCao, @Types as type, tbl_NhanVien.NhanVienID, tbl_NhanVien.MaNhanVien,      
   (SELECT GiaTriMoi FROM @dbl A where  A.STTG =2 AND A.NhanVienID = tbl_DBL.NhanVienID  ) as MucLuongCu,   null as TyleCu,  dbo.BHXH_LayTyLe(QuocTichID, @Todate1)   as Tyle,      
   tbl_NhanVien.SoBHXH as SoSo, tbl_PhongBan.TenPhongBan as PhongBan,  tbl_ChucVu.TenChucVu as ChucVu, tbl_NhanVien.HoVaTen,      
       
   convert(date,case when day(tbl_DBL.NgayHuong)<=15 then dateadd(dd,1-day(tbl_DBL.NgayHuong),tbl_DBL.NgayHuong) else      
   dateadd(mm,1,dateadd(dd,1-day(tbl_DBL.NgayHuong),tbl_DBL.NgayHuong)) end) as TuThang,         
   @ToiThang as ToiThang, GiaTriMoi as MucLuong,      
      
   'tmd' as GhiChu,  N'Tăng mức đóng BHXH' as Nhom,  4 as TrangThai,   null as NgayTraTheBHYT,  convert(bit,0) as KhongTraTheBHYT      
    
   FROM       
   ( SELECT NhanVienID, MaNhanVien, CONCAT(HO, ' ', HoTen) HoVaTen, SoBHXH, PhongBanID, ChucDanhID, ChucVuID, ISNULL(NghiViec,0) NghiViec, NgayNghiViec, QuocTichID  FROM  NhanVien  X       
   WHERE X.PhongBanID IN(SELECT PhongBanID FROM  @PB) AND X.NgayBatDauLam <= @Todate1   AND (ISNULL(X.NGHIVIEC,0) = 0 OR CONVERT(DATE, X.NGAYNGHIVIEC) > @Todate1) AND ISNULL(X.ISDELETED,0) = 0     
   --AND NhanVienID not in (SELECT NhanVienID from NS_BH_NguoiThamGia)       
   )  AS tbl_NhanVien      
   INNER JOIN      
   (SELECT PhongBanID,  MaPhongBan, Ten TenPhongBan FROM PhongBan where PhongBanID in (SELECT PhongBanID FROM  @PB) ) tbl_PhongBan on tbl_NhanVien.PhongBanID = tbl_PhongBan.PhongBanID      
   INNER JOIN     
   (SELECT * FROM @dbl A WHERE STTG =1 AND (SELECT COUNT(NhanVienID) FROM @dbl X WHERE X.NhanVienID = A.NhanVienID AND X.STTG =2 )  > 0 and GiaTriMoi > 0) tbl_DBL on tbl_NhanVien.NhanVienID = tbl_DBL.NhanVienID    
   LEFT JOIN        
   (SELECT ChucVuID, TenChucVu FROM NS_DsChucVu ) tbl_ChucVu on tbl_NhanVien.ChucVuID = tbl_ChucVu.ChucVuID      
   WHERE  @Type1 in (0,4)  ) AS tbl_TMD    
    
  WHERE MucLuongCu < MucLuong     
  AND  (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID=tbl_TMD.NhanVienID  AND tbl_TMD.TuThang BETWEEN  A.NgayBatDau AND  A.NgayKetthuc AND type IN (5,7,8,9))=0      
  AND (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID=tbl_TMD.NhanVienID  AND tbl_TMD.TuThang = A.NgayBatDau AND type in (4,10))=0         
  AND (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID = tbl_TMD.NhanVienID and tbl_TMD.TuThang > A.NgayBatDau)>0      
      
  /*@Type =10 GIẢM  DO GIẢM LƯƠNG*/     
  SET @Types = 10  
  INSERT INTO  @tbl_BienDong    
      (ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, TrangThai, NgayTraTheBHYT, KhongTraTheBHYT)  
      
  SELECT * FROM  (    
  SELECT  @Todate1 as ThangBaoCao, @Types as type, tbl_NhanVien.NhanVienID, tbl_NhanVien.MaNhanVien,      
   (SELECT GiaTriMoi FROM @dbl A where  A.STTG =2 AND A.NhanVienID = tbl_DBL.NhanVienID  ) as MucLuongCu,   null as TyleCu,  dbo.BHXH_LayTyLe(QuocTichID, @Todate1)   as Tyle,      
   tbl_NhanVien.SoBHXH as SoSo, tbl_PhongBan.TenPhongBan as PhongBan,  tbl_ChucVu.TenChucVu as ChucVu, tbl_NhanVien.HoVaTen,      
       
  convert(date,case when day(tbl_DBL.NgayHuong)<=15 then dateadd(dd,1-day(tbl_DBL.NgayHuong),tbl_DBL.NgayHuong) else      
  dateadd(mm,1,dateadd(dd,1-day(tbl_DBL.NgayHuong),tbl_DBL.NgayHuong)) end) as TuThang,         
   @ToiThang as ToiThang, GiaTriMoi as MucLuong,      
      
   'gmd' as GhiChu,  N'Giảm mức đóng BHXH' as Nhom,  @Types as TrangThai,   null as NgayTraTheBHYT,  convert(bit,0) as KhongTraTheBHYT      
    
  FROM       
   ( SELECT NhanVienID, MaNhanVien, CONCAT(HO, ' ', HoTen) HoVaTen, SoBHXH, PhongBanID, ChucDanhID, ChucVuID, ISNULL(NghiViec,0) NghiViec, NgayNghiViec, QuocTichID  FROM  NhanVien  X       
   WHERE X.PhongBanID IN(SELECT PhongBanID FROM  @PB) AND X.NgayBatDauLam <= @Todate1   AND (ISNULL(X.NGHIVIEC,0) = 0 OR CONVERT(DATE, X.NGAYNGHIVIEC) > @Todate1) AND ISNULL(X.ISDELETED,0) = 0     
   --AND NhanVienID not in (SELECT NhanVienID from NS_BH_NguoiThamGia)       
   )  AS tbl_NhanVien      
  INNER JOIN      
  (SELECT PhongBanID,  MaPhongBan, Ten TenPhongBan FROM PhongBan where PhongBanID in (SELECT PhongBanID FROM  @PB) ) tbl_PhongBan on tbl_NhanVien.PhongBanID = tbl_PhongBan.PhongBanID      
  INNER JOIN     
  (SELECT * FROM @dbl A WHERE STTG =1 AND (SELECT COUNT(NhanVienID) FROM @dbl X WHERE X.NhanVienID = A.NhanVienID AND X.STTG =2 )  > 0 and GiaTriMoi > 0) tbl_DBL on tbl_NhanVien.NhanVienID = tbl_DBL.NhanVienID    
  LEFT JOIN        
  (SELECT ChucVuID, TenChucVu FROM NS_DsChucVu ) tbl_ChucVu on tbl_NhanVien.ChucVuID = tbl_ChucVu.ChucVuID      
  WHERE  @Type1 in (0,@Types)  ) AS tbl_TMD    
    
  WHERE MucLuongCu > MucLuong     
  AND  (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID=tbl_TMD.NhanVienID  AND tbl_TMD.TuThang BETWEEN  A.NgayBatDau AND  A.NgayKetthuc AND type IN (5,7,8,9))=0      
  AND (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID=tbl_TMD.NhanVienID  AND tbl_TMD.TuThang = A.NgayBatDau AND type in (4,10))=0         
  AND (SELECT COUNT(NhanVienID) FROM NS_QTDongBHXH A WHERE A.NhanVienID = tbl_TMD.NhanVienID and tbl_TMD.TuThang > A.NgayBatDau)>0      
    
  /*@Type =5 GIẢM  DO NGHỈ VIỆC*/     
  SET @Types = 5  
  INSERT INTO  @tbl_BienDong    
      (ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, TrangThai, NgayTraTheBHYT, KhongTraTheBHYT)  
  
  SELECT ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo , PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, TrangThai, NgayTraTheBHYT, KhongTraTheBHYT   
  FROM   
  (    
   SELECT  @Todate1 as ThangBaoCao, @Types as type, tbl_NhanVien.NhanVienID, tbl_NhanVien.MaNhanVien,      
   NULL as MucLuongCu,   NULL as TyleCu,  dbo.BHXH_LayTyLe(QuocTichID, @Todate1)   as Tyle,      
