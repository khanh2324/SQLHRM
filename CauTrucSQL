CREATE procedure [dbo].[ADD_BC_Checking_ADCo]   
 @PhongBanID int, @Thang int, @Nam int, @DiaDiemID int, @NhomNhanSuID int, @DangNhapID int  
  
as  
begin  
  
-- declare @PhongBanID int = 20, @Thang int = 3, @Nam int = 2025, @DiaDiemID int = 0, @NhomNhanSuID int = 0 , @DangNhapID int = 3072  
 declare @ThangLuong date = eomonth(convert(char(2), @thang) + '/1/' + convert(char(4), @nam) )  
 declare @NgayQuyDoi date = convert(char(2), @thang) + '/26/' + convert(char(4), @nam)   
 declare @DauKy date = dateadd(month, -1, @NgayQuyDoi)  
 declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)     
  
   
 select   
    N'Tháng ' + right(format(@ThangLuong, 'dd/MM/yyyy'), 7) as TieuDe  
  , nv.MaNhanVien as MaNV, nv.Ho + ' ' + nv.HoTen as HoVaTen  
  --, pb.Ten as PhongBan  
  , upper((case when Nhom.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.Ten else v.Lever2Ten end    
     else lld.Ten end     
   )) as PhongBan    
  , cv.TenChucVu as ViTriCongViec, nv.TaiKhoanNganHang as STK, nv.TenNganHang  
  , (select top 1 MaNganHang from dbo.NS_DsNganHang where TenNganHang = nv.TenNganHang) as MaNganHang  
  , isnull(bl.ThucLinh, 0) + isnull(kbs.Khac, 0) as ThanhToan, isnull(bl.ThucLinh, 0) as ThucLinh  
  , isnull(kbs.ChiPhiKeToan, 0) as ChiPhiKeToan, isnull(kbs.TruTamUng, 0) as TruTamUng, isnull(kbs.ChiPhiKhac, 0) as ChiPhiKhac  
  , isnull(kbs.TamUng, 0) as TamUng, isnull(kbs.TruyThuBHXH, 0) as TruyThuBHXH, isnull(kbs.QTTTNCN, 0) as QTT_TNCN, isnull(kbs.Taxi, 0) as Taxi  
  , isnull(kbs.Khac, 0) as Khac, isnull(kbs.LuongThang1, 0) as LuongThang1, isnull(kbs.LuongThang2, 0) as LuongThang2  
    
 from NhanVien nv   
   cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1        
   left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID  
   left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID    
   cross apply dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1    
   left join dbo.NS_DsChucVu cv on cv.ChucVuID = cv1.ChucVuID  
   cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv    
    left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId  
   left join ADD_CostCenter Nhom on nv.CostCenterId = Nhom.CostCenterId    
   left join dbo.NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID       
   left join dbo.NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID  
  
 -- left join NS_DsNganHang nh on nv.TenNganHang = nh.TenNganHang  
  right join  
  (select * from (  
    select   
     bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong  
    from NS_TL_BangLuong bl   
     left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID  
     left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID  
    Where (1=1)  
         and bl.Thang = @Thang  
     and bl.Nam = @Nam    
    ) as A pivot ( sum(TienLuong) for MaSo in( [ThucLinh])   
   ) as B  
  ) as bl on nv.NhanVienID = bl.NhanVienID  
  left join ADD_KhoanBoSungNgoaiLuong kbs on bl.NhanVienID = kbs.NhanVienID and bl.Thang = kbs.Thang and bl.Nam = kbs.Nam  
  
 where (1=1)  
  and pb.PhongBanID in (select valu from GetPhongBanChild_WUser(@PhongBanID, @DangNhapID) )  
  AND pb.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
  and (nv.NhomNhanSuId = @NhomNhanSuID or @NhomNhanSuID = -1001 or @NhomNhanSuID = 0)  
  and (kv.KhuVucID = @DiaDiemID or @DiaDiemID = -1001 or @DiaDiemID = 0)   
  and nv.NhanVienID not in (40452,40462)  
 -- and (CHARINDEX (CONCAT(',', @DiaDiemID,','), nv.KhuVucStr ) > 0 or @DiaDiemID = -1001 or @DiaDiemID = 0)  
   
 order by cv.ThuTu  
END  
  
