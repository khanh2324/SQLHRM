CREATE PROCEDURE [dbo].[NS_LayMaHopDong] @MaLoai nvarchar(50),
@NhanVienID int, @NgayBatDau date
AS
BEGIN

--DECLARE @NgayBatdau DATETIME = GETDATE(),
--@NhanVienId INT = 40452, @MaLoai NVARCHAR(50) = 'HDLD_Tech'

--"Số HĐLĐ chạy tự động theo công thức: [Mã nhân viên].[Viết tắt của Nhóm cost Central].
--[Loại HĐ (Hợp đồng thử việc thì để là TV hoặc Hợp đồng lao động)].[Tháng năm ký HĐ]
--Ví dụ: Nhân viên có mã là 80673, thuộc nhóm Cost Central Văn Phòng, ký Hợp đồng lao động vào tháng 04/2025 thì 
--số hợp đồng sẽ là: 80673.VP.LD.0425"

declare @Nam nvarchar(4) = YEAR(@NgayBatDau)
declare @manhanvien nvarchar(50)= (select MaNhanVien from NhanVien where nhanvienid = @nhanvienid)
--tạm thời để top 1
declare @LoaiHopDongID int = (SELECT TOP 1 LoaiHopDongID from NS_DsLoaiHopDong where MaLoaiHD = @MaLoai)
DECLARE @CostCenter NVARCHAR(50) = (SELECT MaCostCenter FROM dbo.ADD_CostCenter WHERE CostCenterId = 
(SELECT CostCenterId FROM dbo.NhanVien WHERE NhanVienId = @NhanVienId))

DECLARE @LoaiHopDong NVARCHAR(50)
IF @LoaiHopDongID IN (SELECT LoaiHopDongID FROM NS_DsLoaiHopDong where CHARINDEX ( CONCAT(',', MaLoaiHD,','), (SELECT CONCAT(',', GiaTri,',') FROM  SYS_ThongSo where MaSo ='HSNS_MA_HDCT'))>0)
BEGIN
    SET @LoaiHopDong  = 'LD'
END
ELSE
BEGIN
	SET @LoaiHopDong = 'TV'
END

DECLARE @ThangNam NVARCHAR(50) =  RIGHT('0' + CAST(MONTH(@NgayBatDau) AS VARCHAR), 2) +
       RIGHT(CAST(YEAR(@NgayBatDau) AS VARCHAR), 2)

declare @MaHopDong nvarchar(100)

set @MaHopDong = @manhanvien+'.'+@CostCenter+'.'+@LoaiHopDong+'.'+@ThangNam

SELECT @MaHopDong

END
GO
