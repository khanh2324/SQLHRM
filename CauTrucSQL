CREATE FUNCTION [dbo].[fns_Tax_TinhThueTNCNPhaiNop] (@NhanVienID int, @NgayKT_KC date, @Tax_ThuNhapTinhThue decimal(18,2) ) RETURNS decimal(18,2)      AS                 
BEGIN      
    
--declare @Tax_ThuNhapTinhThue decimal(18,2) = 200000000, @NhanVienID int =  (select nhanvienid from  nhanvien where manhanvien ='A01') , @NgayKT_KC date ='01/31/2025'    
declare @ChinhThuc int = (case when  (select dbo.fns_XacDinhNhanVienChinhThuc(@NhanVienID, @NgayKT_KC)) > 0 then 1 else 0 end)    
    
declare @MucThue5 decimal(18,2) = 5000000, @MucThue10 decimal(18,2) = 10000000,  @MucThue15 decimal(18,2) = 18000000    
, @MucThue20 decimal(18,2) = 32000000, @MucThue25 decimal(18,2) = 52000000,  @MucThue30 decimal(18,2) = 80000000    
    
  DECLARE @ResultVar  decimal(18,2)      =0    
--select FORMAT( @Tax_ThuNhapTinhThue, 'N2') Tax_ThuNhapTinhThue, FORMAT( @TienThue, 'N2')  TienThue    
    
  if( @ChinhThuc > 0)    
  begin    
   set @ResultVar = (select case when @Tax_ThuNhapTinhThue <= @MucThue5 then  @Tax_ThuNhapTinhThue * 0.05     
                  when @Tax_ThuNhapTinhThue <= @MucThue10 then @Tax_ThuNhapTinhThue * 0.1 - 250000    
                  when @Tax_ThuNhapTinhThue <= @MucThue15 then @Tax_ThuNhapTinhThue * 0.15 - 750000    
                  when @Tax_ThuNhapTinhThue <= @MucThue20 then @Tax_ThuNhapTinhThue * 0.2 - 1650000                    
                  when @Tax_ThuNhapTinhThue <= @MucThue25 then @Tax_ThuNhapTinhThue * 0.25 - 3250000                   
                  when @Tax_ThuNhapTinhThue <= @MucThue30 then @Tax_ThuNhapTinhThue * 0.3 - 5850000    
                  else @Tax_ThuNhapTinhThue * 0.35 - 9850000    
               end  )
  end    
  else     
  begin    
   set @ResultVar = (case when @Tax_ThuNhapTinhThue < 200000 then 0 else @Tax_ThuNhapTinhThue * 0.1  end)  
  end    
    
--select FORMAT( @Tax_ThuNhapTinhThue, 'N2') Tax_ThuNhapTinhThue, FORMAT( @TienThue, 'N2')  TienThue    
    
    
       
  --select @ResultVar    
  RETURN round(Isnull(@ResultVar, 0) / 0.2, 0) * 0.2        
END        
    
    
    
