CREATE proc [dbo].[sp_PhieuLuongPortal]    (      @NhanVienID int,     @Nam int,    @Thang int    )    as     

begin    

--declare @NhanVienID int  = (select nhanvienid from  nhanvien where manhanvien ='80673')  ,   @Nam int =2025,       @Thang int  =5

--set @NhanVienID = (select nhanvienid from  nhanvien where manhanvien ='A01')
; with cte_thongtinnv as(
                select pb.MaPhongBan, pb.Ten as TenPhongBan, pb.TenPhongBanTA, convert(date,  kc.NgayBD_CongThang) TuNgay, convert(date,kc.NgayKT_CongThang) DenNgay, nv.NhanVienID, nv.MaNhanVien, concat(nv.Ho, ' ', nv.HoTen) HoVaTen, nv.Email 
                , cv.MaChucVu, cv.TenChucVu

                from  NhanVien nv
                left join  PhongBan pb
                on nv.NhanVienID = @NhanVienID
                CROSS APPLY  fnt_GetNgayGioKyCong(pb.CongTyID, CONCAT(@Thang,'/01/' ,@Nam)) kc
                CROSS APPLY   fnt_GetChucVuNhanVienTaiThoiDiem(@NhanVienID, kc.NgayKT_CongThang) cvnv                
                CROSS APPLY   fnt_GetPhongBanNhanVienTaiThoiDiem(@NhanVienID, kc.NgayKT_CongThang) pbnv
                left join  NS_DsChucVu cv on cv.ChucVuID = cvnv.ChucVuID
                where pb.PhongBanID = pbnv.PhongBanID
        ),
        cte_bangcong as(
            select NhanVienID, isnull(OT_TQD_NgayThuong,0) OT_TQD_NgayThuong, isnull( OT_TQD_NgayNghi,0) OT_TQD_NgayNghi , isnull( OT_TQD_NgayLe,0) OT_TQD_NgayLe
            , isnull(OT_TQD_DemThuong,0) OT_TQD_DemThuong, isnull( OT_TQD_DemNghi,0) OT_TQD_DemNghi, ISNULL( OT_TQD_DemLe,0) OT_TQD_DemLe, Isnull(OT_TQD_NgayDemThuong,0) OT_TQD_NgayDemThuong
            ,Isnull( NCC,0) NCC, Isnull(CTL,0) CTL, isnull(XN,0) /8.0 XN, ISNULL( XD,0) XD, Isnull(CTL,0) + isnull(XN,0) /8.0 as TongCTL from  (
                select bct.NhanVienID, bct.SoGioLam, lcc.MaSo  from  NS_TL_ChamCong bct
                left join  NS_TL_LoaiChamCong lcc on  bct.LoaiChamCongID = lcc.LoaiChamCongID
                inner join cte_thongtinnv nv on nv.NhanVienID = bct.NhanVienID
                where bct.NhanVienID = @NhanVienID  and bct.NgayChamCong  between TuNgay and DenNgay
                and MaSo in ('OT_TQD_NgayThuong','OT_TQD_NgayNghi','OT_TQD_NgayLe','OT_TQD_DemThuong','OT_TQD_DemNghi','OT_TQD_DemLe','OT_TQD_NgayDemThuong' ,'NCC','CTL','XN','XD')) pv
                pivot (sum(SoGioLam) for MaSo in(OT_TQD_NgayThuong, OT_TQD_NgayNghi, OT_TQD_NgayLe, OT_TQD_DemThuong, OT_TQD_DemNghi, OT_TQD_DemLe, OT_TQD_NgayDemThuong, NCC, CTL, XN, XD )) pv1
                
        ),
				cte_dbl AS (
						SELECT 
								dbl.*,
								ROW_NUMBER() OVER (
										PARTITION BY dbl.NhanVienID 
										ORDER BY ABS(DATEDIFF(DAY, dbl.NgayHuong, nv.DenNgay))
								) AS rn
						FROM NS_QTDienBienLuong dbl
						INNER JOIN cte_thongtinnv nv ON dbl.NhanVienID = nv.NhanVienID
						WHERE dbl.NgayHuong <= nv.DenNgay
								AND dbl.NhanVienID = @NhanVienID
				), cte_dienbienluongpivot as(

						select *,
						ISNULL([QD_LCB],0) + ISNULL( [QD_PC_TrachNhiem],0) + ISNULL( [QD_PC_ViTri], 0) + ISNULL( [QD_PC_DiLai],0) + ISNULL( [QD_PC_DocHai], 0) + ISNULL( [QD_PC_Khac],0)  + ISNULL( [QD_PC_BuaAn],0) + ISNULL( [QD_ThuongThang],0) as [QD_TongThuNhap]
						
						from  (
						SELECT @NhanVienID NhanVienID, dblct.GiaTri, ll.MaSo	
						FROM cte_dbl dbl
						INNER JOIN NS_QTDienBienLuongChiTiet dblct ON dbl.QTDienBienLuongID = dblct.QTDienBienLuongID
						inner join NS_TL_LoaiLuong ll on dblct.LoaiLuongID = ll.LoaiLuongID
						WHERE dbl.rn = 1) pv
						pivot(max(GiaTri) for MaSo in ( [QD_LCB], [QD_PC_TrachNhiem], [QD_PC_ViTri], [QD_PC_DiLai], [QD_PC_DocHai], [QD_PC_Khac], [QD_PC_BuaAn], [QD_ThuongThang], [QD_TongLuong_PhuCap])) as pv1
				)
							

            select  format(CONVERT(date,convert(nvarchar,@Nam)+'-'+convert(nvarchar,@Thang)+'-01'),'MM/yyyy') ThangNam
						, format(CONVERT(date,dateadd(m,-1,convert(nvarchar,@Nam)+'-'+convert(nvarchar,@Thang)+'-01')),'MM/yyyy') ThangNamTruoc,
						format(  cte_thongtinnv.TuNgay,'dd/MM/yyyy') TuNgaystr, format(cte_thongtinnv.DenNgay, 'dd/MM/yyyy') DenNgaystr 
						, Isnull( [QD_PC_ViTri],0) + Isnull([QD_PC_TrachNhiem],0) as [QD_PC_TrachNhiem_ViTri], Isnull([TLNC_PC_ViTri],0) + ISNULL([TLNC_PC_TrachNhiem],0)  as [TLNC_PC_TrachNhiem_ViTri]
						, Isnull( [TLOT_ChieuThue],0)  +  Isnull( [TLOT_MienThue],0) as [TLOT_Tong], ISNULL( [Tax_GiamTru_BanThan],0) + ISNULL([Tax_GiamTru_NguoiPhuThuoc],0) as [Tax_GiamTru_BanThan_NguoiPhuThuoc]
						,*,
			isnull((select top 1 Khac from ADD_KhoanBoSungNgoaiLuong where NhanVienID=@NhanVienID and Thang=@Thang and Nam=@Nam),0) as Other,
			isnull(ThucLinh,0) + isnull((select top 1 Khac from ADD_KhoanBoSungNgoaiLuong where NhanVienID=@NhanVienID and Thang=@Thang and Nam=@Nam),0) as TongTien
						
		from  (
                Select  bl.NhanVienID, LL.MaSo, ctl.TienLuong 
                    from  NS_TL_BangLuong bl
                    inner join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID
                    inner join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID
                    where bl.NhanVienID = @NhanVienID and Thang = @Thang and Nam = @Nam) pv 
            PIVOT (sum(TienLuong) for MaSo in(
						[CC_XN], [CC_XD], [CC_NghiPhep], [CC_NghiLe], [CC_NghiBu], [CC_CongTac], [CC_NghiCoLuong], [CC_NghiCheDo], [CC_TongCong], [CC_GCC], [CC_TongGioOT], [CC_TongGioOT_NoneTax]
						, [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap],  [TLNC_PC_BuaAn], [TLNC_TongLuong_Thuong_PhuCap_Gop], [TLNC_LuongGio]
						, [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem_Gop]
						, [Thuong_KM_IP], [Thuong_KPI_IP], [Thuong_LuongT13], [Thuong_Nam], [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap], [Thuong_KM], [Thuong_KPI], [Thuong_Nam_IP], [Thuong_ChenhLechT1_IP], [Thuong_CongTruocThue_IP], [Thuong_TruTruocThue_IP]
						, [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong]
						, [Tax_ThuNhapMienThue], [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc], [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue], [Tax_TongThue], [Tax_ThuNhapSauThue]
						, [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax_IP], [PSSThue_TruSauTax], [PSSThue_CongSauTax_IP], [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy], [Tax_ThuNhapMienThue_Gop])) pv_bangluong
            left join  cte_bangcong on pv_bangluong.NhanVienID = cte_bangcong.NhanVienID
            left join  cte_thongtinnv on cte_thongtinnv.NhanVienID = pv_bangluong.NhanVienID
						inner join cte_dienbienluongpivot dbl on cte_thongtinnv.NhanVienID = dbl.NhanVienID

end    

GO
