Create FUNCTION [dbo].[udf_GetNumDaysInMonth] ( @Thang int, @Nam int )
RETURNS INT
AS
BEGIN
	  declare @myDateTime datetime
	  set @myDateTime = convert(nvarchar,convert(nvarchar,@Thang)+'/'+convert(nvarchar,1)+'/'+convert(nvarchar,@Nam))
      DECLARE @rtDate INT
      SET @rtDate =
      CASE WHEN MONTH(@myDateTime)
            IN (1,3, 5, 7, 8, 10, 12) THEN 31
            WHEN MONTH(@myDateTime) IN (4, 6, 9, 11) THEN 30
            ELSE CASE WHEN (YEAR(@myDateTime) % 4 = 0
            AND
            YEAR(@myDateTime) % 100 != 0)
            OR
            (YEAR(@myDateTime) % 400 = 0)
            THEN 29
            ELSE 28 END
      END
      RETURN @rtDate
END
