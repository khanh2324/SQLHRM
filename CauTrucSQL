CREATE PROCEDURE [dbo].[EMAIL_NS_DT_HOCVIEN]
(
      -- Add the parameters for the function here

	  @DotDaoTaoID int,
	  @NoiDungDaoTaoID int,
	  @StrHocVienID nvarchar (1000)

)

AS
BEGIN

	select NhanVien.ThiSinhID, NhanVien.MaNhanVien, NhanVien.Ho+' '+NhanVien.HoTen as HoTenHocVien, 
	case when NhanVien.GioiTinh=N'Nam' then N'Anh' else N'Chị' end as DanhXung_HV,
	case when NhanVien.GioiTinh=N'Nam' then N'Mr.' else N'Ms.' end as DanhXung_EN_HV,
	NS_DsChucVu.TenChucVu as Chucvu,NS_DsChucDanh.TenChucDanh as ChucDanh,
	case when NguoiPhuTrach.GioiTinh=N'Nam' then N'Anh' else N'Chị' end as DanhXung_NguoiPhuTrach,
	case when NguoiPhuTrach.GioiTinh=N'Nam' then N'Mr.' else N'Ms.' end as DanhXung_EN_NguoiPhuTrach,
	NhanVien.Email,NS_DT_DotDaoTao.TenDotDaoTao, NS_DT_DotDaoTao.NoiDaoTao,NS_DT_DotDaoTao.SoLuongHocVien,NS_DT_DotDaoTao.SoThangCamKetDaoTao,NS_DT_DotDaoTao.NoiDungDaoTao,
convert(nvarchar,NS_DT_DotDaoTao.DangKyTuNgay,103) as NgayBD_DangKy,convert(nvarchar,NS_DT_DotDaoTao.DangKyToiNgay,103) as NgayKT_DangKy,
convert(nvarchar,NS_DT_DotDaoTao.TuNgay,103) as NgayBatDau,convert(nvarchar,NS_DT_DotDaoTao.ToiNgay,103) as NgayKetThuc,
NguoiPhuTrach.ho +' '+NguoiPhuTrach.hoten as NguoiPhuTrach,
NS_DT_DotDaoTao.NguoiLienHe,NS_DT_DotDaoTao.NoiDaoTao,NS_DT_DotDaoTao.NoiDungDaoTao,NS_DT_DotDaoTao.SoThangCamKetDaoTao,NS_DT_DotDaoTao.ThoiLuongDuKien,NS_DT_DotDaoTao.ThoiLuong_SoBuoiDuKien,
NS_DT_DotDaoTao_NhanVien.DoiTuong,NS_DT_DotDaoTao_NhanVien.GhiChu,NS_DT_DotDaoTao_NhanVien.TrangThaiThamGia,NS_DT_DotDaoTao_NhanVien.TongDiem,NS_DT_KetQuaDaoTao.TenKetQuaDaoTao as KetQuaDaoTao
from NS_DT_DotDaoTao_NhanVien
inner join NS_DT_DotDaoTao on NS_DT_DotDaoTao_NhanVien.DotDaoTaoID=NS_DT_DotDaoTao.DotDaoTaoID
left join NhanVien on NS_DT_DotDaoTao_NhanVien.NhanVienID=NhanVien.NhanVienID
left join NhanVien NguoiPhuTrach on NS_DT_DotDaoTao.NguoiPhuTrachID=NguoiPhuTrach.NhanVienID
left join NS_DsChucVu on NhanVien.ChucVuID=NS_DsChucVu.ChucVuID
left join NS_DsChucDanh on NhanVien.ChucDanhID=NS_DsChucDanh.ChucDanhID
left join PhongBan on NhanVien.PhongBanID=PhongBan.PhongBanID
left join NS_DT_KetQuaDaoTao on NS_DT_DotDaoTao_NhanVien.KetQuaDaoTaoID=NS_DT_KetQuaDaoTao.KetQuaDaoTaoID
where NS_DT_DotDaoTao_NhanVien.NhanVienID in (select a from GHR_HamCatChuoi(@StrHocVienID, ',')) and NS_DT_DotDaoTao_NhanVien.DotDaoTaoID=@DotDaoTaoID

END
