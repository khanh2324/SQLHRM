CREATE PROCEDURE [dbo].[NS_TL_CC_InsertTongHopCong_TheoNgay] @NhanVienID INT, @NgayChamCong Datetime , @PhongBanID INT, @GioDen TIME, @GioRa TIME, @GioVao TIME, @GioVe TIME, @GhiChu NVARCHAR(500),
@CaLamViecID INT, @SoPhutDiMuon DECIMAL, @SoPhutVeSom int, @SoPhutLamThem int, @SoPhutLamThemDem int, @SoPhutLamDem int, @SoPhutLamViec int, @LamThemSangNgayHomSau bit, 
@SoPhutLamViecThucTe INT, @SoPhutVaoRa INT, @LoaiBatThuong NVARCHAR(200), @BatThuongDienGiai NVARCHAR(500) AS
	
--declare @NhanVienID INT =  (select top 1 NhanVienID from NhanVien where MaNhanVien =  N'80494')
--declare @NgayChamCong Datetime ='06/06/2025'
--declare @CaLamViecID INT = (select dbo.fns_LayCaLamViecNhanVien(@NhanVienID, @NgayChamCong))
--declare @PhongBanID INT = (select dbo.fns_PhongBanNhanVienTaiThoiDiem( @NhanVienID, @NgayChamCong))
--declare @GioDen TIME = '00:00:00', @GioRa TIME = '00:00:00', @GioVao TIME = '00:00:00', @GioVe TIME = '00:00:00' , @GhiChu NVARCHAR(500), @SoPhutLamViec DECIMAL(10,2), @SoPhutLamViecThucTe INT, @SoPhutLamDem decimal(10, 4)
			
drop table if exists  #ChamCong

SET ANSI_WARNINGS ON;


	begin
			set @SoPhutLamDem = 0		set   @GhiChu = N'';		set   @NgayChamCong = CONVERT (DATE, @NgayChamCong)		declare @MaxDate date = GETDATE()

	/*===========================================================*/
	/*Lấy thông tin ban đầu*/
	/*===========================================================*/
			begin 
				declare @DienGiai_GiaiTrinh NVARCHAR(500) = N'', @IsChinhSua bit = 0
				declare @LaNgayNghi_DKC bit = ISNULL ((select TOP 1 (IsNgayNghi) from NS_TL_DangKyCong where CONVERT (DATE, NgayChamCong) = CONVERT (DATE, @NgayChamCong) AND NhanVienID = @NhanVienID AND XetDuyetCLV = 1), 0)
				declare @CongTyID INT = (select CongTyID from PhongBan where PhongBanID = @PhongBanID);
				declare @KyHieuChamCongID INT = 0, @HienThiGiaiTrinhCong bit = 0, @KyHieuChamCong NVARCHAR(50) = N''
				declare @LaThuBay bit = (case  when  DATEPART (WEEKDAY, @NgayChamCong) = 7 then  1 else 0 end )
				declare @LaChuNhat bit = (case  when  DATEPART (WEEKDAY, @NgayChamCong) = 1 then  1 else 0 end )					
				/*CÓ 3 NHÓM ĐỐI TƯỢNG CHÍNH. 3:Đối tượng không cần chấm công,   1: Đối tượng chấm công thông thường, 2: Đối tượng chấm công thông thường ko tính vi phạm đi muộn về sơm*/
				declare @DoiTuongChamCong INT = IIF(Isnull  ((select IsKhongChamCong from  NhanVien where NhanVienID = @NhanVienID),0) =0, 1,3)	
				declare @IsNgayNghiLuanPhien INT = (select isnull(IsNgayNghiLuanPhien,0) from  NhanVien where NhanVienID = @NhanVienID)

                
				declare @ThoiGianBatDauLamDem TIME = '22:00:00', @ThoiGianKetThucLamDem TIME = '06:00:00',  @ThoiGianKetThucLamThemDem TIME = '06:00:00';
				/*Thông số trên ca làm việc*/
				declare @MaCaLamViec NVARCHAR(50) ='',  @SoPhutDiMuonChoPhep int =0, @SoPhutVeSomChoPhep int =0, @ThoiGianNghiGiuaCa int =0, @SoPhutLamViecTieuChuan int =0, @CachTinhGio int = 0
				select @MaCaLamViec = MaCa, @SoPhutDiMuonChoPhep = ISNULL (SoPhutChoPhepDenMuon, 0) ,  @SoPhutVeSomChoPhep =   ISNULL (SoPhutChoPhepVeSom, 0)
				,@ThoiGianNghiGiuaCa = Isnull(ThoiGianNghiGiuaCa,0), @SoPhutLamViecTieuChuan =  ISNULL (SoPhutLamViecTieuChuan, 0), @CachTinhGio  = ISNULL(CachTinhGio,0)
                ,@ThoiGianKetThucLamDem =  ISNULL(Gio_KetThucCaLamViecDem,'06:00:00'), @ThoiGianBatDauLamDem = ISNULL(Gio_BatDauCaLamViecDem,'22:00:00')
                from NS_CaLamViec where CaLamViecID = @CaLamViecID


				declare @NgayBD_CongThang Datetime,@NgayKT_CongThang Datetime				
				select @NgayBD_CongThang = NgayBD_CongThang, @NgayKT_CongThang = NgayKT_CongThang  from fnt_GetNgayGioKyCong (@CongTyID, @NgayChamCong)
				declare @NgayBD_CongNam Datetime  = (select NgayBD_CongThang from fnt_GetNgayGioKyCong (@CongTyID, CONCAT('01/01/', year(@NgayChamCong))) )
	
				declare @MaCLV NVARCHAR(50) = @MaCaLamViec    
				declare @SoPhutDiMuonChoPhep_NCN int =0, @SoPhutVeSomChoPhep_NCN int =0
				--lấy từ đề xuất đi muộn về sớm nuôi con nhỏ
				SELECT @SoPhutDiMuonChoPhep_NCN = SUM(SoPhutDiMuon),  @SoPhutVeSomChoPhep_NCN = SUM(SoPhutVeSom) FROM v_DeXuatDiMuonVeSom  WHERE NhanVienID = @NhanVienID AND @NgayChamCong BETWEEN NgayBatDau AND NgayKetThuc AND XetDuyet = 1;
				
				set @SoPhutDiMuonChoPhep = @SoPhutDiMuonChoPhep + @SoPhutDiMuonChoPhep_NCN
				set @SoPhutVeSomChoPhep = @SoPhutVeSomChoPhep + @SoPhutVeSomChoPhep_NCN


				declare @GioBatDau1 Datetime ,  @GioKetThuc1 Datetime  ,  @GioBatDau2 Datetime  , @GioKetThuc2 Datetime,  @IsCaDem bit
				declare @NgayGio_GioBatDau1 Datetime,  @NgayGio_GioKetThuc1 Datetime,  @NgayGio_GioBatDau2 Datetime, @NgayGio_GioKetThuc2 Datetime

				SELECT @NgayGio_GioBatDau1 = GioBatDau1, @NgayGio_GioKetThuc1 = GioKetThuc1, @NgayGio_GioBatDau2 = GioBatDau2, @NgayGio_GioKetThuc2 = GioKetThuc2
				, @IsCaDem = IsLamSangNgayHomSau, @SoPhutLamViecTieuChuan = SoPhutLamViecTieuChuan
				FROM dbo.fnt_LayNgayGioLamViecTheoCa(@NhanVienID, @NgayChamCong, @CaLamViecID);
			
				set   @GioBatDau1 = @NgayGio_GioBatDau1
				set   @GioKetThuc1 = @NgayGio_GioKetThuc1
				set   @GioBatDau2 = @NgayGio_GioBatDau2
				set   @GioKetThuc2 = @NgayGio_GioKetThuc2

	       
				set @ThoiGianNghiGiuaCa = case  when  @ThoiGianNghiGiuaCa = 0 then  (DATEDIFF (MINUTE, @GioKetThuc1, @GioBatDau2)) else @ThoiGianNghiGiuaCa end ;

				declare @NghiNuaCaDau bit = 0, @NghiNuaCaSau bit = 0
				declare @PhutLamViec_CaDau int = datediff(MINUTE,@NgayGio_GioBatDau1, @NgayGio_GioKetThuc1)
				declare @PhutLamViec_CaSau int = datediff(MINUTE,@NgayGio_GioBatDau2, @NgayGio_GioKetThuc2)

				if(@SoPhutLamViecTieuChuan <=0)
				begin
					set @SoPhutLamViecTieuChuan = @PhutLamViec_CaDau + @PhutLamViec_CaSau 
				end
				
				declare @SoPhutLamViec_Ca decimal(10, 4) =  @PhutLamViec_CaDau + @PhutLamViec_CaSau
		 
				declare @LaNgayLe bit = (select dbo.fns_XacDinhNgayLeCuaNhanVien(@NhanVienID, @NgayChamCong)) 
				declare @LaNgayNghi_BuLe bit = (select dbo.fns_XacDinhNgayBuLeCuaNhanVien(@NhanVienID, @NgayChamCong)) 
				declare @LaNgayNghi bit = (select dbo.fns_XacDinhNgayNghiCuaNhanVien(@NhanVienID, @NgayChamCong)) 
				declare @LaNgayKhongDiLam bit = 0;

				----IF @LaNgayLe = 1 OR @LaNgayNghi_BuLe = 1 OR @LaNgayNghi = 1
				----BEGIN
				----		SET @NgayGio_GioBatDau1 = @NgayChamCong;
				----		SET @NgayGio_GioKetThuc1 = @NgayChamCong;
				----		SET @NgayGio_GioBatDau2  = @NgayChamCong;
				----		SET @NgayGio_GioKetThuc2 = @NgayChamCong;
				----END



			end 

	/*===========================================================
	Tổng thời gian(GIỜ) nghỉ + công tác sau khi trừ time nghỉ trưa
	===========================================================*/
-- Khai báo biến bảng lưu kết quả nghỉ phép + công tác đã xử lý
			declare @Cong_Nghi_CongTac TABLE (				Loai NVARCHAR(50),				KyHieuChamCong NVARCHAR(50),				NgayGio_BD_Nghi DATETIME,				NgayGio_KT_Nghi DATETIME,				ThoiGianNghi INT		);

-- Insert dữ liệu nghỉ phép + công tác (có tính toán thời gian nghỉ)
			INSERT INTO @Cong_Nghi_CongTac (Loai, KyHieuChamCong, NgayGio_BD_Nghi, NgayGio_KT_Nghi, ThoiGianNghi)
			SELECT 
					N.Loai,
					N.KyHieuChamCong,
					NgayGio_BD_Nghi = CASE WHEN @NgayGio_GioBatDau1 > N.NgayBatDau THEN @NgayGio_GioBatDau1 ELSE N.NgayBatDau END,
					NgayGio_KT_Nghi = CASE WHEN @NgayGio_GioKetThuc2 < N.NgayKetThuc THEN @NgayGio_GioKetThuc2 ELSE N.NgayKetThuc END,
					ThoiGianNghi = 
							DATEDIFF(MINUTE, 
									CASE WHEN @NgayGio_GioBatDau1 > N.NgayBatDau THEN @NgayGio_GioBatDau1 ELSE N.NgayBatDau END,
									CASE WHEN @NgayGio_GioKetThuc2 < N.NgayKetThuc THEN @NgayGio_GioKetThuc2 ELSE N.NgayKetThuc END
							) - 
							CASE 
									WHEN DATEADD(SECOND, -1, @NgayGio_GioKetThuc1) between   N.NgayBatDau AND  N.NgayKetThuc and DATEADD(SECOND, 1, @NgayGio_GioBatDau2) between   N.NgayBatDau AND  N.NgayKetThuc   THEN @ThoiGianNghiGiuaCa
									ELSE 0
							END
			FROM (
					SELECT 
							'NghiPhep' AS Loai,        ISNULL(KyHieu.KyHieu, 'NP') AS KyHieuChamCong, NP.NgayBatDau, NP.NgayKetThuc
					FROM NS_QTNghiPhep NP
					LEFT JOIN NS_TL_KyHieuChamCong KyHieu ON NP.KyHieuChamCongID = KyHieu.KyHieuChamCongID
					WHERE NP.NhanVienID = @NhanVienID AND NP.XetDuyet = 1
							AND NOT (NP.NgayKetThuc < @NgayGio_GioBatDau1 OR NP.NgayBatDau > @NgayGio_GioKetThuc2)

					UNION ALL

					SELECT 
							'CongTac' AS Loai,
							 'CT' AS KyHieuChamCong,
							CT.NgayBatDau,
							CT.NgayKetThuc
					FROM NS_QTCongTac CT
					LEFT JOIN NS_DsLyDoCongTac LyDo ON CT.LyDoCongTacID = LyDo.LyDoCongTacID
					WHERE CT.NhanVienID = @NhanVienID AND CT.XetDuyet = 1
							AND NOT (CT.NgayKetThuc < @NgayGio_GioBatDau1 OR CT.NgayBatDau > @NgayGio_GioKetThuc2)
			) N;

-- Tính tổng phút nghỉ phép và công tác
			declare @PhutNghiPhep DECIMAL(10,4) = ISNULL((    SELECT SUM(ThoiGianNghi) FROM @Cong_Nghi_CongTac WHERE Loai = 'NghiPhep'), 0);
			SET @PhutNghiPhep = CASE WHEN @PhutNghiPhep < 0 THEN 0 ELSE @PhutNghiPhep END;

			declare @PhutCongTac DECIMAL(10,4) = ISNULL((    SELECT SUM(ThoiGianNghi) FROM @Cong_Nghi_CongTac WHERE Loai = 'CongTac'), 0);
			SET @PhutCongTac = CASE WHEN @PhutCongTac < 0 THEN 0 ELSE @PhutCongTac END;

-- Đánh dấu là ngày không đi làm nếu tổng thời gian nghỉ >= thời gian chuẩn
			IF (@PhutNghiPhep + @PhutCongTac >= @SoPhutLamViecTieuChuan AND @SoPhutLamViecTieuChuan <> 0)
			BEGIN
					SET @LaNgayKhongDiLam = 1;
			END;


	/*===========================================================
			Xác định lại thời gian làm việc  nếu có nghỉ hoặc công tác < 1 công 
	===========================================================*/
			begin 
				if ((@PhutCongTac + @PhutNghiPhep) > 0 AND @PhutCongTac+ @PhutNghiPhep < @SoPhutLamViecTieuChuan )
				begin
					SELECT TOP 1 @NgayGio_GioBatDau1 = GioBatDau1,				@NgayGio_GioKetThuc1 = GioKetThuc1,				@NgayGio_GioBatDau2 = GioBatDau2,				@NgayGio_GioKetThuc2 = GioKetThuc2
					FROM dbo.fnt_LayNgayGioLamViecTheoNgay(@NhanVienID, @NgayChamCong, @CaLamViecID);

					/*Chỉ có nghỉ nữa ca đầu = 1 hoặc nữa ca sau = 1. không bao giờ xuất hiện cả 2 = 1. nếu cả 2 = 1 thì logic sai*/
					if(@NgayGio_GioBatDau1 = @NgayGio_GioKetThuc1) set @NghiNuaCaDau = 1
					if(@NgayGio_GioBatDau2 = @NgayGio_GioKetThuc2) set @NghiNuaCaSau = 1
				end
                else if (@LaNgayKhongDiLam =1)
				begin
					set @NgayGio_GioBatDau1 = @NgayChamCong
          set @NgayGio_GioKetThuc1 = @NgayChamCong
          set @NgayGio_GioBatDau2 = @NgayChamCong
          set  @NgayGio_GioKetThuc2 = @NgayChamCong
				end;
			end;

--select N'Giờ làm việc cuối cùng' as mkn,   @NgayGio_GioBatDau1 NgayGio_GioBatDau1, @NgayGio_GioKetThuc1 NgayGio_GioKetThuc1, @NgayGio_GioBatDau2 NgayGio_GioBatDau2, @NgayGio_GioKetThuc2 NgayGio_GioKetThuc2, @NghiNuaCaDau NghiNuaCaDau, @NghiNuaCaSau NghiNuaCaSau, @LaNgayKhongDiLam LaNgayKhongDiLam


	/*===========================================================
			Xác định lại thời gian OT
	===========================================================*/
			begin
						-- Tạo bảng @TEMP_OT để lưu kết quả cuối
					declare @TEMP_OT TABLE ( BatDauLamThem DATETIME, KetThucLamThem DATETIME, LoaiLamThem NVARCHAR(10), LoaiTC NVARCHAR(50), TL_TT DECIMAL(10, 4), TL_NB DECIMAL(10, 4), NhomTC NVARCHAR(50), IsKhongChamCong BIT, MaLyDoTangCa NVARCHAR(50) );

       --             select @NgayGio_GioBatDau2, * from  	 NS_TL_DangKyOT OT
							--LEFT JOIN NS_DsLyDoTangCa LD ON OT.LyDoTangCaID = LD.LyDoTangCaID
							--WHERE OT.NhanVienID = @NhanVienID
							--	AND CONVERT(DATE, OT.NgayDangKy) = @NgayChamCong
							--	AND OT.XetDuyet = 1
					-- CTE lọc OT và phân loại vùng
					;WITH OT_Source AS (
							SELECT 
									OT.BatDauLamThem, OT.KetThucLamThem, OT.LyDoTangCaID, LD.MaLyDoTangCa,
									CASE WHEN LD.MaLyDoTangCa = N'TinhTien' THEN 'TINHTIEN' ELSE 'NGHIBU' END AS LoaiTC,
									CASE WHEN OT.BatDauLamThem < @NgayGio_GioBatDau1 THEN 1 ELSE 0 END AS OT_TC,
									CASE WHEN OT.BatDauLamThem < @NgayGio_GioKetThuc1 AND OT.KetThucLamThem > @NgayGio_GioBatDau1 THEN 1 ELSE 0 END AS OT_C1,							
									CASE WHEN OT.BatDauLamThem < @NgayGio_GioBatDau2 AND OT.KetThucLamThem > @NgayGio_GioKetThuc1 THEN 1 ELSE 0 END AS OT_GC,
									CASE WHEN OT.BatDauLamThem < @NgayGio_GioKetThuc2 AND OT.KetThucLamThem > @NgayGio_GioBatDau2 THEN 1 ELSE 0 END AS OT_C2,
									CASE WHEN OT.KetThucLamThem > @NgayGio_GioKetThuc2 THEN 1 ELSE 0 END AS OT_sc,
									0 AS IsKhongChamCong
							FROM NS_TL_DangKyOT OT
							LEFT JOIN NS_DsLyDoTangCa LD ON OT.LyDoTangCaID = LD.LyDoTangCaID
							WHERE OT.NhanVienID = @NhanVienID
								AND CONVERT(DATE, OT.NgayDangKy) = @NgayChamCong
								AND OT.XetDuyet = 1
					)
     
					,
					OT_CTE AS (
							SELECT 'TC' AS LoaiLamThem, LoaiTC,
									BatDau = OT.BatDauLamThem,
									KetThuc = IIF(OT.KetThucLamThem >= @NgayGio_GioBatDau1, @NgayGio_GioBatDau1, OT.KetThucLamThem),
									TL_TT = IIF(OT.LoaiTC = 'NGHIBU', 0, 100),
									TL_NB = IIF(OT.LoaiTC = 'NGHIBU', 100, 0),
									NhomTC = 'TruocCa',
									IsKhongChamCong,
									OT.MaLyDoTangCa
							FROM OT_Source OT WHERE OT.OT_TC = 1

							UNION ALL

							SELECT 'TC', LoaiTC,
									BatDau = IIF(OT.BatDauLamThem <= @NgayGio_GioBatDau1, @NgayGio_GioBatDau1, OT.BatDauLamThem),
									KetThuc = IIF(OT.KetThucLamThem >= @NgayGio_GioKetThuc1, @NgayGio_GioKetThuc1, OT.KetThucLamThem),
									IIF(OT.LoaiTC = 'NGHIBU', 0, 100),
									IIF(OT.LoaiTC = 'NGHIBU', 100, 0),
									'OT_C1', IsKhongChamCong, OT.MaLyDoTangCa
							FROM OT_Source OT
							WHERE OT.OT_C1 = 1 AND (@LaNgayNghi = 1 OR @LaNgayLe = 1 OR @LaNgayKhongDiLam = 1 OR @NghiNuaCaDau = 1)

							UNION ALL /*Đoạn này bỏ qua chưa có xử lý*/
							SELECT 'GC' AS LoaiLamThem, LoaiTC,
									BatDau = IIF(OT.BatDauLamThem < @NgayGio_GioKetThuc1, @NgayGio_GioKetThuc1, OT.BatDauLamThem),--OT.BatDauLamThem,
									KetThuc = IIF(OT.KetThucLamThem > @NgayGio_GioBatDau2, @NgayGio_GioBatDau2, OT.KetThucLamThem),
									TL_TT = IIF(OT.LoaiTC = 'NGHIBU', 0, 100),
									TL_NB = IIF(OT.LoaiTC = 'NGHIBU', 100, 0),
									NhomTC = 'GiuaCa',
									IsKhongChamCong,
									OT.MaLyDoTangCa
							FROM OT_Source OT WHERE OT.OT_GC = 1

							UNION ALL

							SELECT 'SC', LoaiTC,
									BatDau = IIF(OT.BatDauLamThem <= @NgayGio_GioBatDau2, @NgayGio_GioBatDau2, OT.BatDauLamThem),
									KetThuc = IIF(OT.KetThucLamThem >= @NgayGio_GioKetThuc2, @NgayGio_GioKetThuc2, OT.KetThucLamThem),
									IIF(OT.LoaiTC = 'NGHIBU', 0, 100),
									IIF(OT.LoaiTC = 'NGHIBU', 100, 0),
									'OT_C2', IsKhongChamCong, OT.MaLyDoTangCa
							FROM OT_Source OT
							WHERE OT.OT_C2 = 1 AND (@LaNgayNghi = 1 OR @LaNgayLe = 1 OR @LaNgayKhongDiLam = 1 OR @NghiNuaCaSau = 1)

							UNION ALL

							SELECT 'SC', LoaiTC,
									BatDau = IIF(OT.BatDauLamThem <= @NgayGio_GioKetThuc2, @NgayGio_GioKetThuc2, OT.BatDauLamThem),
									KetThuc = OT.KetThucLamThem,
									IIF(OT.LoaiTC = 'NGHIBU', 0, 100),
									IIF(OT.LoaiTC = 'NGHIBU', 100, 0),
									'SauCa', IsKhongChamCong, OT.MaLyDoTangCa
							FROM OT_Source OT
							WHERE OT.OT_sc = 1
					)
	
				---- Insert OT hợp lệ vào bảng
				INSERT INTO @TEMP_OT(LoaiLamThem, LoaiTC, BatDauLamThem, KetThucLamThem, TL_TT, TL_NB, NhomTC, IsKhongChamCong, MaLyDoTangCa)
				SELECT * 		FROM OT_CTE 		WHERE BatDau < KetThuc;



					-- Thêm ca làm việc nếu không nghỉ (tùy theo logic nghỉ)
					IF @LaNgayNghi = 0 AND @LaNgayLe = 0 AND @LaNgayKhongDiLam = 0
					BEGIN
							IF @NghiNuaCaDau = 1
									INSERT INTO @TEMP_OT SELECT @NgayGio_GioBatDau2, @NgayGio_GioKetThuc2, 'C2', 'CLV_C2', 0, 0, 'C2', 0, '';
							ELSE IF @NghiNuaCaSau = 1
									INSERT INTO @TEMP_OT SELECT @NgayGio_GioBatDau1, @NgayGio_GioKetThuc1, 'C1', 'CLV_C1', 0, 0, 'C1', 0, '';
							ELSE
							BEGIN
									INSERT INTO @TEMP_OT SELECT @NgayGio_GioBatDau1, @NgayGio_GioKetThuc1, 'C1', 'CLV_C1', 0, 0, 'C1', 0, '';
									INSERT INTO @TEMP_OT SELECT @NgayGio_GioBatDau2, @NgayGio_GioKetThuc2, 'C2', 'CLV_C2', 0, 0, 'C2', 0, '';
							END
					END

					-- Tính tổng thời gian OT thực tế
					declare @NgayGioDK_Vao DATETIME, @NgayGioDK_Ra  DATETIME		
					SELECT @NgayGioDK_Vao =MIN(BatDauLamThem), @NgayGioDK_Ra = MAX(KetThucLamThem) FROM @TEMP_OT
				 	

					/*Nếu ngày này không làm gì thì giờ chấm công là từ 4h sáng cho đến 20h đêm*/
					if (@NgayGioDK_Vao IS NULL AND @NgayGioDK_Ra IS NULL)
					begin
						set @NgayGioDK_Vao = DATEADD (SECOND, 1, DATEADD (HOUR, 4, @NgayChamCong));
						set @NgayGioDK_Ra = DATEADD (SECOND, -1, DATEADD (HOUR, 20, @NgayChamCong));
					end;
			
			end; 


--select N'Thời gian làm việc' as MKN,  @NgayGioDK_Vao NgayGioDK_Vao	, @NgayGioDK_Ra NgayGioDK_Ra, @NghiNuaCaDau NghiNuaCaDau, @NghiNuaCaSau NghiNuaCaSau
/*
CREATE NONCLUSTERED INDEX IX_CC_NhanVien_ThoiGian 
ON NS_TL_CC_DuLieuChamCong (NhanVienID, ThoiGian)
INCLUDE (DuLieuKhongTongHop);
*/
	/*===========================================================	
			Lấy thời gian chấm công
	===========================================================*/
			begin
				-- 1. Tính số phút tìm ngược / xuôi
					--declare @SoPhutCongThem int = (case when @IsNgayNghiLuanPhien=1 then 270 else 720 end)
					declare @SoPhutCongThem int = (case when @IsNgayNghiLuanPhien=1 then 270 else 270 end)
					--declare @SoPhutCongVao INT  = 	CASE WHEN @NghiNuaCaDau = 1 THEN 60 + @PhutLamViec_CaDau + 270 ELSE 270 END,
					--		@SoPhutCongRa INT   =	CASE WHEN @NghiNuaCaSau = 1 THEN 60 + @PhutLamViec_CaSau + 270 ELSE 270 END;
					--An sửa 
					declare @SoPhutCongVao INT  = 	CASE WHEN @NghiNuaCaDau = 1 THEN 60 + @PhutLamViec_CaDau + @SoPhutCongThem ELSE @SoPhutCongThem END,
							@SoPhutCongRa INT   =	CASE WHEN @NghiNuaCaSau = 1 THEN 60 + @PhutLamViec_CaSau + @SoPhutCongThem ELSE @SoPhutCongThem END;

					declare     @KhongDiLamBuoiSang BIT = 0,    @KhongDiLamBuoiChieu BIT = 0,    @QuenChamCong BIT = 0;

					-- 2. Lấy toàn bộ dữ liệu chấm công hợp lệ trong khung rộng (vào - ra)
					declare @ChamCong TABLE (ThoiGian DATETIME);
					INSERT INTO @ChamCong
					SELECT ThoiGian FROM NS_TL_CC_DuLieuChamCong
					WHERE NhanVienID = @NhanVienID
						AND DuLieuKhongTongHop = 0 AND CONVERT(TIME, ThoiGian) <> '00:00:00'
						AND ThoiGian BETWEEN DATEADD(MINUTE, -@SoPhutCongVao, @NgayGioDK_Vao) AND DATEADD(MINUTE, @SoPhutCongRa, @NgayGioDK_Ra)

                        
					---- 3. Giờ vào gần @NgayGioDK_Vao
					--declare @ChamCong_Vao DATETIME = (SELECT TOP 1 ThoiGian FROM @ChamCong    ORDER BY ABS(DATEDIFF(MINUTE, ThoiGian, @NgayGioDK_Vao)));
					---- 4. Giờ ra gần @NgayGioDK_Ra
					--declare @ChamCong_Ra DATETIME = (SELECT TOP 1 ThoiGian FROM @ChamCong    ORDER BY ABS(DATEDIFF(MINUTE, ThoiGian, @NgayGioDK_Ra)));
                    
          -- 2. Xác định giờ vào (Check-in)
          DECLARE @ChamCong_Vao DATETIME;

          -- Ưu tiên chọn bản ghi không vượt quá giờ vào dự kiến (lấy giá trị lớn nhất <= @NgayGioDK_Vao)
          SELECT TOP 1 @ChamCong_Vao = ThoiGian FROM @ChamCong WHERE ThoiGian <= @NgayGioDK_Vao
          ORDER BY ThoiGian ASC;

          -- Nếu không có bản ghi nào thỏa điều kiện trên, chọn bản ghi có thời gian sau giờ dự kiến (lấy giá trị nhỏ nhất > @NgayGioDK_Vao)
          IF (@ChamCong_Vao IS NULL)
          BEGIN
              SELECT TOP 1 @ChamCong_Vao = ThoiGian FROM @ChamCong WHERE ThoiGian > @NgayGioDK_Vao
              ORDER BY ThoiGian ASC;
          END

          -- 3. Xác định giờ ra (Check-out)
          DECLARE @ChamCong_Ra DATETIME;

          -- Ưu tiên chọn bản ghi có thời gian >= @NgayGioDK_Ra (lấy giá trị nhỏ nhất >= @NgayGioDK_Ra)
          SELECT TOP 1 @ChamCong_Ra = ThoiGian FROM @ChamCong WHERE ThoiGian >= @NgayGioDK_Ra
          ORDER BY ThoiGian DESC;

          -- Nếu không có bản ghi nào thỏa điều kiện trên, chọn bản ghi có thời gian trước @NgayGioDK_Ra (lấy giá trị lớn nhất < @NgayGioDK_Ra)
          IF (@ChamCong_Ra IS NULL)
          BEGIN
              SELECT TOP 1 @ChamCong_Ra = ThoiGian
              FROM @ChamCong
              WHERE ThoiGian < @NgayGioDK_Ra
              ORDER BY ThoiGian DESC;
          END


          if((@ChamCong_Ra is null or @ChamCong_Vao is null or DATEDIFF(MINUTE,@ChamCong_Vao, @ChamCong_Ra ) < 15) and @DoiTuongChamCong <> 3)
          begin
              set @ChamCong_Vao = null
              set @ChamCong_Ra = null
          end
                    
            if(@DoiTuongChamCong =3)
            begin
              set @ChamCong_Vao = @NgayGioDK_Vao
              set @ChamCong_Ra = @NgayGioDK_Ra
            end

					-- 5. Trường hợp chấm công 1 lần
					IF @ChamCong_Vao = @ChamCong_Ra AND @ChamCong_Vao IS NOT NULL
					BEGIN
							IF ABS(DATEDIFF(MINUTE, @ChamCong_Vao, @NgayGioDK_Vao)) 
								 < ABS(DATEDIFF(MINUTE, @ChamCong_Ra, @NgayGioDK_Ra))
									SET @ChamCong_Ra = NULL;
							ELSE
									SET @ChamCong_Vao = NULL;
					END
					-- 6. Xác định các mốc vào/ra
					declare @NgayGioChamCong_GioBatDau1 DATETIME = NULL, @NgayGioChamCong_GioKetThuc1 DATETIME = NULL, @NgayGioChamCong_GioBatDau2 DATETIME = NULL, @NgayGioChamCong_GioKetThuc2 DATETIME = NULL;
								IF @ChamCong_Vao IS NOT NULL OR @ChamCong_Ra IS NOT NULL
			BEGIN
					IF @ChamCong_Vao IS NOT NULL AND @ChamCong_Ra IS NOT NULL
					BEGIN
							IF @NghiNuaCaDau = 1 AND @NghiNuaCaSau = 0
							BEGIN
									SET @NgayGioChamCong_GioBatDau2 = 
											CASE WHEN @ChamCong_Vao < @NgayGio_GioBatDau2 THEN @NgayGio_GioBatDau2 ELSE @ChamCong_Vao END;

									SET @NgayGioChamCong_GioKetThuc2 = 
											CASE WHEN @ChamCong_Ra >  @NgayGio_GioKetThuc2 THEN   @NgayGio_GioKetThuc2  ELSE @ChamCong_Ra END;

									set @NgayGioChamCong_GioBatDau1 = @NgayGioChamCong_GioBatDau2
									set @NgayGioChamCong_GioKetThuc1 = @NgayGioChamCong_GioBatDau2

							END
							ELSE IF @NghiNuaCaDau = 0 AND @NghiNuaCaSau = 1
							BEGIN
							
									SET @NgayGioChamCong_GioBatDau1 = 
											CASE WHEN @ChamCong_Vao  <  @NgayGio_GioBatDau1 THEN   @NgayGio_GioBatDau1 ELSE @ChamCong_Vao END;

									SET @NgayGioChamCong_GioKetThuc1 = 
											CASE WHEN @ChamCong_Ra > @NgayGio_GioKetThuc1 THEN @NgayGio_GioKetThuc1 ELSE @ChamCong_Ra END;

									set @NgayGioChamCong_GioBatDau2 = @NgayGioChamCong_GioKetThuc1
									set @NgayGioChamCong_GioKetThuc2 =@NgayGioChamCong_GioKetThuc1
									
							END
							ELSE -- Đi cả ngày
							BEGIN
									-- Mặc định: giờ vào đầu - ra cuối
									SET @NgayGioChamCong_GioBatDau1 = @ChamCong_Vao;
									SET @NgayGioChamCong_GioKetThuc2 = @ChamCong_Ra;

									-- Xử lý ảo hóa giờ giữa ca
									IF @NgayGio_GioKetThuc1 BETWEEN @ChamCong_Vao AND @ChamCong_Ra
											SET @NgayGioChamCong_GioKetThuc1 = @NgayGio_GioKetThuc1;

									IF @NgayGio_GioBatDau2 BETWEEN @ChamCong_Vao AND @ChamCong_Ra
											SET @NgayGioChamCong_GioBatDau2 = @NgayGio_GioBatDau2;

									-- Không đi làm chiều
									IF @ChamCong_Vao <= @NgayGio_GioBatDau2 AND @ChamCong_Ra <= @NgayGio_GioBatDau2
									BEGIN
											SET @NgayGioChamCong_GioKetThuc1 = @ChamCong_Ra;
											SET @NgayGioChamCong_GioBatDau2 = @ChamCong_Ra;
									END

									-- Không đi làm sáng
									IF @ChamCong_Vao >= @NgayGio_GioKetThuc1 AND @ChamCong_Ra >= @NgayGio_GioKetThuc1
									BEGIN
											SET @NgayGioChamCong_GioKetThuc1 = @ChamCong_Vao;
											SET @NgayGioChamCong_GioBatDau2 = @ChamCong_Vao;
									END

							END
					END
					ELSE
					BEGIN           
					/*Nếu chỉ chấm công lần*/

								IF @NghiNuaCaDau = 1 AND @NghiNuaCaSau = 0
								begin	
									/*Nghỉ nữa ca đầu*/
--select ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioBatDau2)) , ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioKetThuc2))
--,  isnull(@ChamCong_Vao, @ChamCong_Ra) GioChamCong, @NgayGio_GioBatDau2 NgayGio_GioBatDau2,@NgayGio_GioKetThuc2 NgayGio_GioKetThuc2, @NghiNuaCaDau NghiNuaCaDau, @NghiNuaCaSau NghiNuaCaSau
									
										IF ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioBatDau2)) < ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioKetThuc2))
												SET @NgayGioChamCong_GioBatDau2 = isnull(@ChamCong_Vao, @ChamCong_Ra)
										ELSE
												SET @NgayGioChamCong_GioKetThuc2 = isnull(@ChamCong_Vao, @ChamCong_Ra)

								end
								else 
								IF @NghiNuaCaDau = 0 AND @NghiNuaCaSau = 1
								begin
								/*Nghỉ nữa ca sau*/
--select ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioBatDau2)) , ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioKetThuc2))
--,  isnull(@ChamCong_Vao, @ChamCong_Ra) GioChamCong, @NgayGio_GioBatDau1 NgayGio_GioBatDau1,@NgayGio_GioKetThuc1 NgayGio_GioKetThuc1, @NghiNuaCaDau NghiNuaCaDau, @NghiNuaCaSau NghiNuaCaSau
									
									IF ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioBatDau1)) < ABS(DATEDIFF(MINUTE,  isnull(@ChamCong_Vao, @ChamCong_Ra), @NgayGio_GioKetThuc1))
											SET @NgayGioChamCong_GioBatDau1 = isnull(@ChamCong_Vao, @ChamCong_Ra)
									ELSE
											SET @NgayGioChamCong_GioKetThuc1 = isnull(@ChamCong_Vao, @ChamCong_Ra)
								end
								else
								begin
									-- Mặc định: giờ vào đầu - ra cuối
									SET @NgayGioChamCong_GioBatDau1 = @ChamCong_Vao;
									SET @NgayGioChamCong_GioKetThuc2 = @ChamCong_Ra;
								end
							-- Chỉ có 1 dấu vân tay
							SET @QuenChamCong = CASE WHEN @LaNgayKhongDiLam = 1 THEN 0 ELSE 1 END;
					END
			END



					SET @GioDen = CONVERT(TIME, @NgayGioChamCong_GioBatDau1);
					SET @GioRa  = CONVERT(TIME, CASE WHEN @CachTinhGio = 0 THEN '00:00' ELSE @NgayGioChamCong_GioKetThuc1 END);
					SET @GioVao = CONVERT(TIME, CASE WHEN @CachTinhGio = 0 THEN '00:00' ELSE @NgayGioChamCong_GioBatDau2 END);
					SET @GioVe  = CONVERT(TIME, @NgayGioChamCong_GioKetThuc2);
                    	

			end

--select N'Dữ liệu chấm công' as mkn,    @NgayGioChamCong_GioBatDau1 NgayGioChamCong_GioBatDau1, @NgayGioChamCong_GioKetThuc1 NgayGioChamCong_GioKetThuc1
--, @NgayGioChamCong_GioBatDau2 NgayGioChamCong_GioBatDau2, @NgayGioChamCong_GioKetThuc2 NgayGioChamCong_GioKetThuc2, @NgayGioDK_Vao NgayGioDK_Vao, @ChamCong_Ra ChamCong_Ra
--select N'Giờ làm việc' as mkn,    @NgayGio_GioBatDau1 NgayGio_GioBatDau1, @NgayGio_GioKetThuc1 NgayGio_GioKetThuc1
--, @NgayGio_GioBatDau2 NgayGio_GioBatDau2, @NgayGio_GioKetThuc2 NgayGio_GioKetThuc2


	/*===========================================================	
			Tạo logic xử lý bảng công
	===========================================================*/
             begin   
				        WITH ChamCong_CTE_Base AS (
						        SELECT *,
								        -- Có chấm công qua ngày hôm sau?
								        LamSangNgayKhac = CASE WHEN DAY(NgayGioChamCongVao) <> DAY(NgayGioChamCongRa) THEN 1 ELSE 0 END,

								        -- Đi muộn
								        SoPhutDiMuon = CASE 
										        WHEN LoailamThem IN ('C1', 'C2', 'CLV') AND NgayGioChamCongVao IS NOT NULL-- AND NgayGioChamCongRa IS NOT NULL AND NgayGioChamCongVao < NgayGioChamCongRa
												        AND NgayGioChamCongVao >= BatDauLamThem 
										        THEN DATEDIFF(MINUTE, BatDauLamThem, NgayGioChamCongVao)
										        ELSE 0
								        END,

								        -- Về sớm
								        SoPhutVeSom = CASE 
										        WHEN LoailamThem IN ('C1', 'C2', 'CLV') AND NgayGioChamCongRa IS NOT NULL --AND NgayGioChamCongRa IS NOT NULL AND NgayGioChamCongVao < NgayGioChamCongRa
												        AND NgayGioChamCongRa <= KetThucLamThem
										        THEN DATEDIFF(MINUTE, NgayGioChamCongRa, KetThucLamThem)
										        ELSE 0
								        END

						        FROM (
								        SELECT *,
									        NgayGioChamCongVao = 
											        CASE 
													--An them 
															WHEN LoailamThem IN ('TC', 'GC', 'SC') then BatDauLamThem
													--
													        WHEN LoailamThem IN ('TC', 'C1', 'CLV') AND @NgayGioChamCong_GioBatDau1 IS NOT NULL and @NgayGioChamCong_GioBatDau1 <= @NgayGio_GioBatDau2 THEN
															        CASE  
																	        WHEN @NgayGioChamCong_GioBatDau1 BETWEEN BatDauLamThem AND KetThucLamThem THEN @NgayGioChamCong_GioBatDau1 
																	        WHEN @NgayGioChamCong_GioBatDau1 < BatDauLamThem THEN BatDauLamThem 
															        END

                                                                WHEN LoailamThem IN ('GC') AND @NgayGioChamCong_GioKetThuc1 IS NOT NULL and @NgayGioChamCong_GioKetThuc1 between  @NgayGio_GioKetThuc1 and @NgayGio_GioBatDau2 THEN 
															    CASE 
																    WHEN @NgayGioChamCong_GioKetThuc1 BETWEEN BatDauLamThem AND KetThucLamThem THEN  @NgayGioChamCong_GioKetThuc1
																    WHEN @NgayGioChamCong_GioKetThuc1 < BatDauLamThem THEN BatDauLamThem 
															    END	

													        WHEN LoailamThem IN ('SC', 'C2') AND @NgayGioChamCong_GioBatDau2 IS NOT NULL and @NgayGioChamCong_GioBatDau2 >= @NgayGio_GioKetThuc1 THEN 
															        CASE 
																        WHEN @NgayGioChamCong_GioBatDau2 BETWEEN BatDauLamThem AND KetThucLamThem THEN  @NgayGioChamCong_GioBatDau2
																        WHEN @NgayGioChamCong_GioBatDau2 < BatDauLamThem THEN BatDauLamThem 
															        END	
													        ELSE NULL
											        END,

									        NgayGioChamCongRa = 
											        CASE 
													--An them
															WHEN LoailamThem IN ('TC', 'GC', 'SC') then KetThucLamThem
													--
													        WHEN LoailamThem IN ('TC', 'C1', 'CLV') AND @NgayGioChamCong_GioKetThuc1 IS NOT NULL and @NgayGioChamCong_GioKetThuc1 <= @NgayGio_GioBatDau2  THEN
															        CASE
																	        WHEN @NgayGioChamCong_GioKetThuc1 BETWEEN BatDauLamThem AND KetThucLamThem THEN @NgayGioChamCong_GioKetThuc1
																	        WHEN @NgayGioChamCong_GioKetThuc1 > KetThucLamThem THEN KetThucLamThem 
															        END
                                                             WHEN LoailamThem IN ('GC') AND @NgayGioChamCong_GioBatDau2 IS NOT NULL and @NgayGioChamCong_GioBatDau2 between  @NgayGio_GioKetThuc1 and @NgayGio_GioBatDau2  THEN
															        CASE			
																        WHEN @NgayGioChamCong_GioBatDau2 BETWEEN BatDauLamThem AND KetThucLamThem  THEN @NgayGioChamCong_GioBatDau2
																        WHEN @NgayGioChamCong_GioBatDau2 > KetThucLamThem THEN KetThucLamThem  
															        END

													        WHEN LoailamThem IN ('SC', 'C2') AND @NgayGioChamCong_GioKetThuc2 IS NOT NULL and @NgayGioChamCong_GioKetThuc2 >= @NgayGio_GioKetThuc1  THEN
															        CASE			
																        WHEN @NgayGioChamCong_GioKetThuc2 BETWEEN BatDauLamThem AND KetThucLamThem  THEN @NgayGioChamCong_GioKetThuc2
																        WHEN @NgayGioChamCong_GioKetThuc2 > KetThucLamThem THEN KetThucLamThem  
															        END
													        ELSE NULL
											        END
							        FROM @TEMP_OT
						        ) AS BaseCalc
				        ),

				        OT_CTE_TinhGio AS (
						        SELECT *,
								        -- Tổng thời gian làm việc
								        TGlamViec = CASE
										        WHEN NgayGioChamCongVao >= NgayGioChamCongRa THEN 0
										        ELSE DATEDIFF(MINUTE, NgayGioChamCongVao, NgayGioChamCongRa)
								        END,

								        -- Làm đêm hôm trước
								        TGLamViecBanDem_NgayHomTruoc = 
										        CASE 
												        WHEN LamSangNgayKhac = 0 THEN 
														        dbo.fns_TinhThoiGianLamDem(NgayGioChamCongVao, NgayGioChamCongRa, @ThoiGianBatDauLamDem, @ThoiGianKetThucLamDem)
												        ELSE
														        dbo.fns_TinhThoiGianLamDem(NgayGioChamCongVao, CONVERT(DATE, NgayGioChamCongRa), @ThoiGianBatDauLamDem, @ThoiGianKetThucLamDem)
										        END,

								        -- Thời gian làm việc hôm trước
								        TGLamViec_NgayHomTruoc = 
										        CASE 
												        WHEN LamSangNgayKhac = 0 THEN 
														      DATEDIFF(MINUTE, NgayGioChamCongVao,  NgayGioChamCongRa)
												        ELSE														       
														      DATEDIFF(MINUTE, NgayGioChamCongVao, CONVERT(DATE, NgayGioChamCongRa))
										        END,

								        -- Phần hôm sau (qua ngày)
								        TGLamViec_NgayHomSau = 
										        CASE WHEN LamSangNgayKhac = 1 THEN DATEDIFF(MINUTE, CONVERT(DATE, NgayGioChamCongRa), NgayGioChamCongRa) ELSE 0 END,

								        TGLamViecBanDem_NgayHomSau = 
										        CASE WHEN LamSangNgayKhac = 1 
												        THEN dbo.fns_TinhThoiGianLamDem(CONVERT(DATE, NgayGioChamCongRa), NgayGioChamCongRa, @ThoiGianBatDauLamDem, @ThoiGianKetThucLamDem)
												        ELSE 0
										        END,

								        -- Vắng mặt nếu ca C1/C2 mà thiếu dấu vân tay
								        TG_VangMat = CASE 
										        WHEN LoailamThem IN ('C1', 'C2',N'C2') 
												         AND (NgayGioChamCongVao IS NULL OR NgayGioChamCongRa IS NULL)
										        THEN DATEDIFF(MINUTE, BatDauLamThem, KetThucLamThem)
										        ELSE 0
								        END

						        FROM ChamCong_CTE_Base
				        )

				        -- Kết quả cuối cùng
				        SELECT
						        BatDauLamThem, KetThucLamThem, LoailamThem, LoaiTC, NgayGioChamCongVao, NgayGioChamCongRa, LamSangNgayKhac, SoPhutDiMuon, SoPhutVeSom,
						        Vao_NgayLe     = dbo.fns_XacDinhNgayLeCuaNhanVien(@NhanVienID, BatDauLamThem),
						        Ra_NgayLe      = dbo.fns_XacDinhNgayLeCuaNhanVien(@NhanVienID, BatDauLamThem),
						        Vao_NgayNghi   = dbo.fns_XacDinhNgayNghiCuaNhanVien(@NhanVienID, BatDauLamThem),
						        Ra_NgayNghi    = dbo.fns_XacDinhNgayNghiCuaNhanVien(@NhanVienID, BatDauLamThem),
						        TG_VangMat, TGlamViec, TGLamViec_NgayHomTruoc, TGLamViecBanDem_NgayHomTruoc, TGLamViec_NgayHomSau, TGLamViecBanDem_NgayHomSau
				        INTO #CHAMCONG
				        FROM OT_CTE_TinhGio;


			        end

			declare @SoPhutOT_TruocCa int =0, @SoPhutOT_GiuaCa int = 0, @SoPhutOT_SauCa int = 0, @SoPhutLV_BanDem int = 0, @SoPhutLV_BanNgay int = 0, @PhutVangMat int=0,  @SoPhutDiMuonThucTe int = 0,  @SoPhutVeSomThucTe int = 0
			
			SELECT
				@SoPhutOT_TruocCa     = SUM(CASE WHEN LoailamThem = 'TC' THEN TGlamViec ELSE 0 END),
				@SoPhutOT_GiuaCa      = SUM(CASE WHEN LoailamThem = 'GC' THEN TGlamViec ELSE 0 END),
				@SoPhutOT_SauCa       = SUM(CASE WHEN LoailamThem = 'SC' THEN TGlamViec ELSE 0 END),
				@SoPhutLV_BanDem      = SUM(CASE WHEN LoailamThem IN ('C1', 'C2', 'CLV') THEN TGLamViecBanDem_NgayHomTruoc + TGLamViecBanDem_NgayHomSau ELSE 0 END),
				@SoPhutLV_BanNgay     = SUM(CASE WHEN LoailamThem IN ('C1', 'C2', 'CLV') THEN TGlamViec - TGLamViecBanDem_NgayHomTruoc - TGLamViecBanDem_NgayHomSau ELSE 0 END),
				@PhutVangMat					= sum (TG_VangMat), @SoPhutDiMuonThucTe =  SUM(SoPhutDiMuon), @SoPhutVeSomThucTe =SUM(SoPhutVeSom)
				FROM #CHAMCONG;
            set @SoPhutOT_TruocCa = ISNULL(@SoPhutOT_TruocCa,0)
            set @SoPhutOT_GiuaCa = ISNULL(@SoPhutOT_GiuaCa,0)
            set @SoPhutOT_SauCa = ISNULL(@SoPhutOT_SauCa,0)
            set @SoPhutLV_BanDem = ISNULL(@SoPhutLV_BanDem,0)
            set @SoPhutLV_BanNgay = ISNULL(@SoPhutLV_BanNgay,0)
            set @PhutVangMat = ISNULL(@PhutVangMat,0)
            set @SoPhutDiMuonThucTe = ISNULL(@SoPhutDiMuonThucTe,0)
            set @SoPhutVeSomThucTe = ISNULL(@SoPhutVeSomThucTe,0)

			declare @TG_OT_Ngay decimal(10, 4), @TG_OT_Dem decimal(10, 4), @OT_TinhNghiBu decimal(10, 4) = 0, @OT_TinhTien decimal(10, 4) = 0
			, @OT_NLe_Ngay decimal(10, 4) = 0, @OT_NLe_Dem decimal(10, 4) = 0, @OT_NNghi_Ngay decimal(10, 4) = 0, @OT_NNghi_Dem decimal(10, 4) = 0, @OT_NThuong_Ngay decimal(10, 4) = 0, @OT_NThuong_Dem decimal(10, 4) = 0, @OT_NThuong_NgayDem decimal(10, 4) = 0
			, @NB_NLe_Ngay decimal(10, 4) = 0, @NB_NLe_Dem decimal(10, 4) = 0, @NB_NNghi_Ngay decimal(10, 4) = 0, @NB_NNghi_Dem decimal(10, 4) = 0, @NB_NThuong_Ngay decimal(10, 4) = 0, @NB_NThuong_Dem decimal(10, 4) = 0, @NB_NThuong_NgayDem decimal(10, 4) = 0
			
			, @SoPhutDiMuonThucTe_Luu int = 0, @SoPhutTruDiMuon int = 0,  @SoPhutDiMuonThucTe_DuocCong decimal(10, 4) = 0
			, @SoPhutVeSomThucTe_Luu int = 0 , @SoPhutTruVeSom int = 0, @SoPhutVeSomThucTe_DuocCong decimal(10, 4) = 0
			, @TongSoPhutDiMuonVeSom int = 0	, @CongTruDiMuonVeSom   decimal(10, 4) = 0						

	/*===========================================================	
			Đi muộn về sớm
	===========================================================*/
          begin
  
  					    -- Reset giới hạn nếu không đi làm buổi đó
  					    IF @KhongDiLamBuoiSang = 1 SET @SoPhutDiMuonChoPhep = 0;
  					    IF @KhongDiLamBuoiChieu = 1 SET @SoPhutVeSomChoPhep = 0;
  
  					    -- Lấy tổng thời gian vắng mặt phân loại theo từng kiểu
  					    DECLARE @TongVangMat_Sang INT = 0,    @TongVangMat_Chieu INT = 0;
  
  					    IF @PhutVangMat > 0
  					    BEGIN
  							    SELECT
  									    @TongVangMat_Sang = ISNULL(SUM(CASE 
  																											    WHEN TG_VangMat > 0 and LoaiLamThem ='C1'
  																													     AND NgayGioChamCongVao IS NULL 
  																													     --AND @NgayGioChamCong_GioBatDau1 IS NOT NULL 
  																											    THEN TG_VangMat 
  																											    ELSE 0 
  																								     END), 0),
  									    @TongVangMat_Chieu = ISNULL(SUM(CASE 
  																											    WHEN TG_VangMat > 0 and LoaiLamThem ='C2'
  																													     AND NgayGioChamCongRa IS NULL 
  																													     --AND @NgayGioChamCong_GioKetThuc2 IS NOT NULL 
  																											    THEN TG_VangMat 
  																											    ELSE 0 
  																									    END), 0)
  							    FROM #ChamCong;
  					    END;
  
  					    -- Tính đi muộn
  					    SET @SoPhutDiMuonThucTe += @TongVangMat_Sang;
   
  					    IF @LaNgayKhongDiLam = 1 SET @SoPhutDiMuonThucTe = 0;
  					    SET @SoPhutDiMuonThucTe_Luu = @SoPhutDiMuonThucTe;
  					    SET @SoPhutDiMuonThucTe = CASE 
  																			    WHEN @SoPhutDiMuonThucTe <= @SoPhutDiMuonChoPhep THEN 0 
  																			    ELSE @SoPhutDiMuonThucTe 
  																		    END;

  					    SET @SoPhutDiMuonThucTe_DuocCong = CASE 
  																							    WHEN @SoPhutDiMuonThucTe > 0 THEN 0 
  																							    ELSE @SoPhutDiMuonThucTe_Luu 
  																						    END;
  
  					    -- Tính về sớm
  					    SET @SoPhutVeSomThucTe += @TongVangMat_Chieu;
  					    IF @LaNgayKhongDiLam = 1 SET @SoPhutVeSomThucTe = 0;
  					    SET @SoPhutVeSomThucTe_Luu = @SoPhutVeSomThucTe;
  					    SET @SoPhutVeSomThucTe = CASE 
  																			    WHEN @SoPhutVeSomThucTe <= @SoPhutVeSomChoPhep THEN 0 
  																			    ELSE @SoPhutVeSomThucTe 
  																	     END;
  					    SET @SoPhutVeSomThucTe_DuocCong = CASE 
  																							    WHEN @SoPhutVeSomThucTe > 0 THEN 0 
  																							    ELSE @SoPhutVeSomThucTe_Luu 
  																						    END;
  
  					    -- Tổng lại
  					    SET @TongSoPhutDiMuonVeSom = @SoPhutDiMuonThucTe + @SoPhutVeSomThucTe;

		

			    end
                
	

--select N'Đi muộn về sớm' as mkn,  @SoPhutDiMuonThucTe SoPhutDiMuonThucTe	, @SoPhutVeSomThucTe SoPhutVeSomThucTe, @TongSoPhutDiMuonVeSom TongSoPhutDiMuonVeSom
	/*===========================================================	
			Thời gian làm việc ca chính
	===========================================================*/	
			begin
					set @SoPhutLamViecThucTe = @SoPhutLV_BanNgay + @SoPhutLV_BanDem
					set @SoPhutLamViecThucTe = case when @SoPhutLamViecThucTe < 0 then 0 else @SoPhutLamViecThucTe end				
			end

/*===========================================================	
		Giải trình TGDiMuon -  TGVeSom - THEM_GIO
===========================================================*/			
			begin

				declare @GiaiTrinhDiMuonDuocDuyet bit =0, @GiaiTrinhVeSomDuocDuyet bit =0, @GiaiTrinhThieuGioDuocDuyet bit =0
				drop table if exists  #GTC
				Select TongHopTheoNgay_ChinhSuaID, LyDoViPhamID, FieldName, XetDuyet, GiaTriMoi into #GTC  from  NS_TL_CC_TongHopTheoNgay_ChinhSua 
									where NhanVienID = @NhanVienID AND NgayChamCong = @NgayChamCong and XetDuyet in (1, 0, -1) order by NgayChinhSua desc

				if exists  (select 1 from #GTC )
				begin
						 -- Đi muộn
						IF EXISTS (SELECT 1 FROM #GTC WHERE FieldName = 'TGDiMuon' AND XetDuyet = 1)
						BEGIN
								SET @GiaiTrinhDiMuonDuocDuyet = 1;
                                set @SoPhutLamViecThucTe += @SoPhutDiMuonThucTe
								--An them
                                set @SoPhutLV_BanDem = @SoPhutLV_BanDem + (case when @SoPhutLV_BanDem>0 then @SoPhutDiMuonThucTe else 0 end)
								--
                                set @SoPhutDiMuonThucTe =0

						END
						IF EXISTS (SELECT 1 FROM #GTC WHERE FieldName = 'TGVeSom' AND XetDuyet = 1)
						BEGIN
								SET @GiaiTrinhVeSomDuocDuyet = 1;
                                set @SoPhutLamViecThucTe += @SoPhutVeSomThucTe
								--An them
                                set @SoPhutLV_BanDem = @SoPhutLV_BanDem + (case when @SoPhutLV_BanDem>0 then @SoPhutVeSomThucTe else 0 end)
								--
                                set @SoPhutVeSomThucTe =0
						END
						IF EXISTS (SELECT 1 FROM #GTC WHERE FieldName = 'THEM_GIO' AND XetDuyet = 1)
						BEGIN
								SET @GiaiTrinhThieuGioDuocDuyet = 1;
						END


                        SELECT @GhiChu = STUFF((
	                        SELECT DISTINCT 
		                        '; ' + 
		                        CASE 
			                        WHEN FieldName = 'TGDiMuon' AND XetDuyet = 1 THEN N'Giải trình đi muộn được duyệt'
			                        WHEN FieldName = 'TGDiMuon' AND XetDuyet = 0 THEN N'Giải trình đi muộn đang chờ duyệt'
			                        WHEN FieldName = 'TGDiMuon' AND XetDuyet = -1 THEN N'Giải trình đi muộn bị từ chối'

			                        WHEN FieldName = 'TGVeSom' AND XetDuyet = 1 THEN N'Giải trình về sớm được duyệt'
			                        WHEN FieldName = 'TGVeSom' AND XetDuyet = 0 THEN N'Giải trình về sớm đang chờ duyệt'
			                        WHEN FieldName = 'TGVeSom' AND XetDuyet = -1 THEN N'Giải trình về sớm bị từ chối'

			                        WHEN FieldName = 'THEM_GIO' AND XetDuyet = 1 THEN N'Giải trình quên chấm công được duyệt'
			                        WHEN FieldName = 'THEM_GIO' AND XetDuyet = 0 THEN N'Giải trình quên chấm công đang chờ duyệt'
			                        WHEN FieldName = 'THEM_GIO' AND XetDuyet = -1 THEN N'Giải trình quên chấm công bị từ chối'
		                        END
	                        FROM #GTC
	                        FOR XML PATH(''), TYPE
                        ).value('.', 'NVARCHAR(MAX)'), 1, 2, '')


				end
			
                if(@DoiTuongChamCong <> 3)
				begin
					set @GioDen = ISNULL (@GioDen, '00:00:00')
					set @GioRa = ISNULL (@GioRa, '00:00:00')
					set @GioVao = ISNULL (@GioVao, '00:00:00')
					set @GioVe = ISNULL (@GioVe, '00:00:00')
					if(@DoiTuongChamCong =2)
					begin
						set @GhiChu += Char(10)+ N'Không tính đi muộn về sớm'
					end
				end
				else 
				begin
					set @GioDen = '00:00:00'
					set @GioRa =  '00:00:00'
					set @GioVao =  '00:00:00'
					set @GioVe =  '00:00:00'
					set @GhiChu = N'Miễn chấm công'							
				end

            end
            /*Số phút làm việc + tổng thời gian làm việc ngày + đêm*/
            set   @SoPhutLamViec = case  when  @SoPhutLamViecThucTe > 0 then  @SoPhutLamViecThucTe + @SoPhutVeSomThucTe_DuocCong + @SoPhutDiMuonThucTe_DuocCong  else 0 end ;
            if (@SoPhutLamViec > @SoPhutLamViec_Ca)
            begin
                        set @SoPhutLamViec = @SoPhutLamViec_Ca - case when @SoPhutTruDiMuon + @SoPhutTruVeSom > @SoPhutLamViecTieuChuan then @SoPhutLamViecTieuChuan else @SoPhutTruDiMuon + @SoPhutTruVeSom end;
            end;
	/*===========================================================	
			Thời gian làm thêm
	===========================================================*/	

			begin
/*Thời gian OT TÍNH TIỀN thực tế */
/*===========================================================*/
					
					-- Gom tất cả vào một CTE duy nhất
					;WITH OT_TinhTien_CTE AS (
							SELECT Vao_NgayLe, Ra_NgayLe, Vao_NgayNghi, Ra_NgayNghi,  TGLamViec, TGLamViec_NgayHomTruoc, TGLamViec_NgayHomSau, TGLamViecBanDem_NgayHomTruoc, TGLamViecBanDem_NgayHomSau, LoailamThem
							FROM #CHAMCONG WHERE LoaiTC = 'TINHTIEN' AND LoailamThem IN ('TC', 'GC', 'SC')
					)

					SELECT
							@OT_NLe_Dem       = ISNULL(SUM(CASE WHEN Ra_NgayLe = 1 THEN TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayLe = 1 THEN TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@OT_NLe_Ngay      = ISNULL(SUM(CASE WHEN Ra_NgayLe = 1 THEN TGLamViec_NgayHomSau - TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayLe = 1 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@OT_NNghi_Dem     = ISNULL(SUM(CASE WHEN Ra_NgayNghi = 1 THEN TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayNghi = 1 THEN TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@OT_NNghi_Ngay    = ISNULL(SUM(CASE WHEN Ra_NgayNghi = 1 THEN TGLamViec_NgayHomSau - TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayNghi = 1 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@OT_NThuong_NgayDem = ISNULL(SUM(CASE 
																									WHEN Ra_NgayLe = 0 AND Ra_NgayNghi = 0 THEN TGLamViecBanDem_NgayHomSau 
																									ELSE 0 
																							 END), 0)
																	+ ISNULL(SUM(CASE 
																									WHEN Vao_NgayLe = 0 AND Vao_NgayNghi = 0 THEN TGLamViecBanDem_NgayHomTruoc 
																									ELSE 0 
																							 END), 0),
                                                                                             
							@OT_NThuong_Ngay = ISNULL(SUM(CASE 
																									WHEN Ra_NgayLe = 0 AND Ra_NgayNghi = 0 THEN TGLamViec_NgayHomSau -TGLamViecBanDem_NgayHomSau 
																									ELSE 0 
																							 END), 0)
																	+ ISNULL(SUM(CASE 
																									WHEN Vao_NgayLe = 0 AND Vao_NgayNghi = 0 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc 
																									ELSE 0 
																							 END), 0)
					FROM OT_TinhTien_CTE


					-- Nếu không có OT ban ngày thì gán vào OT_NThuong_Dem, ngược lại giữ ở OT_NThuong_NgayDem
					IF @OT_NThuong_Ngay = 0
					BEGIN
							SET @OT_NThuong_Dem = @OT_NThuong_NgayDem;
							SET @OT_NThuong_NgayDem = 0;
					END


					-- Tổng tất cả OT tính tiền
					SET @OT_TinhTien = ISNULL(@OT_NLe_Dem, 0) + ISNULL(@OT_NLe_Ngay, 0) + ISNULL(@OT_NNghi_Dem, 0) + ISNULL(@OT_NNghi_Ngay, 0) + ISNULL(@OT_NThuong_Dem, 0) + ISNULL(@OT_NThuong_Ngay, 0) + ISNULL(@OT_NThuong_NgayDem, 0);

--SELECT N'Làm thêm tính tiền' AS MKN, @OT_NLe_Dem OT_NLe_Dem, @OT_NLe_Ngay OT_NLe_Ngay, @OT_NNghi_Dem OT_NNghi_Dem, @OT_NNghi_Ngay OT_NNghi_Ngay, @OT_NThuong_Dem OT_NThuong_Dem, @OT_NThuong_Ngay OT_NThuong_Ngay,@OT_NThuong_NgayDem OT_NThuong_NgayDem, @OT_TinhTien OT_TinhTien

		/*Thời gian OT NGHỈ BÙ thực tế */
		/*===========================================================*/
    			;WITH OT_NGHIBU_CTE AS (
    					SELECT Vao_NgayLe, Ra_NgayLe, Vao_NgayNghi, Ra_NgayNghi, TGLamViec_NgayHomTruoc, TGLamViec_NgayHomSau, TGLamViecBanDem_NgayHomTruoc, TGLamViecBanDem_NgayHomSau, LoailamThem
    					FROM #CHAMCONG WHERE LoaiTC = 'NGHIBU' AND LoailamThem IN ('TC', 'GC', 'SC')
					)
					SELECT
							@NB_NLe_Dem       = ISNULL(SUM(CASE WHEN Ra_NgayLe = 1 THEN TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayLe = 1 THEN TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@NB_NLe_Ngay      = ISNULL(SUM(CASE WHEN Ra_NgayLe = 1 THEN TGLamViec_NgayHomSau - TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayLe = 1 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@NB_NNghi_Dem     = ISNULL(SUM(CASE WHEN Ra_NgayNghi = 1 THEN TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayNghi = 1 THEN TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@NB_NNghi_Ngay    = ISNULL(SUM(CASE WHEN Ra_NgayNghi = 1 THEN TGLamViec_NgayHomSau - TGLamViecBanDem_NgayHomSau ELSE 0 END), 0)
																+ ISNULL(SUM(CASE WHEN Vao_NgayNghi = 1 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc ELSE 0 END), 0),

							@NB_NThuong_NgayDem = ISNULL(SUM(CASE 
																									WHEN Ra_NgayLe = 0 AND Ra_NgayNghi = 0 THEN TGLamViecBanDem_NgayHomSau 
																									ELSE 0 
																							 END), 0)
																	+ ISNULL(SUM(CASE 
																									WHEN Vao_NgayLe = 0 AND Vao_NgayNghi = 0 THEN TGLamViecBanDem_NgayHomTruoc 
																									ELSE 0 
																							 END), 0),
                        @NB_NThuong_Ngay = ISNULL(SUM(CASE 
																									WHEN Ra_NgayLe = 0 AND Ra_NgayNghi = 0 THEN TGLamViec_NgayHomSau -TGLamViecBanDem_NgayHomSau 
																									ELSE 0 
																							 END), 0)
																	+ ISNULL(SUM(CASE 
																									WHEN Vao_NgayLe = 0 AND Vao_NgayNghi = 0 THEN TGLamViec_NgayHomTruoc - TGLamViecBanDem_NgayHomTruoc 
																									ELSE 0 
																							 END), 0)

					FROM OT_NGHIBU_CTE;	-- Nếu không có OT ban ngày thì gán vào OT_NThuong_Dem, ngược lại giữ ở OT_NThuong_NgayDem
					
					IF @NB_NNghi_Ngay = 0
					BEGIN
							SET @NB_NThuong_Dem = @NB_NThuong_NgayDem;
							SET @NB_NThuong_NgayDem = 0;
					END

						
					set   @OT_TinhNghiBu = ISNULL(@NB_NLe_Dem, 0) + ISNULL(@NB_NLe_Ngay, 0) + ISNULL(@NB_NNghi_Dem, 0) + ISNULL(@NB_NNghi_Ngay, 0) + ISNULL(@NB_NThuong_Ngay, 0) + ISNULL(@NB_NThuong_Dem, 0) + ISNULL(@NB_NThuong_NgayDem, 0)
					
                    set @OT_TinhTien = @OT_NLe_Dem + @OT_NLe_Ngay + @OT_NNghi_Dem + @OT_NNghi_Ngay + @OT_NThuong_Dem + @OT_NThuong_Ngay +  @OT_NThuong_NgayDem + @OT_NThuong_NgayDem
  					set @OT_TinhNghiBu = @NB_NLe_Dem + @NB_NLe_Ngay + @NB_NNghi_Dem + @NB_NNghi_Ngay + @NB_NThuong_Ngay + @NB_NThuong_Dem + @NB_NThuong_NgayDem
  					set @TG_OT_Ngay = @OT_NLe_Ngay + @OT_NNghi_Ngay + @OT_NThuong_Ngay + @NB_NLe_Ngay + @NB_NNghi_Ngay + @NB_NThuong_Ngay
  					set @TG_OT_Dem = @OT_NLe_Dem + @OT_NNghi_Dem + @OT_NThuong_Dem + @NB_NLe_Dem + @NB_NNghi_Dem + @NB_NThuong_Dem +   @OT_NThuong_NgayDem   + @NB_NThuong_NgayDem

					
			end		



/*
		CREATE NONCLUSTERED INDEX IX_NS_TL_CC_TongHop_NhanVien_Ngay_Field
		ON NS_TL_CC_TongHopTheoNgay_ChinhSua(NhanVienID, NgayChamCong, FieldName, XetDuyet)
		INCLUDE (NgayChinhSua, GiaTriMoi);
*/	
	
	/*===========================================================	
			Chi tiết công phép, công tác
	===========================================================*/	
    	begin  
  	        declare @NghiPhep decimal(10, 4) =0,  @NghiBHXH decimal(10, 4) =0,  @NghiKhongLuong decimal(10, 4) =0,  @Nghile decimal(10, 4) =0,  @NghiBuLe decimal(10, 4) =0,  @NghiCheDo decimal(10, 4) =0
  	        ,  @NghiCoLuong decimal(10, 4) =0, @CongTac decimal(10, 4) =0, @NghiBu decimal(10, 4) =0, @NghiThaiSan decimal(10, 4) =0
  
  	        declare @NghiKhongLuong_RO decimal(10, 4) =0, @NghiKhongLuong_KP decimal(10, 4) =0, @NghiKhongLuong_NT decimal(10, 4) =0,   @NghiKhongLuong_0x decimal(10, 4) =0
  	        , @NghiBHXH_O decimal(10, 4) =0, @NghiBHXH_ODN decimal(10, 4) =0, @NghiBHXH_CO decimal(10, 4) =0, @NghiBHXH_DSO decimal(10, 4) =0,  @NghiBHXH_DSS decimal(10, 4) =0
  	        , @NghiBHXH_KT decimal(10, 4) =0, @NghiBHXH_KH decimal(10, 4) =0, @NghiBHXH_ST decimal(10, 4) =0, @NghiBHXH_T decimal(10, 4) =0
  	        , @NghiCheDo_M decimal(10, 4) =0, @NghiCheDo_C decimal(10, 4) =0
  
  	        , @NghiCoLuong_OL decimal(10, 4) =0, @NghiCoLuong_OLF0 decimal(10, 4) =0, @NghiCoLuong_F0 decimal(10, 4) =0, @NghiCoLuong_DC decimal(10, 4) =0
  		
            
            -- Bảng cấu hình mapping loại nghỉ
            /*BoQuaNgayLe =1 bỏ qua ngày lễ nếu đăng ký nghỉ vào ngày lễ
            BoQuaNgayNghiTuan =1 bỏ qua ngày nghỉ tuần nếu đăng ký nghỉ vào ngày nghỉ tuần*/
  			declare @KyHieuMapping TABLE (Ma NVARCHAR(20),Bien NVARCHAR(100),BoQuaNgayNghiTuan bit default 1, BoQuaNgayLe bit default 1);
  			INSERT INTO @KyHieuMapping (Ma, Bien, BoQuaNgayNghiTuan, BoQuaNgayLe)
  					VALUES 
  							/*không hưởng lương*/
  							(N'RO', N'@NghiKhongLuong_RO',1,1),				(N'KP', N'@NghiKhongLuong_KP',1,1),
  							(N'NT', N'@NghiKhongLuong_NT',1,1),				(N'0x', N'@NghiKhongLuong_0x',1,1),
  							/*Nghỉ chế độ _ có hưởng lương*/
  							(N'M', N'@NghiCheDo_M',1,1),				(N'C', N'@NghiCheDo_C',1,1), 
  								/*Nghỉ BHXH không hưởng lương*/
  							(N'CO', N'@NghiBHXH_CO',1,1),	                (N'DSO', N'@NghiBHXH_DSO' ,1,1),				(N'Ô', N'@NghiBHXH_O',1,1),             ('O', N'@NghiBHXH_ODN',1,0),				
  							(N'DSS', N'@NghiBHXH_DSS',1,1),				(N'KH', N'@NghiBHXH_KH',1,1),               (N'KT', N'@NghiBHXH_KT',1,1),	
                              (N'ST', N'@NghiBHXH_ST',1,1),	                (N'S', N'@NghiThaiSan',1,0),	                    (N'T', N'@NghiBHXH_T',1,1),
  							/*Có hưởng lương*/
  							(N'BU', N'@NghiBu',1,1),				(N'CT', N'@CongTac',1,1),
  							(N'P', N'@NghiPhep',1,1),
  							(N'OL', N'@NghiCoLuong_OL',1,1),				(N'OLF0', N'@NghiCoLuong_OLF0',1,1),
  							(N'F0', N'@NghiCoLuong_F0',1,1),                (N'DC', N'@NghiCoLuong_DC',1,1)
  




  -- Bước 2: Bảng kết quả
            DECLARE @KetQua TABLE (Ma NVARCHAR(20), GiaTri DECIMAL(10,4), KyHieu NVARCHAR(20))
  
            -- Bước 3: Xử lý từng loại
            INSERT INTO @KetQua (Ma, GiaTri, KyHieu)
            SELECT k.Ma,GiaTri = CASE WHEN TyLe < 0.85 THEN 0.5 ELSE 1 END, KyHieu = CASE WHEN TyLe < 0.85 THEN k.Ma + N'/2' ELSE k.Ma END
            FROM (
                SELECT m.Ma, m.BoQuaNgayNghiTuan, m.BoQuaNgayLe
                    , TyLe = SUM(c.ThoiGianNghi * 1.0) / NULLIF(@SoPhutLamViecTieuChuan, 0)
                FROM @KyHieuMapping m
                JOIN @Cong_Nghi_CongTac c ON c.KyHieuChamCong = m.Ma
                WHERE
                    (
                        (m.BoQuaNgayNghiTuan = 1 AND m.BoQuaNgayLe = 1 AND @LaNgayNghi = 0 AND @LaNgayLe = 0) OR            /*Chỉ tính ngày bình thường*/
                        (m.BoQuaNgayNghiTuan = 1 AND m.BoQuaNgayLe = 0 AND (@LaNgayNghi = 0 or @LaNgayLe =1)) OR                /*Bỏ qua ngày nghỉ tuần, không bỏ qua lễ*/
                        (m.BoQuaNgayNghiTuan = 0 AND m.BoQuaNgayLe = 1 AND @LaNgayLe = 0) OR
                        (m.BoQuaNgayNghiTuan = 0 AND m.BoQuaNgayLe = 0 )
                    )
                GROUP BY m.Ma, m.BoQuaNgayNghiTuan, m.BoQuaNgayLe
            ) k
            WHERE k.TyLe > 0;
  
            -- Bước 4: Gán giá trị từ @KetQua về các biến tương ứng
            SELECT
            	/*không hưởng lương*/
                @NghiKhongLuong_RO  = ISNULL(MAX(CASE WHEN Ma = 'RO' THEN GiaTri END), 0),
                @NghiKhongLuong_KP  = ISNULL(MAX(CASE WHEN Ma = 'KP' THEN GiaTri END), 0),
                @NghiKhongLuong_NT  = ISNULL(MAX(CASE WHEN Ma = 'NT' THEN GiaTri END), 0),
                @NghiKhongLuong_0x  = ISNULL(MAX(CASE WHEN Ma = '0x' THEN GiaTri END), 0),
                
                 /*Nghỉ chế độ _ có hưởng lương*/
                @NghiCheDo_M = ISNULL(MAX(CASE WHEN Ma = 'M' THEN GiaTri END), 0),
                @NghiCheDo_C = ISNULL(MAX(CASE WHEN Ma = 'C' THEN GiaTri END), 0),
  
                /*Nghỉ BHXH không hưởng lương*/
                @NghiBHXH_CO  = ISNULL(MAX(CASE WHEN Ma = 'CO' THEN GiaTri END), 0),
                @NghiBHXH_DSO    = ISNULL(MAX(CASE WHEN Ma = 'DSO' THEN GiaTri END), 0),
                @NghiBHXH_O = ISNULL(MAX(CASE WHEN Ma = 'Ô' THEN GiaTri END), 0),
                @NghiBHXH_ODN = ISNULL(MAX(CASE WHEN Ma = 'O' THEN GiaTri END), 0),
                @NghiBHXH_DSS = ISNULL(MAX(CASE WHEN Ma = 'DSS' THEN GiaTri END), 0),
                @NghiBHXH_KH = ISNULL(MAX(CASE WHEN Ma = 'KH' THEN GiaTri END), 0),
                @NghiBHXH_KT = ISNULL(MAX(CASE WHEN Ma = 'KT' THEN GiaTri END), 0),
                @NghiBHXH_ST = ISNULL(MAX(CASE WHEN Ma = 'ST' THEN GiaTri END), 0),
                @NghiBHXH_T  = ISNULL(MAX(CASE WHEN Ma = 'T' THEN GiaTri END), 0),
                @NghiThaiSan = ISNULL(MAX(CASE WHEN Ma = 'S' THEN GiaTri END), 0),
  
                /*Có hưởng lương*/
                @NghiBu  = ISNULL(MAX(CASE WHEN Ma = 'BU' THEN GiaTri END), 0),
                @CongTac    = ISNULL(MAX(CASE WHEN Ma = 'CT' THEN GiaTri END), 0),
                @NghiPhep = ISNULL(MAX(CASE WHEN Ma = 'P' THEN GiaTri END), 0),
                @NghiCoLuong_OL = ISNULL(MAX(CASE WHEN Ma = 'OL' THEN GiaTri END), 0),
                @NghiCoLuong_OLF0 = ISNULL(MAX(CASE WHEN Ma = 'OLF0' THEN GiaTri END), 0),
                @NghiCoLuong_F0 = ISNULL(MAX(CASE WHEN Ma = 'F0' THEN GiaTri END), 0),
                @NghiCoLuong_DC = ISNULL(MAX(CASE WHEN Ma = 'DC' THEN GiaTri END), 0)
                from @KetQua


            set @NghiKhongLuong = @NghiKhongLuong_RO + @NghiKhongLuong_KP + @NghiKhongLuong_NT  + @NghiKhongLuong_0x
            set @NghiCheDo = @NghiCheDo_M + @NghiCheDo_C
            set @NghiBHXH = @NghiBHXH_CO + @NghiBHXH_DSO + @NghiBHXH_O +  @NghiBHXH_ODN + @NghiBHXH_DSS + @NghiBHXH_KH + @NghiBHXH_KT + @NghiBHXH_ST  + @NghiBHXH_T
            set @NghiCoLuong = @NghiCoLuong_OL+ @NghiCoLuong_OLF0 + @NghiCoLuong_F0 + @NghiCoLuong_DC*0.5
            SET ANSI_WARNINGS ON;
            SELECT @KyHieuChamCong =     ISNULL(@KyHieuChamCong, '') +    ISNULL((        SELECT '' + KyHieu        FROM @KetQua        FOR XML PATH(''), TYPE    ).value('.', 'NVARCHAR(200)'), '');
            set @KyHieuChamCongID =Isnull( (select top 1 KyHieuChamCongID from  NS_TL_KyHieuChamCong where KyHieu in (select KyHieu from  @KetQua )),0)

            set @NghiBuLe = case  when  @LaNgayNghi_BuLe =1 then  1 else  0 end ;
    		if (@NghiBuLe > 0)
    		begin 
    				set   @KyHieuChamCong += case  when  @NghiBuLe > 0.5 then  'BL' else 'BL/2' end ;
                    set    @KyHieuChamCongID = case when @KyHieuChamCongID = 0 then  41 else @KyHieuChamCongID end
    		end ;
    

    		/*@NghiLe*/
    		set   @NghiLe = case  when  @LaNgayLe = 1 then  1 else 0 end ;
    		if (@NghiLe > 0)
    		begin 
    				set   @KyHieuChamCong += case  when  @NghiLe > 0.5 then  'L' else 'L/2' end ;
                    set    @KyHieuChamCongID = case when @KyHieuChamCongID = 0 then  20 else @KyHieuChamCongID end
    		end ;
             set    @KyHieuChamCongID = case when @KyHieuChamCongID = 0 and (@LaNgayNghi =1 or @LaNgayNghi_DKC =1) then  36 else @KyHieuChamCongID end
  
        end

  		declare @TongCongNghi decimal(10, 4) = @NghiPhep + @NghiBu + @NghiBuLe + @NghiLe + @CongTac + @NghiThaiSan + @NghiKhongLuong + @NghiCheDo +@NghiBHXH + @NghiCoLuong		      	
  		if (@TongCongNghi >= 1)
  		begin 
  			 set   @GhiChu = N'';
  		end ;		


		/*NẾU KO LÀ NGÀY NGHỈ HOẶC TỔNG CÔNG NGHỈ < 0*/
  		if (@LaNgayNghi = 0 AND @TongCongNghi < 1)
  		begin 
  			 /* Ghi chú*/
  			 if (ISNULL (@NgayGioChamCong_GioBatDau1, 0) = 0 AND ISNULL (@NgayGioChamCong_GioKetThuc2, 0) = 0)
  			 begin 
  					if ((SELECT case  when  @LaNgayLe = 1 OR @LaChuNhat = 1  OR @NghiPhep > 0 OR @MaCaLamViec LIKE N'%OFF%' then  1 else 0 end ) = 0)
  						  set   @GhiChu = N'Không xác định được dữ liệu chấm công';
  			 end ;
  			 else
  			 begin 
  					if (ISNULL (@NgayGioChamCong_GioBatDau1, 0) = 0)
  						  set   @GhiChu = N'Không xác định được thời gian đến';
  					if (ISNULL (@NgayGioChamCong_GioKetThuc2, 0) = 0)
  						  set   @GhiChu = N'Không xác định được thời gian về';
  			 end ;
  
  		end ;
  
  		begin 
  			 set   @GioDen = ISNULL (@GioDen, '00:00:00');
  			 set   @GioRa = ISNULL (@GioRa, '00:00:00');
  			 set   @GioVao = ISNULL (@GioVao, '00:00:00');
  			 set   @GioVe = ISNULL (@GioVe, '00:00:00');

			 --set @GioDen = case when @GioVe = '00:00:00' then '00:00:00' else @GioDen end
			 --set @GioVe = case when @GioDen = '00:00:00' then '00:00:00' else @GioVe end
  		end ;
  
  		/*LẤY KÝ HIỆU CHẤM CÔNG - HIỂN THỊ GIẢI TRÌNH CÔNG*/
  		begin 
  				



		-----An thêm
		DECLARE @SoPhutDiMuonThucTe_TAM int = @SoPhutDiMuonThucTe, @SoPhutVeSomThucTe_TAM int = @SoPhutVeSomThucTe
		if @SoPhutDiMuonThucTe > 0 and @SoPhutLamViec > 0 and (select count (*) from v_DeXuatDiMuonVeSom where NhanVienID=@NhanVienID and @NgayChamCong BETWEEN NgayBatDau AND NgayKetThuc AND XetDuyet = 1 and SoPhutDiMuon>0)>0
		begin
			set @SoPhutDiMuonThucTe = @SoPhutDiMuonThucTe - (select SoPhutDiMuon from v_DeXuatDiMuonVeSom where NhanVienID=@NhanVienID and @NgayChamCong BETWEEN NgayBatDau AND NgayKetThuc AND XetDuyet = 1 and SoPhutDiMuon>0)
			set @SoPhutDiMuonThucTe = case when @SoPhutDiMuonThucTe < 0 then 0 else @SoPhutDiMuonThucTe end
			set @SoPhutDiMuonThucTe_TAM = @SoPhutDiMuonThucTe_TAM - @SoPhutDiMuonThucTe
			set @SoPhutLamViec = @SoPhutLamViec + @SoPhutDiMuonThucTe_TAM
		end
		if @SoPhutVeSomThucTe > 0 and @SoPhutLamViec > 0 and (select count (*) from v_DeXuatDiMuonVeSom where NhanVienID=@NhanVienID and @NgayChamCong BETWEEN NgayBatDau AND NgayKetThuc AND XetDuyet = 1 and SoPhutVeSom>0)>0
		begin
			set @SoPhutVeSomThucTe = @SoPhutVeSomThucTe - (select SoPhutVeSom from v_DeXuatDiMuonVeSom where NhanVienID=@NhanVienID and @NgayChamCong BETWEEN NgayBatDau AND NgayKetThuc AND XetDuyet = 1 and SoPhutVeSom>0)
			set @SoPhutVeSomThucTe = case when @SoPhutVeSomThucTe < 0 then 0 else @SoPhutVeSomThucTe end
			set @SoPhutVeSomThucTe_TAM = @SoPhutVeSomThucTe_TAM - @SoPhutVeSomThucTe
			set @SoPhutLamViec = @SoPhutLamViec + @SoPhutVeSomThucTe_TAM
		end
		--set @SoPhutLamViec = @SoPhutLamViec + @SoPhutDiMuonThucTe_TAM + @SoPhutVeSomThucTe_TAM
		-------------

		declare @TGLamViec decimal(10, 2) = 0, @TGLamViec_Dem decimal(10, 2) = 0
        
        set @SoPhutLamViec =ROUND(convert(decimal(10,2), coalesce(@SoPhutLamViec *1.0/ nullif(@SoPhutLamViecTieuChuan ,0) * 8.0, 0)    )   ,0)
		set  @TGLamViec =  @SoPhutLamViec

        set @SoPhutLamDem = ROUND(convert(decimal(10,2), coalesce(@SoPhutLV_BanDem*1.0 / nullif(@SoPhutLamViecTieuChuan ,0) * 8.0, 0)   )  ,0)
        set @TGLamViec_Dem =  @SoPhutLamDem

        set @TGLamViec  =  IIF(@TGLamViec> @SoPhutLamViec_Ca, @SoPhutLamViec_Ca,@TGLamViec)
         

        set @KyHieuChamCong = case when @SoPhutLamViec > 0 then  CONCAT('/', FORMAT(@TGLamViec,'N0'), (case when @SoPhutLamDem> 8 then '*' else '' end)) else  @KyHieuChamCong end
		
        set @KyHieuChamCong = case when @LaNgayNghi =1 then  '/NT' else  @KyHieuChamCong end
		set @KyHieuChamCong = case when LEFT(@KyHieuChamCong, 1) = '/' then SUBSTRING (@KyHieuChamCong, 2, LEN (@KyHieuChamCong) - 1) else @KyHieuChamCong end;

		if (@TongCongNghi < 1 AND @LaNgayLe = 0 AND @LaNgayNghi = 0 and @TongCongNghi > 0)
		begin
			set @DienGiai_GiaiTrinh = CONCAT (N'Giờ làm việc ', @MaCaLamViec, ': ', left(format(@NgayGio_GioBatDau1,'HH:mm'),5),'_',left(format(@NgayGio_GioKetThuc1,'HH:mm'),5), ' : ', left(format(@NgayGio_GioBatDau2,'HH:mm'),5),'_',left(format(@NgayGio_GioKetThuc2,'HH:mm'),5));
		end;
		else	if (    @LaNgayLe = 0 AND @LaNgayNghi = 0 and @TongCongNghi = 0)
		begin
			set @DienGiai_GiaiTrinh = CONCAT (N'Ca làm việc ', @MaCaLamViec, ': ', left(format(@NgayGio_GioBatDau1,'HH:mm'),5),'_',left(format(@NgayGio_GioKetThuc1,'HH:mm'),5), ' : ', left(format(@NgayGio_GioBatDau2,'HH:mm'),5),'_',left(format(@NgayGio_GioKetThuc2,'HH:mm'),5)) ;
		end;

		if exists (select QTCongTacID FROM NS_QTCongTac		WHERE  NgayBatDau <= @NgayGio_GioKetThuc2 AND NgayKetThuc >= @NgayGio_GioBatDau1 AND NhanVienID = @NhanVienID AND XetDuyet = 0)
		begin
