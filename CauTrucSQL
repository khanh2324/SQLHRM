	from (
		select 
			  nv.MaNhanVien as MaNV, nv.Ho + ' ' + nv.HoTen as TenNhanVien, bl_text.NhomCostCenter as NhomCostCentral, bl_text.CostCenter as CostCentral

			, isnull(bl.[TLNC_LCB], 0) as LuongGop
			, isnull(bl.[TLNC_PC_TrachNhiem], 0) as PCTrachNhiem, isnull(bl.[TLNC_PC_ViTri], 0) as PCViTri, isnull(bl.[TLNC_PC_DiLai], 0) as PCDiLai
			, isnull(bl.[TLNC_PC_DocHai], 0) as PCDocHai, isnull(bl.[TLNC_PC_Khac], 0) as PCKhac, isnull(bl.[TLNC_PC_BuaAn], 0) as PCBuaAn
			, isnull(bl.[TLNC_ThuongThang], 0) as ThuongThang, isnull(bl.[Thuong_KM], 0) as ThuongKM
		
			, isnull(bl.[TLOT_ChieuThue], 0) as LuongLamThemCoBan, isnull(bl.[TLOT_MienThue], 0) as LuongLamThemChenhLech, isnull(bl.[TLOT_LamCaDem], 0) as LuongTraThemCaDem
			, isnull(bl.[Thuong_ChenhLechT1], 0) as ChenhLechThang1, isnull(bl.[Thuong_KPI], 0) as ThuongKPI, isnull(bl.[Thuong_LuongT13], 0) as LuongThang13
			, isnull(bl.[Thuong_Nam], 0) as ThuongNam, isnull(bl.[Thuong_CongTruocThue], 0) as CongKhac, isnull(bl.[Thuong_TruTruocThue], 0) as TruTruocThue
			, isnull(bl.[TongThuNhap], 0) as TongPhaiTra, isnull(bl.[BH_Tong_NLD], 0) as TongBHNV, isnull(bl.[BH_Tong_CTY], 0) as TongBHCTY

			, isnull(bl.[BH_Tong], 0) as TongBHNV_CTY, isnull(bl.[Tax_GiamTru_BanThan], 0) as MucGiamTruGiaCanh, isnull(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) as MucGiamTruNguoiPhuThuoc
			, isnull(bl.[Tax_SoNguoiPhuThuoc], 0) as SoNguoiPhuThuoc, isnull(bl.[Tax_ThuNhapChiuThue], 0) as ThuNhapChiuThue, isnull(bl.[Tax_TongThue], 0) as MucThuePhaiNop
			, isnull(bl.[Tax_ThuNhapSauThue], 0) as ThuNhapSauThue, isnull(bl.[PSSThue_CongDoan_NLD], 0) as PhiCongDoanCaNhan
