CREATE PROCEDURE [dbo].[ADD_XD_XOADANGKYLAMTHEMGIO]
(@BuocThucHienID int,@BuocTiepTheoID int,@NguoiTaoID int,@XetDuyetID int)
AS
BEGIN

--select * from WF_QuyTrinh_BuocThucHien where QuyTrinhID=7
--declare @BuocTiepTheoID INT=1045
--DECLARE @XetDuyetID INT = 17150

declare @ID int = (select ObjectID from SYS_XetDuyet where XetDuyetID=@XetDuyetID)
declare @NhanVienID int = (select NhanVienID from NS_TL_DangKyOT where DangKyOTID = @ID)
declare @NgayOT date = (select convert(date,BatDauLamThem) from NS_TL_DangKyOT where DangKyOTID = @ID)
declare @ThuOT int = (select Thu from NS_BH_NgayThang where @NgayOT = Ngay)
declare @SoGioOT decimal(10,1) = (select datediff(minute,BatDauLamThem,KetThucLamThem) from NS_TL_DangKyOT where DangKyOTID = @ID) / 60

DECLARE @ChucVuQLTT INT =  (SELECT ChucVuID FROM NhanVien WHERE NhanVienID=(SELECT NhanVienID FROM SYS_NguoiDung WHERE NguoiDungID=(SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienID = @NhanVienID)))
DECLARE @CapTrenQLTT INT = (SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienID = (SELECT NhanVienID FROM dbo.SYS_NguoiDung
							WHERE NguoiDungID = (SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienId = @NhanVienID)))
DECLARE @ChucVuId INT = (SELECT ChucVuId FROM dbo.NhanVien WHERE NhanVienId = @NhanVienID)
DECLARE @NhomNhanSu INT = (SELECT NhomNhanSuId FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)
DECLARE @PhongBanId INT = (SELECT PhongBanID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)
DECLARE @IDCapPhong INT = (SELECT dbo.fns_LayPhongBanIDTheoCap(1010,@PhongBanId))
DECLARE @IDCapBoPhan INT = (SELECT dbo.fns_LayPhongBanIDTheoCap(1011,@PhongBanId))
--Xử lý riêng trường hợp phòng kỹ thuật đang ko có người đứng đầu
IF @IDCapPhong = 155 AND (SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong) IS NULL
BEGIN
    SET @IDCapPhong = @IDCapBoPhan
END

--nhóm nhân sự văn phòng
IF @NhomNhanSu = 1 AND @PhongBanId NOT IN (SELECT PhongBanID FROM dbo.PhongBan WHERE MaPhongBan like N'%LAB')
BEGIN
	--Nếu line manager là người nằm ở cấp Công ty (gồm các vị trí: giám đốc toàn quốc, phó giám đốc toàn quốc, giám đốc tài chính vùng, giám đốc kỹ thuật vùng...) thì chỉ cần 1 cấp duyệt là Line manager
    IF @ChucVuQLTT IN (SELECT ChucVuID FROM dbo.NhanVien WHERE PhongBanID =  20)
	BEGIN
	    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID
	END
	-- Nếu trưởng VHTK chính là Line manager thì chỉ cần 1 cấp duyệt là Trưởng VHTK
	ELSE IF @ChucVuQLTT in (SELECT ChucVuID FROM dbo.NS_DsChucVu WHERE TenChucVu LIKE N'Trưởng Vận hành Tổng kho%')
	BEGIN
	    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID 
	END
	-- Nếu trưởng BP chính là Line manager thì chỉ cần 1 cấp duyệt là Trưởng BP
	ELSE IF @ChucVuQLTT = (SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong)
	BEGIN
	    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID
	END
	ELSE
	BEGIN
		IF @BuocTiepTheoID = 1076
		BEGIN
		    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID 
		END
		--quản lý cấp phòng
		ELSE IF @BuocTiepTheoID = 1077
		BEGIN
		    SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
				(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
				(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong))
		END
	END
END
--nhóm nhân sự vận hành
ELSE IF @NhomNhanSu = 2 AND @PhongBanId NOT IN (SELECT PhongBanID FROM dbo.PhongBan WHERE MaPhongBan like N'%LAB')
BEGIN
    IF @ChucVuQLTT in (SELECT ChucVuID FROM dbo.NS_DsChucVu WHERE TenChucVu LIKE N'Trưởng Vận hành Tổng kho%')
	BEGIN
	    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID 
	END
	--Với vị trí công việc là Trưởng VHTK thì người duyệt là giám đốc vận hành
	ELSE IF @ChucVuId IN (SELECT ChucVuID FROM dbo.NS_DsChucVu WHERE TenChucVu LIKE N'Trưởng Vận hành Tổng kho%')
	BEGIN
	     SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
				(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
				(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong))
	END
	ELSE
	BEGIN
	    IF @BuocTiepTheoID = 1076
		BEGIN
		    select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID 
		END
		--quản lý cấp phòng
		ELSE IF @BuocTiepTheoID = 1077
		BEGIN
		     SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
				(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
				(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapBoPhan))
		END
	END
END
--Riêng với Nhân sự của Phòng thí nghiệm các Tổng kho thì trải qua 3 cấp duyệt
ELSE
BEGIN
    IF @BuocTiepTheoID = 1076
	BEGIN
		select BaoCaoTrucTiepID from NhanVien where NhanVienID = @NhanVienID 
	END
	--Trưởng phòng QA/QC
	ELSE IF @BuocTiepTheoID = 1077
	BEGIN
		SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
				(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
				(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE MaPhongBan = 'QAQC'))
	END
	-- Trưởng phòng Kỹ thuật
	ELSE
	BEGIN
	    SELECT NguoiDungID FROM SYS_NguoiDung WHERE NhanVienID =
				(SELECT TOP 1 NhanVienID FROM NhanVien WHERE ChucVuID = 
				(SELECT ChucVuLanhDaoID FROM dbo.PhongBan WHERE PhongBanID = @IDCapPhong))
	END
END

END

