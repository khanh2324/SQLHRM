 Set @LTTC  =isnull(@LTTC,1800000)  
  
 DELETE NS_TL_BangTrichBHXH where Ngay =@NgayThang and PhongBanID in (SELECT PhongBanID from @PB)  

/*TrangThaiTGCongDoan được chọn: thì nó ko tham gia! mặc định là tham gia công đoàn*/  
  
   --INSERT INTO dbo.NS_TL_BangTrichBHXH  
   --(MaNhanVien ,NhanVienID ,HoVaTen ,ThuNhapHaiNoi ,TenPhongBan2  
   --,PBID ,PhongBanID1 ,ThuTu ,QuocTich ,IsVeHuu  
   --,MucLuong ,Type ,TyGia ,NhomNhanVienID ,IsCD ,LuongToiThieuID  
   --,Ngay ,IsTrichNop ,ML_BHXH ,ML_BHTN ,TL_BHXHCTY  
   --,TL_BHTNLDCTY ,TL_BHYTCTY ,TL_BHTNCTY ,TL_BHXHNLD ,TL_BHYTNLD  
   --,TL_BHTNNLD ,Thang ,Nam   
     
   --,CONGDOAN ,KPCD  
   --,CD ,BHXH_CTY ,BHTNLD_CTY ,BHYT_CTY ,BHTN_CTY ,BHXH_NLD  
   --,BHYT_NLD ,BHTN_NLD ,BH_NLD ,BH_CTY ,TONGBH)  
    
   --SELECT *,@Thang as Thang,@Nam as Nam,  
   --round(case when IsTrichNop=0 or IsCD=1 or QuocTich <>N'Việt Nam'  then 0  else (case when ML_BHXH*0.01>=(@LTTC*0.1) then (@LTTC*0.1) else ML_BHXH*0.01 end) end,0) as CONGDOAN,  
  
   --round(case when IsTrichNop=0  or  IsVeHuu=1 or QuocTich <>N'Việt Nam'  then 0 else ML_BHXH*0.02 end,0) as KPCD,  
  
   --round(case when IsTrichNop=0 or IsCD=0 or QuocTich <>N'Việt Nam'  then 0 else (case when ML_BHXH*0.01>=@LTTC*0.1 then @LTTC*0.1 else ML_BHXH*0.01 end) end,0)  
   --+  
   --round(case when IsTrichNop=0  or  IsVeHuu=1 or QuocTich <>N'Việt Nam'  then 0 else ML_BHXH*0.02 end,0) as CD,  
  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHCTY/100.0 end,0) as BHXH_CTY,  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHTNLDCTY/100.0 end,0) as BHTNLD_CTY,  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTCTY/100.0 end,0) as BHYT_CTY,  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNCTY/100.0 end,0) as BHTN_CTY,  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHNLD/100.0 end,0) as BHXH_NLD,  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTNLD/100.0 end,0) as BHYT_NLD,  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNNLD/100.0 end,0) as BHTN_NLD,  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHNLD/100.0 end,0)+  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTNLD/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNNLD/100.0 end,0) as BH_NLD,  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHTNLDCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNCTY/100.0 end,0) as BH_CTY,  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHNLD/100.0 end,0)+  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTNLD/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNNLD/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHXHCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHXH*TL_BHTNLDCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 and NhomNhanVienID !=1 then 0 else ML_BHXH*TL_BHYTCTY/100.0 end,0)+  
   --round(case when IsTrichNop=0 then 0 else ML_BHTN*TL_BHTNCTY/100.0 end,0) as TONGBH  
  
   --from(  
     SELECT  MaNhanVien, NhanVienID, HoVaTen, ThuNhapHaiNoi, TenPhongBan, CongTyID, PhongBanID, ThuTu, QuocTich, IsVeHuu, MucLuong, Types, TyGia, NhomNhanVienID  
     , IsCD,  @fdate Ngay,  
     case when types in (5,7,8,9) or ThuNhapHainoi = 1 then 0 else 1 end as IsTrichNop,  
  
     case when MucLuong*TyGia>=20*@LTTC then 20*@LTTC else MucLuong*TyGia end as ML_BHXH  
     , case when MucLuong>=20 * LTTV then 20 * LTTV else MucLuong end as ML_BHTN  
     /*Công ty đóng*/  
     , case when IsVeHuu =1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHXH_CTY else TyLe_BHXH_CTY_NNG  end as TL_BHXHCTY /*Xã hội*/  
     , case when  IsVeHuu=1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHYT_CTY else TyLe_BHYT_CTY_NNG  end as TL_BHYTCTY /*Y Tế*/  
     , case when  IsVeHuu=1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHTN_CTY else TyLe_BHTN_CTY_NNG  end as TL_BHTNCTY /*Thất nghiệp*/  
  
     /*Nhân viên đóng*/  
     , case when IsVeHuu =1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHXH_NLD else TyLe_BHXH_NNG  end as TL_BHXHNLD /*Xã hội*/  
     , case when  IsVeHuu=1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHYT_NLD else TyLe_BHYT_NNG  end as TL_BHYTNLD /*Y Tế*/  
     , case when  IsVeHuu=1 then 0 when  QuocTich=N'Việt Nam' then TyLe_BHTN_NLD else TyLe_BHTN_NNG  end as TL_BHTNNLD /*Thất nghiệp*/  
  
  
     from  
      (  
						 SELECT MaNhanVien, NhanVienID,  HoVaTen, isnull(convert(int,ThuNhapHaiNoi),0) as ThuNhapHaiNoi,  
						 TenPhongBan as TenPhongBan, tbl_PB.PhongBanID as PhongBanID, isnull(tbl_PB.CongTyID,0) as CongTyID, tbl_PB.ThuTu,  
						 isnull(NS_DsQuocTich.TenNuoc,N'Việt Nam') as QuocTich, isnull(tbl_NV.IsVeHuu,0) as  IsVeHuu  
          
						 ,isnull((SELECT max(MucLuong) from NS_QTDongBHXH where NS_QTDongBHXH.NhanVienID =  tbl_NV.NhanVienID  
						 and NgayBatDau = (SELECT max(NgayBatDau) from NS_QTDongBHXH as QT where QT.NhanVienID= tbl_NV.NhanVienID  
						 and NgayBatDau<@tdate and ThangBaoCao<@tdate and QT.MucLuong>0)),0) as MucLuong,  
  
						 isnull((SELECT max(Type) from NS_QTDongBHXH where NS_QTDongBHXH.NhanVienID = tbl_NV.NhanVienID  
						 and @fdate between NS_QTDongBHXH.NgayBatDau and NS_QTDongBHXH.NgayketThuc),1) as Types,  
  
						 1 as TyGia,  
  
						 case when isnull((SELECT max(Type) from NS_QTDongBHXH where NS_QTDongBHXH.NhanVienID = tbl_NV.NhanVienID  
						 and @fdate between NS_QTDongBHXH.NgayBatDau and NS_QTDongBHXH.NgayketThuc),1) in (7,8,5)  
						 and isnull((SELECT max(convert(int,isnull(KhongTraTheBHYT,0))) from NS_QTDongBHXH where NS_QTDongBHXH.NhanVienID = tbl_NV.NhanVienID  
						 and @fdate between NS_QTDongBHXH.NgayBatDau and NS_QTDongBHXH.NgayketThuc),0) = 1 then 1 else 0 end  
						 as NhomNhanVienID  
          
						 ,isnull(tbl_NV.TrangThaiTGCongDoan,0) as IsCD
						 , Case when @MaVung ='V1' then @LTTV1 when @MaVung = 'V2' then @LTTV2 when @MaVung = 'V3' then @LTTV3 when @MaVung ='V4' then @LTTV4 else @LTTV1 END LTTV  
           
						 FROM  
							(SELECT NhanVienID, PhongBanID, MaNhanVien, CONCAT(HO, ' ', HoTen) HoVaTen, ChucDanhID, ChucVuID, NghiViec, NgayNghiViec, TrangThaiTGCongDoan,  IsVeHuu, ThuNhapHaiNoi , QuocTichID FROM  NhanVien  X   
							WHERE X.PhongBanID IN(SELECT PhongBanID FROM  @PB) AND X.NgayBatDauLam <= @tdate AND (ISNULL(X.NghiViec,0) = 0 or CONVERT(DATE, X.NgayNghiViec) > @fdate) AND ISNULL(X.IsDeleted,0) = 0 ) tbl_NV  
  
						 LEFT JOIN    
							NS_DsQuocTich on tbl_NV.QuocTichID = NS_DsQuocTich.QuocTichID  
          
						 LEFT JOIN    
							(SELECT PhongBanID,  MaPhongBan, Ten TenPhongBan, CongTyID, ThuTu FROM PhongBan  where PhongBanID in (SELECT PhongBanID FROM  @PB)) tbl_PB on tbl_PB.PhongBanID = tbl_NV.PhongBanID  
          
       
      ) as tbl_NVI  
  
     CROSS JOIN  
       (  
       SELECT top 1 NgayBatDau ,TyLe_BHXH_CTY ,TyLe_BHYT_CTY ,TyLe_BHTN_CTY ,TyLe_BHXH_NLD ,TyLe_BHYT_NLD ,TyLe_BHTN_NLD   
       ,TyLe_BHXH_CTY_NNG ,TyLe_BHYT_CTY_NNG ,TyLe_BHTN_CTY_NNG, TyLe_BHXH_NNG ,TyLe_BHYT_NNG  ,TyLe_BHTN_NNG   
       ,GhiChu  
  
         FROM dbo.NS_BH_TyLeThamGiaBHXH where NgayBatDau <= @tdate order by  NgayBatDau desc  
       ) as tbl_Tyle 
			 
			 --where MucLuong>0  
  
   --) as BangTinh order by ThuTu, MaNhanVien  
  

  
   --SELECT NhanVien.MaNhanVien N'Mã nhân viên', nhanvien.ho+' '+HoTen as N'Họ và tên',SYS_ThongTinCongTy.madonvi as N'Mã đơn vị', PhongBan.Ten as N'Phòng ban'  
   --,NS_DsChucVu.TenChucVu as N'Tên chức danh',NS_TL_BangTrichBHXH.BHXH_CTY,BHYT_CTY,BHTN_CTY,CONGDOAN as CongDoan,BHXH_NLD,BHYT_NLD,BHTN_NLD,KPCD As KinhPhiCongDoan  
   --FROM  NS_TL_BangTrichBHXH left join NhanVien on nhanvien.NhanVienID=NS_TL_BangTrichBHXH.NhanVienID  
   --left join PhongBan on PhongBan.PhongBanID=nhanvien.PhongBanID  
   --left join SYS_ThongTinCongTy on SYS_ThongTinCongTy.ID=PhongBan.CongTyID  
   --left join NS_DsChucVu on NS_DsChucVu.ChucVuID=nhanvien.ChucVuID  
   --where NS_TL_BangTrichBHXH.Thang=@thang and NS_TL_BangTrichBHXH.Nam=@nam and   
   -- PBID in (SELECT valu from GetPhongBanChilds(@PhongBanID)) and Thang=@Thang and Nam=@Nam   
  

