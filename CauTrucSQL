CREATE PROCEDURE [dbo].[ADD_BangLuong_ADCo_QTTThang]       
 @PhongBanID int, @Nam int, @NhanVienID int, @DangNhapID int      
      
as      

--DECLARE @PhongBanID INT = 20,   
--        @Nam INT = 2025,
--        @NhanVienID INT = 0,
--        @DangNhapID INT = 3115;

--DECLARE @ThangLuong DATE = EOMONTH(CONVERT(CHAR(2), @Thang) + '/1/' + CONVERT(CHAR(4), @Nam));
--DECLARE @NgayQuyDoi DATE = CONVERT(CHAR(2), @Thang) + '/26/' + CONVERT(CHAR(4), @Nam);
--DECLARE @DauKy DATE = DATEADD(MONTH, -1, @NgayQuyDoi);
DECLARE @Date DATE = DATEFROMPARTS(@Nam, 12, 31)

SELECT
    CONVERT(INT, ROW_NUMBER() OVER
        (
            ORDER BY (
                CASE
                    WHEN Nhom.Ten = N'Văn phòng' THEN 
                        CASE 
                            WHEN cappb.Level < 4 THEN pb.ThuTuSapXep 
                            ELSE (SELECT TOP 1 ThuTuSapXep FROM dbo.PhongBan WHERE PhongBanID = v.Lever2ID) 
                        END
                    ELSE 100 + lld.ThuTu 
                END
            )
        )
    ) AS STT,

    nv.MaNhanVien AS MaNV,
    nv.Ho + ' ' + nv.HoTen AS TenNhanVien,
    cv.TenChucVu AS ViTriCongViec,
    bl_text.CapBac AS CapBac,

    UPPER(
        CASE 
            WHEN Nhom.Ten = N'Văn phòng' THEN 
                CASE WHEN cappb.Level < 4 THEN pb.Ten ELSE v.Lever2Ten END
            ELSE lld.Ten 
        END
    ) AS TenPhongBan,

    kv.TenKhuVuc AS DiaDiemLamViec,
    bl_text.NhomCostCenter AS NhomCostCenter,
    bl_text.CostCenter AS CostCenter,
    nv.NgayBatDauLam AS NgayVaoLam,
    nv.NgayNghiViec AS NgayNghiViec,

    -- Thêm cột ThangLuong để phân biệt các dòng theo tháng lương
    bl.Thang AS ThangLuong,

    ISNULL(bl.[CC_TongCong], 0) AS NgayCongThucTe,
    ISNULL(bl.[TLNC_LCB], 0) AS LuongCoBan,
    ISNULL(bl.[TLNC_PC_TrachNhiem], 0) AS PCTrachNhiem,
    ISNULL(bl.[TLNC_PC_ViTri], 0) AS PCViTri,
    ISNULL(bl.[TLNC_PC_DiLai], 0) AS PCDiLai,
    ISNULL(bl.[TLNC_PC_DocHai], 0) AS PCDocHai,
    ISNULL(bl.[TLNC_PC_Khac], 0) AS PCKhac,
    ISNULL(bl.[TLNC_PC_BuaAn], 0) AS PCTienAn,
    ISNULL(bl.[TLNC_ThuongThang], 0) AS ThuongThang,
    ISNULL(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) AS TongLuongVaPhuCap,

    ISNULL(bl.[TLOT_ChieuThue], 0) AS OTChiuThue,
    ISNULL(bl.[TLOT_MienThue], 0) AS OTKhongChiuThue,
    ISNULL(bl.[TLOT_LamCaDem], 0) AS TienCaDem,
    ISNULL(bl.[TLOT_TongLuongOT_LamCaDem], 0) AS TongOTVaCaDem,
    ISNULL(bl.[Thuong_KM], 0) AS ThuongKM,
    ISNULL(bl.[Thuong_KPI], 0) AS ThuongKPI,
    ISNULL(bl.[Thuong_LuongT13], 0) AS LuongThang13,
    ISNULL(bl.[Thuong_Nam], 0) AS ThuongNam,
    ISNULL(bl.[Thuong_ChenhLechT1], 0) AS ChenhLechThang1,
    ISNULL(bl.[Thuong_CongTruocThue], 0) AS CongTruocThue,
    ISNULL(bl.[Thuong_TruTruocThue], 0) AS TruTruocThue,
    ISNULL(bl.[Thuong_TongThuong], 0) AS TongThuongVaKhoanTruocThue,
    ISNULL(bl.[TongThuNhap], 0) AS TongThuNhap,

    ISNULL(bl.[BH_LuongBHXH], 0) AS MucLuongBHXH,
    ISNULL(bl.[BH_LuongBHTN], 0) AS MucLuongBHTN,
    ISNULL(bl.[BH_Tong_NLD], 0) AS BHNhanVien,
    ISNULL(bl.[BH_Tong_CTY], 0) AS BHCongTy,
    ISNULL(bl.[BH_Tong], 0) AS TongBHXH,

    ISNULL(bl.[Tax_ThuNhapChiuThue], 0) AS ThuNhapChiuThue,
    ISNULL(bl.[Tax_GiamTru_BanThan], 0) AS GiamTruBanThan,
    ISNULL(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) AS GiamTruNguoiPhuThuoc,
    ISNULL(bl.[Tax_SoNguoiPhuThuoc], 0) AS SoNguoiPhuThuoc,
    ISNULL(bl.[Tax_ThuNhapTinhThue], 0) AS ThuNhapTinhThue,
    ISNULL(bl.[Tax_TongThue], 0) AS ThueTNCN,
    ISNULL(bl.[Tax_ThuNhapSauThue], 0) AS ThuNhapSauThue,

    ISNULL(bl.[PSSThue_CongDoan_NLD], 0) AS CongDoanPhiNV,
    ISNULL(bl.[PSSThue_CongDoan_CTY], 0) AS KinhPhiCongDoanCTY,
    ISNULL(bl.[PSSThue_TruSauTax], 0) AS TruSauThue,
    ISNULL(bl.[PSSThue_CongSauTax], 0) AS CongSauThue,
    ISNULL(bl.[ThucLinh], 0) AS ThucLinh,
    ISNULL(bl.[ChiPhiCongTy], 0) AS ChiPhiCongTy

FROM NhanVien nv
    CROSS APPLY dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1
    LEFT JOIN dbo.PhongBan pb ON pb.PhongBanID = pb1.PhongBanID
    CROSS APPLY dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1
    LEFT JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = cv1.ChucVuID
    CROSS APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv
    LEFT JOIN dbo.NS_DsKhuVuc kv ON kv.KhuVucID = ddlv.KhuVucId
    LEFT JOIN dbo.v_SoDoToChucPhongBan v ON pb.PhongBanID = v.PhongBanID
    LEFT JOIN dbo.NS_DsCapPhongBan cappb ON pb.CapPhongBanID = cappb.CapPhongBanID
    LEFT JOIN NS_DsCapBac cb ON nv.CapBacID = cb.CapBacID
    LEFT JOIN ADD_CostCenter Nhom ON nv.CostCenterId = Nhom.CostCenterId
    LEFT JOIN dbo.ADD_CostCentral cost ON nv.CostCentral = cost.CostCentralId
    LEFT JOIN dbo.NS_DsLoaiLaoDong lld ON nv.LoaiLaoDongID = lld.LoaiLaoDongID

    RIGHT JOIN( SELECT * FROM(
            SELECT 
                bl.NhanVienID,
                bl.Thang,
                bl.Nam,
                ll.MaSo,
                ctl.TienLuong
            FROM dbo.ADD_NS_TL_BangLuong_ChiTraThucTe bl        
            LEFT JOIN dbo.ADD_NS_TL_ChiTietLuong_ChiTraThucTe ctl 
                ON bl.BangLuongID = ctl.BangLuongID             
            LEFT JOIN dbo.NS_TL_LoaiLuong ll 
                ON ctl.LoaiLuongID = ll.LoaiLuongID
            WHERE 1 = 1
              -- CHỈ LỌC THEO NĂM, KHÔNG LỌC THEO THÁNG
              AND bl.Nam = @Nam
              AND (bl.NhanVienID = @NhanVienID OR @NhanVienID = -1001 OR @NhanVienID = 0)
        ) AS A
        PIVOT
        (
            SUM(TienLuong)
            FOR MaSo IN
            (
                [CC_TongCong],
                [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai],
                [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn],
                [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap],
                [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem],
                [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam],
                [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong],
                [TongThuNhap],
                [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],
                [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc],
                [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue],
                [Tax_TongThue], [Tax_ThuNhapSauThue],
                [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY],
                [PSSThue_TruSauTax], [PSSThue_CongSauTax],
                [ThucLinh], [ChiPhiCongTy]
            )
        ) AS B
    ) AS bl
        ON nv.NhanVienID = bl.NhanVienID

    LEFT JOIN
    (
        SELECT *
        FROM
        (
            SELECT 
                bl.NhanVienID,
                bl.Thang,
                bl.Nam,
                ll.MaSo,
                ctl.TienLuongStr
            FROM dbo.ADD_NS_TL_BangLuong_ChiTraThucTe bl       
            LEFT JOIN dbo.ADD_NS_TL_ChiTietLuong_ChiTraThucTe ctl 
                ON bl.BangLuongID = ctl.BangLuongID            
            LEFT JOIN dbo.NS_TL_LoaiLuong ll 
                ON ctl.LoaiLuongID = ll.LoaiLuongID
            WHERE 1 = 1
              AND bl.Nam = @Nam                                
              AND (bl.NhanVienID = @NhanVienID OR @NhanVienID = -1001 OR @NhanVienID = 0)
        ) AS A
        PIVOT
        (
            MAX(TienLuongStr)
            FOR MaSo IN ([CapBac], [NhomCostCenter], [CostCenter])
        ) AS B
    ) AS bl_text 
        ON  nv.NhanVienID = bl_text.NhanVienID
		AND bl.Thang      = bl_text.Thang       
		AND bl.Nam        = bl_text.Nam

WHERE pb.PhongBanID IN (SELECT valu FROM GetPhongBanChild_WUser(@PhongBanID, @DangNhapID))
  AND nv.MaNhanVien <> '80090'
  AND nv.NhanVienID NOT IN (40452,40462,40461)
  AND nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))

ORDER BY STT;
GO
/****** Object:  StoredProcedure [dbo].[ADD_BangLuongVanHanh_ADCo]    Script Date: 03/04/2026 16:11:45 ******/
