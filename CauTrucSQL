CREATE FUNCTION [dbo].[HS_TinhSoNgayPhepTheoQuyDinh]
(
	@NhanVienID int,
	@Ngay date
)
RETURNS  decimal(10,2)
AS
BEGIN
	Declare @songay decimal(10,2)
	declare @ngaycuoinam date=convert(date,convert(nvarchar,year(@ngay))+'-12-31')
	declare @ngaybatdaulam date=(select convert(date,NgayBatDauLam) from NhanVien where NhanVienID=@NhanVienID)
	declare @nghiviec int=isnull((select nghiviec from NhanVien where NhanVienID=@NhanVienID),0)
	declare @ngaynghiviec date=(select convert(date,NgayNghiViec) from NhanVien where NhanVienID=@NhanVienID)

	set @songay=12
	
	if (@nghiviec=0)
		begin
			if (year(@ngaybatdaulam)<year(@Ngay) or (year(@ngaybatdaulam)=year(@Ngay) and month(@ngaybatdaulam)=1 and day(@ngaybatdaulam)=1))
				begin
					set @songay=@songay
				end
			else
				begin
					set @songay=(datediff(day,@ngaybatdaulam,@ngaycuoinam)+1)*@songay/365
				end
		end
	else
		begin
			if (year(@ngaybatdaulam)<year(@ngaynghiviec) or (year(@ngaybatdaulam)=year(@ngaynghiviec) and month(@ngaybatdaulam)=1 and day(@ngaybatdaulam)=1 and @ngaynghiviec=@ngaycuoinam))
				begin
					set @songay=@songay
				end
			else
				begin
					set @songay=(datediff(day,@ngaybatdaulam,@ngaynghiviec)+1)*@songay/365
				end
		end

	RETURN @songay+isnull(dbo.HS_TinhSoNgayDuocNghiTheoThamNien(@nhanvienid,@ngay),0)
END
