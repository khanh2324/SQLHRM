	set @TuNgay = DATEFROMPARTS(year(@TuNgay), month(@TuNgay), 1)
	set @DenNgay = DATEFROMPARTS(year(@DenNgay), month(@DenNgay), 1)
	declare @Date date = convert(char(2), month(@DenNgay)) + '/25/' + convert(char(4), year(@DenNgay))
	

	select 
		  distinct N'Từ tháng ' + format(@TuNgay, 'MM/yyyy') + N' đến tháng ' + format(@DenNgay, 'MM/yyyy') as TieuDe, a.NhomCostCentral
		, count(a.MaNV) as SoLuong, sum(a.LuongGop) as LuongGop, sum(a.PCTrachNhiem) as PCTrachNhiem, sum(a.PCViTri) as PCViTri
		, sum(a.PCDiLai) as PCDiLai, sum(a.PCDocHai) as PCDocHai, sum(a.PCKhac) as PCKhac, sum (a.PCBuaAn) as PCBuaAn
		, sum(a.ThuongThang) as ThuongThang, sum(a.ThuongKM) as ThuongKM, sum(a.LuongLamThemCoBan) as LuongLamThemCoBan
		, sum (a.LuongLamThemChenhLech) as LuongLamThemChenhLech, sum(a.LuongTraThemCaDem) as LuongTraThemCaDem
		, sum(a.ChenhLechThang1) as ChenhLechThang1, sum(a.ThuongKPI) as ThuongKPI, sum (a.LuongThang13) as LuongThang13
		, sum(a.ThuongNam) as ThuongNam, sum(a.CongKhac) as CongKhac, sum(a.TruTruocThue) as TruTruocThue, sum (a.TongPhaiTra) as TongPhaiTra

		, sum(a.TongBHNV) as TongBHNV, sum(a.TongBHCTY) as TongBHCTY, sum(a.TongBHNV_CTY) as TongBHNV_CTY
		--, 11000000 as MucGiamTruGiaCanh, 4400000 as MucGiamTruNguoiPhuThuoc
		, sum(a.MucGiamTruGiaCanh) as MucGiamTruGiaCanh
