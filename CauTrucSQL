GO
CREATE FUNCTION [dbo].[fnt_LayNgayGioLamViecTheoCa] (      @NhanVienID INT,      @NgayChamCong DATE,      @CaLamViecID INT  )  RETURNS TABLE  AS  RETURN        
      
(        
      
 -- declare  @NhanVienID INT    = (select nhanvienid from  nhanvien where manhanvien ='OOS_0188 ')  ,      @NgayChamCong DATE ='2025/03/01'      
 --declare @CaLamViecID INT =(select CaLamViecID from  dbo.fnt_GetCaLamViecNhanVienTaiThoiDiem(@NhanVienID, @NgayChamCong))      
      
    WITH MaLoaiCong AS (        
        SELECT MaLoaiCongChuan = ISNULL((        
            SELECT ACC.MaLoaiCongChuan        
            FROM NhanVien NV        
            INNER JOIN ADD_LoaiCongChuan ACC ON NV.LoaiCongChuanID = ACC.LoaiCongChuanID        
            WHERE NV.NhanVienID = @NhanVienID        
        ), '48H')        
    ),        
    GioCa AS (        
        SELECT        
            MaCa,        
            GioBatDau1,        
            GioKetThuc1 =         
                CASE         
                    WHEN Thu = 7 AND MaLoaiCongChuan = N'40H' THEN GioBatDau1        
                    ELSE GioKetThuc1        
                END,        
            GioBatDau2 =         
                CASE         
                    WHEN Thu = 7 AND MaLoaiCongChuan = N'40H' THEN GioBatDau1        
                    WHEN Thu = 7 AND MaLoaiCongChuan = N'44H' THEN GioKetThuc1        
                    ELSE GioBatDau2        
                END,        
            GioKetThuc2 =         
                CASE         
                    WHEN Thu = 7 AND MaLoaiCongChuan = N'40H' THEN GioBatDau1        
                    WHEN Thu = 7 AND MaLoaiCongChuan = N'44H' THEN GioKetThuc1        
                    ELSE GioKetThuc2        
                END,        
            Thu, MaLoaiCong.MaLoaiCongChuan        
        FROM NS_CaLamViec,        
             MaLoaiCong,        
             (SELECT Thu = DATEPART(WEEKDAY, @NgayChamCong)) AS NgayThu        
        WHERE CaLamViecID = @CaLamViecID        
    )        
  select MaCa, GioBatDau1, GioKetThuc1, GioBatDau2, GioKetThuc2      
  , DATEDIFF(MINUTE, GioBatDau1 , GioKetThuc1 ) +  (case when Thu = 7 and MaLoaiCongChuan ='44H' then (DATEDIFF(MINUTE, GioBatDau1 , GioKetThuc1 )) else DATEDIFF(MINUTE, GioBatDau2 , GioKetThuc2 ) end ) as SoPhutLamViecTieuChuan      
  , case when day(GioBatDau1) <> DAY (GioKetThuc2) then 1 else 0 end   IsLamSangNgayHomSau, MaLoaiCongChuan      
  from  (      
    SELECT       
        MaCa,  Thu, MaLoaiCongChuan,      
        
        GioBatDau1 = CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioBatDau1, 8), 120),        
        
        GioKetThuc1 = CASE         
            WHEN GioBatDau1 <= GioKetThuc1        
                THEN CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioKetThuc1, 8), 120)        
            ELSE DATEADD(DAY, 1, CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioKetThuc1, 8), 120))        
        END,        
        
        GioBatDau2 = CASE         
            WHEN GioBatDau1 <= GioBatDau2        
                THEN CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioBatDau2, 8), 120)        
            ELSE DATEADD(DAY, 1, CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioBatDau2, 8), 120))        
        END,        
        
        GioKetThuc2 = CASE         
            WHEN GioBatDau1 <= GioKetThuc2        
                THEN CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioKetThuc2, 8), 120)        
            ELSE DATEADD(DAY, 1, CONVERT(DATETIME, CONVERT(CHAR(10), @NgayChamCong, 120) + ' ' + LEFT(GioKetThuc2, 8), 120))        
        END      
    FROM GioCa        
  ) GioLamViec      
);        
      
/*      
  Chỉ lấy giờ làm việc đúng theo rule của khách hàng, không quan tâm đó là ngày nghỉ ngày lễ gì ráo      
