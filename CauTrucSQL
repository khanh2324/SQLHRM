create FUNCTION [dbo].[fns_LayPhongBanIDTheoCap] (    @CapPhongBanID INT,    @PhongBanID INT)  RETURNS NVARCHAR(200)  AS

BEGIN
    DECLARE @Result int

    -- Dùng CTE để lấy danh sách phòng ban cha (không cần gọi hàm khác)
    ;WITH PhongBanPath AS (
        SELECT PhongBanID, PhongBanChaID, 1 AS Level
        FROM PhongBan
        WHERE PhongBanID = @PhongBanID
        
        UNION ALL
        
        SELECT p.PhongBanID, p.PhongBanChaID, pp.Level + 1
        FROM PhongBan p
        INNER JOIN PhongBanPath pp ON p.PhongBanID = pp.PhongBanChaID
        WHERE p.PhongBanChaID IS NOT NULL
    )
    -- Tìm phòng ban có cấp phù hợp trong đường dẫn
    SELECT TOP 1 @Result = p.PhongBanID
    FROM PhongBan p
    INNER JOIN PhongBanPath pp ON p.PhongBanID = pp.PhongBanID
    WHERE p.CapPhongBanID = @CapPhongBanID
    ORDER BY pp.Level DESC, p.ThuTuSapXep DESC;
    
    RETURN ISNULL(@Result, @PhongBanID);
END;
GO
