create  FUNCTION [dbo].[fnt_LayNgayThangNam] (@NgayBatDau DATE, @NgayketThuc DATE)    
RETURNS @ReturnTable TABLE (Nam INT, Thang INT, Ngay INT)  AS  

BEGIN    
    
  --declare @NgayBatDau date ='2022-01-01'    
  --declare @NgayketThuc date='2022-03-01'    
  DECLARE @NgayBatDau_RUN DATE = @NgayBatDau;    
  DECLARE @RUN INT = 0, @Check_Nam BIT = 1, @Check_Thang BIT = 1, @Check_Ngay BIT = 1;    
    
  DECLARE @Year INT = 0;    
  DECLARE @Month INT = 0;    
  DECLARE @Day INT = 1;    
    
  /*Đếm năm*/    
  WHILE (@NgayBatDau_RUN <= @NgayketThuc AND @RUN = 0)    
  BEGIN    

    IF (@NgayketThuc >= (DATEADD (YEAR, 1, @NgayBatDau_RUN)))    
    BEGIN    
      SET @NgayBatDau_RUN = (DATEADD (YEAR, 1, @NgayBatDau_RUN));    
      SET @Year += 1;    
    END;    
    ELSE    
    BEGIN    
      SET @RUN = 1;  
			--IF(@Year > 0)
			--BEGIN
			--	SET @NgayBatDau_RUN = (DATEADD (DAY, -1, @NgayBatDau_RUN));    
			--END
    END;    
  END;    
    
  --SELECT @NgayBatDau_RUN KetThucNam, @Year    Nam
    
  SET @RUN = 0;    
  /*đếm tháng*/    
  WHILE (@NgayBatDau_RUN <= @NgayketThuc AND @RUN = 0)    
  BEGIN    
    IF (@NgayketThuc >= (DATEADD (MONTH, 1, @NgayBatDau_RUN)))    
    BEGIN    
      SET @NgayBatDau_RUN = (DATEADD (MONTH, 1, @NgayBatDau_RUN));    
      SET @Month += 1;    
    END;    
    ELSE    
    BEGIN    
      SET @RUN = 1;    
			--IF(@Month > 0)
			--BEGIN
			--	SET @NgayBatDau_RUN = (DATEADD (DAY, -1, @NgayBatDau_RUN));    
			--END
    END;    
  END;    
    
    
  SET @RUN = 0;    
  /*đếm ngày*/    
  WHILE (@NgayBatDau_RUN <= @NgayketThuc AND @RUN = 0)    
  BEGIN    
    IF (@NgayketThuc >= (DATEADD (DAY, 1, @NgayBatDau_RUN)) AND @RUN = 0)    
    BEGIN    
      SET @NgayBatDau_RUN = (DATEADD (DAY, 1, @NgayBatDau_RUN));    
      SET @Day += 1;    
    END;    
    ELSE    
    BEGIN    
      SET @RUN = 1;    
    END;    
  END;    
    
  --SELECT @NgayBatDau_RUN KetThucNgay, @Day    Ngay,  @NgayketThuc NgayketThuc

	
  IF (@Day >= 28)    
  BEGIN    
    IF (MONTH (@NgayketThuc) = 2)    
    BEGIN    
      IF (YEAR (@NgayketThuc) % 4 = 0 AND @Day = 29)    
      BEGIN    
        SET @Month += 1;    
      END;    
      ELSE    
      BEGIN    
        SET @Month += 1;    
      END;    
      SET @Day = 0;    
    END;    
    ELSE    
    BEGIN    
      IF (MONTH (@NgayketThuc) IN ( 1, 3, 5, 7, 8, 10, 12 ) AND @Day = 31)    
      BEGIN    
        SET @Month += 1;    
        SET @Day = 0;    
      END;    
      ELSE    
      BEGIN    
        IF (MONTH (@NgayketThuc) IN ( 4, 6, 9, 11 ) AND @Day = 30)    
        BEGIN    
          SET @Month += 1;    
          SET @Day = 0;    
        END;    
      END;    
    END;    
    
  END;    
   IF(@Month = 12)  
  BEGIN  
  SET @Year +=1  
  SET @Month =0  
  
  END  
    
    
  INSERT @ReturnTable(Nam, Thang, Ngay)
	SELECT @Year Nam, @Month Thang, @Day Ngay;    
  RETURN;    
    
END;    
GO
