CREATE FUNCTION [dbo].[fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem](@NhanVienID int, @NgayKiemTra DATE)   
RETURNS TABLE  AS
RETURN      
    
--declare @NhanVienID int = 40266
--declare @NgayKiemTra date = '2024-04-23'

(  
WITH DL AS (
    SELECT
        NhanVienID,
        CASE WHEN NgayHieuLuc <= @NgayKiemTra THEN ADD_DiaDiemLamViecMoiID ELSE ADD_DiaDiemLamViecCuID END AS KhuVucID,
        ROW_NUMBER() OVER (
            PARTITION BY NhanVienID
            ORDER BY 
                CASE WHEN NgayHieuLuc <= @NgayKiemTra THEN 0 ELSE 1 END,
                ABS(DATEDIFF(DAY, NgayHieuLuc, @NgayKiemTra))
        ) AS rn
    FROM NS_QTChuyenCanBo
    WHERE XetDuyet = 1 AND NhanVienID = @NhanVienID
)
SELECT 
    nv.NhanVienID,
    ISNULL(dl.KhuVucID, nv.KhuVucID) AS KhuVucID
FROM NhanVien nv
LEFT JOIN DL ON nv.NhanVienID = DL.NhanVienID AND DL.rn = 1
WHERE ISNULL(nv.IsDeleted, 0) = 0 AND nv.NhanVienID = @NhanVienID
);
  
/*  
cách dùng SELECT              
nv.NhanVienID,  pb.PhongBanID, cv.ChucVuID,ddlv.DiaDiemLamViecID  FROM NhanVien nv 
CROSS APPLY dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, nv.NgayBatDauLam) pb          
CROSS APPLY dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, nv.NgayBatDauLam) cv  
CROSS APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, nv.NgayBatDauLam) ddlv  
*/
GO
