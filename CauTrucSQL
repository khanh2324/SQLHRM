INSERT @ResulTable (SoPhepChuyenTuNamTruoc, SoPhepTheoQuyDinh,  SoPhepDaNghi, SoPhepConLai, ThamNien,NghiBuTonNamTruoc,NghiBuDuocHuong,NghiBuDaSuDung,NghiBuConLai,SoPhepTonNamTruoc,ADD_NgayClearPhep,ADD_NghiBuQuaHan,SoThangLamViec,SoThangLamViecCongThamNien)
SELECT SoPhepChuyenTuNamTruoc, SoPhepTheoQuyDinh,  SoPhepDaNghi, SoPhepConLai, ThamNien,NghiBuTonNamTruoc,NghiBuDuocHuong,NghiBuDaSuDung,NghiBuConLai,SoPhepTonNamTruoc,ADD_NgayClearPhep,ADD_NghiBuQuaHan,SoThangLamViec,SoThangLamViecCongThamNien
FROM  dbo.fnt_LayThongTinTinhPhepNam(@NhanVienID, @ToDate)

DECLARE @SoPhepTonNamTruoc DECIMAL(10,3) = (SELECT SoPhepTonNamTruoc FROM  @ResulTable)
DECLARE @ADD_NgayClearPhep DATETIME = (SELECT ADD_NgayClearPhep FROM  @ResulTable)
DECLARE @NghiBuConLai DECIMAL(10,3) = (SELECT NghiBuConLai FROM  @ResulTable)
DECLARE @SoPhepDaNghi DECIMAL(10,3) = (SELECT SoPhepDaNghi FROM  @ResulTable)

DECLARE @LoaiCongChuan INT =(SELECT LoaiCongChuanID FROM dbo.NhanVien WHERE NhanVienID=@NhanVienID)
DECLARE @MaLoaiCongChuan NVARCHAR(50) = (SELECT MaLoaiCongChuan FROM NhanVien LEFT JOIN dbo.ADD_LoaiCongChuan ON ADD_LoaiCongChuan.LoaiCongChuanID = NhanVien.LoaiCongChuanID WHERE NhanVienId = @NhanVienID)
DECLARE @LoaiCongChuanID INT = (SELECT LoaiCongChuanID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)

declare @SoPhutNghiBuConLai decimal(18,3) = (select isnull(NghiBuConLai, 0) from NhanVien where NhanVienID=@NhanVienID)
declare @WFH_Thang decimal(18,3) = (select sum(isnull(b.SoNgayNghi, 0)) from NS_QTNghiPhep a join NS_QTNghiPhep_ChiTiet b on a.QTNghiPhepID = b.QTNghiPhepID where a.NhanVienID = @nhanvienid and  year(NgayNghiPhep) = year(@ToDate) and month(NgayNghiPhep) = month(@ToDate) and b.KyHieuChamCongID = 9 and a.XetDuyet <> -1)
declare @WFH_Nam decimal(18,3) = (select sum(isnull(b.SoNgayNghi, 0)) from NS_QTNghiPhep a join NS_QTNghiPhep_ChiTiet b on a.QTNghiPhepID = b.QTNghiPhepID where a.NhanVienID = @nhanvienid and  year(NgayNghiPhep) = year(@ToDate) and b.KyHieuChamCongID = 9 and a.XetDuyet <> -1)

DECLARE @IsPhanCa INT = (SELECT IsNgayNghiLuanPhien FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID)

--DECLARE @NhomNhanSuID INT = (SELECT NhomNhanSuID FROM dbo.NhanVien WHERE NhanVienid = @NhanVienID)


declare @CaLamViecID int, @CaLV_NV int
set @CaLV_NV = (select isnull(CaLVID,0) from NhanVien where NhanVienID=@NhanVienID)  
set @CaLamViecID = isnull((select CaLamViecID from NS_TL_DangKyCong where nhanvienid=@NhanVienID and convert(date,NgayChamCong)=convert(date,@Fromdate)),@CaLV_NV)

DECLARE @CaLamViecToDate INT = (select CaLamViecID from NS_TL_DangKyCong where nhanvienid=@NhanVienID and convert(date,NgayChamCong)=convert(date,@ToDate))
declare @Gio1 time(7)= (select GioBatDau1 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
declare @Gio2 time(7)= (select GioKetThuc1 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
declare @Gio3 time(7)= (select GioBatDau2 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
declare @Gio4 time(7)= (select GioKetThuc2 from NS_CaLamViec where CaLamViecID=@CaLamViecID)


declare @SoPhepConLai decimal(10,2) = (select SoPhepConLai from NhanVien where NhanVienID = @NhanVienID)
DECLARE @GioiTinh NVARCHAR(50) = (select GioiTinh from NhanVien where NhanVienID = @NhanVienID)

declare @GioBatDauDky time(7)=convert(time(7),@FromDate)  
declare @GioKetThucDky time(7)=convert(time(7),@ToDate)
DECLARE @ThuFromDate INT = (SELECT thu FROM dbo.NS_BH_NgayThang WHERE CONVERT(DATE,Ngay) = CONVERT(DATE,@FromDate))
DECLARE @ThuToDate INT = (SELECT thu FROM dbo.NS_BH_NgayThang WHERE CONVERT(DATE,Ngay) = CONVERT(DATE,@ToDate))

DECLARE @SoNgayCoCa INT = (SELECT COUNT(*) FROM dbo.NS_TL_DangKyCong WHERE NhanVienID = @NhanVienID AND NgayChamCong BETWEEN @FromDate AND @ToDate AND CaLamViecID NOT IN (72,0))

declare @ThoiGianNGhiGiuaCa int  

	DECLARE @DLT7 int = @LoaiCongChuanID--Đối tượng chấm công

DECLARE @SNT7 int =(SELECT COUNT(*) from dbo.[SoNgayT7](@FromDate,@ToDate))-- tính số ngày t7 trong khoảng thời gian nghỉ
DECLARE @PT7 DECIMAL(10,5)--Số ngày phép nghỉ t7 trong khoảng thời gian nghỉ
DECLARE @SPCL DECIMAL(10,2)=(SELECT ISNULL(SoPhepConLai,0) FROM dbo.NhanVien WHERE NhanVienID=@NhanVienID) -- Số phép còn lại
DECLARE @SPDK DECIMAL(10,2)=  ISNULL((SELECT SUM(SoNgayNghi) FROM dbo.NS_QTNghiPhep WHERE NhanVienID=@NhanVienID AND KyHieuChamCongID=6 AND (XetDuyet=0 OR XetDuyet=100) AND YEAR(NgayBatDau)=YEAR(@FromDate)),0)
	DECLARE @SoNgayCaHC INT 
	IF @DLT7 = 3 AND @IsPhanCa = 1
	BEGIN
		SELECT @SoNgayCaHC = COUNT(DISTINCT CONVERT(date, NgayChamCong))
		FROM NS_TL_DangKyCong
		WHERE NhanVienID = @NhanVienID
		  AND CaLamViecID = 68
		  AND NgayChamCong BETWEEN @FromDate AND @ToDate
		IF (@GioBatDauDky IN (@Gio3) OR @GioKetThucDky IN (@Gio2))
		BEGIN
			SET @SoNgayNghi = @SoNgayCaHC + 0.5
		END
		ELSE
		BEGIN
			SET @SoNgayNghi = @SoNgayCaHC + 1
		END
	END
	IF @DLT7=3 AND @IsPhanCa = 0--đi làm 48h/tuần
		BEGIN
			SET @PT7=@SNT7
		END
	ELSE  IF @DLT7=2--đi làm 44h/tuần
		BEGIN
			SET @PT7=@SNT7*0.5
		END
		ELSE 
		BEGIN
			SET @PT7=0
		END

	--Làm tròn 0.5,1.5,...
	

--declare @SoNgayNghi1 DECIMAL(10,1)
BEGIN
	set @SoNgayNghi = (round(@SoNgayNghi*2,0)/2)+@PT7
END

	IF @SoNgayNghi < 0 
	BEGIN
	    SET @SoNgayNghi = 0
	END

declare @SoPhutLamViecTieuChuan decimal(10,2)  
set @SoPhutLamViecTieuChuan= (select isnull(SoPhutLamViecTieuChuan,0) from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
set @SoPhutLamViecTieuChuan= (case when @SoPhutLamViecTieuChuan=0 then 480 else @SoPhutLamViecTieuChuan end)  

declare @SoGioDangKy decimal(10,2)  
IF(convert(date,@FromDate)=convert(date,@ToDate))  
begin  
	set @SoGioDangKy= (select datediff(MINUTE,@GioBatDauDky,@GioKetThucDky)-isnull(@ThoiGianNGhiGiuaCa,0))/60.00  
	--fix số ngày nghỉ = 0.5 trong các loại nghỉ nửa ngày
	set @SoNgayNghi= case when @KyHieuChamCongID in (99999) then 0.5 else @SoGioDangKy/(@SoPhutLamViecTieuChuan/60.00) end
	set @SoNgayNghi= case when @SoNgayNghi>1 then 1 else @SoNgayNghi end  
END

DECLARE @isKhoaCong BIT = CASE
    WHEN EXISTS (
        SELECT 1
        FROM NS_TL_KhoaLuong
        WHERE @FromDate >= DATEFROMPARTS(YEAR(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),
                                         MONTH(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),26)
          AND @FromDate <= DATEFROMPARTS(Nam, Thang, 25))
    THEN 1 ELSE 0 END;

IF @isKhoaCong > 0 AND @KyHieuChamCongID NOT IN (SELECT KyHieuChamCongID FROM NS_TL_KyHieuChamCong WHERE KyHieu IN ('TS'))
BEGIN
	SELECT N'Bạn không thể đăng ký nghỉ vào tháng đã khóa công!', CONVERT(BIT,0), ROUND(@SoNgayNghi, 1) 
end
ELSE IF @GioBatDauDky NOT IN (@Gio1,@Gio3) OR @GioKetThucDky NOT IN (@Gio2,@Gio4)
BEGIN
	SELECT N'Bạn chỉ được đăng ký trong khoảng thời gian của ca làm việc'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
--ELSE IF @GioiTinh = N'Nam' AND @KyHieuChamCongID IN (26,32,33,39)
ELSE IF @GioiTinh = N'Nam' AND @KyHieuChamCongID IN (26,32,39)
BEGIN
    SELECT N'Loại nghỉ bạn đăng ký chỉ dành cho nhân viên nữ'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
ELSE IF @MaLoaiCongChuan = '40h' AND (@ThuFromDate IN (1,7) OR @ThuToDate IN (1,7))
BEGIN
    SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
ELSE IF @MaLoaiCongChuan = '44h' AND (@ThuFromDate IN (1) OR @ThuToDate IN (1) OR (@ThuToDate = 7 AND @GioKetThucDky = @Gio4))
BEGIN
    SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
ELSE IF @MaLoaiCongChuan = '48h' AND @IsPhanCa = 0 AND (@ThuFromDate IN (1) OR @ThuToDate IN (1))
BEGIN
    SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
ELSE IF @CaLamViecID = 68 AND (@ThuFromDate IN (1) OR @ThuToDate IN (1)) AND @MaLoaiCongChuan <> '48h'
BEGIN
    SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
ELSE IF @CaLamViecID = 72 OR @CaLamViecToDate = 72
BEGIN
    SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
END
--ELSE IF DATEDIFF(DAY,CONVERT(DATE,@FromDate),GETDATE()) > 7
--BEGIN
--    SELECT N'Bạn chỉ có thể đăng ký phép back date 7 ngày'  ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
--END
ELSE
BEGIN
	
    IF @CaLamViecID <> 68
		BEGIN
			SELECT N'Chỉ nhân viên ca hành chính mới được đăng ký nghỉ phép' ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
		END
	ELSE
	BEGIN
		IF (@KyHieuChamCongID IN (25))
		BEGIN
			IF(@SoNgayNghi > (SELECT NghiBuConLai FROM NhanVien WHERE NhanVienID = @NhanVienID))
			BEGIN
				SELECT N'Thời gian đăng ký vượt quá quỹ nghỉ bù!' ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1)
				RETURN
			END
			ELSE IF @ToDate <= @ADD_NgayClearPhep AND @SoPhepDaNghi < @SoPhepTonNamTruoc
			BEGIN
			    SELECT N'Bạn vẫn còn '+CONVERT(NVARCHAR(50),@SoPhepTonNamTruoc-@SoPhepDaNghi)+N' phép tồn năm ngoái,hãy đăng ký nghỉ phép!' ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1)
			END
			ELSE
			BEGIN
				SELECT N'' ,CONVERT(BIT,1),@SoNgayNghi
				RETURN
			END
		END
		--ELSE IF (@ToDate > @ADD_NgayClearPhep OR @SoPhepDaNghi >= @SoPhepTonNamTruoc) AND @NghiBuConLai >= @SoNgayNghi AND @NghiBuConLai >= 0.5 AND @KyHieuChamCongID = 21
		ELSE IF (@ToDate > @ADD_NgayClearPhep OR @SoPhepDaNghi >= @SoPhepTonNamTruoc) AND @NghiBuConLai >= 0.5 AND @KyHieuChamCongID = 21
		BEGIN
		    SELECT N'Bạn vẫn còn '+CONVERT(NVARCHAR(50),@NghiBuConLai)+N' quỹ nghỉ bù, hãy đăng ký nghỉ bù!' ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1)
		END
		ELSE IF (@SoPhepConLai < @SoNgayNghi AND @KyHieuChamCongID  IN (21))
		BEGIN
			SELECT N'Không có đủ phép để đăng ký!' ,CONVERT(BIT,0),ROUND(@SoNgayNghi, 1) 
			RETURN
		END
		ELSE IF(@FromDate>@ToDate)  -- check thời gian bắt đầu nhỏ hơn thời gian kết thúc	
		BEGIN 
			SELECT N'Thời gian bắt đầu phải nhỏ hơn thời gian kết thúc!' ,CONVERT(BIT,0),@SoNgayNghi  
			RETURN
		END  
		ELSE
		BEGIN
			SELECT N'' ,CONVERT(BIT,1),@SoNgayNghi
			RETURN
		END
	END
END

END
