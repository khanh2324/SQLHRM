			, isnull(bl.[PSSThue_CongSauTax], 0) as CongKhacSauThue, isnull(bl.[ThucLinh], 0) as ThanhToan, isnull(bl.[ChiPhiCongTy], 0) as Final

			--, isnull(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) as TongLuongVaPhuCap
