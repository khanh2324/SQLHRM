		left join NS_DsChucVu on NS_TD_ThiSinh_DotTuyenDung.ChucVuID = NS_DsChucVu.ChucVuID
		left join PhongBan on NS_TD_ThiSinh_DotTuyenDung.PhongBanID = PhongBan.PhongBanID
