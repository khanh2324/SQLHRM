  --AND NhanVienID = @NhanVienID         
  --ORDER BY DotDanhGiaID DESC        
  ----AND BoTieuChiStrID = @BoTieuChi        
  --)    
  
  SET @DotDanhGiaChuanID = (SELECT DotDanhGiaID FROM dbo.NS_DG_NhanVien_MucTieu WHERE NhanVienMucTieuID = @IDD)
        
  UPDATE dbo.NS_DG_NhanVien_MucTieu SET DotDanhGiaID = @DotDanhGiaChuanID WHERE NhanVienMucTieuID = @IDD        
    
  DECLARE @NhomDanhGiaID INT = (SELECT NhomDanhGiaID FROM dbo.NS_DG_DotDanhGia WHERE DotDanhGiaID = @DotDanhGiaChuanID)    
      
  DECLARE @IsTuDanhGia INT = (SELECT IsTuDanhGia FROM dbo.NS_DG_NhomDanhGia WHERE NhomDanhGiaID = @NhomDanhGiaID)    
    
  UPDATE dbo.NS_DG_DotDanhGia SET TrangThai = 1,TrangThai_ThietLapMucTieu = 3 WHERE DotDanhGiaID = @DotDanhGiaChuanID           
     
        
             
;WITH CTE AS        
(        
    SELECT         
        NhanVienMucTieuID,        
        ROW_NUMBER() OVER (        
            PARTITION BY NhanVienID, TieuChiID, DotDanhGiaID        
            ORDER BY NhanVienMucTieuID DESC        
        ) AS RN        
    FROM dbo.NS_DG_NhanVien_MucTieu        
)        
DELETE FROM CTE        
WHERE RN > 1        
    
 --DELETE dbo.NS_DG_DanhGia_KetQua WHERE DotDanhGiaID = @IDD      
      
 INSERT INTO NS_DG_DanhGia_KetQua(NhanVienID,DanhGiaID,DotDanhGiaID,TieuChiID,TieuChiChaID,BoTieuChiID,TenTieuChi,DiemNhap,TrongSo,      
 MucTieu,TongDiem,GhiChu)      
      
 SELECT nvmt.NhanVienID,0,nvmt.DotDanhGiaID,nvmt.TieuChiID,nvmt.TieuChiChaID,nvmt.BoTieuChiID,nvmt.TenTieuChi,ADD_DiemNhap,nvmt.TrongSo      
 ,nvmt.MucTieu,ADD_TongDiem,nvmt.GhiChu      
 FROM NS_DG_NhanVien_MucTieu nvmt      
 INNER JOIN dbo.NS_DG_DotDanhGia ddg ON ddg.DotDanhGiaID = nvmt.DotDanhGiaID      
 INNER JOIN dbo.NS_DG_DanhGia dg ON dg.DotDanhGiaID = ddg.DotDanhGiaID      
 WHERE NhanVienMucTieuID = @IDD AND dg.QuyTrinhBuocThucHienID <> 0      
      
END 
