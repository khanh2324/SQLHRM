CREATE PROCEDURE [dbo].[Tax_QuyetToanTNCN_Nam]    
(    
    @Nam INT    
)    
AS    
BEGIN    
    SET NOCOUNT ON;    
    
    -------------------------------------------------    
    -- 1. Xóa dữ liệu cũ năm này trong bảng QT năm    
    -------------------------------------------------    
    DELETE FROM dbo.ADD_QuyetToanThueNam    
    WHERE Nam = @Nam;    
    
    
    -------------------------------------------------    
    -- 2. Tổng hợp theo NĂM cho NHÂN VIÊN (từ ADD_Tax_Thang)    
    -------------------------------------------------    
    ;WITH EmpYear AS    
    (    
        SELECT     
            t.NhanVienID,    
            nv.MaNhanVien,    
            HoVaTen   = nv.Ho + N' ' + nv.HoTen,    
            nv.MaSoThue,    
            @Nam AS Nam,    
            TongThuNhapChiuThueNam = SUM(ISNULL(t.ThuNhapChiuThue,0)),    
            TongGiamTruBanThanNam  = SUM(ISNULL(t.GiamTruBanThan,0)),    
            TongGiamTruNguoiPTNam  = SUM(ISNULL(t.GiamTruNguoiPT,0)),    
            SoNguoiPhuThuocMax     = MAX(ISNULL(t.SoNguoiPhuThuoc,0)),    
            TongThuNhapTinhThueNam = SUM(ISNULL(t.ThuNhapTinhThue,0)),    
            TongThueDaKhauTruNam   = SUM(ISNULL(t.TongThueKhauTru,0)),    
            BH_Tong_NLD   = SUM(ISNULL(t.BH_Tong_NLD,0)),    
            SoThangCoThuNhap       = SUM(CASE WHEN ISNULL(t.ThuNhapChiuThue,0) > 0 THEN 1 ELSE 0 END),    
            UyQuyenTinhThue = CASE WHEN EXISTS (    
                    SELECT 1 FROM ADD_UyQuyenThue u WHERE u.NhanVienID = t.NhanVienID AND u.Nam = @Nam) THEN 1 ELSE 0    
            END    
        FROM dbo.ADD_Tax_Thang AS t    
        INNER JOIN dbo.NhanVien AS nv     
            ON nv.NhanVienID = t.NhanVienID    
  LEFT JOIN dbo.ADD_UyQuyenThue uq ON uq.NhanVienID = nv.NhanVienID    
        WHERE t.Nam = @Nam    
        GROUP BY t.NhanVienID, nv.MaNhanVien, nv.Ho, nv.HoTen, nv.MaSoThue    
    ),    
    EmpYearCalc AS    
    (    
        SELECT     
            e.*,    
            -- Thu nhập dùng để quyết toán (ở đây mình dùng luôn tổng ThuNhapTinhThueNam đã tính theo tháng)    
            ThuNhapTinhThueQuyetToan = e.TongThuNhapTinhThueNam,    
    
            -- Thuế phải nộp năm:    
            --  - Nếu ỦY QUYỀN: tính lại theo lũy tiến trên thu nhập bình quân tháng * số tháng có thu nhập    
            --  - Nếu KHÔNG ỦY QUYỀN: coi tổng thuế đã khấu trừ trong năm là thuế phải nộp    
            ThueTNCNPhaiNopNam =    
                CASE     
                    WHEN e.UyQuyenTinhThue = 1     
                         AND e.SoThangCoThuNhap > 0    
                    THEN     
                        dbo.fn_TinhThueTNCN_LuyTien(    
                            e.TongThuNhapTinhThueNam / NULLIF(e.SoThangCoThuNhap,0)    
                        ) * e.SoThangCoThuNhap    
                    ELSE     
                        e.TongThueDaKhauTruNam    
                END    
        FROM EmpYear e    
    )    

    -------------------------------------------------    
    -- 3. Tổng hợp NĂM cho ĐỐI TƯỢNG VÃNG LAI    
    -------------------------------------------------    
    ,VangLaiYear AS    
    (    
        SELECT    
            NhanVienID             = NULL,    
            MaNhanVien             = NULL,    
            vl.HoVaTen,    
            vl.MaSoThue,    
            @Nam AS Nam,    
            TongThuNhapChiuThueNam = SUM(ISNULL(vl.SoTien,0)),    
            TongGiamTruBanThanNam  = CAST(0 AS DECIMAL(18,2)),    
            TongGiamTruNguoiPTNam  = CAST(0 AS DECIMAL(18,2)),    
            SoNguoiPhuThuocMax     = NULL,    
            TongThuNhapTinhThueNam = SUM(ISNULL(vl.SoTien,0)),       -- toàn bộ TN vãng lai chịu 10%    
            TongThueDaKhauTruNam   = SUM(ISNULL(vl.ThueDaKhauTru,0)),    
            ThueTNCNPhaiNopNam     = SUM(ISNULL(vl.ThueDaKhauTru,0))  -- bằng tổng thuế 10% đã khấu trừ    
        FROM dbo.ADD_DoiTuongVangLai AS vl    
        WHERE vl.Nam = @Nam    
        GROUP BY vl.HoVaTen, vl.MaSoThue    
    )    
    
    -------------------------------------------------    
    -- 4. Ghi kết quả vào bảng ADD_QuyetToanThueNam    
    -------------------------------------------------    
    INSERT INTO dbo.ADD_QuyetToanThueNam    
    (    
        NhanVienID,    
        MaNhanVien,    
        HoVaTen,    
        MaSoThue,    
        Nam,    
        LoaiDoiTuong,    
        TongThuNhapChiuThueNam,    
        TongGiamTruBanThanNam,    
        TongGiamTruNguoiPTNam,    
        SoNguoiPhuThuocMax,    
        TongThuNhapTinhThueNam,    
        TongThueDaKhauTruNam,    
        ThueTNCNPhaiNopNam,  
  BH_Tong_NLD,  
        ChenhLechThueNam    
    )    
    -- 4.1. Nhân viên nội bộ    
    SELECT     
        e.NhanVienID,    
        e.MaNhanVien,    
        e.HoVaTen,    
        e.MaSoThue,    
        e.Nam,    
        LoaiDoiTuong           = N'NhanVien',    
        e.TongThuNhapChiuThueNam,    
        e.TongGiamTruBanThanNam,    
        e.TongGiamTruNguoiPTNam,    
        e.SoNguoiPhuThuocMax,    
        e.TongThuNhapTinhThueNam,    
        e.TongThueDaKhauTruNam,    
        e.ThueTNCNPhaiNopNam,    
  BH_Tong_NLD,  
        ChenhLechThueNam       = e.ThueTNCNPhaiNopNam - e.TongThueDaKhauTruNam    
    FROM EmpYearCalc AS e    
    
    UNION ALL    
    
    -- 4.2. Đối tượng vãng lai (không có NhanVienID)    
    SELECT    
        v.NhanVienID,    
        v.MaNhanVien,    
        v.HoVaTen,    
        v.MaSoThue,    
        v.Nam,    
        LoaiDoiTuong           = N'VangLai',    
        v.TongThuNhapChiuThueNam,    
        v.TongGiamTruBanThanNam,    
        v.TongGiamTruNguoiPTNam,    
        v.SoNguoiPhuThuocMax,    
        v.TongThuNhapTinhThueNam,    
        v.TongThueDaKhauTruNam,    
        v.ThueTNCNPhaiNopNam,   
  0,  
        ChenhLechThueNam       = v.ThueTNCNPhaiNopNam - v.TongThueDaKhauTruNam    
    FROM VangLaiYear AS v;    
    
    -------------------------------------------------    
    -- 5. Trả ra kết quả cho năm được chọn    
    -------------------------------------------------    
    SELECT *    
    FROM dbo.ADD_QuyetToanThueNam    
    WHERE Nam = @Nam    
    ORDER BY LoaiDoiTuong, MaNhanVien, HoVaTen;    
    
END; 
GO
