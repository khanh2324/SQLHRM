CREATE PROCEDURE [dbo].[XD_LayDSCongTac]  
@NhanVienID int,      
@NguoiDungID int,      
@MaLoaiQuyTrinh nvarchar(100),      
@QuyTrinhID int,      
@TrangThai int      
AS      
BEGIN      
SELECT  
WF_QuyTrinh_ThucHien.QuyTrinhThucHienID,  
WF_QuyTrinh.TenQuyTrinh as TenXetDuyet,  
NhanVien.Ho + ' ' + NhanVien.HoTen as NguoiTao,--N'Họ và tên',  
NS_DsChucVu.TenChucVu as ChucVu,
CONVERT(nvarchar(10),ct.NgayBatDau,103) as NgayTao,
--CONVERT(nvarchar(10),ct.NgayBatDau,103) as N'Ngày bắt đầu',  
--CONVERT(nvarchar(10),ct.NgayKetThuc,103) as N'Ngày kết thúc',  
FORMAT(ct.NgayBatDau, 'dd/MM/yyyy HH:mm:ss') N'Ngày bắt đầu',  
FORMAT(ct.NgayKetThuc, 'dd/MM/yyyy HH:mm:ss') N'Ngày kết thúc', 
ct.CongViecCuThe as N'Công việc cụ thể',  
ct.NoiCongTac as N'Nơi công tác'  
FROM WF_QuyTrinh_ThucHien      
 inner join       
 (SELECT * FROM SYS_XetDuyet WHERE TrangThai=0 or TrangThai=100 Or TrangThai=@TrangThai) as SYS_XetDuyet      
 --SYS_XetDuyet    
 on SYS_XetDuyet.XetDuyetID=WF_QuyTrinh_ThucHien.XetDuyetID      
 inner join NS_QTCongTac ct on ct.QTCongTacID = SYS_XetDuyet.ObjectID      
 left join NhanVien on NhanVien.NhanVienID = ct.NhanVienID      
 --left join PhongBan on PhongBan.PhongBanID = NhanVien.PhongBanID      
 left join NS_DsChucVu on NS_DsChucVu.ChucVuID = nhanvien.ChucVuID      
 inner join WF_QuyTrinh on WF_QuyTrinh.QuyTrinhID = SYS_XetDuyet.QuyTrinhID      
 left join SYS_NhomXetDuyet on WF_QuyTrinh_ThucHien.NhomXetDuyetID = SYS_NhomXetDuyet.NhomXetDuyetID    
 left join SYS_NguoiDung_NhomXetDuyet on SYS_NhomXetDuyet.NhomXetDuyetID = SYS_NguoiDung_NhomXetDuyet.NhomXetDuyetID    
WHERE 1=1    
 --AND ((SYS_XetDuyet.TrangThai=0 or SYS_XetDuyet.TrangThai=100) OR (SYS_XetDuyet.TrangThai=@TrangThai))      
 AND WF_QuyTrinh_ThucHien.TrangThai=@TrangThai    
 AND ((ISNULL(WF_QuyTrinh_ThucHien.NguoiDungXetDuyetID,0) <> 0 AND WF_QuyTrinh_ThucHien.NguoiDungXetDuyetID=@NguoiDungID)     
  OR (ISNULL(WF_QuyTrinh_ThucHien.NguoiDungXetDuyetID,0) = 0 AND SYS_NguoiDung_NhomXetDuyet.NguoiDungID = @NguoiDungID))     
 AND (WF_QuyTrinh.QuyTrinhID=@QuyTrinhID)      
END  
GO
