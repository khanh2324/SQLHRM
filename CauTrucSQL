CREATE PROCEDURE [dbo].[TL_DSKhoaLuong]
	@Nam int
AS
BEGIN
	set nocount on;

	declare @tbThang Table(Thang int)
	INSERT INTO @tbThang(Thang) Values (1)
	INSERT INTO @tbThang(Thang) Values (2)
	INSERT INTO @tbThang(Thang) Values (3)
	INSERT INTO @tbThang(Thang) Values (4)
	INSERT INTO @tbThang(Thang) Values (5)
	INSERT INTO @tbThang(Thang) Values (6)
	INSERT INTO @tbThang(Thang) Values (7)
	INSERT INTO @tbThang(Thang) Values (8)
	INSERT INTO @tbThang(Thang) Values (9)
	INSERT INTO @tbThang(Thang) Values (10)
	INSERT INTO @tbThang(Thang) Values (11)
	INSERT INTO @tbThang(Thang) Values (12)

	SELECT tbThang.Thang, @Nam as Nam, 
		Convert(bit, case
						 WHEN ISNULL(NS_TL_KhoaLuong.Type, 0)=1 Or ISNULL(NS_TL_KhoaLuong.Type, 0)=3 then 1
						 else 0
					end) as KhoaCong,
		Convert(bit,case
			 WHEN ISNULL(NS_TL_KhoaLuong.Type, 0)=2 Or ISNULL(NS_TL_KhoaLuong.Type, 0)=3 then 1
			 else 0
		end) as KhoaLuong
	FROM @tbThang as tbThang
	Left join NS_TL_KhoaLuong on NS_TL_KhoaLuong.Thang = tbThang.Thang And NS_TL_KhoaLuong.Nam = @Nam
END

