			then 
			(select max(ChucVuMoiID) from ns_qtchuyencanbo as qt where 
			NhanVienID = @NhanVienID and 
			@date between convert(date,qt.ngayhieuluc) and isnull((select dateadd(dd,-1,MIN(convert(date,ngayhieuluc))) from
			NS_QTChuyenCanBo where NhanVienID = @nhanvienid
			and NgayHieuLuc > qt.NgayHieuLuc),'1/1/2099'))
			else
			(
			select max(ChucVuCuID) from ns_qtchuyencanbo where nhanvienid = @nhanvienid
			and ngayhieuluc = (select min(ngayhieuluc) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)
			)
			end
		)
	end
	)
	-- xét chức danh

		set @chucdanhid =
	(select 
	case when (select count(*) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)=0
	then 
		(select chucdanhid from nhanvien where NhanVienID = @nhanvienid) 
	else
		(
			case when (select COUNT(*) from ns_qtchuyencanbo as qt where 
			NhanVienID = @NhanVienID and 
			@date between convert(date,qt.ngayhieuluc) and dateadd(dd,-1,isnull((select MIN(convert(date,ngayhieuluc)) from
			NS_QTChuyenCanBo where NhanVienID = @nhanvienid
			and NgayHieuLuc > qt.NgayHieuLuc),'1/1/2099')))>0
			then 
			(select max(ChucDanhMoiID) from ns_qtchuyencanbo as qt where 
			NhanVienID = @NhanVienID and 
			@date between convert(date,qt.ngayhieuluc) and isnull((select dateadd(dd,-1,MIN(convert(date,ngayhieuluc))) from
			NS_QTChuyenCanBo where NhanVienID = @nhanvienid
			and NgayHieuLuc > qt.NgayHieuLuc),'1/1/2099'))
			else
			(
			select max(ChucDanhCuID) from ns_qtchuyencanbo where nhanvienid = @nhanvienid
			and ngayhieuluc = (select min(ngayhieuluc) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)
			)
			end
		)
	end
	)

	-- xét nghỉ việc
	set @nghiviec = 
	(
		select case when (select count(*) from NS_NhanVien_NghiViec where NhanVienID = @nhanvienid)=0
		then
			(case when 
			(select isnull(nghiviec,0) from nhanvien where nhanvienid = @nhanvienid) = 1 
			then 1 else 0 end
			)
		else
			(case when 
			(select count(*) from ns_nhanvien_nghiviec where nhanvienid = @nhanvienid
			and @date between CONVERT(date,ngayhieuluc) and ISNULL(CONVERT(date,ngaydilamlai),'1/1/2099')
			) = 0 then 0 else 1 end)
		end	
				
	)
	insert into @trave(nhanvienid,phongbanid,nghiviec,chucvuid,chucdanhid)
	select @nhanvienid,@phongbanid,@nghiviec,@chucvuid,@chucdanhid
	delete @tbl where nhanvienid = @nhanvienid
	set @dem = (select count(*) from @tbl)
end

 return
end
