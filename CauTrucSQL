CREATE PROCEDURE [dbo].[HS_LayParameters_DienBienLuong]
@QTDienBienLuongID int
AS
BEGIN
select*,
(select max(GiaTri) from NS_QTDienBienLuongChiTiet inner join NS_TL_LoaiLuong on NS_QTDienBienLuongChiTiet.LoaiLuongID = NS_TL_LoaiLuong.LoaiLuongID
where NS_QTDienBienLuongChiTiet.QTDienBienLuongID = QTCuID and MaSo = 'LCB') as LCB_Cu
from(
select NhanVien.MaNhanVien,NhanVien.Ho+' '+NhanVien.HoTen as HoVaTen,
case when NhanVien.GIoiTInh = N'Nam' then N'Ông' else N'Bà' end as OngBa,
PhongBan.Ten as PhongBan,NS_DsChucVu.TenChucVu,NS_QTDienBienLuong.SoQuyetDinh,
NS_QTDienBienLuong.NgayQuyetDinh,NS_QTDienBienLuong.NgayHuong,NS_QTDienBienLuongChiTiet.GiaTri,
NS_TL_LoaiLuong.MaSo,(select max(QTDienBienLuongID) from NS_QTDienBienLuong as QTDBL
where QTDBL.NhanVienID = NS_QTDienBienLuong.NhanVienID and QTDBL.NgayHuong =
(select max(NgayHuong) from NS_QTDienBienLuong as QTCU where QTCU.NhanVienID = NS_QTDienBienLuong.NhanVienID
and QTCU.NgayHuong < NS_QTDienBienLuong.NgayHuong)) as QTCuID,
NhanVien.DienThoai,NhanVien.DiaChi,NhanVien.DiaChiThuongTru
,NhanVien.GioiTinh
from NS_QTDienBienLuong
inner join NhanVien on NS_QTDienBienLuong.NhanVienID = NhanVien.NhanVienID
inner join PhongBan on NhanVien.PhongBanID = PHongBan.PhongBanID
inner join NS_DsChucVu on NhanVien.ChucVuID = NS_DsChucVu.ChucVuID
inner join NS_QTDienBienLuongChiTiet on NS_QTDienBienLuong.QTDienBienLuongID = NS_QTDienBienLuongChiTiet.QTDienBienLuongID
inner join NS_TL_LoaiLuong on NS_QTDienBienLuongChiTiet.LoaiLuongID = NS_TL_LoaiLuong.LoaiLuongID
where NS_QTDienBienLuong.QTDienBienLuongID = @QTDienBienLuongID
) as a pivot(max(GiaTri) for MaSo in ([LCB])) as pvt

END

