CREATE PROCEDURE [dbo].[HSNS_CONGTAC_GETNOTIFY]
@NhanVienID int,
@FromDate Datetime,
@ToDate Datetime,
@LyDoCongTacID int,
@NguoiDungID int,
@QTCongTacID int
AS
BEGIN
	DECLARE @LoaiCongChuan INT =(SELECT LoaiCongChuanID FROM dbo.NhanVien WHERE NhanVienID=@NhanVienID)
	DECLARE @MaLoaiCongChuan NVARCHAR(50) = (SELECT MaLoaiCongChuan FROM NhanVien 
	LEFT JOIN dbo.ADD_LoaiCongChuan ON ADD_LoaiCongChuan.LoaiCongChuanID = NhanVien.LoaiCongChuanID WHERE NhanVienId = @NhanVienID)
	DECLARE @ThuFromDate INT = (SELECT thu FROM dbo.NS_BH_NgayThang WHERE CONVERT(DATE,Ngay) = CONVERT(DATE,@FromDate))
	DECLARE @ThuToDate INT = (SELECT thu FROM dbo.NS_BH_NgayThang WHERE CONVERT(DATE,Ngay) = CONVERT(DATE,@ToDate))
	
declare @CaLamViecID int, @CaLV_NV int
set @CaLV_NV = (select isnull(CaLVID,0) from NhanVien where NhanVienID=@NhanVienID)  
set @CaLamViecID = isnull((select CaLamViecID from NS_TL_DangKyCong where nhanvienid=@NhanVienID and convert(date,NgayChamCong)=convert(date,@Fromdate)),@CaLV_NV)

	DECLARE @CaLamViecToDate INT = (select CaLamViecID from NS_TL_DangKyCong where nhanvienid=@NhanVienID and convert(date,NgayChamCong)=convert(date,@ToDate))
	declare @Gio1 time(7)= (select GioBatDau1 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
	declare @Gio2 time(7)= (select GioKetThuc1 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
	declare @Gio3 time(7)= (select GioBatDau2 from NS_CaLamViec where CaLamViecID=@CaLamViecID)  
	declare @Gio4 time(7)= (select GioKetThuc2 from NS_CaLamViec where CaLamViecID=@CaLamViecID)
	declare @GioBatDauDky time(7)=convert(time(7),@FromDate)  
	declare @GioKetThucDky time(7)=convert(time(7),@ToDate)


	DECLARE @isKhoaCong BIT = CASE
    WHEN EXISTS (
        SELECT 1
        FROM NS_TL_KhoaLuong
        WHERE @FromDate >= DATEFROMPARTS(YEAR(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),
                                         MONTH(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),26)
          AND @FromDate <= DATEFROMPARTS(Nam, Thang, 25))
    THEN 1 ELSE 0 END;



	IF @isKhoaCong > 0
	BEGIN
		SELECT N'Bạn không thể đăng ký công tác vào tháng đã khóa công!', CONVERT(BIT,0), 1
	end
	ELSE IF (DATEPART(MINUTE, @FromDate) not in (0,15,30,45) or DATEPART(MINUTE, @ToDate) not in (0,15,30,45))
	begin
		select N'Đăng ký tối thiểu 1 giờ, không đăng ký lẻ phút!', convert(bit,0), 1
	end 
	ELSE IF (select count(*) from NS_QTNghiPhep where NhanVienID=@NhanVienID and (convert(datetime,NgayBatDau) between convert(datetime,@FromDate) and convert(datetime,@ToDate) or convert(datetime,NgayKetThuc) between convert(datetime,@FromDate) and convert(datetime,@ToDate))) > 0
	begin
		select N'Đã tồn tại đơn đăng kí nghỉ trong thời gian đăng kí công tác!', convert(bit,0), 1
	END
	ELSE IF @GioBatDauDky NOT IN (@Gio1,@Gio3) OR @GioKetThucDky NOT IN (@Gio2,@Gio4)
	BEGIN
		SELECT N'Bạn chỉ được đăng ký trong khoảng thời gian của ca làm việc'  ,convert(bit,0), 1 
	END
	else if @FromDate >= @ToDate
	begin
		select N'Thời gian bắt đầu công tác phải nhỏ hơn thời gian kết thúc!', convert(bit,0), 1
	END
	--ELSE IF DATEDIFF(DAY,CONVERT(DATE,@FromDate),GETDATE()) > 7
	--BEGIN
	--    SELECT N'Bạn chỉ có thể đăng ký công tác back date 7 ngày'  ,CONVERT(BIT,0),1
	--END
    ELSE IF @MaLoaiCongChuan = '40h' AND (@ThuFromDate IN (1,7) OR @ThuToDate IN (1,7))
    BEGIN
        select N'Thời gian mà bạn chọn đang là ngày nghỉ tuần', convert(bit,0), 1
    END
	ELSE IF @MaLoaiCongChuan = '44h' AND (@ThuFromDate IN (1) OR @ThuToDate IN (1))
	BEGIN
		SELECT N'Thời gian mà bạn chọn đang là ngày nghỉ tuần'  ,CONVERT(BIT,0), 1
	END
	--else if DATEDIFF(HOUR,@FromDate,@ToDate)>8 and DATEDIFF(day,getdate(),convert(date,@FromDate))<1 and @NguoiDungID <>13835
	--begin
	--select N'Công tác trên 8 tiếng phải đăng kí trước 1 ngày',convert(bit,0),1
	--end
	--else if DATEDIFF(HOUR,@FromDate,@ToDate)<8 and DATEDIFF(HOUR,convert(time,getdate()),convert(time,@FromDate))<0
	--begin
	--select N'Đăng kí công tác <8 tiếng phải đăng kí trước giờ bắt đầu'
	--end
	else	
	begin
		select N'', convert(bit,1), 1
	end
END
GO
