	select NhanVien.MaNhanVien,NhanVien.Ho+' '+NhanVien.HoTen as HoVaTen,PhongBan.Ten as PhongBan,NS_DsChucVu.TenChucVu,
	case when NS_QTDaoTao.SauKhiVaoCongTy=1 then N'Sau khi vào công ty' else N'Trước khi vào công ty' end as ThoiDiemDaoTao,
	NS_QTDaoTao.LopDaoTao as KhoaDaoTao, NS_QTDaoTao.NoiDungDaoTao, NS_QTDaoTao.TuNgay, NS_QTDaoTao.ToiNgay,
	convert(nvarchar,NS_QTDaoTao.TuNgay,103)+' - '+convert(nvarchar,NS_QTDaoTao.ToiNgay,103) as ThoiGianDaoTao,
	NS_DsHinhThucDaoTao.TenHinhThuc as HinhThucDaoTao, NS_DT_KhoaDaoTao.TenKhoaDaoTao as ChuongTrinhDaoTao,
	NS_DT_KetQuaDaoTao.TenKetQuaDaoTao as KetQuaDaoTao,NS_QTDaoTao.DiemSo,NS_QTDaoTao.ChiPhiCaNhan,
	NS_QTDaoTao.SoThangCamKetSauDaoTao, NS_DsQuocTich.TenNuoc as NuocDaoTao,NS_DsTruongDaoTao.Ten as TruongDaoTao,
	NS_DsHeDaoTao.Ten as HeDaoTao, NS_DsNganhHoc.TenNganhHoc as NganhHoc, NS_DsChuyenNganh.Ten as ChuyenNganh,
	NS_DsVanBang.TenVanBang as BangCap, NS_DsChungChi.Ten as ChungChi
	from NS_QTDaoTao
	inner join NhanVien on NS_QTDaoTao.NhanVienID=NhanVien.NhanVienID
