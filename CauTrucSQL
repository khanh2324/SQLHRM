create FUNCTION [dbo].[fnt_GetChucVuNhanVienTaiThoiDiem](@NhanVienID int, @NgayKiemTra DATE)
RETURNS TABLE
AS
RETURN
WITH DL AS (
    SELECT 
        NhanVienID,
