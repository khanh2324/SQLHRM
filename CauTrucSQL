CREATE    FUNCTION [dbo].[fns_SoLuongNhanVienTrongPhongBanTaiThoiDiem_CoPbCon]  ( @PhongBanID INT, @NgayHieuLuc date )  RETURNS int  AS  
BEGIN  
 DECLARE @Values int =0  
  
 SET @Values = ( 
select count(NhanVienID) from (
  select top 1 with ties NhanVienID,  PhongBanMoiID , ChucVuMoiID, ChucDanhMoiID from
		  ( select top 1 with ties 1 Ranks, NhanVienID, PhongBanMoiID , ChucVuMoiID, ChucDanhMoiID  from NS_QTChuyenCanBo  where   CONVERT(Date, NgayHieuLuc) <= @NgayHieuLuc     order by row_number() over (partition by  NhanVienID order by  NgayHieuLuc desc)
		   union all   
		   select top 1 with ties 2 Ranks, NhanVienID,  PhongBanCuID, ChucVuCuID, ChucDanhCuID  from NS_QTChuyenCanBo  where   CONVERT(Date, NgayHieuLuc) >  @NgayHieuLuc     order by row_number() over (partition by  NhanVienID order by  NgayHieuLuc asc)
		   union all
		   SELECT 3 Ranks, NhanVienID,  PhongBanID, ChucVuID, ChucDanhID FROM  NhanVien ) As ccb 	  
  order by row_number() over (partition by  NhanVienID order by  Ranks asc)) as a
	where NhanVienID in

	(SELECT NhanVienID FROM  NhanVien  X WHERE X.NgayBatDauLam <= @NgayHieuLuc AND (ISNULL(X.NghiViec,0) = 0 or CONVERT(DATE, X.NgayNghiViec) > @NgayHieuLuc) AND ISNULL(X.IsDeleted,0) = 0 )

	and (PhongBanMoiID in (select PhongBanID from dbo.fn_LayPhongBanCon(@PhongBanID)) ) )  
  RETURN ISNULL(@Values,0)  
END  
