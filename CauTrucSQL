CREATE PROCEDURE [dbo].[Tinh_ChotLuongBackDate]  
(  
	@Thang int,
    @Nam INT  ,
	@PhongBanID int
)  
AS  
BEGIN  
    SET NOCOUNT ON;  
--DECLARE @Thang INT = 9, @Nam   INT = 2025, @PhongBanID INT = 174

DECLARE @NBDKC INT =(SELECT TRY_CAST(GiaTri AS INT) FROM SYS_ThongSo WHERE MaSo = 'NBDCC')

DECLARE @fdate DATE =
(
    CASE WHEN @NBDKC IN (0,1) THEN DATEFROMPARTS(@Nam,@Thang,1) ELSE DATEADD(MONTH,-1,DATEFROMPARTS(@Nam,@Thang,@NBDKC)) END
)

DECLARE @tdate DATE = DATEADD(DAY,-1,DATEADD(MONTH,1,@fdate))
DELETE ADD_TL_ChenhLechBackDate
WHERE ThangChiLuong = @Thang
  AND NamChiLuong   = @Nam
;WITH BangGoc AS
(
    SELECT DISTINCT
        nv.NhanVienID,
        MONTH(cc.NgayChamCong) AS ThangTL,
        YEAR(cc.NgayChamCong)  AS NamTL,
        nv.PhongBanID
    FROM NS_TLBD_ChamCong cc
    INNER JOIN NhanVien nv ON cc.NhanVienID = nv.NhanVienID
    WHERE CONVERT(date,cc.NgayChamCong) BETWEEN @fdate AND @tdate
      AND nv.PhongBanID IN (SELECT valu FROM getphongbanchilds(@PhongBanID))
      AND ISNULL(nv.NghiViec,0) = 0
)
, LBD_SUM AS
(
    SELECT
        bl.NhanVienID,
        bl.Thang AS ThangTL,
        bl.Nam   AS NamTL,
        ll.MaSo,
        SUM(ct.TienLuong) AS TienLuong
    FROM NS_TLBD_BangLuong bl
    INNER JOIN NS_TLBD_ChiTietLuong ct ON bl.BangLuongID = ct.BangLuongID
    INNER JOIN NS_TL_LoaiLuong ll ON ct.LoaiLuongID = ll.LoaiLuongID
    WHERE EXISTS
    (
        SELECT 1
        FROM BangGoc bg
        WHERE bg.NhanVienID = bl.NhanVienID
          AND bg.ThangTL    = bl.Thang
          AND bg.NamTL      = bl.Nam
    )
    GROUP BY bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo
)
, LBD AS
(
    SELECT *
    FROM LBD_SUM
    PIVOT
    (SUM(TienLuong)
        FOR MaSo IN
        (
            [TLNC_TongLuong_Thuong_PhuCap],
            [TLOT_TongLuongOT_LamCaDem],
            [Thuong_KPI],
            [Thuong_CongTruocThue],
            [Thuong_TruTruocThue],
            [BH_Tong_NLD],
            [BH_Tong_CTY],
            [PSSThue_CongDoan_NLD],
            [PSSThue_CongDoan_CTY],
            [PSSThue_TruSauTax],
            [PSSThue_CongSauTax]
        )
    ) p
)
, LDC AS
(
    SELECT *
    FROM
    (
        SELECT
            bl.NhanVienID,
            bl.Thang AS ThangTL,
            bl.Nam   AS NamTL,
            ll.MaSo,
            ct.TienLuong
        FROM NS_TL_BangLuong bl
        INNER JOIN NS_TL_ChiTietLuong ct ON bl.BangLuongID = ct.BangLuongID
        INNER JOIN NS_TL_LoaiLuong ll ON ct.LoaiLuongID = ll.LoaiLuongID
    ) src
    PIVOT
    (
        SUM(TienLuong)
        FOR MaSo IN
        (
            [TLNC_TongLuong_Thuong_PhuCap],
            [TLOT_TongLuongOT_LamCaDem],
            [Thuong_KPI],
            [Thuong_CongTruocThue],
            [Thuong_TruTruocThue],
            [BH_Tong_NLD],
            [BH_Tong_CTY],
            [PSSThue_CongDoan_NLD],
            [PSSThue_CongDoan_CTY],
            [PSSThue_TruSauTax],
            [PSSThue_CongSauTax]
        )
    ) p
)
INSERT INTO [dbo].[ADD_TL_ChenhLechBackDate]
([NhanVienID],[PhongBanID],[MaNhanVien],[HoVaTen],[ViTriCongViec]
,[ThangTL],[NamTL],[ThangChiLuong],[NamChiLuong],
[LBD_TLNC_TongLuong_Thuong_PhuCap],[LDC_TLNC_TongLuong_Thuong_PhuCap], [ChenhLech_TLNC_TongLuong_Thuong_PhuCap]
,[LBD_TLOT_TongLuongOT_LamCaDem],[LDC_TLOT_TongLuongOT_LamCaDem], [ChenhLech_TLOT_TongLuongOT_LamCaDem],
[LBD_Thuong_KPI],[LDC_Thuong_KPI], [ChenhLech_Thuong_KPI],[LBD_Thuong_CongTruocThue],
[LDC_Thuong_CongTruocThue], [ChenhLech_Thuong_CongTruocThue],[LBD_Thuong_TruTruocThue],
[LDC_Thuong_TruTruocThue], [ChenhLech_Thuong_TruTruocThue],
[LBD_BH_Tong_NLD],[LDC_BH_Tong_NLD], [ChenhLech_BH_Tong_NLD],[LBD_BH_Tong_CTY],
[LDC_BH_Tong_CTY], [ChenhLech_BH_Tong_CTY],[LBD_PSSThue_CongDoan_NLD],[LDC_PSSThue_CongDoan_NLD], 
[ChenhLech_PSSThue_CongDoan_NLD],[LBD_PSSThue_CongDoan_CTY],[LDC_PSSThue_CongDoan_CTY], 
[ChenhLech_PSSThue_CongDoan_CTY],[LBD_PSSThue_TruSauTax],[LDC_PSSThue_TruSauTax], 
[ChenhLech_PSSThue_TruSauTax],[LBD_PSSThue_CongSauTax],[LDC_PSSThue_CongSauTax],
[ChenhLech_PSSThue_CongSauTax])
SELECT
bg.NhanVienID,bg.PhongBanID,nv.MaNhanVien,nv.Ho+' '+nv.HoTen AS HoVaTen,cv.TenChucVu AS ViTriCongViec,
bg.ThangTL,bg.NamTL,@Thang AS ThangChiLuong,@Nam AS NamChiLuong,
ISNULL(LBD.TLNC_TongLuong_Thuong_PhuCap,0) AS LBD_TLNC_TongLuong_Thuong_PhuCap,
ISNULL(LDC.TLNC_TongLuong_Thuong_PhuCap,0) AS LDC_TLNC_TongLuong_Thuong_PhuCap,
(ISNULL(LBD.TLNC_TongLuong_Thuong_PhuCap,0)-ISNULL(LDC.TLNC_TongLuong_Thuong_PhuCap,0)) AS ChenhLech_TLNC_TongLuong_Thuong_PhuCap,

ISNULL(LBD.TLOT_TongLuongOT_LamCaDem,0) AS LBD_TLOT_TongLuongOT_LamCaDem,
ISNULL(LDC.TLOT_TongLuongOT_LamCaDem,0) AS LDC_TLOT_TongLuongOT_LamCaDem,
(ISNULL(LBD.TLOT_TongLuongOT_LamCaDem,0)-ISNULL(LDC.TLOT_TongLuongOT_LamCaDem,0)) AS ChenhLech_TLOT_TongLuongOT_LamCaDem,

ISNULL(LBD.Thuong_KPI,0) AS LBD_Thuong_KPI,
ISNULL(LDC.Thuong_KPI,0) AS LDC_Thuong_KPI,
(ISNULL(LBD.Thuong_KPI,0)-ISNULL(LDC.Thuong_KPI,0)) AS ChenhLech_Thuong_KPI,

ISNULL(LBD.Thuong_CongTruocThue,0) AS LBD_Thuong_CongTruocThue,
ISNULL(LDC.Thuong_CongTruocThue,0) AS LDC_Thuong_CongTruocThue,
(ISNULL(LBD.Thuong_CongTruocThue,0)-ISNULL(LDC.Thuong_CongTruocThue,0)) AS ChenhLech_Thuong_CongTruocThue,

ISNULL(LBD.Thuong_TruTruocThue,0) AS LBD_Thuong_TruTruocThue,
ISNULL(LDC.Thuong_TruTruocThue,0) AS LDC_Thuong_TruTruocThue,
(ISNULL(LBD.Thuong_TruTruocThue,0)-ISNULL(LDC.Thuong_TruTruocThue,0)) AS ChenhLech_Thuong_TruTruocThue,

ISNULL(LBD.BH_Tong_NLD,0) AS LBD_BH_Tong_NLD,
ISNULL(LDC.BH_Tong_NLD,0) AS LDC_BH_Tong_NLD,
(ISNULL(LBD.BH_Tong_NLD,0)-ISNULL(LDC.BH_Tong_NLD,0)) AS ChenhLech_BH_Tong_NLD,

ISNULL(LBD.BH_Tong_CTY,0) AS LBD_BH_Tong_CTY,
ISNULL(LDC.BH_Tong_CTY,0) AS LDC_BH_Tong_CTY,
(ISNULL(LBD.BH_Tong_CTY,0)-ISNULL(LDC.BH_Tong_CTY,0)) AS ChenhLech_BH_Tong_CTY,

ISNULL(LBD.PSSThue_CongDoan_NLD,0) AS LBD_PSSThue_CongDoan_NLD,
ISNULL(LDC.PSSThue_CongDoan_NLD,0) AS LDC_PSSThue_CongDoan_NLD,
(ISNULL(LBD.PSSThue_CongDoan_NLD,0)-ISNULL(LDC.PSSThue_CongDoan_NLD,0)) AS ChenhLech_PSSThue_CongDoan_NLD,

ISNULL(LBD.PSSThue_CongDoan_CTY,0) AS LBD_PSSThue_CongDoan_CTY,
ISNULL(LDC.PSSThue_CongDoan_CTY,0) AS LDC_PSSThue_CongDoan_CTY,
(ISNULL(LBD.PSSThue_CongDoan_CTY,0)-ISNULL(LDC.PSSThue_CongDoan_CTY,0)) AS ChenhLech_PSSThue_CongDoan_CTY,

ISNULL(LBD.PSSThue_TruSauTax,0) AS LBD_PSSThue_TruSauTax,
ISNULL(LDC.PSSThue_TruSauTax,0) AS LDC_PSSThue_TruSauTax,
(ISNULL(LBD.PSSThue_TruSauTax,0)-ISNULL(LDC.PSSThue_TruSauTax,0)) AS ChenhLech_PSSThue_TruSauTax,

ISNULL(LBD.PSSThue_CongSauTax,0) AS LBD_PSSThue_CongSauTax,
ISNULL(LDC.PSSThue_CongSauTax,0) AS LDC_PSSThue_CongSauTax,
(ISNULL(LBD.PSSThue_CongSauTax,0)-ISNULL(LDC.PSSThue_CongSauTax,0)) AS ChenhLech_PSSThue_CongSauTax

FROM BangGoc bg
LEFT JOIN dbo.NhanVien nv ON nv.NhanVienID = bg.NhanVienID
LEFT JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = nv.ChucVuID
LEFT JOIN LBD lbd 
    ON bg.NhanVienID = lbd.NhanVienID
   AND bg.ThangTL    = lbd.ThangTL
   AND bg.NamTL      = lbd.NamTL
LEFT JOIN LDC ldc
    ON bg.NhanVienID = ldc.NhanVienID
   AND bg.ThangTL    = ldc.ThangTL
   AND bg.NamTL      = ldc.NamTL

select 
    ChotLuongBackDateID as ID,
    MaNhanVien as N'Mã nhân viên', 
    HoVaTen as N'Họ và tên',
    ViTriCongViec as N'Chức vụ',
    convert(nvarchar,ThangTL) + '/' + convert(nvarchar,NamTL) as N'Tháng lương',

    [LBD_TLNC_TongLuong_Thuong_PhuCap]  as N'Tổng lương và phụ cấp theo ngày công hiện tại',
    [LDC_TLNC_TongLuong_Thuong_PhuCap]  as N'Tổng lương và phụ cấp theo ngày công đã chi',
    [ChenhLech_TLNC_TongLuong_Thuong_PhuCap] as N'Chênh lệch tổng lương và phụ cấp theo ngày công',

    [LBD_TLOT_TongLuongOT_LamCaDem]  as N'Tổng tiền làm thêm giờ và ca đêm hiện tại',
    [LDC_TLOT_TongLuongOT_LamCaDem]  as N'Tổng tiền làm thêm giờ và ca đêm đã chi',
    [ChenhLech_TLOT_TongLuongOT_LamCaDem] as N'Chênh lệch tổng tiền làm thêm giờ và ca đêm',

    [LBD_Thuong_KPI]  as N'Thưởng KPI hiện tại',
    [LDC_Thuong_KPI]  as N'Thưởng KPI đã chi',
    [ChenhLech_Thuong_KPI] as N'Chênh lệch thưởng KPI',

    [LBD_Thuong_CongTruocThue]  as N'Cộng trước thuế hiện tại',
    [LDC_Thuong_CongTruocThue]  as N'Cộng trước thuế đã chi',
    [ChenhLech_Thuong_CongTruocThue] as N'Chênh lệch cộng trước thuế',

    [LBD_Thuong_TruTruocThue]  as N'Trừ trước thuế hiện tại',
    [LDC_Thuong_TruTruocThue]  as N'Trừ trước thuế đã chi',
    [ChenhLech_Thuong_TruTruocThue] as N'Chênh lệch trừ trước thuế',

    [LBD_BH_Tong_NLD]  as N'BHXH, BHYT, BHTN (Nhân viên) hiện tại',
    [LDC_BH_Tong_NLD]  as N'BHXH, BHYT, BHTN (Nhân viên) đã chi',
    [ChenhLech_BH_Tong_NLD] as N'Chênh lệch BHXH, BHYT, BHTN (Nhân viên)',

    [LBD_BH_Tong_CTY]  as N'BHXH, BHYT, BHTN (Công ty) hiện tại',
    [LDC_BH_Tong_CTY]  as N'BHXH, BHYT, BHTN (Công ty) đã chi',
    [ChenhLech_BH_Tong_CTY] as N'Chênh lệch BHXH, BHYT, BHTN (Công ty)',

    [LBD_PSSThue_CongDoan_NLD]  as N'Công đoàn phí (Nhân viên) hiện tại',
    [LDC_PSSThue_CongDoan_NLD]  as N'Công đoàn phí (Nhân viên) đã chi',
    [ChenhLech_PSSThue_CongDoan_NLD] as N'Chênh lệch công đoàn phí (Nhân viên)',

    [LBD_PSSThue_CongDoan_CTY]  as N'Kinh phí công đoàn (Công ty) hiện tại',
    [LDC_PSSThue_CongDoan_CTY]  as N'Kinh phí công đoàn (Công ty) đã chi',
    [ChenhLech_PSSThue_CongDoan_CTY] as N'Chênh lệch kinh phí công đoàn (Công ty)',

    [LBD_PSSThue_TruSauTax]  as N'Trừ sau thuế hiện tại',
    [LDC_PSSThue_TruSauTax]  as N'Trừ sau thuế đã chi',
    [ChenhLech_PSSThue_TruSauTax] as N'Chênh lệch trừ sau thuế',

    [LBD_PSSThue_CongSauTax]  as N'Cộng sau thuế hiện tại',
    [LDC_PSSThue_CongSauTax]  as N'Cộng sau thuế đã chi',
    [ChenhLech_PSSThue_CongSauTax] as N'Chênh lệch cộng sau thuế'

from [ADD_TL_ChenhLechBackDate] 
where ThangTL = @Thang 
  and NamTL   = @Nam;

END
GO
