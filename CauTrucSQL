CREATE FUNCTION [dbo].[GetPhongBanChild_WUser](@parentID int, @userid int)
RETURNS @tbl TABLE (id int, valu INT PRIMARY KEY, prID int)
WITH EXECUTE AS CALLER
AS
 begin
  WITH temp(id, name, alevel)
        as (
                Select PhongBanID as id,Ten as name, 0 as aLevel
                From PhongBan
                Where PhongBanChaID=@parentID
                Union All
