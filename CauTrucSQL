		select ROW_NUMBER() over (order by id desc) as tt,@phongbanid as pbid,ten from  @tbltam
  ) as tbl pivot (max(ten) for tt in ([1],[2],[3],[4],[5],[6])) as pvt
		delete from @tbltam
