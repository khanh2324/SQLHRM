CREATE PROCEDURE [dbo].[HS_LayParameters_ThiSinh]        
@ThiSinhID INT,  
@DotTuyenDungID   INT = NULL   
AS        
BEGIN      
    
--DECLARE  @ThiSinhID      INT = 3243       
--    , @DotTuyenDungID INT = 1119;       
  
-- Nếu muốn dùng 0 như là "không lọc" thì:  
IF @ThiSinhID = 0       SET @ThiSinhID = NULL;  
IF @DotTuyenDungID = 0  SET @DotTuyenDungID = NULL;  
  
SELECT  CONVERT(NVARCHAR,GETDATE(),103) NgayHienTai,  
	 TenHo+' '+NS_TD_ThiSinh.Ten AS HoTen, 
	 dbo.fuChuyenCoDauThanhKhongDau(TenHo+' '+NS_TD_ThiSinh.Ten) HoTenTA,
	 SoCMTND CCCD, IsNULL(CONVERT(NVARCHAR,tstd.NgayBatDauLam,103),'') NgayBatDauLam, 
	 IsNULL(CONVERT(NVARCHAR,DATEADD(MONTH,2,tstd.NgayBatDauLam),103),'') NgayKetThucThuViec,
	 NoiCap NoiCapCCCD, ISNULL(CONVERT(NVARCHAR,NgayCap,103),'') NgayCapCCCD,
	 DienThoai, DiaChiLienHe,
     DATEDIFF(YEAR, NgaySinh, GETDATE()) AS Tuoi, ISNULL(NS_TD_ThiSinh.Email,'') Email,  
     ISNULL(NS_TD_ThiSinh.SoNamKinhNghiem,0) SoNamKinhNghiem,  
     SoCMTND, CONVERT(NVARCHAR,NgaySinh,103) NgaySinh, TenTrinhDo,  
     NS_TD_ThiSinh.TrangThai as UV_Status, ISNULL(TT.TenTrangThai,'') TrangThaiUngVien,  
	Dot.TenDotTuyenDung, CV.TenChucVu, cv.TenChucVuTA,  cd.TenChucDanh, cd.TenChucDanhTA
	, pb.Ten TenPhongBan, pb.TenPhongBanTA,
	CASE WHEN NS_TD_ThiSinh.GioiTinh='Nam' then 'Anh' else N'Chị'end DanhXung ,
	ISNULL(tstd.MucLuongMongMuon,0) LuongCoBan,
	dbo.Num2Text(ISNULL(tstd.MucLuongMongMuon, 0)) AS LuongCoBanTV,
	dbo.Num2Text_English(ISNULL(tstd.MucLuongMongMuon, 0)) AS LuongCoBanTA,
	ISNULL(tstd.ADD_PhuCapDocHai,0) PhuCapDocHai,
	dbo.Num2Text(ISNULL(tstd.ADD_PhuCapDocHai, 0)) AS PhuCapDocHaiTV,
	dbo.Num2Text_English(ISNULL(tstd.ADD_PhuCapDocHai, 0)) AS PhuCapDocHaiTA,
	ISNULL(tstd.ADD_ThuongHangThang,0) ThuongHangThang,
	dbo.Num2Text(ISNULL(tstd.ADD_ThuongHangThang, 0)) AS ThuongHangThangTV,
	dbo.Num2Text_English(ISNULL(tstd.ADD_ThuongHangThang, 0)) AS ThuongHangThangTA,
	ISNULL(tstd.MucLuongMongMuon,0) + ISNULL(tstd.ADD_PhuCapDocHai,0) + ISNULL(tstd.ADD_ThuongHangThang,0) TongLuong,
	dbo.Num2Text_English(ISNULL(tstd.MucLuongMongMuon,0) + ISNULL(tstd.ADD_PhuCapDocHai,0) + ISNULL(tstd.ADD_ThuongHangThang,0)) AS TongLuongTA,
	dbo.Num2Text(ISNULL(tstd.MucLuongMongMuon,0) + ISNULL(tstd.ADD_PhuCapDocHai,0) + ISNULL(tstd.ADD_ThuongHangThang,0)) AS TongLuongTV,
	ISNULL(kv.TenKhuVuc,'') TenKhuVuc
    FROM NS_TD_DotTuyenDung Dot   
            left join NS_DsChucVu CV on CV.ChucVuID = Dot.ViTriTuyenDungID  
			LEFT JOIN dbo.PhongBan pb ON pb.PhongBanID = cv.PhongBanID
			LEFT JOIN dbo.NS_DsChucDanh cd ON cd.ChucDanhID = cv.ChucDanhID
			LEFT JOIN dbo.NS_TD_ThiSinh_DotTuyenDung tstd ON tstd.DotTuyenDungID = Dot.DotTuyenDungID  
            inner join NS_TD_ThiSinh on tstd.ThiSinhID = NS_TD_ThiSinh.ThiSinhID   
			LEFT JOIN NS_TD_TrangThai_UngVien TT on TT.TrangThaiUngVienID = NS_TD_ThiSinh.TrangThai  
            left join NS_DsTrinhDo on NS_TD_ThiSinh.TrinhDoID =NS_DsTrinhDo.TrinhDoID 
			LEFT JOIN dbo.NS_DsKhuVuc kv ON kv.KhuVucID = CONVERT(INT,Dot.KhuVucID)
WHERE   
    (@ThiSinhID      IS NULL OR NS_TD_ThiSinh.ThiSinhID      = @ThiSinhID)  
    AND (@DotTuyenDungID IS NULL OR Dot.DotTuyenDungID = @DotTuyenDungID);  
    
        
         
END 
