CREATE PROCEDURE [dbo].[LayThongTinNhanThan]
(@ID INT)
AS
BEGIN

--declare @ID int = 2296
SELECT 
    nv.MaNhanVien,
    nv.Ho +' '+ nv.HoTen AS HoVaTen,
	pb.Ten PhongBan,
	cv.TenChucVu,
    qh.QuanHe,
    qh.HoTen AS HoTenNguoiThan,
	CONVERT(NVARCHAR(50),qh.NgaySinh,103) AS NgaySinhNguoiThan,
    qh.GioiTinh
FROM dbo.NS_QTQuanHeGiaDinh qh
JOIN dbo.NhanVien nv ON qh.NhanVienID = nv.NhanVienID
LEFT JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = nv.ChucVuID
LEFT JOIN dbo.PhongBan pb ON pb.PhongBanID = nv.PhongBanID
WHERE qh.QTQuanHeGiaDinhID = @ID

	
END

