CREATE PROC [dbo].[sp_TuDongTongHopCongTheoNgay]  
  @NgayChamCong DATE, @NgayKetThuc date, @NhanVienID INT  
AS  
  
--DECLARE  @NgayChamCong DATE, @NgayKetThuc date, @NhanVienID int     
--set  @NgayChamCong = '12/23/2022' set  @NgayKetThuc = getdate() set @NhanVienID = 0  
  
DECLARE @TEMP_DULIEU TABLE  
  (STT INT , NhanVienID INT , PhongBanID INT , CaLamViecID INT , NgayChamCong DATETIME , NgayKT_CongThang DATETIME);  
INSERT @TEMP_DULIEU  
SELECT ROW_NUMBER () OVER (ORDER BY  NhanVienID, NgayChamCong ) AS [STT]  
              ,  *  
     , ( SELECT NgayKT_CongThang  
           FROM dbo.fn_LayNgayGioKyCong (ISNULL (( SELECT CongTyID  
                                                     FROM PhongBan X  
                                                    WHERE X.PhongBanID = AZ.PhongBanID)  
                                               , 0)  
                                       , AZ.NgayChamCong) ) NgayKT_CongThang  
  FROM  
       ( 
			 SELECT NhanVienID  
              , ISNULL (( SELECT TOP 1 WITH TIES PhongBanMoiID  
                            FROM NS_QTChuyenCanBo X  
                           WHERE X.NhanVienID = A.NhanVienID AND X.NgayHieuLuc <= B.Ngay  
                           ORDER BY ROW_NUMBER () OVER (PARTITION BY NhanVienID  
                                                            ORDER BY NgayHieuLuc DESC))  
                      , A.PhongBanID) PhongBanID  
              , ISNULL (( SELECT TOP 1 WITH TIES CaLamViecID  
                            FROM NS_TL_DangKyCong X  
                           WHERE X.NhanVienID = A.NhanVienID AND X.NgayChamCong = B.Ngay  
                           ORDER BY ROW_NUMBER () OVER (PARTITION BY NhanVienID  
                                                            ORDER BY NgayChamCong DESC))  
                      , CaLVID) CaLamViecID  
              , Ngay NgayChamCong -- , NgayBatDauLam, NgayNghiViec  , b.Ngay
           FROM  
                ( SELECT NhanVienID  
                       , PhongBanID  
                       , CaLVID  
                       , NgayBatDauLam  
                       , ISNULL (CONVERT (DATE, NgayNghiViec), @NgayKetThuc) NgayNghiViec  
                    FROM NhanVien  
                   WHERE CHARINDEX (  
                          ','+ CONVERT (NVARCHAR(50), NhanVienID)+','  
                         , (CASE  
                              WHEN @NhanVienID = 0 THEN  
                                (SELECT STUFF (  
                                          ( SELECT ',' + CAST(t.NhanVienID AS VARCHAR(MAX))  
                                              FROM  
                                                   ( SELECT NhanVienID  
                                                       FROM NhanVien X  
                                                      WHERE X.NgayBatDauLam <= @NgayChamCong  
                                                        AND  
                                                            (  ISNULL (X.NghiViec, 0) = 0  
                                                            OR CONVERT (DATE, X.NgayNghiViec) > @NgayChamCong)  
                                                        AND ISNULL (X.IsDeleted, 0) = 0) t  
                                            FOR XML PATH (''))  
                                        , 1, 0, ''))+','  
                            ELSE CONCAT(',', CONVERT (NVARCHAR(50), @NhanVienID), ',') END)) > 0) A  
              , ( SELECT Ngay  
                    FROM NS_BH_NgayThang  
                   WHERE Ngay BETWEEN @NgayChamCong AND @NgayKetThuc) B  
       WHERE A.NgayBatDauLam <= B.Ngay AND A.NgayNghiViec >= B.Ngay AND B.Ngay <= GETDATE ()  
     ) AZ  where ISNULL(CaLamViecID, 0) <> 0
ORDER BY STT;  
  
DECLARE @RUN INT = 1;  
DECLARE @CaLamViecID INT = 0;  
DECLARE @PhongBanID INT = 0;  
DECLARE @NgayKT_CongThang DATE;  
DECLARE @NgayHienTai DATE = GETDATE ();  
  
DECLARE @STT INT = (SELECT MAX (STT) FROM @TEMP_DULIEU);  

WHILE (@RUN <= @STT)  
  BEGIN  
    SET @NhanVienID =  
      ( SELECT NhanVienID  
          FROM @TEMP_DULIEU  
         WHERE STT = @RUN);  
    SET @CaLamViecID =  
      ( SELECT CaLamViecID  
          FROM @TEMP_DULIEU  
         WHERE STT = @RUN);  
    SET @PhongBanID =  
      ( SELECT PhongBanID  
          FROM @TEMP_DULIEU  
         WHERE STT = @RUN);  
    SET @NgayChamCong =  
      ( SELECT NgayChamCong  
          FROM @TEMP_DULIEU  
         WHERE STT = @RUN);  
    SET @NgayKT_CongThang =  
      ( SELECT NgayKT_CongThang  
          FROM @TEMP_DULIEU  
         WHERE STT = @RUN);  
    SET @NgayKT_CongThang = CASE WHEN @NgayKT_CongThang > @NgayHienTai THEN @NgayHienTai ELSE @NgayKT_CongThang END;  
  
  
    DELETE NS_TL_CC_TongHopTheoNgay WHERE NhanVienid =@NhanVienID AND NgayChamCong =@NgayChamCong AND ISNULL( IsChinhSua,0) =0       
   -- select  @RUN RUN,  @STT STT;  
    EXEC NS_TL_CC_InsertTongHopCong_TheoNgay @NhanVienID, @NgayChamCong, @PhongBanID, '00:00:00', '00:00:00', '00:00:00', '00:00:00', '', @CaLamViecID, 0, 0, 0, 0, 0, 0, 0, 0, 0, '', '';  
  
    SET @RUN += 1;  
   
    IF 1=1 --and (@NgayChamCong = @NgayKT_CongThang)  
    BEGIN  
      DECLARE @Thang INT = MONTH (@NgayKT_CongThang);  
      DECLARE @Nam INT = YEAR (@NgayKT_CongThang);  
      EXEC NS_TL_CC_InsertTongHopCong_TheoThang @NhanVienID, @Thang, @Nam;  
  
    --select CONCAT(N'Tổng hợp công xong cho nhân viên:', @NhanVienID,' - ', format( @RUN-1,'n0') ,'/',format(@STT,'n0'), N'(ngày)')  
    END;

  END;
GO
