 WHERE NhanVienMucTieuID = @IDD            
        
 DECLARE @BoTieuChi NVARCHAR(50) = (SELECT BoTieuChiStrID FROM dbo.NS_DG_NhanVien_MucTieu WHERE NhanVienMucTieuID = @IDD)        
        
