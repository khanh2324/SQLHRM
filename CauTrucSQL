/****** Object:  StoredProcedure [dbo].[spc_DanhMucNgayLe]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
  
  
CREATE proc [dbo].[spc_DanhMucNgayLe] @Nam int, @MoTa nvarchar(250), @NhomNhanSuID int,  @TuNgay date,  @ToiNgay date, @IsBuLe bit, @ID int as    
    
--declare @CongTyID int, @MoTa nvarchar(250), @LoaiLamThemID int,  @TuNgay date,  @ToiNgay date, @QuocTichID int, @IsBuLe bit, @ID int    
    
    
begin    
   
  if(isnull(@Nam,0)=0)     
  begin    
   select N'Năm không được để trống!'    
  return    
  end    
    
  if(isnull(@MoTa, '')='')     
  begin    
   select N'Tên ngày lễ không được để trống!'    
  return    
  end    
    
    
  if(isnull(@TuNgay, '')='')     
  begin    
   select N'Từ ngày không được để trống!'    
  return    
  end    
    
  if(isnull(@ToiNgay, '')='')     
  begin    
   select N'Đến ngày không được để trống!'    
  return    
  end    
    
    
      
  if(@TuNgay > @ToiNgay)     
  begin    
   select N'Từ ngày không được lớn hơn đến ngày!'    
  return    
  end    
    
      
  if((select count(*) from NS_TL_NgayLe where  (@TuNgay  between TuNgay and ToiNgay or @ToiNgay between TuNgay and ToiNgay or TuNgay  between @TuNgay and @ToiNgay or ToiNgay between @TuNgay and @ToiNgay )     
  and (@ID=0 or (@ID>0 and @ID!=NS_TL_NgayLe.NgayLeID)))>0)          
  begin          
   select N'Trùng thông tin đã tồn tại, vui lòng kiểm tra lại!'          
   return          
  end    
end    
    
    
GO
