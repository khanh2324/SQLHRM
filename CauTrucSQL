    -- Lấy giờ làm việc gốc theo ca
    DECLARE @GioBatDau1 DATETIME, @GioKetThuc1 DATETIME, @GioBatDau2 DATETIME, @GioKetThuc2 DATETIME;

    SELECT TOP 1        @GioBatDau1 = GioBatDau1,        @GioKetThuc1 = GioKetThuc1,        @GioBatDau2 = GioBatDau2,        @GioKetThuc2 = GioKetThuc2    FROM dbo.fnt_LayNgayGioLamViecTheoCa(@NhanVienID, @NgayChamCong, @CaLamViecID);

    -- Lấy các khoảng nghỉ đã gom nhóm
    DECLARE @Nghi TABLE (NgayGio_BD_Nghi DATETIME, NgayGio_KT_Nghi DATETIME);

    INSERT INTO @Nghi
		SELECT *    FROM dbo.fnt_LayNghiVsCongTac_PhanCum(@NhanVienID, @GioBatDau1, @GioKetThuc2);

    DECLARE @MinNghi DATETIME = (SELECT MIN(NG) FROM (
        SELECT NgayGio_BD_Nghi AS NG FROM @Nghi
        UNION ALL
        SELECT NgayGio_KT_Nghi FROM @Nghi) AS T);

    DECLARE @MaxNghi DATETIME = (SELECT MAX(NG) FROM (
        SELECT NgayGio_BD_Nghi AS NG FROM @Nghi
        UNION ALL
        SELECT NgayGio_KT_Nghi FROM @Nghi) AS T);

    DECLARE @NghiCaDau BIT = 0, @NghiCaSau BIT = 0;

    IF NOT (@MaxNghi < @GioBatDau1 OR @MinNghi > @GioKetThuc1)
        SET @NghiCaDau = 1;
    IF NOT (@MaxNghi < @GioBatDau2 OR @MinNghi > @GioKetThuc2)
        SET @NghiCaSau = 1;

    IF EXISTS (SELECT 1 FROM @Nghi)
    BEGIN
        IF (@NghiCaDau = 1 AND @NghiCaSau = 1)
        BEGIN
            IF (@MinNghi <= @GioBatDau1 AND @MaxNghi >= @GioKetThuc2)
            BEGIN
                SET @GioKetThuc1 = @GioBatDau1;
                SET @GioBatDau2 = @GioBatDau1;
                SET @GioKetThuc2 = @GioBatDau1;
            END
            ELSE
            BEGIN
                IF (@MinNghi <= @GioBatDau1)
                BEGIN
                    SET @GioBatDau1 = @MaxNghi;
                    SET @GioKetThuc1 = @MaxNghi;
                    SET @GioBatDau2 = @MaxNghi;
                END
                IF (@MaxNghi >= @GioKetThuc2)
                BEGIN
                    SET @GioKetThuc1 = @MinNghi;
                    SET @GioBatDau2 = @MinNghi;
                    SET @GioKetThuc2 = @MinNghi;
                END
            END
        END
        ELSE IF (@NghiCaDau = 1)
        BEGIN
            IF (@MinNghi <= @GioBatDau1 AND @MaxNghi >= @GioKetThuc1)
            BEGIN
                SET @GioBatDau1 = @GioBatDau2;
                SET @GioKetThuc1 = @GioBatDau2;
            END
            ELSE IF (@MinNghi <= @GioBatDau1)
                SET @GioBatDau1 = @MaxNghi;
            ELSE IF (@MaxNghi >= @GioKetThuc1)
                SET @GioKetThuc1 = @MinNghi;
        END
        ELSE IF (@NghiCaSau = 1)
        BEGIN
            IF (@MaxNghi >= @GioKetThuc2 AND @MinNghi <= @GioBatDau2)
            BEGIN
                SET @GioBatDau2 = @GioKetThuc1;
                SET @GioKetThuc2 = @GioKetThuc1;
            END
            ELSE IF (@MaxNghi >= @GioKetThuc2)
                SET @GioKetThuc2 = @MinNghi;
            ELSE IF (@MinNghi <= @GioBatDau2)
                SET @GioBatDau2 = @MaxNghi;
        END
    END

    INSERT INTO @ResultTable
    SELECT @GioBatDau1, @GioKetThuc1, @GioBatDau2, @GioKetThuc2;

    RETURN;
END
GO
