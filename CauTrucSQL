CREATE PROCEDURE [dbo].[ADD_BangLuong_ADCo_Backdate_SS]           
 @PhongBanID INT, @Thang INT, @Nam INT, @NhanVienID INT, @DangNhapID INT          
          
AS          
          
  --DECLARE @PhongBanID INT = 20,
  --      @Thang INT = 10,
  --      @Nam INT = 2025,
  --      @NhanVienID INT = 0,
  --      @DangNhapID INT = 3115;

DECLARE @ThangLuong DATE     = EOMONTH(CONVERT(CHAR(2), @Thang) + '/1/' + CONVERT(CHAR(4), @Nam));
DECLARE @NgayQuyDoi DATE     = CONVERT(CHAR(2), @Thang) + '/26/' + CONVERT(CHAR(4), @Nam);
DECLARE @DauKy DATE          = DATEADD(MONTH, -1, @NgayQuyDoi);
DECLARE @Date DATE           = CONVERT(CHAR(2), @Thang) + '/25/' + CONVERT(CHAR(4), @Nam);

SELECT
    CONVERT(INT,
        ROW_NUMBER() OVER
        (
            ORDER BY
            (
                CASE
                    WHEN Nhom.Ten = N'Văn phòng'
                        THEN CASE
                                WHEN cappb.Level < 4 THEN pb.ThuTuSapXep
                                ELSE (SELECT TOP 1 ThuTuSapXep FROM dbo.PhongBan WHERE PhongBanID = v.Lever2ID)
                             END
                    ELSE 100 + lld.ThuTu
                END
            )
        )
    ) AS STT,

    nv.MaNhanVien AS MaNV,
    nv.Ho + ' ' + nv.HoTen AS TenNhanVien,
    cv.TenChucVu AS ViTriCongViec,
    bl_text.CapBac AS CapBac,
    UPPER(
        CASE
            WHEN Nhom.Ten = N'Văn phòng'
                THEN CASE
                        WHEN cappb.Level < 4 THEN pb.Ten
                        ELSE v.Lever2Ten
                     END
            ELSE lld.Ten
        END
    ) AS TenPhongBan,
    kv.TenKhuVuc AS DiaDiemLamViec,
    bl_text.NhomCostCenter AS NhomCostCenter,
    bl_text.CostCenter AS CostCenter,
    nv.NgayBatDauLam AS NgayVaoLam,
    nv.NgayNghiViec AS NgayNghiViec,

    -- ======================
    --  CHÊNH LỆCH LƯƠNG (BD - CHÍNH)
    -- ======================

    -- Công & lương cơ bản + phụ cấp
    ISNULL(bl_bd.[CC_TongCong], 0) - ISNULL(bl.[CC_TongCong], 0) AS NgayCongThucTe,
    ISNULL(bl_bd.[TLNC_LCB], 0) - ISNULL(bl.[TLNC_LCB], 0) AS LuongCoBan,
    ISNULL(bl_bd.[TLNC_PC_TrachNhiem], 0) - ISNULL(bl.[TLNC_PC_TrachNhiem], 0) AS PCTrachNhiem,
    ISNULL(bl_bd.[TLNC_PC_ViTri], 0) - ISNULL(bl.[TLNC_PC_ViTri], 0) AS PCViTri,
    ISNULL(bl_bd.[TLNC_PC_DiLai], 0) - ISNULL(bl.[TLNC_PC_DiLai], 0) AS PCDiLai,
    ISNULL(bl_bd.[TLNC_PC_DocHai], 0) - ISNULL(bl.[TLNC_PC_DocHai], 0) AS PCDocHai,
    ISNULL(bl_bd.[TLNC_PC_Khac], 0) - ISNULL(bl.[TLNC_PC_Khac], 0) AS PCKhac,
    ISNULL(bl_bd.[TLNC_PC_BuaAn], 0) - ISNULL(bl.[TLNC_PC_BuaAn], 0) AS PCTienAn,
    ISNULL(bl_bd.[TLNC_ThuongThang], 0) - ISNULL(bl.[TLNC_ThuongThang], 0) AS ThuongThang,
    ISNULL(bl_bd.[TLNC_TongLuong_Thuong_PhuCap], 0) - ISNULL(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) AS TongLuongVaPhuCap,

    -- OT, ca đêm
    ISNULL(bl_bd.[TLOT_ChieuThue], 0) - ISNULL(bl.[TLOT_ChieuThue], 0) AS OTChiuThue,
    ISNULL(bl_bd.[TLOT_MienThue], 0) - ISNULL(bl.[TLOT_MienThue], 0) AS OTKhongChiuThue,
    ISNULL(bl_bd.[TLOT_LamCaDem], 0) - ISNULL(bl.[TLOT_LamCaDem], 0) AS TienCaDem,
    ISNULL(bl_bd.[TLOT_TongLuongOT_LamCaDem], 0) - ISNULL(bl.[TLOT_TongLuongOT_LamCaDem], 0) AS TongOTVaCaDem,

    -- Thưởng
    ISNULL(bl_bd.[Thuong_KM], 0) - ISNULL(bl.[Thuong_KM], 0) AS ThuongKM,
    ISNULL(bl_bd.[Thuong_KPI], 0) - ISNULL(bl.[Thuong_KPI], 0) AS ThuongKPI,
    ISNULL(bl_bd.[Thuong_LuongT13], 0) - ISNULL(bl.[Thuong_LuongT13], 0) AS LuongThang13,
    ISNULL(bl_bd.[Thuong_Nam], 0) - ISNULL(bl.[Thuong_Nam], 0) AS ThuongNam,
    ISNULL(bl_bd.[Thuong_ChenhLechT1], 0) - ISNULL(bl.[Thuong_ChenhLechT1], 0) AS ChenhLechThang1,
    ISNULL(bl_bd.[Thuong_CongTruocThue], 0) - ISNULL(bl.[Thuong_CongTruocThue], 0) AS CongTruocThue,
    ISNULL(bl_bd.[Thuong_TruTruocThue], 0) - ISNULL(bl.[Thuong_TruTruocThue], 0) AS TruTruocThue,
    ISNULL(bl_bd.[Thuong_TongThuong], 0) - ISNULL(bl.[Thuong_TongThuong], 0) AS TongThuongVaKhoanTruocThue,
    ISNULL(bl_bd.[TongThuNhap], 0) - ISNULL(bl.[TongThuNhap], 0) AS TongThuNhap,

    -- Bảo hiểm
    ISNULL(bl_bd.[BH_LuongBHXH], 0) - ISNULL(bl.[BH_LuongBHXH], 0) AS MucLuongBHXH,
    ISNULL(bl_bd.[BH_LuongBHTN], 0) - ISNULL(bl.[BH_LuongBHTN], 0) AS MucLuongBHTN,
    ISNULL(bl_bd.[BH_Tong_NLD], 0) - ISNULL(bl.[BH_Tong_NLD], 0) AS BHNhanVien,
    ISNULL(bl_bd.[BH_Tong_CTY], 0) - ISNULL(bl.[BH_Tong_CTY], 0) AS BHCongTy,
    ISNULL(bl_bd.[BH_Tong], 0) - ISNULL(bl.[BH_Tong], 0) AS TongBHXH,

    -- Thuế
    ISNULL(bl_bd.[Tax_ThuNhapChiuThue], 0) - ISNULL(bl.[Tax_ThuNhapChiuThue], 0) AS ThuNhapChiuThue,
    ISNULL(bl_bd.[Tax_GiamTru_BanThan], 0) - ISNULL(bl.[Tax_GiamTru_BanThan], 0) AS GiamTruBanThan,
    ISNULL(bl_bd.[Tax_GiamTru_NguoiPhuThuoc], 0) - ISNULL(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) AS GiamTruNguoiPhuThuoc,
    ISNULL(bl_bd.[Tax_SoNguoiPhuThuoc], 0) - ISNULL(bl.[Tax_SoNguoiPhuThuoc], 0) AS SoNguoiPhuThuoc,
    ISNULL(bl_bd.[Tax_ThuNhapTinhThue], 0) - ISNULL(bl.[Tax_ThuNhapTinhThue], 0) AS ThuNhapTinhThue,
    ISNULL(bl_bd.[Tax_TongThue], 0) - ISNULL(bl.[Tax_TongThue], 0) AS ThueTNCN,
    ISNULL(bl_bd.[Tax_ThuNhapSauThue], 0) - ISNULL(bl.[Tax_ThuNhapSauThue], 0) AS ThuNhapSauThue,

    -- Công đoàn, sau thuế
    ISNULL(bl_bd.[PSSThue_CongDoan_NLD], 0) - ISNULL(bl.[PSSThue_CongDoan_NLD], 0) AS CongDoanPhiNV,
    ISNULL(bl_bd.[PSSThue_CongDoan_CTY], 0) - ISNULL(bl.[PSSThue_CongDoan_CTY], 0) AS KinhPhiCongDoanCTY,
    ISNULL(bl_bd.[PSSThue_TruSauTax], 0) - ISNULL(bl.[PSSThue_TruSauTax], 0) AS TruSauThue,
    ISNULL(bl_bd.[PSSThue_CongSauTax], 0) - ISNULL(bl.[PSSThue_CongSauTax], 0) AS CongSauThue,

    -- Thực lĩnh & chi phí
    ISNULL(bl_bd.[ThucLinh], 0) - ISNULL(bl.[ThucLinh], 0) AS ThucLinh,
    ISNULL(bl_bd.[ChiPhiCongTy], 0) - ISNULL(bl.[ChiPhiCongTy], 0) AS ChiPhiCongTy

FROM NhanVien nv
    CROSS APPLY dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1
    LEFT JOIN dbo.PhongBan pb ON pb.PhongBanID = pb1.PhongBanID
    CROSS APPLY dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1
    LEFT JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = cv1.ChucVuID
    CROSS APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv
    LEFT JOIN dbo.NS_DsKhuVuc kv ON kv.KhuVucID = ddlv.KhuVucId
    LEFT JOIN dbo.v_SoDoToChucPhongBan v ON pb.PhongBanID = v.PhongBanID
    LEFT JOIN dbo.NS_DsCapPhongBan cappb ON pb.CapPhongBanID = cappb.CapPhongBanID
    LEFT JOIN NS_DsCapBac cb ON nv.CapBacID = cb.CapBacID
    LEFT JOIN ADD_CostCenter Nhom ON nv.CostCenterId = Nhom.CostCenterId
    LEFT JOIN dbo.ADD_CostCentral cost ON nv.CostCentral = cost.CostCentralId
    LEFT JOIN dbo.NS_DsLoaiLaoDong lld ON nv.LoaiLaoDongID = lld.LoaiLaoDongID

    -- ======================
    --  PIVOT LƯƠNG BD (NS_TLBD_*)
    -- ======================
    RIGHT JOIN
    (
        SELECT *
        FROM
        (
            SELECT bl.NhanVienID,
                   bl.Thang,
                   bl.Nam,
                   ll.MaSo,
                   ctl.TienLuong
            FROM NS_TLBD_BangLuong bl
                LEFT JOIN NS_TLBD_ChiTietLuong ctl ON bl.BangLuongID = ctl.BangLuongID
                LEFT JOIN NS_TL_LoaiLuong ll ON ctl.LoaiLuongID = ll.LoaiLuongID
            WHERE bl.Thang = @Thang
              AND bl.Nam = @Nam
              AND (bl.NhanVienID = @NhanVienID OR @NhanVienID IN (-1001, 0))
        ) AS A
        PIVOT
        (
            SUM(TienLuong) FOR MaSo IN
            (
                [CC_TongCong], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri],
                [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn],
                [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap],
                [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem],
                [TLOT_TongLuongOT_LamCaDem],
                [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam],
                [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue],
                [Thuong_TongThuong], [TongThuNhap],
                [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],
                [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc],
                [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue], [Tax_TongThue],
                [Tax_ThuNhapSauThue],
                [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax],
                [PSSThue_CongSauTax],
                [ThucLinh], [ChiPhiCongTy]
            )
        ) AS B
    ) bl_bd
        ON nv.NhanVienID = bl_bd.NhanVienID

    -- ======================
    --  PIVOT LƯƠNG CHÍNH (NS_TL_*)
    -- ======================
    LEFT JOIN
    (
        SELECT *
        FROM
        (
            SELECT bl.NhanVienID,
                   bl.Thang,
                   bl.Nam,
                   ll.MaSo,
                   ctl.TienLuong
            FROM NS_TL_BangLuong bl
                LEFT JOIN NS_TL_ChiTietLuong ctl ON bl.BangLuongID = ctl.BangLuongID
                LEFT JOIN NS_TL_LoaiLuong ll ON ctl.LoaiLuongID = ll.LoaiLuongID
            WHERE bl.Thang = @Thang
              AND bl.Nam = @Nam
              AND (bl.NhanVienID = @NhanVienID OR @NhanVienID IN (-1001, 0))
        ) AS A
        PIVOT
        (
            SUM(TienLuong) FOR MaSo IN
            (
                [CC_TongCong], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri],
                [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn],
                [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap],
                [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem],
                [TLOT_TongLuongOT_LamCaDem],
                [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam],
                [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue],
                [Thuong_TongThuong], [TongThuNhap],
                [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],
                [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc],
                [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue], [Tax_TongThue],
                [Tax_ThuNhapSauThue],
                [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax],
                [PSSThue_CongSauTax],
                [ThucLinh], [ChiPhiCongTy]
            )
        ) AS B
    ) bl
        ON nv.NhanVienID = bl.NhanVienID

    -- ======================
    --  PIVOT TEXT (CapBac, CostCenter...) từ BD
    -- ======================
    LEFT JOIN
    (
        SELECT *
        FROM
        (
            SELECT bl.NhanVienID,
                   bl.Thang,
                   bl.Nam,
                   ll.MaSo,
                   ctl.TienLuongStr
            FROM NS_TLBD_BangLuong bl
                LEFT JOIN NS_TLBD_ChiTietLuong ctl ON bl.BangLuongID = ctl.BangLuongID
                LEFT JOIN NS_TL_LoaiLuong ll ON ctl.LoaiLuongID = ll.LoaiLuongID
            WHERE bl.Thang = @Thang
              AND bl.Nam = @Nam
              AND (bl.NhanVienID = @NhanVienID OR @NhanVienID IN (-1001, 0))
        ) AS A
        PIVOT
        (
            MAX(TienLuongStr) FOR MaSo IN
            (
                [CapBac], [NhomCostCenter], [CostCenter]
            )
        ) AS B
    ) bl_text
        ON nv.NhanVienID = bl_text.NhanVienID

WHERE pb.PhongBanID IN (SELECT valu FROM GetPhongBanChild_WUser(@PhongBanID, @DangNhapID))
  AND nv.MaNhanVien <> '80090'
  AND nv.NhanVienID NOT IN (40452, 40462, 40461)
  AND nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
ORDER BY STT;
GO
/****** Object:  StoredProcedure [dbo].[ADD_BangLuong_ADCo_MrTam]    Script Date: 03/04/2026 16:11:44 ******/
SET ANSI_NULLS ON
GO
