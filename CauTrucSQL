create FUNCTION [dbo].[fnt_LayNgayGioKyCong](@CongTyID  int, @NgayChamCong DATE)        
RETURNS @ReturnTable TABLE (NgayBD_CongThang datetime, NgayKT_CongThang datetime)        AS        

begin        

	--declare @CongTyID  int = 0, @NgayChamCong DATE = getdate()

  declare  @NBDCC int =Isnull((select try_cast( GiaTri as int) from  SYS_ThongSo where MaSo ='NBDCC' ),0)
  declare @NKTCC int =Isnull((select try_cast( GiaTri as int) from  SYS_ThongSo where MaSo ='NKTCC' ),0) 

  --declare  @NBDCC int =(  select Isnull((select try_cast( GiaTri as int) from SYS_ThongSo_GiaTri where ThongSoID = (select ThongSoID from  SYS_ThongSo where MaSo ='NBDCC' ) and CongTyID =@CongTyID),0))     
  --declare @NKTCC int = (  select Isnull((select try_cast( GiaTri as int) from SYS_ThongSo_GiaTri where ThongSoID = (select ThongSoID from  SYS_ThongSo where MaSo ='NKTCC' ) and CongTyID =@CongTyID),0))
        
		declare @NgayBD_CongThang DATETIME ,   @NgayKT_CongThang DATETIME       
		declare @NCC date = @NgayChamCong      

		IF(@NBDCC IN(0,1))      
		begin      
			set @NgayBD_CongThang=concat(month(@NgayChamCong),'/01/',year(@NgayChamCong), ' 00:00:00')      
			set @NgayKT_CongThang=concat(EOmonth(@NgayChamCong), ' 23:59:59')      
		end      
		ELSE IF(DAY(@NCC) >= @NBDCC)      
		begin       
			set @NgayBD_CongThang=concat(month(@NCC),'/',@NBDCC,'/',year(@NCC), ' 00:00:00')      
			set @NCC = dateadd(month, 1, @NCC)      
			set @NgayKT_CongThang=concat(month(@NCC),'/',@NKTCC,'/',year(@NCC), ' 23:59:59')      
		end      
		ELSE      
		begin        
			set @NgayKT_CongThang=concat(month(@NCC),'/',@NKTCC,'/',year(@NCC), ' 23:59:59')      
			set @NCC = dateadd(month, -1, @NCC)      
			set @NgayBD_CongThang=concat(month(@NCC),'/',@NBDCC,'/',year(@NCC), ' 00:00:00')      
		end      
      
      
      
	 INSERT @ReturnTable  (NgayBD_CongThang, NgayKT_CongThang)        
	 select @NgayBD_CongThang NgayBD_CongThang, @NgayKT_CongThang NgayKT_CongThang      
	 RETURN          
end        
        
      
