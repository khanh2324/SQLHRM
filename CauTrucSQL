WITH EXECUTE AS CALLER
AS
 begin
 declare @tbl table (nhanvienid int)
insert into @tbl
select nhanvienid from nhanvien where convert(date,ngaybatdaulam)<=@date
declare @nhanvienid int
declare @phongbanid int,@chucvuid int,@nghiviec bit,@chucdanhid int
