create FUNCTION [dbo].[HS_TinhSoNgayDuocNghiTheoThamNien]
(
@NhanVienID int,
@ngay date
)
RETURNS decimal(10,2)
AS
BEGIN

declare @SoNgay int
declare @NgayBatDauThuViec date
set @NgayBatDauThuViec=(select ngaybatdaulam from nhanvien where nhanvienid=@NhanVienID)
declare @NgayChinhThuc date
set  @NgayChinhThuc=(select ngaytinhluongcoban from nhanvien where nhanvienid=@NhanVienID)

	if(len(@NgayBatDauThuViec)>0)
		begin
			if dateadd(year,5*1,@NgayBatDauThuViec)<=@ngay  AND dateadd(year,5*2,@NgayBatDauThuViec)>@ngay
				begin
					set @SoNgay=1
				end
			else if dateadd(year,5*2,@NgayBatDauThuViec)<=@ngay  AND dateadd(year,5*3,@NgayBatDauThuViec)>@ngay
				begin
					set @SoNgay=2
				end
			else if dateadd(year,5*3,@NgayBatDauThuViec)<=@ngay  AND dateadd(year,5*4,@NgayBatDauThuViec)>@ngay
				begin
					set @SoNgay=3
				end
			else if dateadd(year,5*4,@NgayBatDauThuViec)<=@ngay  AND dateadd(year,5*5,@NgayBatDauThuViec)>@ngay
				begin
					set @SoNgay=4
				end
			else if dateadd(year,5*5,@NgayBatDauThuViec)<=@ngay  AND dateadd(year,5*6,@NgayBatDauThuViec)>@ngay
				begin
					set @SoNgay=5
				end
			else
				begin
					set @SoNgay=0
				end
		end

RETURN @SoNgay
END


