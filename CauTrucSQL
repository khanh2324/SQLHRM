CREATE proc [dbo].[EMAIL_NS_TD_HIRED]  
@DotTuyenDUngID int,  
@StrThiSinhID nvarchar(1000),  
@ThiSinhID int  
AS  
begin  
 Select  
 TS.TenHo + ' '+ TS.Ten as HoVaTen, 
dbo.fuChuyenCoDauThanhKhongDau(TS.TenHo + ' '+ TS.Ten) as HoVaTenTA, 
 CONVERT(nvarchar,TS.NgaySinh,103) NgaySinh,   
  TS.GioiTinh, 
  CASE when TS.GioiTinh like N'%Nam%' then N'Ông' else N'Bà' end as OngBa, 
  CASE when TS.GioiTinh like N'%Nam%' then N'Mr' else N'Ms' end as OngBaTA, 
  CASE when TS.GioiTinh like N'%Nam%' then N'Anh' else N'Chị' end as AnhChi,  
  CV.TenChucVu as ViTriTuyenDung,  
  CV.TenChucVuTA as ViTriTuyenDungTA,  
  PB.Ten as PhongBan, CB.TenBac CapBac,   
  convert(nvarchar,TSTD.NgayBatDauLam,103) NgayBatDauLam, convert(nvarchar,TSTD.ThoiGianThuViec,103) BatDauThuViec , convert(nvarchar,TSTD.NgayHetThuViec,103) KetThucThuViec,  
  QLTT.Ten as QuanLyTrucTiep, TSTD.NoiLamViec,  
  DOT.MoTaCongViec,  
  --NHD.Ho + ' '+ NHD.Hoten as NguoiHuongDan,  
  Convert(nvarchar, TSTD.NgaySanSangDiLam ,103) as NgaySanSangDiLam,  
  TSTD.ThoiGianThuViec,  
  KV.TenKhuVuc as NoiLamViec,  
  Format(TSTD.LuongCoBan, '#,#') as LuongCoBan ,  
  
  Day(Getdate()) as Ngay,  
  Month(Getdate()) as Thang,  
  Cast(Year (Getdate()) as nvarchar(4)) as Nam,  
  TS.Email  
  
  
from NS_TD_ThiSinh_DotTuyenDung  TSTD   
 left join NS_TD_DotTuyenDung DOT on TSTD.DotTuyenDungID=DOT.DotTuyenDungID  
 left join NS_TD_ThiSinh TS on TSTD.ThiSinhID=TS.ThiSinhID  
 left join NS_DsChucVu CV on TSTD.ChucVuID=CV.ChucVuID  
 left join NS_DsCapBac CB on CB.CapBacID=CV.CapBacID  
 LEFT join NS_DsKhuVuc KV on TSTD.KhuVucID=KV.KhuVucID  
 left join PhongBan PB on TSTD.PhongBanID=PB.PhongBanID  
 left join (select MaNhanVien, Ho+' '+HoTen Ten, NguoiDungID from NhanVien inner join SYS_NguoiDung on NhanVien.NhanVienID=SYS_NguoiDung.NguoiDungID) QLTT on QLTT.NguoiDungID=TSTD.QuanLyTrucTiepID  
 --left join NhanVien NHD on NS_TD_ThiSinh_DotTuyenDung.NguoihuongDanID = NHD.NhanVienID  
where 
--TSTD.TrangThai in (3)  and 
TSTD.ThiSinhID in (select a from GHR_HamCatChuoi(@StrThiSinhID, ','))  and 
TSTD.DotTuyenDungID = @DotTuyenDungID  
  
end  
  
