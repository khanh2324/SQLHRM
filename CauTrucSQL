CREATE FUNCTION [dbo].[fns_TinhThoiGianLamDem]    (    @NgayGio_Vao DATETIME,      @NgayGio_Ra DATETIME,     @Gio_BatDauCaDem NVARCHAR(10),     @Gio_KetThucCaDem NVARCHAR(10))  RETURNS INT      
AS      
BEGIN      
    DECLARE @ResultVar INT      
       
--declare @NgayGio_Vao datetime =  '04/01/2024 01:00' , @NgayGio_Ra datetime  = '04/03/2024 05:30'      
--declare  @Gio_BatDauCaDem nvarchar(10) ='22:00:00' , @Gio_KetThucCaDem  nvarchar(10) ='06:00:00'         
      
  declare @bdcd_C1 time ='00:00',  @ktcd_C1 time ='00:00', @bdcd_C2 time ='00:00', @ktcd_C2 time ='00:00'      
      
  if(@Gio_BatDauCaDem > @Gio_KetThucCaDem)      
  begin      
    set @bdcd_C1 = @Gio_BatDauCaDem      
    set @ktcd_C2 = @Gio_KetThucCaDem      
  end      
  else      
  begin      
    set @bdcd_C1 = @Gio_BatDauCaDem      
    set @ktcd_C1 = @Gio_KetThucCaDem      
  end      
      
  declare  @NightShifts TABLE (start_time datetime, end_time datetime,  CaDem2 int, CaDem1 int, Ngay date)      
  insert into @NightShifts(start_time, end_time ,  CaDem2, CaDem1 , Ngay)      
  SELECT start_time, end_time,      
 -- Thời gian làm đêm từ 0h đến 6h       
        CASE       
            WHEN start_time  <    (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@ktcd_C2, 8)))       
            THEN DATEDIFF(minute,       
                          CASE WHEN start_time > (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@bdcd_C2, 8)))   THEN start_time ELSE (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@bdcd_C2, 8)))  END,      
                          CASE WHEN end_time < (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@ktcd_C2, 8)))  THEN end_time ELSE (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@ktcd_C2, 8)))   END)      
            ELSE 0      
        END AS CaDem2,      
        
        -- Thời gian làm đêm từ 22h đến 24h      
        CASE       
            WHEN       
     end_time >  (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@bdcd_C1, 8)))      
            THEN DATEDIFF(minute,       
                          CASE WHEN start_time > (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@bdcd_C1, 8))) THEN start_time ELSE (DATEADD (DAY, DATEDIFF (DAY, 0, Ngay), LEFT(@bdcd_C1, 8))) END,      
                          CASE WHEN end_time <  (DATEADD (DAY, DATEDIFF (DAY, CASE WHEN @Gio_BatDauCaDem > @Gio_KetThucCaDem THEN -1 ELSE 0 END, Ngay), LEFT(@ktcd_C1, 8))) THEN end_time       
        ELSE  (DATEADD (DAY, DATEDIFF (DAY, CASE WHEN @Gio_BatDauCaDem > @Gio_KetThucCaDem THEN -1 ELSE 0 END, Ngay), LEFT(@ktcd_C1, 8)))  END)      
            ELSE 0      
        END AS CaDem1, Ngay      
      
    FROM       
  (select  case when @NgayGio_Vao > Ngay then @NgayGio_Vao else Ngay end start_time      
  , case when @NgayGio_Ra <  DATEADD(MILLISECOND, 86400000-2,Ngay ) then @NgayGio_Ra else DATEADD(Day, 1, Ngay) end end_time, Ngay      
  from  NS_BH_NgayThang where Ngay between CONVERT(date, @NgayGio_Vao ) and  CONVERT(date, @NgayGio_Ra )) as work_logs      
      
	 
          
    SET @ResultVar = (SELECT    sum (CaDem2 + CaDem1)  AS total_night_hours FROM @NightShifts);      

	--IF @ResultVar < 0 
	--BEGIN
	--    SET @ResultVar = 0
	--END

    RETURN ISNULL(@ResultVar, 0);      
END 
GO
