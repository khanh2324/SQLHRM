sum(isnull(Bangluong.Tax_SoNguoiPhuThuoc, 0)) - sum(isnull(Bangluong.Tax_SoNguoiPhuThuoc_TT, 0)) AS Tax_SoNguoiPhuThuoc,
sum(isnull(Bangluong.Tax_GiamTru_NguoiPhuThuoc, 0)) - sum(isnull(Bangluong.Tax_GiamTru_NguoiPhuThuoc_TT, 0)) AS Tax_GiamTru_NguoiPhuThuoc,
