create  FUNCTION [dbo].[fnt_GetPhongBanNhanVienTaiThoiDiem](@NhanVienID int, @NgayKiemTra DATE)   RETURNS TABLE  AS      
    
RETURN      
(      
    WITH DL AS (      
        SELECT      
            NhanVienID, CASE WHEN NgayHieuLuc <= @NgayKiemTra THEN PhongBanMoiID ELSE PhongBanCuID END AS PhongBanID,      
            ROW_NUMBER() OVER (      
                PARTITION BY NhanVienID      
                ORDER BY       
                    CASE WHEN NgayHieuLuc <= @NgayKiemTra THEN 0 ELSE 1 END,      
                    ABS(DATEDIFF(DAY, NgayHieuLuc, @NgayKiemTra))      
            ) AS rn      
        FROM NS_QTChuyenCanBo      
        WHERE XetDuyet = 1  and NhanVienID= @NhanVienID    
    )      
    SELECT       
        nv.NhanVienID,      
        ISNULL(dl.PhongBanID, nv.PhongBanID) AS PhongBanID      
    FROM NhanVien nv      
    LEFT JOIN DL ON nv.NhanVienID = DL.NhanVienID AND DL.rn = 1      
    WHERE ISNULL(nv.IsDeleted, 0) = 0  and nv.NhanVienID= @NhanVienID    
);   
  
