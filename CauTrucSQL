CREATE PROCEDURE [dbo].[RECRUIT_REQUEST_GETNOTIFY]  
		@ChucVuID int,
		@NgayThang datetime,
		@LyDoTuyen nvarchar(500),
		@ThayTheNhanVien nvarchar(300),
		@GhiChu nvarchar(3000),
		@NguoiDungID int,
		@PhongBanID int,
		@SoLuong decimal(10,2)
AS
BEGIN
		if(len(@LyDoTuyen)<=6)
		begin
			select N'Vui lòng nhập lý do đề xuất!',convert(bit,0)
		end
		else	
		begin

			if(@SoLuong<=0)
				begin
					select N'Vui lòng nhập số lượng yêu cầu!',convert(bit,0)
				end
				else		
				begin

					if(len(@ThayTheNhanVien)<2 and @LyDoTuyen=N'Thay thế cán bộ nghỉ việc')
						begin
							select N'Đề xuất không hợp lệ, vui lòng nhập tên nhân sự nghỉ việc vào ô “Tuyển dụng thay thế”!',convert(bit,0)
						end
					else
					begin
						if(len(@ThayTheNhanVien)<2 and @LyDoTuyen=N'Thay thế cán bộ điều chuyển nội bộ' )
							begin
								select N'Đề xuất không hợp lệ, vui lòng nhập tên nhân sự điều chuyển vào ô “Tuyển dụng thay thế”!',convert(bit,0)
							end

						else
							begin
								select N'Đề xuất tuyển dụng thành công!',convert(bit,1)
							end
					end
				end
		end
END
