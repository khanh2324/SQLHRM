			,[Muc4],[SoLuongChiTieu],[DanChungKetQuaTHCV],[IsHighLevel],[GiaTriNhoNhat],
			(select max(GhiChu) from NS_DG_DanhGia_KetQua where NS_DG_DanhGia_KetQua.TieuChiID=NS_DG_NhanVien_MucTieu.TieuChiID
			and NS_DG_DanhGia_KetQua.DanhGiaID=(select min(DanhGiaID) from NS_DG_DanhGia where DotDanhGiaID=@DotDanhGiaCuID and QuyTrinhBuocThucHienID=0)),
			(select max(GhiChu) from NS_DG_DanhGia_KetQua where NS_DG_DanhGia_KetQua.TieuChiID=NS_DG_NhanVien_MucTieu.TieuChiID
			and NS_DG_DanhGia_KetQua.DanhGiaID=@DanhGiaID)
			from NS_DG_NhanVien_MucTieu
			where DotDanhGiaID=@DotDanhGiaCuID

		end
			

	--insert into ADD_DQ_DiemKPI(NhanVienID,Thang,Nam,DiemKPI,NhomDanhGiaID)
