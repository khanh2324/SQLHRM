CREATE FUNCTION [dbo].[fnt_LayNghiVsCongTac_PhanCum](    @NhanVienID INT,    @GioBD DATETIME,    @GioKT DATETIME)
RETURNS @ReturnTable TABLE (    NgayGio_BD_Nghi DATETIME,    NgayGio_KT_Nghi DATETIME) AS
BEGIN
    DECLARE @Temp TABLE (NgayGio_BD_Nghi DATETIME, NgayGio_KT_Nghi DATETIME);

    INSERT INTO @Temp
    SELECT
        CASE WHEN @GioBD > NgayBatDau THEN @GioBD ELSE DATETIMEFROMPARTS(YEAR(NgayBatDau), MONTH(NgayBatDau), DAY(NgayBatDau), DATEPART(HOUR, NgayBatDau), DATEPART(MINUTE, NgayBatDau), 0, 0) END,
        CASE WHEN @GioKT < NgayKetThuc THEN @GioKT ELSE DATETIMEFROMPARTS(YEAR(NgayKetThuc), MONTH(NgayKetThuc), DAY(NgayKetThuc), DATEPART(HOUR, NgayKetThuc), DATEPART(MINUTE, NgayKetThuc), 0, 0) END
    FROM NS_QTNghiPhep
    WHERE NhanVienID = @NhanVienID AND XetDuyet = 1
        AND NOT (NgayKetThuc < @GioBD OR NgayBatDau > @GioKT)

    UNION ALL

    SELECT
        CASE WHEN @GioBD > NgayBatDau THEN @GioBD ELSE DATETIMEFROMPARTS(YEAR(NgayBatDau), MONTH(NgayBatDau), DAY(NgayBatDau), DATEPART(HOUR, NgayBatDau), DATEPART(MINUTE, NgayBatDau), 0, 0) END,
        CASE WHEN @GioKT < NgayKetThuc THEN @GioKT ELSE DATETIMEFROMPARTS(YEAR(NgayKetThuc), MONTH(NgayKetThuc), DAY(NgayKetThuc), DATEPART(HOUR, NgayKetThuc), DATEPART(MINUTE, NgayKetThuc), 0, 0) END
    FROM NS_QTCongTac
    WHERE NhanVienID = @NhanVienID AND XetDuyet = 1
        AND NOT (NgayKetThuc < @GioBD OR NgayBatDau > @GioKT);

    ;WITH CTE AS (
        SELECT *,
            ROW_NUMBER() OVER (ORDER BY NgayGio_BD_Nghi) AS RowNum,
            CASE 
                WHEN LAG(NgayGio_KT_Nghi) OVER (ORDER BY NgayGio_BD_Nghi) IS NULL THEN 1
                WHEN DATEDIFF(MINUTE, LAG(NgayGio_KT_Nghi) OVER (ORDER BY NgayGio_BD_Nghi), NgayGio_BD_Nghi) <= 0 THEN 0
                ELSE 1
            END AS IsNewGroup
        FROM @Temp
    ),
    Grouped AS (
        SELECT *, SUM(IsNewGroup) OVER (ORDER BY RowNum ROWS UNBOUNDED PRECEDING) AS GroupID
        FROM CTE
    )
    INSERT INTO @ReturnTable (NgayGio_BD_Nghi, NgayGio_KT_Nghi)
    SELECT MIN(NgayGio_BD_Nghi), MAX(NgayGio_KT_Nghi)
    FROM Grouped
    GROUP BY GroupID
    ORDER BY MIN(NgayGio_BD_Nghi);

    RETURN;
END;
GO
