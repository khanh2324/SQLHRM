  --, isnull(bl.[TLOT_ChieuThue], 0) as OTChiuThue, isnull(bl.[TLOT_MienThue], 0) as OTKhongChiuThue, isnull(bl.[TLOT_LamCaDem], 0) as TienCaDem  
  --, isnull(bl.[TLOT_TongLuongOT_LamCaDem], 0) as TongOTVaCaDem, isnull(bl.[Thuong_KM], 0) as ThuongKM, isnull(bl.[Thuong_KPI], 0) as ThuongKPI  
  --, isnull(bl.[Thuong_LuongT13], 0) as LuongThang13, isnull(bl.[Thuong_Nam], 0) as ThuongNam, isnull(bl.[Thuong_ChenhLechT1], 0) as ChenhLechThang1  
  --, isnull(bl.[Thuong_CongTruocThue], 0) as CongTruocThue, isnull(bl.[Thuong_TruTruocThue], 0) as TruTruocThue  
  --, isnull(bl.[Thuong_TongThuong], 0) as TongThuongVaKhoanTruocThue, isnull(bl.[TongThuNhap], 0) as TongThuNhap  
  
  --, isnull(bl.[BH_LuongBHXH], 0) as MucLuongBHXH, isnull(bl.[BH_LuongBHTN], 0) as MucLuongBHTN  
  --, isnull(bl.[BH_Tong_CTY], 0) as BHCongTy, isnull(bl.[BH_Tong], 0) as TongBHXH    
     
  --, isnull(bl.[Tax_TongThue], 0) as ThueTNCN, isnull(bl.[Tax_ThuNhapSauThue], 0) as ThuNhapSauThue  
  --, isnull(bl.[PSSThue_CongDoan_NLD], 0) as CongDoanPhiNV, isnull(bl.[PSSThue_CongDoan_CTY], 0) as KinhPhiCongDoanCTY, isnull(bl.[PSSThue_TruSauTax], 0) as TruSauThue  
  --, isnull(bl.[PSSThue_CongSauTax], 0) as CongSauThue, isnull(bl.[ThucLinh], 0) as ThucLinh, isnull(bl.[ChiPhiCongTy], 0) as ChiPhiCongTy  
  
 from NhanVien nv   
   cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1        
   left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID  
   left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID    
   cross apply dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1    
   left join dbo.NS_DsChucVu cv on cv.ChucVuID = cv1.ChucVuID  
 left join NS_DsCapBac cb on nv.CapBacID = cb.CapBacID  
 left join ADD_CostCenter CostCenter on nv.CostCenterId = CostCenter.CostCenterId  
    cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv    
    left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId  
   left join ADD_CostCenter Nhom on nv.CostCenterId = Nhom.CostCenterId    
   left join dbo.NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID       
   left join dbo.NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID  
 right join  
 (select * from (  
  select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong  
  
  from NS_TL_BangLuong bl   
  left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID  
