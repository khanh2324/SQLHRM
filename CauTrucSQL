CREATE FUNCTION [dbo].[fnt_LayThongTinTinhPhepNam] (@NhanVienID INT, @ToDate DATE)   
	RETURNS @ResulTable TABLE (NhanVienID INT,SoPhepChuyenTuNamTruoc DECIMAL(10,3),SoPhepTonDaSuDung  DECIMAL(10,3),SoPhepTheoQuyDinh DECIMAL(10,3), SoPhepDaNghi DECIMAL(10,3), SoPhepConLai DECIMAL(10,3),ThamNien DECIMAL(10,3),
	NghiBuTonNamTruoc DECIMAL(10,3),NghiBuDuocHuongNamMoi DECIMAL(10,3),NghiBuDuocHuong DECIMAL(10,3),NghiBuDaSuDung DECIMAL(10,3),NghiBuConLai DECIMAL(10,3),SoPhepTonNamTruoc DECIMAL(10,3),ADD_NgayClearPhep DATETIME,ADD_NghiBuQuaHan DECIMAL(10,3),SoThangLamViec INT,SoThangLamViecCongThamNien INT)

AS      

BEGIN      

	--declare @NhanVienID int = 40336
	--DECLARE @ToDate DATETIME = GETDATE()
	--DECLARE @ResulTable TABLE (NhanVienID INT,SoPhepChuyenTuNamTruoc DECIMAL(10,3),SoPhepTonDaSuDung  DECIMAL(10,3),SoPhepTheoQuyDinh DECIMAL(10,3), SoPhepDaNghi DECIMAL(10,3), SoPhepConLai DECIMAL(10,3),ThamNien DECIMAL(10,3),
	--NghiBuTonNamTruoc DECIMAL(10,3),NghiBuDuocHuongNamMoi DECIMAL(10,3),NghiBuDuocHuong DECIMAL(10,3),NghiBuDaSuDung DECIMAL(10,3),NghiBuConLai DECIMAL(10,3),SoPhepTonNamTruoc DECIMAL(10,3),ADD_NgayClearPhep DATETIME,ADD_NghiBuQuaHan DECIMAL(10,3),SoThangLamViec INT,SoThangLamViecCongThamNien INT)

	DECLARE @CongTyID INT = (SELECT CongTyID FROM  PhongBan WHERE PhongBanID =  (SELECT PhongBanID FROM  NhanVien WHERE NhanVienID = @NhanVienID))      
	DECLARE @NgayDauThang DATE =(SELECT NgayBD_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, @ToDate ))    
	DECLARE @NgayCuoiThang DATE =(SELECT NgayKT_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, @ToDate ))    
	DECLARE @NgayDauNam DATE=(SELECT NgayBD_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, CONCAT('01/01/', YEAR(@ToDate))))      
	DECLARE @NgayCuoiNam DATE=(SELECT NgayKT_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, CONCAT('12/01/', YEAR(@ToDate)))) 
	DECLARE @IsChinhThuc BIT  = CASE WHEN  (SELECT dbo.fns_XacDinhNhanVienChinhThuc(@NhanVienID, @ToDate)) > 0 THEN 1 ELSE 0 END      
	DECLARE @NgayBatDauLam DATE =(SELECT NgayBatDauLam FROM  NhanVien WHERE NhanVienID = @NhanVienID)    
	DECLARE @VaoLamNamTinhPhep BIT = CASE WHEN YEAR(@NgayBatDauLam) = YEAR(@ToDate) THEN 1 ELSE 0 END  
	DECLARE @SoThangCongThemThamNien INT = (select sum(datediff(month,TuNgay,ToiNgay)) from NS_QTKinhNghiem where NhanVienID = @NhanVienID and NoiLamViec=N'ADCo' and XetDuyet=1)
	DECLARE @ThamNien INT = ( ISNULL ((SELECT Nam * 12 + Thang FROM   dbo.fnt_LayNgayThangNam(@NgayBatDauLam, @ToDate)),0)) / 60.0 
	DECLARE @SoThangLamViec INT = ISNULL ((SELECT Nam * 12 + Thang FROM   dbo.fnt_LayNgayThangNam(@NgayBatDauLam, @ToDate)),0) 
	-- Minh Thêm số tháng làm việc + kinh nghiệm ADCo
	DECLARE @SoThangLamViecCongThamNien int = @SoThangLamViec + isnull(@SoThangCongThemThamNien,0)


	DECLARE @NgayNghiViec DATE;

	if (select top 1 NgayDiLamLai from ns_nhanvien_nghiviec where NhanVienID=@NhanVienID order by NgayHieuLuc desc) is null
	begin
		set @NgayNghiViec = (SELECT NgayHieuLuc FROM dbo.NS_NhanVien_NghiViec WHERE dbo.NS_NhanVien_NghiViec.NhanVienID = @NhanVienID)
	end

	DECLARE @DaNghiViec BIT =     (CASE WHEN @NgayNghiViec IS NULL THEN 0 ELSE 1 END)  
	SET @NgayNghiViec = (ISNULL(@NgayNghiViec, DATEADD(YEAR, 100, @toDate)))  

	declare @ChucVuID int = (SELECT dbo.fns_ChucVuNhanVienTaiThoiDiem(@NhanVienID,EOMONTH( @ToDate)))   
	declare @NghiViecNamTinhPhep bit = CASE WHEN YEAR(@NgayNghiViec) = YEAR(@ToDate) THEN 1 ELSE 0 END 
	declare @NgayChotPhepNam DATE  =ISNULL( (SELECT CONVERT(date, GiaTri, 103) FROM  SYS_ThongSo where MaSo ='NGAYXOAPHEPTON')  ,DATEFROMPARTS(YEAR(@ToDate), 3, 31))    
	set @NgayChotPhepNam = case when @NgayChotPhepNam = '1900-01-01' then DATEFROMPARTS(YEAR(@ToDate), 3, 31) else @NgayChotPhepNam end  
	set @NgayChotPhepNam = CONCAT(MONTH(@NgayChotPhepNam),'/' ,DAY(@NgayChotPhepNam),'/' ,YEAR(@ToDate))   
	
	declare @PhepTon DECIMAL(10, 3) = ISNULL ((SELECT MAX (PhepTon) FROM NS_TL_PhepTon WHERE YEAR (@NgayBatDauLam) <= Nam AND   NhanVienID = @NhanVienID AND   Nam = YEAR (@ToDate) - 1) ,0);            
	
	--DECLARE @NgayDeXuatPhepTon DATE =  ISNULL((SELECT MAX (NgayClearPhep) FROM NS_TL_PhepTon WHERE YEAR (@NgayBatDauLam) <= Nam AND   NhanVienID = @NhanVienID AND   Nam = YEAR (@ToDate) - 1),
	--(SELECT TOP 1 CONVERT(DATE,GiaTriDateTime) FROM dbo.DX_DeXuat_DuLieuDeXuat 
	--LEFT JOIN dbo.DX_DeXuat ON DX_DeXuat.DeXuatID = DX_DeXuat_DuLieuDeXuat.DeXuatID
	--WHERE TruongDuLieuID = 2029 AND DX_DeXuat.XetDuyet = 1 AND YEAR(GiaTriDateTime) = YEAR(@ToDate) AND DX_DeXuat.NguoiDeXuatID = @NhanVienID
	--ORDER BY DX_DeXuat.DeXuatID DESC))
	DECLARE @NgayDeXuatPhepTon DATE =  ISNULL(
		(SELECT TOP 1 CONVERT(DATE,GiaTriDateTime) FROM dbo.DX_DeXuat_DuLieuDeXuat 
		LEFT JOIN dbo.DX_DeXuat ON DX_DeXuat.DeXuatID = DX_DeXuat_DuLieuDeXuat.DeXuatID
		WHERE TruongDuLieuID = 2029 AND DX_DeXuat.XetDuyet = 1 AND YEAR(GiaTriDateTime) = YEAR(@ToDate) AND DX_DeXuat.NguoiDeXuatID = @NhanVienID
		ORDER BY DX_DeXuat.DeXuatID DESC),
	(SELECT MAX (NgayClearPhep) FROM NS_TL_PhepTon WHERE YEAR (@NgayBatDauLam) <= Nam AND   NhanVienID = @NhanVienID AND   Nam = YEAR (@ToDate) - 1)
	)

	--Số phép cho 1 số trường hợp đặc biệt ở hồ sơ
	DECLARE @SoPhepQuyDinh INT = (SELECT ADD_SoPhepQuyDinh FROM NhanVien WHERE NhanVienId = @NhanVienID)
			
	--Nghỉ bù
	-- Tạm thời không xét đến tháng năm vì nghỉ bù không có ngày hết hạn
	declare @PhepDaNghi_NB decimal(10,2) = isnull((select sum(SoNgayNghi) from NS_QTNghiPhep where NhanVienID = @NhanVienID and XetDuyet IN (1,0)
										AND CONVERT(DATE,NgayBatDau) BETWEEN @NgayDauNam AND @NgayCuoiNam
										AND KyHieuChamCongID IN (SELECT KyHieuChamCongID FROM dbo.NS_TL_KyHieuChamCong WHERE KyHieu IN ('BU'))),0)
										+ ISNULL((SELECT SUM(NghiBuThucTeDaNghi) FROM ADD_NghiBuThucTe WHERE IsDauKy = 1 and NhanVienId = @NhanVienID)  ,0) 
	--declare @PhepTheoQuyDinh_NB decimal(10,2) = isnull((select sum(SoGioLam)/8.0 from dbo.NS_TL_ChamCong where NhanVienID = @NhanVienID 
	--									--AND CONVERT(DATE,NgayChamCong) BETWEEN @NgayDauNam AND @NgayCuoiNam
	--									AND LoaiChamCongID IN (SELECT LoaiChamCongID FROM dbo.NS_TL_LoaiChamCong WHERE MaSo LIKE N'%NB%')),0)
	DECLARE @PhepTheoQuyDinh_NB DECIMAL(10,2) = ISNULL((
    SELECT 
	SUM(cc.SoGioLam *
        CASE l.MaSo
            WHEN 'NB_TQD_NgayThuong'     THEN 1.5
            WHEN 'NB_TQD_DemThuong'      THEN 2.0
            WHEN 'NB_TQD_NgayDemThuong'  THEN 2.1
            WHEN 'NB_TQD_NgayNghi'       THEN 2.0
            WHEN 'NB_TQD_DemNghi'        THEN 2.7
            WHEN 'NB_TQD_NgayLe'         THEN 3.0
            WHEN 'NB_TQD_DemLe'          THEN 3.9
            ELSE 0 END) / 8.0
	--SUM(cc.SoGioLam)/8.0
    FROM dbo.NS_TL_ChamCong cc
    INNER JOIN dbo.NS_TL_LoaiChamCong l ON cc.LoaiChamCongID = l.LoaiChamCongID 
	WHERE cc.NhanVienID = @NhanVienID AND CONVERT(DATE,cc.NgayChamCong) >= '2025-07-26'
	AND l.MaSo LIKE 'NB_TQD_%'), 0)
	+ ISNULL((SELECT SUM(NghiBuThucTeDuocHuong) FROM ADD_NghiBuThucTe WHERE NhanVienId = @NhanVienID),0) 

	DECLARE @PhepTheoQuyDinhNamMoi_NB DECIMAL(10,2) = ISNULL((
    SELECT 
	SUM(cc.SoGioLam *
        CASE l.MaSo
            WHEN 'NB_TQD_NgayThuong'     THEN 1.5
            WHEN 'NB_TQD_DemThuong'      THEN 2.0
            WHEN 'NB_TQD_NgayDemThuong'  THEN 2.1
            WHEN 'NB_TQD_NgayNghi'       THEN 2.0
            WHEN 'NB_TQD_DemNghi'        THEN 2.7
            WHEN 'NB_TQD_NgayLe'         THEN 3.0
            WHEN 'NB_TQD_DemLe'          THEN 3.9
            ELSE 0 END) / 8.0
	--SUM(cc.SoGioLam)/8.0
    FROM dbo.NS_TL_ChamCong cc
    INNER JOIN dbo.NS_TL_LoaiChamCong l ON cc.LoaiChamCongID = l.LoaiChamCongID 
	WHERE cc.NhanVienID = @NhanVienID AND CONVERT(DATE,cc.NgayChamCong) >= '2025-07-26' AND CONVERT(DATE,cc.NgayChamCong) BETWEEN @NgayDauNam AND @NgayCuoiNam
	AND l.MaSo LIKE 'NB_TQD_%'), 0)
	+ ISNULL((SELECT SUM(NghiBuThucTeDuocHuong) FROM ADD_NghiBuThucTe WHERE NhanVienId = @NhanVienID and Nam=year(@ToDate)),0) 
	
	DECLARE @NghiBuTonNamTruoc DECIMAL(10,3) = isnull((SELECT PhepTon FROM  ADD_NghiBu WHERE NhanVienID = @NhanVienID AND Nam = YEAR(@ToDate) - 1),0)
	--set @PhepTheoQuyDinhNamMoi_NB = case when year(@ToDate)=2025 then @PhepTheoQuyDinh_NB - ISNULL((SELECT SUM(NghiBuThucTeDuocHuong) FROM ADD_NghiBuThucTe WHERE NhanVienId = @NhanVienID),0) else @PhepTheoQuyDinhNamMoi_NB end
	set @PhepTheoQuyDinh_NB = @PhepTheoQuyDinhNamMoi_NB + @NghiBuTonNamTruoc

	declare @SoPhepConLai_NB decimal(10,2) = @PhepTheoQuyDinh_NB-@PhepDaNghi_NB

	--Đề xuất gia hạn phép tồn
	IF @NgayDeXuatPhepTon > @NgayChotPhepNam
	BEGIN
	    SET @NgayChotPhepNam= @NgayDeXuatPhepTon
	END
	/*==================== cập nhật phép theo quy định ===================*/      

	DECLARE @SoPhepTheoQuyDinh DECIMAL(10, 3) = 0   
	--Xử lý với nhân viên mới vào làm
	DECLARE @NgayBatDauTinhPhepTrongNam DATE = CASE WHEN @NgayBatDauLam >= @NgayDauNam THEN  @NgayBatDauLam ELSE @NgayDauNam END    	  
	DECLARE @NgayKetThucTinhPhepTrongNam DATE = CASE WHEN @SoThangLamViec >= 12 THEN  @NgayCuoiNam ELSE @NgayCuoiThang END  /*Chỉ tính phép đến ngày cuối cùng của kỳ công trước đó*/
	DECLARE @NgayTinhNghiViec DATETIME

	IF DAY(@NgayBatDauTinhPhepTrongNam) > 15
	BEGIN
		SET @NgayBatDauTinhPhepTrongNam = DATEFROMPARTS(YEAR(DATEADD(MONTH,1,@NgayBatDauTinhPhepTrongNam)), MONTH(DATEADD(MONTH,1,@NgayBatDauTinhPhepTrongNam)), 01)
	END
	
	IF DAY(@NgayNghiViec) > 15
		SET @NgayTinhNghiViec = CONVERT(NVARCHAR(10), DATEADD(MONTH, 1, DATEFROMPARTS(YEAR(@NgayNghiViec), MONTH(@NgayNghiViec), 25)), 23);
	ELSE
		SET @NgayTinhNghiViec = CONVERT(NVARCHAR(10), DATEFROMPARTS(YEAR(@NgayNghiViec), MONTH(@NgayNghiViec), 25), 23);

	IF (@DaNghiViec = 1 )      
	BEGIN      
		IF(YEAR(@NgayNghiViec) = YEAR(@ToDate))  
		BEGIN  
			SET @NgayKetThucTinhPhepTrongNam =  @NgayTinhNghiViec
		END  
		ELSE  
		BEGIN  
			SET @NgayKetThucTinhPhepTrongNam  = @NgayBatDauTinhPhepTrongNam  
		END  
	END    

	if(@IsChinhThuc=0)  
	begin
		SET @NgayKetThucTinhPhepTrongNam  = @NgayBatDauTinhPhepTrongNam  
	end  

	declare @SoNgayPhepChucVu decimal(10,2) = (select case when PhepNam is null or PhepNam = 0 then 12 else PhepNam end from NS_DsChucVu where ChucVuID = @ChucVuID)

	declare @PhepNam decimal(10,2)= case when year(@NgayBatDauLam) = year(@ToDate) then 12 else @SoNgayPhepChucVu end

	declare @tblPhep table (Ngay Date, NgayBatDauLam date, NgayNghiViec date, NgayBD_CongThang date, NgayKT_CongThang date, ThamNien decimal(10,5), SoPhep decimal(10,5), PhepNam decimal(10,5)  
	,  ChucVuID int, MaChucVu nvarchar(50) , PN_Setup  decimal(10,5) )    

	insert into @tblPhep( Ngay, NgayBatDauLam, NgayNghiViec, NgayBD_CongThang, NgayKT_CongThang, ThamNien, SoPhep, PhepNam, ChucVuID, MaChucVu, PN_Setup )  
	select Ngay, NgayBatDauLam, NgayNghiViec, NgayBD_CongThang, NgayKT_CongThang, ThamNien
			,(case 
				when NgayBatDauLam between NgayBD_CongThang and NgayKT_CongThang then
					case
						when (NgayBatDauLam between NgayBD_CongThang and NgayKT_CongThang) and day(NgayBatDauLam) < 16 then 1 
						when (NgayBatDauLam between NgayBD_CongThang and NgayKT_CongThang) and day(NgayBatDauLam) > 15 then 0 
					end
				when NgayNghiViec between NgayBD_CongThang and NgayKT_CongThang then
					case
						when month(NgayNghiViec) = MONTH (NgayBD_CongThang) then 0			
						when (NgayNghiViec between NgayBD_CongThang and NgayKT_CongThang) and day(NgayNghiViec) < 16 then 0 
						when (NgayNghiViec between NgayBD_CongThang and NgayKT_CongThang) and day(NgayNghiViec) > 15 then 1 
					end
				when convert(date,NgayNghiViec) < convert(date,NgayBD_CongThang) then 0
				else @PhepNam/12.0
			end)	as SoPhep
			,@PhepNam/12.0 PhepNam, 0 ChucVuID, N'Phép ở HSNS' MaChucVu,  @PhepNam PN_Setup 
	from (
		select * , 0 SoPhep
		from    
		(select *, @NgayBatDauLam NgayBatDauLam, @NgayNghiViec NgayNghiViec  
		, (SELECT NgayBD_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, Ngay ))  NgayBD_CongThang, 
		(SELECT NgayKT_CongThang FROM  fnt_LayNgayGioKyCong(@CongTyID, Ngay ))  NgayKT_CongThang , 
		@ThamNien/12.0 as ThamNien  
		from    
		(SELECT distinct (FORMAT(Ngay, 'MM/01/yyyy')) Ngay FROM  NS_BH_NgayThang 
                    where Ngay between  @NgayBatDauTinhPhepTrongNam and @NgayKetThucTinhPhepTrongNam
                    and YEAR(Ngay) = YEAR(@ToDate)
        ) as tbl_Ngay
		--where YEAR(Ngay) = YEAR(@NgayKetThucTinhPhepTrongNam)
		) as tbl_ngaycv
		) as tbl_ngaycv      

	--SELECT * FROM @tblPhep
	set @SoPhepTheoQuyDinh =(select sum(SoPhep) from @tblPhep ) + @ThamNien

	IF @SoPhepQuyDinh = 0
	BEGIN	 SET @SoPhepQuyDinh = @SoPhepTheoQuyDinh END

	else IF @SoPhepQuyDinh IS NOT NULL OR @SoPhepQuyDinh > 0
	BEGIN
		SET @SoPhepTheoQuyDinh =  @SoPhepQuyDinh + @ThamNien
	END
	
	/*Phép năm làm tròn quy tắc làm tròn lên bước nhảy 0.5: <0.5 => 0.5 < 1 =? 1*/  
	--set @SoPhepTheoQuyDinh = CEILING(@SoPhepTheoQuyDinh/0.5) * 0.5     
  
	/*'01/01/2023' ngày bắt đầu xử dụng phần mềm*/      
	declare @NgayBatDauSuDung DATE = '01/01/2025'

	/*@PhepDaNghiTrongNam = số phép nhân viên đã nghỉ trước @NgayBatDauSuDung trong năm bắt đầu sử dụng phần mềm + công Phép đã nghỉ (có sau khi tổng hợp công)*/
	
	declare @PhepDaNghiTrongNam DECIMAL(10, 3) =       
		ISNULL ( (SELECT SUM( SoNgayNghi) FROM  NS_QTNghiPhep   --Số ngày nghỉ phép lấy từ quá trình nghỉ phép từ ngày bắt đầu sử dụng phần mềm để đăng ký phép
		WHERE NhanVienID = @NhanVienID and KyHieuChamCongID IN (SELECT KyHieuChamCongID FROM  NS_TL_KyHieuChamCong WHERE KyHieu  IN ('P')) and XetDuyet in  (0,1)  --1 là đã duyệt, 2 là chờ xóa  
		AND   CONVERT( DATE,NgayKetThuc) >= @NgayBatDauSuDung AND YEAR(NgayBatDau) = YEAR(@ToDate)) ,0)      
		+ ISNULL ((SELECT TOP 1 SoPhepThucTeDaNghi FROM ADD_PhepThucTe WHERE isDauKy = 1 AND YEAR(@ToDate) = Nam AND @NhanVienID = NhanVienId ORDER BY Thang DESC)  ,0) 
  
	declare @PhepDaNghiTrongNam_TruocKhiChot DECIMAL(10, 3) =       
		ISNULL ((SELECT SUM( SoNgayNghi) FROM  NS_QTNghiPhep   
		WHERE NhanVienID = @NhanVienID AND KyHieuChamCongID IN (SELECT KyHieuChamCongID FROM  NS_TL_KyHieuChamCong WHERE KyHieu  IN ('P')) and XetDuyet in  (0,1)  --1 là đã duyệt, 2 là chờ xóa
		AND  NgayKetThuc <= @NgayChotPhepNam AND YEAR(NgayBatDau) = YEAR(@ToDate)),0)      
		

	declare @SoPhepConLai DECIMAL(10, 3) =       
		  --CASE WHEN @ToDate <= @NgayChotPhepNam /*Nếu chưa đến ngày chốt phép*/ THEN  @SoPhepTheoQuyDinh + @PhepTon  - @PhepDaNghiTrongNam 
		  --Thêm trường hợp nếu nhân viên nghỉ việc thì trừ hết số phép tồn
		 case when  @ToDate <= @NgayChotPhepNam and year(@NgayNghiViec) = year(@ToDate) and @ToDate >= @NgayNghiViec 
					then ( case when (@PhepTon - @PhepDaNghiTrongNam) >= 0 then @SoPhepTheoQuyDinh else @SoPhepTheoQuyDinh + (@PhepTon - @PhepDaNghiTrongNam) end)
					--then @SoPhepTheoQuyDinh  - (@PhepDaNghiTrongNam - @PhepTon) 
		 else CASE WHEN @ToDate <= @NgayChotPhepNam /*Nếu chưa đến ngày chốt phép*/ THEN  @SoPhepTheoQuyDinh + @PhepTon  - @PhepDaNghiTrongNam
		 --kết thúc thêm
		ELSE    /*Nếu đã qua ngày chốt phép*/   
			(CASE /*Phép tồn > phép đã nghỉ trước ngày chốt*/   
				WHEN @PhepTon > @PhepDaNghiTrongNam_TruocKhiChot  THEN @SoPhepTheoQuyDinh  - (@PhepDaNghiTrongNam - @PhepDaNghiTrongNam_TruocKhiChot)     
			/*nếu số ngày phép đã nghỉ > phép tồn năm trước */   
			ELSE  @SoPhepTheoQuyDinh + @PhepTon - @PhepDaNghiTrongNam  END)      
		END END;      
    
	declare @SoPhepChuyenTuNamTruoc decimal(10,2) = @PhepTon
	set @PhepTon = case when  @ToDate <= @NgayChotPhepNam THEN @PhepTon else case when @PhepTon  > @PhepDaNghiTrongNam_TruocKhiChot then @PhepDaNghiTrongNam_TruocKhiChot else @PhepTon end  end  
	declare @PhepTonBiXoa decimal(10,2) =  case when  @ToDate <= @NgayChotPhepNam then 0   
	else case when @PhepTon  > @PhepDaNghiTrongNam_TruocKhiChot then @PhepTon - @PhepDaNghiTrongNam_TruocKhiChot else 0 end  end    

INSERT @ResulTable (NhanVienID,SoPhepChuyenTuNamTruoc, SoPhepTheoQuyDinh,  SoPhepDaNghi, SoPhepConLai, ThamNien,
		NghiBuTonNamTruoc,NghiBuDuocHuong,NghiBuDuocHuongNamMoi,NghiBuDaSuDung,NghiBuConLai,SoPhepTonNamTruoc,ADD_NgayClearPhep,ADD_NghiBuQuaHan,SoThangLamViec,SoThangLamViecCongThamNien)
SELECT @NhanVienID,@SoPhepChuyenTuNamTruoc,@SoPhepTheoQuyDinh,@PhepDaNghiTrongNam,@SoPhepConLai,@ThamNien,
		@NghiBuTonNamTruoc,@PhepTheoQuyDinh_NB,@PhepTheoQuyDinhNamMoi_NB,@PhepDaNghi_NB,@SoPhepConLai_NB,@PhepTon,@NgayChotPhepNam,0,@SoThangLamViec,@SoThangLamViecCongThamNien
            
	--select * from @tblPhep
	--select * from @ResulTable
	

	RETURN   
END   


