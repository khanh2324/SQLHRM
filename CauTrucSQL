create FUNCTION [dbo].[GetPhongBanChaIds](@parentID INT)  
RETURNS @tbl TABLE (valu INT, lev INT)  
WITH EXECUTE AS CALLER  
AS  
 BEGIN  
 DECLARE @pbChaID INT = @parentID  
 DECLARE @phongbanid INT  
 SET @phongbanid = @pbChaID  
 INSERT INTO @tbl(valu, lev) VALUES (@pbChaID, (select CapPhongBanID from PhongBan where PhongBanID=@pbChaID))  
 WHILE (1=1)  
 BEGIN  
  DECLARE @cvchaID INT = (SELECT ISNULL(PhongBanChaID,0) FROM PhongBan WHERE PhongBanID=@phongbanid)  
  IF (@cvchaID<=0 OR @cvchaID IS NULL OR @cvchaID=@phongbanid)  
   BREAK;  
  IF ((SELECT COUNT(*) FROM @tbl WHERE valu=@cvchaID)>0)  
   BREAK;  
  SET @phongbanid = @cvchaid  
  INSERT INTO @tbl(valu, lev) VALUES (@cvchaid, (select CapPhongBanID from PhongBan where PhongBanID=@cvchaID))  
 END  
 RETURN  
END
