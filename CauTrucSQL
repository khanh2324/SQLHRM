CREATE PROC [dbo].[LayThongTinDeXuat] @ID INT        
AS        
BEGIN        
 --declare @ID int = 42    
     
 select TieuDe,NgayDeXuat,NguoiDeXuat,MaNguoiDeXuat,NguoiDeXuat_PhongBan,NguoiDeXuat_ChucVu,    
 left([2030],10) as DXNV_NgayBatDau,    
 left([2031],10) as DXNV_NgayKetThuc,    
 CONVERT(INT,[2032]) AS DXNV_SoPhutDiMuon,    
 CONVERT(INT,[2033]) AS DXNV_SoPhutVeSom,    
 left([2029],10) as DXNV_NgayXoaPhepTon,    
 [2034] as DXNV_GhiChu  ,  
 left([2035],10) as DXNV_NgayNghiViec,   
 ldnv.Ten DXNV_LyDoNghiViec,
 nv.MaNhanVien DXBG_MaNhanVien,
 nv.Ho+' '+nv.HoTen DXBG_HoVaTen,
 CONVERT(NVARCHAR,nvnv.NgayHieuLuc) DXBG_NgayNghiViec,
 ld.Ten DXBG_LyDoNghiViec
 from (        
 select TieuDe,convert(varchar(10),NgayDeXuat,103) as NgayDeXuat,concat(nvdx.ho,' ',nvdx.HoTen) as NguoiDeXuat,        
 (select Ten from PhongBan where PhongBan.PhongBanID = nvdx.PhongBanID) as NguoiDeXuat_PhongBan,        
 (select TenChucVu from NS_DsChucVu where NS_DsChucVu.ChucVuID = nvdx.ChucVuID) as NguoiDeXuat_ChucVu,       
 nvdx.MaNhanVien MaNguoiDeXuat,dldx.TruongDuLieuID,dldx.GiaTri from DX_DeXuat dx        
 left join NhanVien nvdx on dx.NguoiDeXuatID = nvdx.NhanVienID        
 left join DX_DeXuat_DuLieuDeXuat dldx on dldx.DeXuatID = dx.DeXuatID        
 where dx.DeXuatID=@ID) pvt        
 pivot        
 (max(GiaTri)        
 for TruongDuLieuID in([2030],[2031],[2032],[2033],[2034],[2029],[2035],[2036],[2037])        
 ) a        
 LEFT JOIN dbo.NS_DsLyDoNghiViec ldnv ON ldnv.LyDoNghiViecID = [a].[2036]   
 LEFT JOIN dbo.NhanVien nv ON nv.NhanVienID = [a].[2037]
 LEFT JOIN dbo.NS_NhanVien_NghiViec nvnv ON nvnv.NhanVienID = nv.NhanVienID
 LEFT JOIN dbo.NS_DsLyDoNghiViec ld ON ld.LyDoNghiViecID = nvnv.LyDoNghiViecID
    
END
GO
