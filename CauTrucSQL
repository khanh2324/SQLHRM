CREATE FUNCTION [dbo].[fn_LayGiaTriTaiViTriTrongMang]  
(  @SearchString nvarchar(2000),   @PhanCach nvarchar(20),     @ViTriCanLay int )  
RETURNS nvarchar(500)  
AS   
--declare @SearchString nvarchar(200) = '2849,3480,3481,3482,3483'  
--declare @PhanCach nvarchar(20) =','   
--declare @ViTriCanLay int =5      
BEGIN  
 -- Declare the return variable here  
 DECLARE @ResultVar nvarchar(500)  
 Declare @Index int =0  
 Declare @ComparativeValue nvarchar(500) = null   
 Declare @CuPhapPhanCach nvarchar(22) =   '%'+@PhanCach+'%'
WHILE LEN(@SearchString) > 0  
BEGIN  
SET @Index =  @Index+1;  
    IF PATINDEX(@CuPhapPhanCach, @SearchString) > 0  
    BEGIN  
        SET @ComparativeValue = SUBSTRING(@SearchString,0,PATINDEX(@CuPhapPhanCach, @SearchString))  
  IF( @ViTriCanLay = @Index)  
  BEGIN  
   Set @ResultVar = @ComparativeValue  
   BREAK;  
  END  
        SET @SearchString = SUBSTRING(@SearchString,LEN(@ComparativeValue + @PhanCach) + 1,LEN(@SearchString))   
    END  
    ELSE  
    BEGIN  
        SET @ComparativeValue = @SearchString  
        SET @SearchString = NULL  
  if( @ViTriCanLay = @Index)  
          Set @ResultVar = @ComparativeValue  
  ELSE  
  Set @ResultVar = null  
    END  
END  
 RETURN @ResultVar  
  
END  
