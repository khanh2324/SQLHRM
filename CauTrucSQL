CREATE procedure [dbo].[ADD_BangLuongVanHanh_ADCo_PB] 
	@PhongBanID int, @Thang int, @Nam int, @LoaiLaoDongID int,  @DangNhapID int

as
begin

   --declare @PhongBanID int = 20, @Thang int = 3, @Nam int = 2025, @LoaiLaoDongID int = 0, @DangNhapID int = 3115  

	 declare @ThangLuong date = eomonth(convert(char(2), @thang) + '/1/' + convert(char(4), @nam) )  
	 declare @NgayQuyDoi date = convert(char(2), @thang) + '/26/' + convert(char(4), @nam)   
	 declare @DauKy date = dateadd(month, -1, @NgayQuyDoi)  
	 declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)   
   
	 select distinct a.TieuDe, a.LoaiLaoDongID, a.TenLoaiLaoDong, a.STT, format(getdate(), 'HH:mm:ss dd/MM/yyyy') as NgayXuat
	 from (
	 select  
	      N'Tháng ' + convert(nvarchar(10),format(@ThangLuong, 'MM/yyyy') ) as TieuDe,  lld.LoaiLaoDongID as LoaiLaoDongID
		, upper((case when Nhom.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.Ten else v.Lever2Ten end  
		   else lld.Ten end   
			)) as TenLoaiLaoDong  
	   , (case   
		    when Nhom.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.ThuTuSapXep else (select top 1 ThuTuSapXep from dbo.PhongBan where PhongBanID = v.Lever2ID) end  
	      else 100 + lld.ThuTu end   
		 ) as STT  

		--, lld.Ten as TenLoaiLaoDong

	 from NhanVien nv   
		 cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1      
		 left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
		 left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID  
		 left join ADD_CostCenter Nhom on nv.CostCenterId = Nhom.CostCenterId  
		 left join dbo.NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID  		 
		 left join dbo.NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID  	
		 right join  
			 (select * from (  
				  select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong  
				  from NS_TL_BangLuong bl   
					  left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID  
					  left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID   
				  Where (1=1)  
					  and bl.Thang = @Thang  
					  and bl.Nam = @Nam  				 
				  ) as A pivot ( sum(TienLuong) for MaSo in( [CC_TongCong], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac],   
															   [TLNC_PC_BuaAn], [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap], [TLOT_ChieuThue], [TLOT_MienThue],   
															   [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem], [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam],   
															   [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap],   
															   [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],   
															   [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc], [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue],   
															   [Tax_TongThue], [Tax_ThuNhapSauThue], [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax],   
															   [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy]   ) ) as B  
				 ) as bl on nv.NhanVienID = bl.NhanVienID   
  
	 where pb.PhongBanID in (select valu from GetPhongBanChild_WUser(@PhongBanID, @DangNhapID) )  
		and (lld.LoaiLaoDongID = @LoaiLaoDongID or @LoaiLaoDongID = -1001 or @LoaiLaoDongID = 0)
		and nv.MaNhanVien <> '80090'
		AND pb.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
	 )a 
	 order by a.STT

        
END
GO
/****** Object:  StoredProcedure [dbo].[ADD_BaoCaoThue051]    Script Date: 03/04/2026 16:11:45 ******/
