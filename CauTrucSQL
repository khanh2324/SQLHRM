  DECLARE @MaLoaiQuyTrinh NVARCHAR(50) =( SELECT MaLoaiQuyTrinh FROM  WF_QuyTrinh WHERE QuyTrinhID =(SELECT QuyTrinhID FROM  SYS_XetDuyet WHERE XetDuyetID = @XDID))                
