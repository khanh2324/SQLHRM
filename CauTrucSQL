FROM  dbo.fnt_LayThongTinTinhPhepNam(@NhanVienID, @ToDate) 

DECLARE @SoPhepChuyenTuNamTruoc DECIMAL(10,3) = (SELECT SoPhepChuyenTuNamTruoc FROM  @ResulTable)
DECLARE @SoPhepTheoQuyDinh DECIMAL(10,3) = (SELECT SoPhepTheoQuyDinh FROM  @ResulTable)
DECLARE @SoPhepDaNghi DECIMAL(10,3) = (SELECT SoPhepDaNghi FROM  @ResulTable)
DECLARE @SoPhepConLai DECIMAL(10,3) = (SELECT SoPhepConLai FROM  @ResulTable)
DECLARE @ThamNien DECIMAL(10,3) = (SELECT ThamNien FROM  @ResulTable)
DECLARE @NghiBuTonNamTruoc DECIMAL(10,3) = (SELECT PhepTon FROM  ADD_NghiBu WHERE NhanVienID = @NhanVienID AND Nam = YEAR(@ToDate) - 1)
DECLARE @NghiBuDuocHuong DECIMAL(10,3) = (SELECT NghiBuDuocHuong FROM  @ResulTable)
DECLARE @NghiBuDuocHuongNamMoi DECIMAL(10,3) = (SELECT NghiBuDuocHuongNamMoi FROM  @ResulTable)
DECLARE @NghiBuDaSuDung DECIMAL(10,3) = (SELECT NghiBuDaSuDung FROM  @ResulTable)
DECLARE @NghiBuConLai DECIMAL(10,3) = (SELECT NghiBuConLai FROM  @ResulTable)
DECLARE @SoPhepTonNamTruoc DECIMAL(10,3) = (SELECT SoPhepTonNamTruoc FROM  @ResulTable)
DECLARE @ADD_NgayClearPhep DATETIME = (SELECT ADD_NgayClearPhep FROM  @ResulTable)
DECLARE @SoThangLamViec DECIMAL(10,3) = (SELECT SoThangLamViec FROM  @ResulTable)
DECLARE @SoThangLamViecCongThamNien DECIMAL(10,3) = (SELECT SoThangLamViecCongThamNien FROM  @ResulTable)


           
UPDATE NhanVien SET SoPhepChuyenTuNamTruoc = @SoPhepChuyenTuNamTruoc, SoPhepTheoQuyDinh = @SoPhepTheoQuyDinh ,SoPhepDaNghi = @SoPhepDaNghi, SoPhepConLai = @SoPhepConLai,ThamNien=@ThamNien,
NghiBuDuocHuong=@NghiBuDuocHuong,NghiBuDuocHuongNamMoi=@NghiBuDuocHuongNamMoi,NghiBuDaSuDung=@NghiBuDaSuDung,NghiBuConLai=@NghiBuConLai,NghiBuTonNamTruoc=@NghiBuTonNamTruoc,
ADD_SoThangThamNienCongDon = @SoThangLamViecCongThamNien, ADD_SoThangThamNien = @SoThangLamViec,SoPhepTonNamTruoc=@SoPhepTonNamTruoc,ADD_NgayClearPhep = @ADD_NgayClearPhep

WHERE NhanVienID = @NhanVienID;  

/*CẬP NHẬT PHÉP TỒN VÀO NGÀY 26/12*/
   
		IF (DAY (@ToDate) = 26 AND MONTH (@ToDate) = 12)
		BEGIN
				DELETE NS_TL_PhepTon WHERE NhanVienID = @NhanVienID AND Nam = YEAR(@ToDate)
				INSERT INTO NS_TL_PhepTon (NhanVienID, Nam, PhepTon, NgayClearPhep) 
				SELECT NhanVienID, YEAR (@ToDate) , SoPhepConLai, DATEFROMPARTS(YEAR(@ToDate)+1, 03, 31) FROM NhanVien WHERE NhanVienID = @NhanVienID
	
				DELETE ADD_NghiBu WHERE NhanVienID = @NhanVienID AND Nam = YEAR(@ToDate)
				INSERT INTO ADD_NghiBu (NhanVienID, Nam, PhepTon)
				SELECT NhanVienID, YEAR (@ToDate) , NghiBuConLai FROM NhanVien WHERE NhanVienID = @NhanVienID 
		END;
END
