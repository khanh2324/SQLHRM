CREATE PROCEDURE [dbo].[HS_LayParameters_DieuChuyen]
@QTChuyenCanBoID int
AS
BEGIN
	--DECLARE @QTChuyenCanBoId INT = 3046
	declare @nhanvienid int = (SELECT NhanVienID FROM NS_QTChuyenCanBo WHERE QTChuyenCanBoID=@QTChuyenCanBoID)

	select
	nhanvien.MaNhanVien ,
	nhanvien.ho+' '+nhanvien.hoten as HoVaTen,
	convert(nvarchar,nhanvien.ngaysinh,103) as NgaySinh,nhanvien.DiaChiThuongTru,
	nhanvien.DienThoai,
	NS_QTChuyenCanBo.NgayHieuLuc,
	NS_QTChuyenCanBo.SoQuyetDinh,
	isnull(convert(nvarchar(10), NS_QTChuyenCanBo.NgayHetHan, 103), '') AS NgayHetHan, 
	isnull(convert(nvarchar(10), DATEADD(MONTH,2,NS_QTChuyenCanBo.NgayHieuLuc), 103), '') AS NgayHetTV,
	NS_QTChuyenCanBo.NgayChuyen as NgayQuyetDinh,
	ISNULL(pbc.ten,'') as PhongBanCu,
	ISNULL(pbm.ten,'') as PhongBanMoi,ISNULL(cvc.TenChucVu,'') as ChucVuCu,ISNULL(cvm.TenChucVu,'') as ChucVuMoi,
	ISNULL(cdc.TenChucDanh,'') as ChucDanhCu,ISNULL(cdm.TenChucDanh,'') as ChucDanhMoi,
	ISNULL(TenLyDoChuyenCanBo,'') as LyDoChuyenCanBo,
	case when NhanVien.GioiTinh =N'Nam' then N'Ông' else N'Bà' end as OngBa,
	case when NhanVien.GioiTinh =N'Nam' then N'Anh' else N'Chị' end as AnhChi,
	NhanVien.GioiTinh,NhanVien.CMTND,NhanVien.NgayCapCMT,NhanVien.NoiCapCMT,
	ISNULL(LCBM.GiaTri, 0) as LuongCoBanMoi,
	ISNULL(PCDHM.GiaTri, 0) as PhuCapDocHaiMoi,
	ISNULL(LTM.GiaTri, 0) as ThuongThangMoi,
	ISNULL(LCBM.GiaTri, 0) + ISNULL(PCDHM.GiaTri, 0) + ISNULL(LTM.GiaTri, 0) AS TongMoi,

	ISNULL(LCBC.GiaTri, 0) as LuongCoBanCu,
	ISNULL(PCDHC.GiaTri, 0) as PhuCapDocHaiCu,
	ISNULL(LTC.GiaTri, 0) as ThuongThangCu,
	ISNULL(LCBC.GiaTri, 0) + ISNULL(PCDHC.GiaTri, 0) + ISNULL(LTC.GiaTri, 0) AS TongCu,

	CASE when isnull(NVK.GioiTinh, '') = N'Nữ' then N'Bà' when isnull(NVK.GioiTinh, '') = N'Nam' then N'Ông' else '' end as OngBaNK,
	ISNULL(NVK.Ho, '')+' '+isnull(NVK.HoTen, '') as HoVaTenNK,
	upper(isnull(NVK.Ho, '')+' '+isnull(NVK.HoTen, '')) as HoVaTenNKVietHoa,
	dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NVK.Ho, '')+' '+isnull(NVK.HoTen, '')) HoTenNKTA,
	isnull(CVK.TenChucVu, '') as TenChucVuNK,
	isnull(CVK.TenChucVuTA, '') AS TenChucVuNKTA,
	UPPER(ISNULL(CVK.TenChucVu, '')) as TenChucVuNKVietHoa,
	CDK.TenChucDanh AS TenChucDanhNK,isnull(QTK.TenNuoc, '') as QuocTichNK,
	HDC.MaHopDong AS MaHopDongC, HDC.NgayKyHD NgayKyHDC, ISNULL(NS_QTChuyenCanBo.LyDoChuyen,'') LyDoChuyen
	from NS_QTChuyenCanBo
	inner join nhanvien on nhanvien.nhanvienid=NS_QTChuyenCanBo.NhanVienID
	left join NS_DsLyDoChuyenCanBo on NS_DsLyDoChuyenCanBo.LyDoChuyenCanBoID=NS_QTChuyenCanBo.LyDoChuyenID
	inner join phongban pbc on pbc.phongbanid=NS_QTChuyenCanBo.PhongBanCuID
	inner join phongban pbm on NS_QTChuyenCanBo.phongbanmoiid = pbm.phongbanid
	left join NS_DsChucVu cvc on cvc.ChucVuID=NS_QTChuyenCanBo.ChucVuCuID
	left join NS_DsChucVu cvm on cvm.ChucVuID=NS_QTChuyenCanBo.ChucVuMoiID
	left join NS_DsChucDanh cdc on cdc.ChucDanhID=NS_QTChuyenCanBo.ChucDanhCuID
	left join NS_DsChucDanh cdm on cdm.ChucDanhID=NS_QTChuyenCanBo.ChucDanhMoiID
	left join NS_DsQuocTich on NS_DsQuocTich.QuocTichID=nhanvien.QuocTichID
	left join NS_QTDienBienLuong as DBLM on nhanvien.NhanVienID = DBLM.NhanVienID and  DBLM.QTDienBienLuongID =
	(select max(QTDienBienLuongID) from NS_QTDienBienLuong where NS_QTDienBienLuong.NhanVienID = NhanVien.NhanVienID
				and NgayHuong = (select max(NgayHuong) from NS_QTDienBienLuong as QTDBL where QTDBL.NhanVienID = NhanVien.NhanVienID
				and convert(date,QTDBL.NgayHuong)>=CONVERT(DATE,NS_QTChuyenCanBo.NgayHieuLuc)))
	left join NS_QTDienBienLuongChiTiet as LCBM on DBLM.QTDienBienLuongID = LCBM.QTDienBienLuongID and LCBM.LoaiLuongID = 1
	left join NS_QTDienBienLuongChiTiet as PCDHM on DBLM.QTDienBienLuongID = PCDHM.QTDienBienLuongID and LCBM.LoaiLuongID = 5
	LEFT join NS_QTDienBienLuongChiTiet as LTM on DBLM.QTDienBienLuongID = LTM.QTDienBienLuongID and LTM.LoaiLuongID = 8

	--SELECT  * FROM dbo.NS_TL_LoaiLuong
	--luong cu
	left join NS_QTDienBienLuong as DBLC on nhanvien.NhanVienID = DBLC.NhanVienID and  DBLC.QTDienBienLuongID =
	(select max(QTDienBienLuongID) from NS_QTDienBienLuong where NS_QTDienBienLuong.NhanVienID = NhanVien.NhanVienID
				and NgayHuong = (select max(NgayHuong) from NS_QTDienBienLuong as QTDBL where QTDBL.NhanVienID = NhanVien.NhanVienID
				and convert(date,QTDBL.NgayHuong) < CONVERT(DATE,NS_QTChuyenCanBo.NgayHieuLuc)))
	left join NS_QTDienBienLuongChiTiet as LCBC on DBLC.QTDienBienLuongID = LCBC.QTDienBienLuongID and LCBC.LoaiLuongID = 1
	left join NS_QTDienBienLuongChiTiet as PCDHC on DBLC.QTDienBienLuongID = PCDHC.QTDienBienLuongID and LCBC.LoaiLuongID = 5
	LEFT join NS_QTDienBienLuongChiTiet as LTC on DBLC.QTDienBienLuongID = LTC.QTDienBienLuongID and LTC.LoaiLuongID = 8
	LEFT JOIN dbo.NS_HopDong HDC ON nhanvien.NhanVienID = HDC.NhanVienID AND HDC.HopDongID =
	(select max(HopDongID) from NS_HopDong where NS_HopDong.NhanVienID = NhanVien.NhanVienID
				and NgayBatDau = (select max(NgayBatDau) from NS_HopDong as QTDBL where QTDBL.NhanVienID = NhanVien.NhanVienID
				and convert(date,QTDBL.NgayBatDau) <= CONVERT(DATE,NS_QTChuyenCanBo.NgayHieuLuc)))

	LEFT JOIN NhanVien NVK ON NVK.NhanVienID = NS_QTChuyenCanBo.NguoiKyID
	LEFT join NS_DsQuocTich as QTK on NVK.QuocTichID = QTK.QuocTichID
	LEFT join NS_DsChucVu as CVK on NVK.ChucVuID = CVK.ChucVuID
	LEFT join NS_DsChucDanh as CDK on NVK.ChucDanhID = CDK.ChucDanhID
	WHERE NS_QTChuyenCanBo.QTChuyenCanBoID=@QTChuyenCanBoID
	
END

GO
