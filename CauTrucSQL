            INNER JOIN NS_NhanVien_NghiViec nvnv WITH (NOLOCK) ON nv.NhanVienID = nvnv.NhanVienID
                AND MONTH(@Todate1) = MONTH(nvnv.NgayHieuLuc)
                AND YEAR(@Todate1) = YEAR(nvnv.NgayHieuLuc)
                --AND dbo.BHXH_TinhSoNgayNghi(MONTH(nvnv.NgayHieuLuc), YEAR(nvnv.NgayHieuLuc), nv.NhanVienID) >= 14
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
            LEFT JOIN NS_BH_NguoiThamGia bh WITH (NOLOCK) ON nv.NhanVienID = bh.NhanVienID AND bh.Status <> @Types
            WHERE bh.NhanVienID IS NOT NULL
        )
        -- Kết quả cuối cùng
          INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
