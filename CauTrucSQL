CREATE PROCEDURE [dbo].[LayQuaTrinhCongTac]  
@ID int  
AS  
BEGIN  
 --DECLARE @ID INT = 3451  
select NhanVien.MaNhanVien,NhanVien.ho+' '+NhanVien.hoten as HoVaTen,ns_dschucvu.TenChucVu,phongban.ten as PhongBan,  
--CONVERT(NVARCHAR(50),NS_QTCongTac.NgayBatDau,103) NgayBatDau,  
--CONVERT(NVARCHAR(50),NS_QTCongTac.NgayKetThuc,103) NgayKetThuc,  
