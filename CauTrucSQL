CREATE PROCEDURE [dbo].[DG_XepLoaiDanhGia]
@PhongBanID int,
@KyDanhGia int,
@Thang int,
@Quy int,
@Nam int	
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;
	IF (@KyDanhGia=1)
	BEGIN
				SELECT TongDiem,
					   NS_DG_CongViec.CongViecID,
					   NhanVienID
				FROM   NS_DG_CongViec
				INNER JOIN 
					   (
						   SELECT SUM(NS_DG_TongHopDanhGiaChiTiet.DiemSo * NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia)/SUM(NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia) as TongDiem,
								  CongViecID, 
								  NS_DG_TongHopDanhGiaChiTiet.NhanVienID 
						   FROM 
								  NS_DG_TongHopDanhGiaChiTiet
						   INNER JOIN NhanVien on NhanVien.NhanVienID = NS_DG_TongHopDanhGiaChiTiet.NhanVienID
						   WHERE 
								  NS_DG_TongHopDanhGiaChiTiet.Quy=@Quy And NS_DG_TongHopDanhGiaChiTiet.Nam=@Nam And NS_DG_TongHopDanhGiaChiTiet.Thang=@Thang
								  AND NhanVien.PhongBanID IN (SELECT valu FROM  GetPhongBanChilds(@PhongBanID))
						   Group By CongViecID, NS_DG_TongHopDanhGiaChiTiet.NhanVienID
					   ) as NS_DG_TongHopDanhGiaChiTiet on NS_DG_TongHopDanhGiaChiTiet.CongViecID = NS_DG_CongViec.CongViecID
				WHERE  NS_DG_CongViec.Level=0
	END
	ELSE
	BEGIN
		IF (@KyDanhGia=2) 
		BEGIN
				SELECT TongDiem,
					   NS_DG_CongViec.CongViecID,
					   NhanVienID
				FROM   NS_DG_CongViec
				INNER JOIN 
					   (
						   SELECT SUM(NS_DG_TongHopDanhGiaChiTiet.DiemSo * NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia)/SUM(NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia) as TongDiem,
								  CongViecID, 
								  NS_DG_TongHopDanhGiaChiTiet.NhanVienID 
						   FROM 
								  NS_DG_TongHopDanhGiaChiTiet
						   INNER JOIN NhanVien on NhanVien.NhanVienID = NS_DG_TongHopDanhGiaChiTiet.NhanVienID
						   WHERE 
								  NS_DG_TongHopDanhGiaChiTiet.Quy=@Quy And NS_DG_TongHopDanhGiaChiTiet.Nam=@Nam And NS_DG_TongHopDanhGiaChiTiet.Thang=0
								  AND NhanVien.PhongBanID IN (SELECT valu FROM  GetPhongBanChilds(@PhongBanID))
						   Group By CongViecID, NS_DG_TongHopDanhGiaChiTiet.NhanVienID
					   ) as NS_DG_TongHopDanhGiaChiTiet on NS_DG_TongHopDanhGiaChiTiet.CongViecID = NS_DG_CongViec.CongViecID
				WHERE  NS_DG_CongViec.Level=0
		END
		ELSE
		BEGIN
			IF (@KyDanhGia=3)
			BEGIN
				SELECT TongDiem,
					   NS_DG_CongViec.CongViecID,
					   NhanVienID
				FROM   NS_DG_CongViec
				INNER JOIN 
					   (
						   SELECT SUM(NS_DG_TongHopDanhGiaChiTiet.DiemSo * NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia)/SUM(NS_DG_TongHopDanhGiaChiTiet.HeSoDanhGia) as TongDiem,
								  CongViecID, 
								  NS_DG_TongHopDanhGiaChiTiet.NhanVienID 
						   FROM 
								  NS_DG_TongHopDanhGiaChiTiet
						   INNER JOIN NhanVien on NhanVien.NhanVienID = NS_DG_TongHopDanhGiaChiTiet.NhanVienID
						   WHERE 
								  NS_DG_TongHopDanhGiaChiTiet.Quy=0 And NS_DG_TongHopDanhGiaChiTiet.Nam=@Nam And NS_DG_TongHopDanhGiaChiTiet.Thang=0
								  AND NhanVien.PhongBanID IN (SELECT valu FROM  GetPhongBanChilds(@PhongBanID))
						   Group By CongViecID, NS_DG_TongHopDanhGiaChiTiet.NhanVienID
					   ) as NS_DG_TongHopDanhGiaChiTiet on NS_DG_TongHopDanhGiaChiTiet.CongViecID = NS_DG_CongViec.CongViecID
				WHERE  NS_DG_CongViec.Level=0
			END
		END
	END
END
