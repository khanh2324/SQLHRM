create function [dbo].[fns_TinhTroCapThoiViec](@NhanVienNghiViecID int,@IsTroCapThoiViec bit)
returns decimal(18,0)
as
begin
--declare @NhanVienNghiViecID int = 3476
--declare @IsTroCapThoiViec int = 1

declare @SoThangTinhTroCap int = 0
declare @NhanVienID int = (select NhanVienID from NS_NhanVien_NghiViec where NhanVienNghiViecID=@NhanVienNghiViecID)
declare @ThoiGianNghiViec date = (select NgayHieuLuc from NS_NhanVien_NghiViec where NhanVienNghiViecID=@NhanVienNghiViecID)
DECLARE @TrungBinhLuong decimal(20,5)
declare @SoThangTSKDBH int =(SELECT isnull(SoThangTSKDBH,0) FROM    NS_NhanVien_NghiViec where NhanVienNghiViecID=@NhanVienNghiViecID)
declare @SoThangTVKDBH int =(SELECT isnull(SoThangTVKDBH,0) FROM    NS_NhanVien_NghiViec where NhanVienNghiViecID=@NhanVienNghiViecID)
declare @SoTienTroCap decimal(18,0) = 0

if(isnull(@SoThangTinhTroCap,0) = 0 or isnull(@SoThangTinhTroCap,0)>0)
begin
	declare @A int = (select 
	case when NgayBatDauLam < '01/01/2009' then datediff(day, convert(date,NgayBatDauLam),'01/01/2009') else 0 end
	from NhanVien 
	where NhanVienID = @NhanVienID)

	declare @B int = (select
	case
		when year(hd.NgayBatDau) <= 2009 and year(hd.NgayKetThuc) <= 2009 then 0
		else
			case
				when hd.NgayBatDau is not null then datediff(day,convert(date,hd.NgayBatDau), convert(date,hd.NgayKetThuc)) 
				else 0
			end
	end
	from NhanVien nv left join NS_HopDong hd on nv.NhanVienID = hd.NhanVienID
	where nv.NhanVienID = @NhanVienID and hd.LoaiHopDongID in (27))

	declare @C int = (select sum(datediff(day,NgayBatDau,NgayKetthuc)) from NS_QTDongBHXH where NhanVienID= @NhanVienID and LoaiBienDongID in (8,9))
	
	declare @TongSoThangTC decimal(18,2) =(((isnull(@A,0) + isnull(@B,0) + isnull(@C,0)) /30) +isnull(@SoThangTSKDBH,0)+isnull(@SoThangTVKDBH,0))/12.0
	declare @SoNgayDKTP decimal(18,2)=isnull((select  ABS( @TongSoThangTC) - FLOOR(ABS( @TongSoThangTC))),0)

	set  @TongSoThangTC = case when  @SoNgayDKTP>0.5 then FLOOR(ABS( @TongSoThangTC))+1 else FLOOR(ABS( @TongSoThangTC))+0.5 end 
	--update NS_NhanVien_NghiViec set SoThangTinhTroCap = ((isnull(@A,0) + isnull(@B,0) + isnull(@C,0)) /30) +isnull(@SoThangTSKDBH,0)+isnull(@SoThangTVKDBH,0) where NhanVienNghiViecID=@NhanVienNghiViecID
	--update NS_NhanVien_NghiViec set SoThangTinhTroCap = @TongSoThangTC*12 where NhanVienNghiViecID=@NhanVienNghiViecID
	set  @SoThangTinhTroCap = @TongSoThangTC*12 --(isnull(@A,0) + isnull(@B,0) + isnull(@C,0)) /30  
end


--================= Tính lương trung bình
--if(isnull(@LTB,0) = 0)
--begin
	set @TrungBinhLuong =  dbo.BHXH_TINHTRUNGBINHLUONG6T(@NhanVienID,MONTH(@ThoiGianNghiViec),YEAR(@ThoiGianNghiViec))
	--update NS_NhanVien_NghiViec set LuongTrungBinh = @TrungBinhLuong where NhanVienNghiViecID=@NhanVienNghiViecID
--end

if (@IsTroCapThoiViec>0)
begin
	--update NS_NhanVien_NghiViec set TroCapThoiViec= isnull(@TrungBinhLuong,0)*((@SoThangTinhTroCap)/12.0*0.5)   where NhanVienNghiViecID=@NhanVienNghiViecID
	set @SoTienTroCap = isnull(@TrungBinhLuong,0)*((@SoThangTinhTroCap)/12.0*0.5)
end

return @SoTienTroCap

end
GO
