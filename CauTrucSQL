GO
CREATE PROCEDURE [dbo].[Tax_Build_Thang]  
    @Thang INT,  
    @Nam   INT  
AS  
BEGIN  
    SET NOCOUNT ON;  
  
    DELETE dbo.ADD_Tax_Thang  
    WHERE Thang = @Thang AND Nam = @Nam;  
  
 --xử lý bảng lương 2 dòng nếu import  
    ;WITH BL_HopLe AS  
    (  
        SELECT  
            bl.BangLuongID,  
            ct.NhanVienID,  
            SUM(CASE WHEN ll.MaSo = 'ThucLinh' THEN ct.TienLuong ELSE 0 END) AS TienThucLinh,  
            ROW_NUMBER() OVER  
            (  
                PARTITION BY ct.NhanVienID,  
                             SUM(CASE WHEN ll.MaSo = 'ThucLinh' THEN ct.TienLuong ELSE 0 END)  
                ORDER BY bl.BangLuongID  
            ) AS RN  
        FROM dbo.ADD_NS_TL_BangLuong_ChiTraThucTe bl  
        JOIN dbo.ADD_NS_TL_ChiTietLuong_ChiTraThucTe ct ON bl.BangLuongID = ct.BangLuongID  
        JOIN dbo.NS_TL_LoaiLuong ll ON ll.LoaiLuongID = ct.LoaiLuongID  
        WHERE bl.Thang = @Thang  
          AND bl.Nam   = @Nam  
        GROUP BY bl.BangLuongID, ct.NhanVienID  
    )  
    INSERT INTO dbo.ADD_Tax_Thang  
    (  
        NhanVienID, Thang, Nam,  
        ThuNhapChiuThue,  
        GiamTruBanThan,  
        GiamTruNguoiPT,  
        SoNguoiPhuThuoc,  
        ThuNhapTinhThue,  
        TongThueKhauTru,  
        BH_Tong_NLD  
    )  
    SELECT  
        ct.NhanVienID,  
        @Thang,  
        @Nam,  
        SUM(CASE WHEN ll.MaSo = 'Tax_ThuNhapChiuThue'       THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'Tax_GiamTru_BanThan'       THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'Tax_GiamTru_NguoiPhuThuoc' THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'Tax_SoNguoiPhuThuoc'       THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'Tax_ThuNhapTinhThue'      THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'Tax_TongThue'             THEN ct.TienLuong ELSE 0 END),  
        SUM(CASE WHEN ll.MaSo = 'BH_Tong_NLD'              THEN ct.TienLuong ELSE 0 END)  
    FROM BL_HopLe blhl  
    JOIN dbo.ADD_NS_TL_ChiTietLuong_ChiTraThucTe ct ON blhl.BangLuongID = ct.BangLuongID  
    JOIN dbo.NS_TL_LoaiLuong ll ON ll.LoaiLuongID = ct.LoaiLuongID  
    WHERE blhl.RN = 1  
    GROUP BY ct.NhanVienID;  
  
    SELECT N'Tổng hợp thu nhập tính thuế tháng thành công !' AS Mess,*  
    FROM dbo.ADD_Tax_Thang  
    WHERE Thang = @Thang AND Nam = @Nam;  
END;  
GO
/****** Object:  StoredProcedure [dbo].[Tax_QuyetToanTNCN_Nam]    Script Date: 03/04/2026 16:11:45 ******/
