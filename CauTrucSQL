CREATE proc [dbo].[ADD_ThucHienDongYPheDuyet]    
@ID int, @LyDo nvarchar(500), @XDID int , @YKien nvarchar(500)     
as                  
begin             
  declare @MaLoaiQuyTrinh Nvarchar(50) =( select MaLoaiQuyTrinh from  WF_QuyTrinh where QuyTrinhID =(select QuyTrinhID from  SYS_XetDuyet where XetDuyetID = @XDID))                
  declare @ObjectCode nvarchar(150) =(select ObjectCode from  SYS_XetDuyet where XetDuyetID = @XDID)                           
  declare @ObjectID  int =(select ObjectID from  SYS_XetDuyet where XetDuyetID = @XDID)                    
  declare @NgayBD date, @NgayKT date, @NhanVienID int                
  declare @Todate date = getdate()      
    
if(@MaLoaiQuyTrinh='DXNV')    
begin    
  update DX_DeXuat set XetDuyet = 1 where DeXuatID = @ID    
    
  DECLARE @NgayDeXuatNghiViec DATE = (SELECT GiaTriDateTime FROM dbo.DX_DeXuat_DuLieuDeXuat  
  INNER JOIN dbo.DX_DeXuat ON DX_DeXuat.DeXuatID = DX_DeXuat_DuLieuDeXuat.DeXuatID  
  INNER JOIN dbo.DX_LoaiDeXuat_TruongDuLieu ON DX_LoaiDeXuat_TruongDuLieu.TruongDuLieuID = DX_DeXuat_DuLieuDeXuat.TruongDuLieuID  
  WHERE DX_DeXuat.DeXuatID = @ID AND DX_DeXuat_DuLieuDeXuat.TenTruongDuLieu = N'Ngày nghỉ việc')  
  
  DECLARE @LyDoNghiViec INT = (SELECT CONVERT(INT,GiaTri) FROM dbo.DX_DeXuat_DuLieuDeXuat  
  INNER JOIN dbo.DX_DeXuat ON DX_DeXuat.DeXuatID = DX_DeXuat_DuLieuDeXuat.DeXuatID  
  INNER JOIN dbo.DX_LoaiDeXuat_TruongDuLieu ON DX_LoaiDeXuat_TruongDuLieu.TruongDuLieuID = DX_DeXuat_DuLieuDeXuat.TruongDuLieuID  
  WHERE DX_DeXuat.DeXuatID = @ID AND DX_DeXuat_DuLieuDeXuat.TenTruongDuLieu = N'Lý do nghỉ việc')  
  
  SET @NhanVienID =  (SELECT NguoiDeXuatID FROM dbo.DX_DeXuat WHERE DeXuatID = @ID)  
    
  INSERT INTO NS_NhanVien_NghiViec(NhanVienID,NgayQuyetDinh,LyDoNghiViecID,HinhThucNghiViecID,NgayHieuLuc,XetDuyet)  
  SELECT @NhanVienID,GETDATE(),@LyDoNghiViec,1,@NgayDeXuatNghiViec,1  
  
  IF CONVERT(DATE,@NgayDeXuatNghiViec) <= CONVERT(DATE,GETDATE())  
  BEGIN  
      UPDATE dbo.NhanVien SET TrangThaiID = 11,NghiViec = 1, NgayNghiViec = @NgayDeXuatNghiViec  
   WHERE NhanVienID = @NhanVienID  
  END  
  
   
end   
ELSE IF (@MaLoaiQuyTrinh='DXBG')
BEGIN
    update DX_DeXuat set XetDuyet = 1 where DeXuatID = @ID    
END
ELSE IF (@MaLoaiQuyTrinh='XD_TD_NHUCAU')
BEGIN
    update NS_TD_NhuCauTuyenDung set TrangThai=1 where NhuCauTuyenDungID=@ID
	UPDATE NS_TD_NhuCauTuyenDung set YKienPheDuyet=(select NguoiXetDuyet+' - '+GhiChu as NguoiDuyet_YKien from WF_QuyTrinh_ThucHien 
	WHERE QuyTrinhThucHienID=(select max(QuyTrinhThucHienID) as QuyTrinhThucHienID from WF_QuyTrinh_ThucHien
	WHERE XetDuyetID=(select XetDuyetID from SYS_XetDuyet where ObjectID=@ID and ObjectCode='NS_TD_NhuCauTuyenDung'))) where NhuCauTuyenDungID=@ID
END

    
    
end          
    
    
GO
