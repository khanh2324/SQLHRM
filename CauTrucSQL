CREATE FUNCTION [dbo].[BHXH_LayHDDauTien](@NhanVienID int)    RETURNS DateTime     WITH EXECUTE AS CALLER    
AS    
BEGIN    
        DECLARE @Result DateTime =         
        (          
            SELECT TOP 1 WITH TIES NgayBatDau FROM NS_HopDong  WHERE NhanVienID = @NhanVienID        
            AND LoaiHopDongID  in (SELECT LoaiHopDongID FROM NS_DsLoaiHopDong where CHARINDEX ( CONCAT(',', MaLoaiHD,','), (SELECT CONCAT(',', GiaTri,',') FROM  SYS_ThongSo where MaSo ='HSNS_MA_HDCT')) > 0)       
            ORDER BY ROW_NUMBER() OVER (PARTITION BY  NhanVienID ORDER BY  NgayBatDau asc)        
        )        
return @Result
END    
    
  
GO
