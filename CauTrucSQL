CREATE Function [dbo].[Cloud_Nhanvien_CungPhongBan]
(
@NhanVienID int
)
Returns Nvarchar(3000)
begin
Declare @PhongBanID int= (Select PhongBanId from NhanVien where NhanvienID = @NhanVienID)

Declare @DsNhanVien nvarchar(3000) 
Set @DsNhanVien = (
					Select  ' <tr><td>' + convert(nvarchar(100), STT) +  '.  </td><td>' + TenNV + '</td></tr>' 
					from
						(
							Select  top 5 ROW_NUMBER () over (Order by  Ns_DschucDanh.ThuTu, Nhanvien.NgayBatdauLam) As STT,
							Ho + ' '+ Hoten  + ' - ' + Ns_dsChucVu.TenChucVu as TenNV, NS_DsChucDanh.ThuTu
							from NhanVien 
								left join NS_DsTrinhDo on NS_DsTrinhDo.TrinhDoID = NhanVien.TrinhDoID
								left join NS_DsChucVu on Nhanvien.ChucVuID = NS_DsChucVu.ChucVuID 
								left join NS_DsChucDanh on Nhanvien.ChucDanhID =  NS_DsChucDanh.ChucDanhID
							--where NhanVien.PhongBanID = @PhongBanID
						) as DsNV
					For xml path('')
					)
	Set @DsNhanVien = '<table border="0"> ' + @DsNhanVien +  '</table>'
	Set @DsNhanVien = REPLACE(@DsNhanVien, '&lt;', '<')
	Set @DsNhanVien = REPLACE(@DsNhanVien, '&gt;', '>')
	return @DsNhanVien
end
GO
