CREATE FUNCTION [dbo].[TNCN](@TNCT int)
RETURNS int
AS
 begin
  if @TNCT < 0 RETURN 0
  if @TNCT > 80000000
  set @TNCT = @TNCT *0.35 - 9850000  
  else if @TNCT > 52000000
  set @TNCT = @TNCT * 0.3 - 5850000
  else if @TNCT > 32000000
  set @TNCT=@TNCT * 0.25 - 3250000
  else if @TNCT > 18000000
  set @TNCT=@TNCT * 0.2 - 1650000
  else if @TNCT > 10000000
  set @TNCT=@TNCT * 0.15 - 750000
  else if @TNCT > 5000000
  set @TNCT=@TNCT * 0.1 - 250000
  else set @TNCT=@TNCT*0.05
 return @TNCT
end

