CREATE PROCEDURE [dbo].[Email_LayThongSoDanhGia]    
@NhomDanhGiaID int, @DotDanhGiaID int    
AS    
BEGIN    
    
Declare @NguoiTuChoiID int =(SELECT TOP 1 NguoiTuChoiID FROM NS_DG_DanhGia_Huy WHERE DotDanhGiaID = @DotDanhGiaID  ORDER BY DanhGiaHuyID DESC);    
    
    
    
 WITH TuDanhGia AS (    
    SELECT    
        DotDanhGiaID,    
        CONVERT(NVARCHAR, NgayDanhGia, 103) AS NgayTuDanhGia,    
        TenNguoiDanhGia AS TenNguoiTuDanhGia     
    FROM           
            NS_DG_DanhGia    
        WHERE    
            DotDanhGiaID = @DotDanhGiaID    
            AND IsTuDanhGia = 1    
 ),    
 NguoiDuyetMoiNhat AS (    
     SELECT    
         DotDanhGiaID,    
         CONVERT(NVARCHAR, NgayDanhGia, 103) AS NgayDuyetQuanLy,    
         TenNguoiDanhGia AS TenNguoiDuyetQuanLy    
     FROM    
         (SELECT    
             DotDanhGiaID,    
             NgayDanhGia,    
             TenNguoiDanhGia,    
             ROW_NUMBER() OVER(PARTITION BY DotDanhGiaID ORDER BY DanhGiaID DESC) AS rn    
         FROM    
             NS_DG_DanhGia    
         WHERE    
             DotDanhGiaID = @DotDanhGiaID    
             AND IsTuDanhGia = 0    
         ) AS RankedQLTTDanhGia    
     WHERE    
         rn = 1    
 )    
 SELECT    
     ddg.DotDanhGiaID,    
     ddg.TenDotDanhGia,    
     ddg.MaDotDanhGia,    
     ddg.MaNhanVien,    
     ddg.HoVaTen,
	 dbo.fuChuyenCoDauThanhKhongDau(ddg.HoVaTen) FullName,
     ddg.TenPhongBan,    
     ddg.TenChucVu,    
     CASE    
         WHEN nv.GioiTinh = N'Nam' THEN N'Anh'    
         WHEN nv.GioiTinh = N'Nữ' THEN N'Chị'    
         ELSE N'Khác'    
     END AS GioiTinh,
	 CASE    
         WHEN nv.GioiTinh = N'Nam' THEN N'Mr'    
         WHEN nv.GioiTinh = N'Nữ' THEN N'Ms'    
         ELSE N'Mr'    
     END AS Gender,
     CONVERT(NVARCHAR, ddg.NBD_DanhGia, 103) AS NBD_DanhGia,    
     CONVERT(NVARCHAR, ddg.NKT_DanhGia, 103) AS NKT_DanhGia,    
     CONVERT(NVARCHAR, ddg.NBD_NhapChiTieu, 103) AS NBD_NhapChiTieu,    
     CONVERT(NVARCHAR, ddg.NKT_NhapChiTieu, 103) AS NKT_NhapChiTieu,    
     ddg.Nam AS NS_DG_DotDanhGia,       
     ddg.Thang ,    
     ddg.Nam,    
      CASE    
         WHEN ddg.TrangThai = -1 THEN N'Nhập chỉ tiêu'    
         WHEN ddg.TrangThai = 0 THEN N'Tự đánh giá'    
         ELSE N'Đánh giá theo quy trình'    
     END AS TrangThaiStr,    
     ddg.CreatedDate,    
     ddg.TongDiem,    
     ddg.GhiChu AS LyDoTuChoi,    
     case when qlt.TenNguoiDuyetQuanLy is not null then qlt.TenNguoiDuyetQuanLy    
       else (select ND_HoVaTen from SYS_NguoiDung where SYS_NguoiDung.NguoiDungID = ddg.QuanLyTrucTiepID) END    
       AS HoVaTen_QL,    
      
  (SELECT NhanVien.Ho+' '+NhanVien.HoTen FROM  sys_nguoidung inner join nhanvien on nhanvien.nhanvienid=sys_nguoidung.nhanvienid     
  where sys_nguoidung.nguoidungid in (@NguoiTuChoiID))  TuChoi_HoVaTenQL ,    
   --QLDG.Ho+' '+QLDG.HoTen as DongY_HoVaTenQL,    
     
    case when qlt.NgayDuyetQuanLy is not null then qlt.NgayDuyetQuanLy    
      else CONVERT(NVARCHAR, GETDATE(), 103) end     
      as NgayDuyet,    
     case when tdg.NgayTuDanhGia is not null then tdg.NgayTuDanhGia     
      else CONVERT(NVARCHAR, GETDATE(), 103) end as NgayDanhGia,    
     ddg.LyDoTuChoiPheDuyetMucTieu,    
     CONVERT(NVARCHAR, GETDATE(), 103) AS NgayTuChoiMucTieu    
 FROM    
     NS_DG_DotDanhGia AS ddg    
 INNER JOIN    
     NS_DG_QuyTrinh AS qt ON qt.QuyTrinhID = ddg.QuyTrinhID    
 LEFT JOIN    
     SYS_NguoiDung AS snd ON snd.NguoiDungID = ddg.NguoiXetDuyetMucTieuID    
 LEFT JOIN    
     NS_DG_QuyTrinh_BuocThucHien AS qtbh ON qtbh.BuocThucHienID = ddg.BuocThucHienTiepTheoID    
 LEFT JOIN    
     NhanVien AS nv ON nv.NhanVienID = ddg.NhanVienID    
 LEFT JOIN    
     TuDanhGia AS tdg ON tdg.DotDanhGiaID = ddg.DotDanhGiaID -- Join với CTE Tự đánh giá    
 LEFT JOIN    
     NguoiDuyetMoiNhat AS qlt ON qlt.DotDanhGiaID = ddg.DotDanhGiaID -- Join với CTE QLTT    
 LEFT JOIN    
     SYS_NguoiDung AS NDDG ON NDDG.NguoiDungID = ddg.NguoiXetDuyetTiepTheoID    
 left join nhanvien QLDG on  QLDG.NhanVienID=NDDG.NhanVienID    
     
     
     
 WHERE    
     ddg.NhomDanhGiaID = @NhomDanhGiaID    
     AND ddg.DotDanhGiaID = @DotDanhGiaID;     
     
/*    
SELECT  DotDanhGiaID, TenDotDanhGia, MaDotDanhGia, NS_DG_DotDanhGia.MaNhanVien, HoVaTen, TenPhongBan, TenChucVu,    
case when GioiTinh=N'Nam' then N'Anh' when GioiTinh=N'Nữ' then N'Chị'  else N'Khác' end GioiTinh,    
            convert(nvarchar,NBD_DanhGia,103) NBD_DanhGia, convert(nvarchar,NKT_DanhGia,103)NKT_DanhGia    
      , convert(nvarchar,NBD_NhapChiTieu,103) NBD_NhapChiTieu, convert(nvarchar,NKT_NhapChiTieu,103)NKT_NhapChiTieu ,    
      NS_DG_DotDanhGia.Nam NS_DG_DotDanhGia,NS_DG_DotDanhGia.Thang,NS_DG_DotDanhGia.Nam,    
            case     
             when TrangThai=-1 then N'Nhập chỉ tiêu'    
             when TrangThai=0  then N'Tự đánh giá'    
             else N'Đánh giá theo quy trình'    
            end as TrangThaiStr,NS_DG_DotDanhGia.CreatedDate, TongDiem, NS_DG_DotDanhGia.GhiChu as LyDoTuChoi,    
            Case     
                When NS_DG_DotDanhGia.NguoiXetDuyetMucTieuID>0 Then SYS_NguoiDung.ND_HoVaTen     
                ELSE HoVaTen_NguoiDuyetMucTieu    
           end as HoVaTen_QL     , (SELECT top 1 convert(nvarchar,NgayDanhGia,103) FROM  NS_DG_DanhGia where DotDanhGiaID= @DotDanhGiaID and TenBuocDanhGia=N'Quản lý trực tiếp' ) as NgayDuyet,    
     (SELECT top 1 convert(nvarchar,NgayDanhGia,103) FROM  NS_DG_DanhGia where DotDanhGiaID= @DotDanhGiaID and TenBuocDanhGia=N'Tự đánh giá' ) as NgayDanhGia    
    ,LyDoTuChoiPheDuyetMucTieu, convert(nvarchar,GETDATE(),103) as NgayTuChoiMucTieu    
            FROM NS_DG_DotDanhGia    
                inner join NS_DG_QuyTrinh on NS_DG_QuyTrinh.QuyTrinhID = NS_DG_DotDanhGia.QuyTrinhID    
                left join SYS_NguoiDung on SYS_NguoiDung.NguoiDungID = NS_DG_DotDanhGia.NguoiXetDuyetMucTieuID    
                left join NS_DG_QuyTrinh_BuocThucHien QT on QT.BuocThucHienID = NS_DG_DotDanhGia.BuocThucHienTiepTheoID    
        left join nhanvien on nhanvien.nhanvienid= NS_DG_DotDanhGia.NhanVienID    
            WHERE --(1=1) AND (NS_DG_DotDanhGia.PhongBanID in (SELECT Valu FROM dbo.GetPhongBanChilds(3262))) AND     
      --(NS_DG_DotDanhGia.TrangThai=0)  and NS_DG_DotDanhGia.nhanvienid=@NhanVienID and    
       NhomDanhGiaID=@NhomDanhGiaID and DotDanhGiaID=@DotDanhGiaID    
*/           
    
END    
GO
