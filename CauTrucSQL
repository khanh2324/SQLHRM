CREATE PROCEDURE [dbo].[ChotPhepNam]
	@Nam int
AS
BEGIN
	delete NS_TL_PhepTon where Nam=@Nam
declare @Date date=convert(date,'12/31/'+convert(nvarchar,@Nam))
declare @tbl table (NhanVienID int)
insert into @tbl
select NhanVienID from NhanVien where NhanVien.NgayBatDauLam<=@Date
and (isnull(NhanVien.NghiViec,0)=0 or (NhanVien.NghiViec=1 and year(NhanVien.NgayNghiViec)>@Nam))
declare @Dem int = (select count(*) from @tbl)
declare @NVID int
while(@Dem!=0)
	begin
		set @NVID=(select top 1 NhanVienID from @tbl)
		exec dbo.HS_UpdatePhepTheoQuyDinh @NVID,@Date
		insert into NS_TL_PhepTon(NhanVienID,Nam,PhepTon)
		select @NVID,@Nam,SoPhepConLai from NhanVien where NhanVienID=@NVID
		delete @tbl where NhanVienID=@NVID
		set @Dem = (select count(*) from @tbl)
	end
END
GO
/****** Object:  StoredProcedure [dbo].[DanhGiaLaiXe]    Script Date: 03/04/2026 16:11:45 ******/
