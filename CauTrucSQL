create Function [dbo].[DsDonVi_ChucVu]
(
@PhongBanId int
)
Returns @Tb table (STT nvarchar(100),PhongBanID int, ChucVuID int, PhongBan nvarchar(100), TenChucVu nvarchar(100), level int, ThuTu int, PhongBanchaID int)

as
begin
Insert into @Tb
	Select STT ,
			PhongBanID, ChucVuID, PhongBan, TenChucVu, level, ThuTu , PhongBanchaID
	from
	(
		Select NULL as STT,
			PhongBanId,  Ten PhongBan , level, ThuTu , PhongBanchaID , 0 as ChucVuID, '' as TenChucVu
		from PhongBan where PhongBanId in (Select valu from GetPhongBanChilds(@PhongBanID))
	
	union
		Select ROW_NUMBER() over (Partition by ten order by PhongBanID, ChucVuId ) STT, * 
		from
			(Select distinct PhongBan.PhongbanID ,PhongBan.Ten, 0 AAAA, PhongBan.ThuTu, PhongBan.PhongBanChaID, NS_DsChucVu.ChucVuID, NS_DsChucVu.TenChucVu
			from Nhanvien inner join PhongBan on NhanVien.PhongBanID= PhongBan.PhongBanID
			inner join NS_DsChucVu on NhanVien.ChucVuID = NS_DsChucVu.ChucVuID
			where PhongBan.Phongbanid in (Select valu from GetPhongBanChilds(@PhongBanID))
			) ABC
	) A
	order by PhongBanid, ChucvuID
	
	return
end
GO
