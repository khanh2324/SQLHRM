GROUP BY
    pb.PhongBanID,
	pb.MaPhongBan,
    pb.Ten,
    YEAR(cc.NgayChamCong),
    MONTH(cc.NgayChamCong)
ORDER BY
    pb.Ten,
    YEAR(cc.NgayChamCong),
    MONTH(cc.NgayChamCong);

