and WF_QuyTrinh_ThucHien.QuyTrinhThucHienID  = (select MAX(quytrinhthuchienid) from WF_QuyTrinh_ThucHien as a
where a.XetDuyetID = SYS_XetDuyet.XetDuyetID)
)

