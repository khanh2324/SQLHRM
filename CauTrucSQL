sum(isnull(Bangluong.TLNC_PC_TrachNhiem, 0)) - sum(isnull(Bangluong.TLNC_PC_TrachNhiem_TT, 0)) AS TLNC_PC_TrachNhiem,
sum(isnull(Bangluong.TLNC_LCB, 0)) - sum(isnull(Bangluong.TLNC_LCB_TT, 0)) AS TLNC_LCB,
sum(isnull(Bangluong.CC_GCC, 0)) - sum(isnull(Bangluong.CC_GCC_TT, 0)) AS CC_GCC,
sum(isnull(Bangluong.CC_TongCong, 0)) - sum(isnull(Bangluong.CC_TongCong_TT, 0)) AS CC_TongCong,
sum(isnull(Bangluong.CC_NghiCheDo, 0)) - sum(isnull(Bangluong.CC_NghiCheDo_TT, 0)) AS CC_NghiCheDo,
sum(isnull(Bangluong.CC_NghiCoLuong, 0)) - sum(isnull(Bangluong.CC_NghiCoLuong_TT, 0)) AS CC_NghiCoLuong,
sum(isnull(Bangluong.CC_CongTac, 0)) - sum(isnull(Bangluong.CC_CongTac_TT, 0)) AS CC_CongTac,
sum(isnull(Bangluong.CC_NghiBu, 0)) - sum(isnull(Bangluong.CC_NghiBu_TT, 0)) AS CC_NghiBu,
sum(isnull(Bangluong.CC_NghiLe, 0)) - sum(isnull(Bangluong.CC_NghiLe_TT, 0)) AS CC_NghiLe,
sum(isnull(Bangluong.CC_NghiPhep, 0)) - sum(isnull(Bangluong.CC_NghiPhep_TT, 0)) AS CC_NghiPhep,
sum(isnull(Bangluong.CC_XD, 0)) - sum(isnull(Bangluong.CC_XD_TT, 0)) AS CC_XD,
sum(isnull(Bangluong.CC_XN, 0)) - sum(isnull(Bangluong.CC_XN_TT, 0)) AS CC_XN,
sum(isnull(Bangluong.QD_TongLuong_PhuCap, 0)) - sum(isnull(Bangluong.QD_TongLuong_PhuCap_TT, 0)) AS QD_TongLuong_PhuCap,
sum(isnull(Bangluong.QD_ThuongThang, 0)) - sum(isnull(Bangluong.QD_ThuongThang_TT, 0)) AS QD_ThuongThang,
sum(isnull(Bangluong.QD_PC_BuaAn, 0)) - sum(isnull(Bangluong.QD_PC_BuaAn_TT, 0)) AS QD_PC_BuaAn,
sum(isnull(Bangluong.QD_PC_Khac, 0)) - sum(isnull(Bangluong.QD_PC_Khac_TT, 0)) AS QD_PC_Khac,
sum(isnull(Bangluong.QD_PC_DocHai, 0)) - sum(isnull(Bangluong.QD_PC_DocHai_TT, 0)) AS QD_PC_DocHai,
sum(isnull(Bangluong.QD_PC_DiLai, 0)) - sum(isnull(Bangluong.QD_PC_DiLai_TT, 0)) AS QD_PC_DiLai,
sum(isnull(Bangluong.QD_PC_ViTri, 0)) - sum(isnull(Bangluong.QD_PC_ViTri_TT, 0)) AS QD_PC_ViTri,
sum(isnull(Bangluong.QD_PC_TrachNhiem, 0)) - sum(isnull(Bangluong.QD_PC_TrachNhiem_TT, 0)) AS QD_PC_TrachNhiem,
sum(isnull(Bangluong.QD_LCB, 0)) - sum(isnull(Bangluong.QD_LCB_TT, 0)) AS QD_LCB
    FROM
    (
        SELECT Bl.Thang,
               Bl.Nam,
               LL.MaSo,
               ISNULL(Ctl.TienLuong, 0) TienLuong,
               Bl.NhanVienID
        FROM dbo.NS_TL_BangLuong Bl
            JOIN dbo.NS_TL_ChiTietLuong Ctl
                ON Ctl.BangLuongID = Bl.BangLuongID
            JOIN dbo.NS_TL_LoaiLuong LL
                ON LL.LoaiLuongID = Ctl.LoaiLuongID
			JOIN @BLT ON [@BLT].NhanVienID = Bl.NhanVienID AND ThucLinhT1!=ThucLinhT2
				cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(bl.NhanVienID, @Date) pb1      
				left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
			    cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(bl.NhanVienID, @Date) ddlv  
	 			left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId

        WHERE (
                  Bl.Nam = @Nam
                  AND Bl.Thang = @Thang
              )
              AND pb.PhongBanID IN
                  (
                      SELECT valu FROM dbo.GetPhongBanChild_WUser(@PhongBanID, @DangNhapID)
                  )
				  AND pb.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
              AND
              (  kv.KhuVucID = @DiaDiemID
                  OR @DiaDiemID = 0
                  OR @DiaDiemID = -1001
              )
              AND Bl.NhanVienID IN
                  (
                      SELECT NhanVien.NhanVienID
                      FROM dbo.NhanVien
                      WHERE (
                                NhanVien.NhomNhanSuId = @NhomNhanSuID
                                OR ISNULL(@NhomNhanSuID, 0) = 0
                                OR @NhomNhanSuID = -1001
                            )
                  )
-----------------------
union all
        SELECT Bl.Thang,
               Bl.Nam,
               LL.MaSo + '_TT' as MaSo,
               ISNULL(Ctl.TienLuong, 0) TienLuong,
               Bl.NhanVienID
        FROM dbo.NS_TL_BangLuong Bl
            JOIN dbo.NS_TL_ChiTietLuong Ctl
                ON Ctl.BangLuongID = Bl.BangLuongID
            JOIN dbo.NS_TL_LoaiLuong LL
                ON LL.LoaiLuongID = Ctl.LoaiLuongID
			JOIN @BLT ON [@BLT].NhanVienID = Bl.NhanVienID AND ThucLinhT1!=ThucLinhT2
				cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(bl.NhanVienID, @Date_TT) pb1      
				left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
			    cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(bl.NhanVienID, @Date_TT) ddlv  
	 			left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId

        WHERE (
                  Bl.Nam = year(@Date_TT)
                  AND Bl.Thang = month(@Date_TT)
              )
              AND pb.PhongBanID IN
                  (
                      SELECT valu FROM dbo.GetPhongBanChild_WUser(@PhongBanID, @DangNhapID)
                  )
              AND
              (  kv.KhuVucID = @DiaDiemID
                  OR @DiaDiemID = 0
                  OR @DiaDiemID = -1001
              )
              AND Bl.NhanVienID IN
                  (
                      SELECT NhanVien.NhanVienID
                      FROM dbo.NhanVien
                      WHERE (
                                NhanVien.NhomNhanSuId = @NhomNhanSuID
                                OR ISNULL(@NhomNhanSuID, 0) = 0
                                OR @NhomNhanSuID = -1001
                            )
                  )
    ) Bangluong
    PIVOT
    (
        SUM(TienLuong)
        FOR MaSo IN ([QD_LCB], [QD_LCB_New], [QD_PC_TrachNhiem], [QD_PC_TrachNhiem_New], [QD_PC_ViTri],
                     [QD_PC_ViTri_New], [QD_PC_DiLai], [QD_PC_DiLai_New], [QD_PC_DocHai], [QD_PC_DocHai_New],
                     [QD_PC_Khac], [QD_PC_Khac_New], [QD_PC_BuaAn], [QD_PC_BuaAn_New], [QD_ThuongThang],
                     [QD_ThuongThang_New], [QD_TongLuong_PhuCap], [QD_TongLuong_PhuCap_New], [CC_XN], [CC_XD],
                     [CC_NghiPhep], [CC_NghiLe], [CC_NghiBu], [CC_CongTac], [CC_NghiCheDo], [CC_NghiCoLuong],
                     [CC_TongCong], [CC_GCC], [TLNC_LuongGio], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri],
                     [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn], [TLNC_ThuongThang],
                     [TLNC_TongLuong_Thuong_PhuCap], [TLNC_TongLuong_Thuong_PhuCap_Gop], [CC_TongGioOT],
                     [CC_TongGioOT_NoneTax], [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem],
                     [TLOT_TongLuongOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem_Gop], [Thuong_KM_IP], [Thuong_KM],
                     [Thuong_KPI_IP], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam_IP], [Thuong_Nam],
                     [Thuong_ChenhLechT1_IP], [Thuong_ChenhLechT1], [Thuong_CongTruocThue_IP], [Thuong_CongTruocThue],
                     [Thuong_TruTruocThue_IP], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap],
                     [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong], [Tax_ThuNhapMienThue],
