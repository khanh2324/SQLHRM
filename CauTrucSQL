CREATE PROCEDURE [dbo].[ESS_OTREG_GETNOTIFY]
@BDLamSauCa TIME(7),@BDLamTruocCa TIME(7),@CaLamViecID INT,@DienGiaiTangCa NVARCHAR(500),@KTLamSauCa TIME(7),@KTLamTruocCa TIME(7)
,@LyDoTangCaID INT,@NguoiDungID INT, @NhanVienID INT,@SoGioLamSauCa DECIMAL(18,1),@SoGioLamTruocCa DECIMAL(18,1),@NgayDangKy DATETIME,@DangKyOTID INT AS

BEGIN

--DECLARE @BDLamSauCa TIME(7),@BDLamTruocCa TIME(7),@CaLamViecID INT,@DienGiaiTangCa NVARCHAR(500),@KTLamSauCa TIME(7),@KTLamTruocCa TIME(7)
--,@LyDoTangCaID INT,@NguoiDungID INT, @NhanVienID INT,@SoGioLamSauCa DECIMAL(18,1),@SoGioLamTruocCa DECIMAL(18,1),@NgayDangKy DATETIME,@DangKyOTID INT
--SET @BDLamSauCa='00:00:00' SET @BDLamTruocCa='08:00:00' SET @CaLamViecID=68 SET @DangKyOTID=0 SET @DienGiaiTangCa=N'test3' SET 
--@KTLamSauCa='00:00:00' SET @KTLamTruocCa='12:00:00' SET @LyDoTangCaID=2 SET @NgayDangKy='2025-06-28 09:06:07.130' SET @NguoiDungID=3115 SET 
--@NhanVienID=40452 SET @SoGioLamSauCa=0 SET @SoGioLamTruocCa=0

DECLARE @NgayBD DATETIME, @NgayKT DATETIME;

-- Tính khoảng thời gian từ 26 tháng trước đến 25 tháng hiện tại dựa vào @NgayDangKy
SET @NgayBD = DATEFROMPARTS(YEAR(DATEADD(MONTH, -1, @NgayDangKy)), MONTH(DATEADD(MONTH, -1, @NgayDangKy)), 26);
SET @NgayKT = DATEFROMPARTS(YEAR(@NgayDangKy), MONTH(@NgayDangKy), 25);

	--DECLARE @isKhoaCong BIT = CASE WHEN (SELECT COUNT(*) FROM NS_TL_KhoaLuong WHERE Thang=MONTH(@NgayDangKy) AND Nam=YEAR(@NgayDangKy)) > 0 THEN 1 ELSE 0 END
	DECLARE @IsKhoaCong BIT = CASE
    WHEN EXISTS (
        SELECT 1
        FROM NS_TL_KhoaLuong
        WHERE @NgayDangKy >= DATEFROMPARTS(YEAR(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),
                                         MONTH(DATEADD(MONTH, -1, DATEFROMPARTS(Nam, Thang, 1))),26)
          AND @NgayDangKy <= DATEFROMPARTS(Nam, Thang, 25))
    THEN 1 ELSE 0 END;
	DECLARE @PhongBanID INT = (SELECT PhongBanID FROM NhanVien WHERE NhanVienID=@NhanVienID)
	DECLARE @Thu INT = (select Thu from NS_BH_NgayThang where Ngay=convert(date,@NgayDangKy))
	--DECLARE @LaNgayLe bit =(CASE WHEN (SELECT count(*) FROM NS_TL_NgayLe WHERE convert(date,@NgayDangKy) BETWEEN TuNgay AND ToiNgay AND  ISNULL( IsBuLe,0) = 0 )>0 THEN 1 ELSE 0 END)		
	--DECLARE @LaNgayNghiBuLe bit =(CASE WHEN ( SELECT count(*) FROM  NS_TL_NgayLe WHERE convert(date,@NgayDangKy) BETWEEN TuNgay AND ToiNgay AND  ISNULL( IsBuLe,0) = 1) >0 THEN 1 ELSE 0 END)
	declare @LaNgayLe bit = (select dbo.fns_XacDinhNgayLeCuaNhanVien(@NhanVienID, @NgayDangKy)) 
	declare @LaNgayNghiBuLe bit = (select dbo.fns_XacDinhNgayBuLeCuaNhanVien(@NhanVienID, @NgayDangKy)) 
	declare @LaNgayNghi bit = (select dbo.fns_XacDinhNgayNghiCuaNhanVien(@NhanVienID, @NgayDangKy)) 
	--DECLARE @SoPhutLamOT decimal(10,2) =(select sum(TongSoPhutDangKyLamThem) from NS_TL_DangKyOT where NhanVienID = @NhanVienID and month(NgayDangKy) = month(@NgayDangKy) and year(NgayDangKy) = year(@NgayDangKy) AND LyDoTangCaID = 1)
	DECLARE @SoPhutLamOT DECIMAL(10,2) = (
    SELECT SUM(TongSoPhutDangKyLamThem) FROM NS_TL_DangKyOT
    WHERE NhanVienID = @NhanVienID AND NgayDangKy BETWEEN @NgayBD AND @NgayKT AND LyDoTangCaID = 4)
	DECLARE @SoPhutLamOTNam decimal(10,2) =(select sum(TongSoPhutDangKyLamThem) from NS_TL_DangKyOT where NhanVienID = @NhanVienID and year(NgayDangKy) = year(@NgayDangKy) AND LyDoTangCaID = 4)
	--DECLARE @SoPhutLamOTTrongNam decimal(10,2) =(select sum(TongSoPhutDangKyLamThem) from NS_TL_DangKyOT where NhanVienID = @NhanVienID and year(NgayDangKy) = year(@NgayDangKy))
	


	DECLARE @NhomNV INT = (SELECT NhomNhanSuId FROM NhanVien WHERE NhanVienID = @NhanVienID)
	-- Xử lý trường hợp ca để xét OT ngày làm việc 4h và OT ngày nghỉ,lễ là 12h
	DECLARE @LoaiCongChuan NVARCHAR(50) = (SELECT MaLoaiCongChuan FROM NhanVien LEFT JOIN dbo.ADD_LoaiCongChuan ON ADD_LoaiCongChuan.LoaiCongChuanID = NhanVien.LoaiCongChuanID
	WHERE NhanVienID = @NhanVienID)

	DECLARE @CLV INT
	IF @LoaiCongChuan = '48H'
	BEGIN
	    SET @CLV = ISNULL((SELECT MAX(caLamViecID) FROM NS_TL_DangKyCong WHERE 
		CONVERT(DATE,NgayChamCong)=CONVERT(DATE,@NgayDangKy) AND NhanVienID=@NhanVienID AND XetDuyetCLV=1),0)
	END
	ELSE
	BEGIN
		--trưởng hợp 40H ko làm thứ 7 và ,44H có làm thứ 7
		IF (@LoaiCongChuan = '40h' AND @Thu IN (1,7)) OR (@LoaiCongChuan = '44h' AND @Thu IN (1))
		BEGIN
		    SET @CLV = 0
		END
		ELSE
		BEGIN SET @CLV =  @CaLamViecID END	

		if (@LaNgayLe = 1 or @LaNgayNghiBuLe = 1)
		begin
			set @CLV = 0
		end
	END

	declare @GioBatDau1_CLV time = (select GioBatDau1 from NS_CaLamViec where CaLamViecID = @CLV)
	declare @GioKetThuc1_CLV time = (select GioKetThuc1 from NS_CaLamViec where CaLamViecID = @CLV)
	declare @GioBatDau2_CLV time = (select GioBatDau2 from NS_CaLamViec where CaLamViecID = @CLV)
	declare @GioKetThuc2_CLV time = (select GioKetThuc2 from NS_CaLamViec where CaLamViecID = @CLV)
	declare @SoPhutTieuChuan int = (select SoPhutLamViecTieuChuan from NS_CaLamViec where CaLamViecID = @CLV)
	
	---An set TH ca đêm
	declare @NgayGioBatDau1_CLV Datetime, @NgayGioKetThuc1_CLV Datetime, @NgayGioBatDau2_CLV Datetime , @NgayGioKetThuc2_CLV Datetime,  @IsCaDem bit=0,
		@NgayGio_BDLamTruocCa Datetime, @NgayGio_KTLamTruocCa Datetime
	if (select IsLamSangNgayHomSau from NS_CaLamViec where CaLamViecID = @CLV)=1
	begin
		SELECT @NgayGioBatDau1_CLV = GioBatDau1, @NgayGioKetThuc1_CLV = GioKetThuc1, @NgayGioBatDau2_CLV = GioBatDau2, @NgayGioKetThuc2_CLV = GioKetThuc2, @IsCaDem = IsLamSangNgayHomSau
		FROM dbo.fnt_LayNgayGioLamViecTheoCa(@NhanVienID, convert(date,@NgayDangKy), @CaLamViecID)
		set @NgayGio_BDLamTruocCa = CAST(CAST(@NgayDangKy AS DATE) AS DATETIME) + CAST(@BDLamTruocCa AS DATETIME)
		set @NgayGio_KTLamTruocCa = CAST(CAST(@NgayDangKy AS DATE) AS DATETIME) + CAST(@KTLamTruocCa AS DATETIME)
	end
	---

	IF @LoaiCongChuan = '44h' AND @Thu IN (7)
	BEGIN
	    SET @GioBatDau2_CLV = '00:00:00'
	    SET @GioKetThuc2_CLV = '00:00:00'
	END

	DECLARE @LoaiNhanVienID INT = (SELECT LoaiNhanVienOTId FROM NhanVien WHERE NhanVienID = @NhanVienID)
	DECLARE @KhuVucId INT = (SELECT KhoGocID FROM dbo.NhanVien WHERE NhanVienid = @NhanVienID)
	declare @SoGioOTToiDa int =  isnull((SELECT TOP 1 SoGioOT FROM ADD_TongGioOT WHERE NgayHieuLuc <= @NgayDangKy AND KhuVucId = @KhuVucId ORDER BY NgayHieuLuc DESC),40)

	DECLARE @SoPhut INT;

	--Tính phút, nếu kết thúc >= bắt đầu thì tính bình thường, nếu nhỏ hơn thì tính qua đêm
	SET @SoPhut = DATEDIFF(MINUTE,CAST(@BDLamTruocCa AS DATETIME),
	CASE
		WHEN @KTLamTruocCa >= @BDLamTruocCa THEN CAST(@KTLamTruocCa AS DATETIME)
		ELSE DATEADD(DAY, 1, CAST(@KTLamTruocCa AS DATETIME))
	END);
	-- xử lý cộng số phút đăng ký vào tổng số phút OT
	SET @SoPhutLamOT = ISNULL(@SoPhutLamOT,0) + CONVERT(DECIMAL(10,2),@SoPhut)
	SET @SoPhutLamOTNam = ISNULL(@SoPhutLamOTNam,0) + CONVERT(DECIMAL(10,2),@SoPhut)
	-- xử lý cộng dồn số OT tối đa theo khu vực
	IF OBJECT_ID('tempdb..#DsOTToiDa') IS NOT NULL DROP TABLE #DsOTToiDa
	CREATE TABLE #DsOTToiDa (ThangThu INT,NgayHieuLuc DATETIME,NgayKetThuc DATETIME,GioOTToiDa DECIMAL(10,2),
	GioOTDaSuDung DECIMAL(10,2),GioDuChuyenTiep DECIMAL(10,2), GioOTDuocPhep DECIMAL(10,2))

	;WITH LichThang AS (
    SELECT 
        ROW_NUMBER() OVER (ORDER BY NgayHieuLuc) AS ThangThu,
        NgayHieuLuc,
        DATEADD(DAY, -1, LEAD(NgayHieuLuc, 1, '9999-12-31') OVER (ORDER BY NgayHieuLuc)) AS NgayKetThuc,
        KhuVucID,
        SoGioOT
    FROM ADD_TongGioOT WHERE KhuVucId = @KhuVucId
),
OT_DangKy AS (
    SELECT 
        d.NgayDangKy,
        d.NhanVienID,
        SUM(d.TongSoPhutDangKyLamThem)/60.0 AS TongGioOTDangKy
    FROM NS_TL_DangKyOT d
    WHERE d.NhanVienID = @NhanVienID AND LyDoTangCaID = 4
    GROUP BY d.NgayDangKy, d.NhanVienID
),
LichNhanVien AS (
    SELECT 
        l.ThangThu,
        l.NgayHieuLuc,
        l.NgayKetThuc,
        l.KhuVucID,
        l.SoGioOT AS GioOTToiDa,
        ISNULL(SUM(o.TongGioOTDangKy), 0) AS GioOTDaSuDung
    FROM LichThang l
    LEFT JOIN OT_DangKy o 
        ON o.NgayDangKy BETWEEN l.NgayHieuLuc AND l.NgayKetThuc
        AND o.NhanVienID = @NhanVienID
    GROUP BY l.ThangThu, l.NgayHieuLuc, l.NgayKetThuc, l.KhuVucID, l.SoGioOT
),
CumulativeOT AS (
    -- Anchor
    SELECT 
        ThangThu,
        NgayHieuLuc,
        NgayKetThuc,
        GioOTToiDa,
        GioOTDaSuDung,
        CAST(0 AS DECIMAL(10,2)) AS GioDuChuyenTiep,
        CAST(GioOTToiDa AS DECIMAL(10,2)) AS GioOTDuocPhep
    FROM LichNhanVien
    WHERE ThangThu = 1
    UNION ALL
    -- Recursive
    SELECT 
        cur.ThangThu,
        cur.NgayHieuLuc,
        cur.NgayKetThuc,
        cur.GioOTToiDa,
        cur.GioOTDaSuDung,
        CAST(
            CASE 
                WHEN prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep > 40 
                THEN 40 
                ELSE prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep 
            END AS DECIMAL(10,2)
        ) AS GioDuChuyenTiep,
        CASE WHEN CAST(
            cur.GioOTToiDa +
            CASE 
                WHEN prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep > 40 
                THEN 40 
                ELSE prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep 
            END AS DECIMAL(10,2)
        ) > 40 THEN 40 ELSE 
		CAST(
            cur.GioOTToiDa +
            CASE 
                WHEN prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep > 40 
                THEN 40 
                ELSE prev.GioOTToiDa - prev.GioOTDaSuDung + prev.GioDuChuyenTiep 
            END AS DECIMAL(10,2)
        ) END AS GioOTDuocPhep
    FROM LichNhanVien cur
    JOIN CumulativeOT prev ON cur.ThangThu = prev.ThangThu + 1
)
INSERT INTO #DsOTToiDa (ThangThu,NgayHieuLuc,NgayKetThuc,GioOTToiDa,GioOTDaSuDung,GioDuChuyenTiep,GioOTDuocPhep)
SELECT ThangThu,NgayHieuLuc,NgayKetThuc,GioOTToiDa,GioOTDaSuDung,GioDuChuyenTiep,GioOTDuocPhep FROM CumulativeOT;

DECLARE @SoGioOTCongDon INT = (SELECT GioOTDuocPhep FROM #DsOTToiDa WHERE @NgayDangKy BETWEEN NgayHieuLuc AND NgayKetThuc )

IF @SoGioOTCongDon > @SoGioOTToiDa
BEGIN
    SET @SoGioOTToiDa = @SoGioOTCongDon
END
IF @SoGioOTCongDon < 0
BEGIN
    SET @SoGioOTToiDa = @SoGioOTCongDon
END

	--IF @LyDoTangCaID = 1 AND @NhomNV = 1
	--BEGIN
	--    select N'Nhân viên khối văn phòng không thể đăng ký OT tính tiền', convert(bit,0), 1
	--END
	
	IF @IsKhoaCong > 0
	BEGIN
	    SELECT N'Bạn không thể đăng ký OT vào tháng đã khóa công!', convert(bit,0), 1
	END
	ELSE IF @LoaiNhanVienID = 1
	BEGIN
	    select N'Bạn không được đăng ký OT', convert(bit,0), 1
	END
	ELSE IF @LoaiNhanVienID = 2 AND @LyDoTangCaID = 5
	BEGIN
	    select N'Bạn chỉ được đăng ký OT tính tiền', convert(bit,0), 1
	END
	ELSE IF @LoaiNhanVienID = 3 AND @LyDoTangCaID = 4
	BEGIN
	    select N'Bạn chỉ được đăng ký OT nghỉ bù', convert(bit,0), 1
	END
	ELSE IF convert(date,concat(convert(date,@NgayDangKy),' ',@BDLamTruocCa)) between (select NgayBatDau from NS_QTNghiPhep where NhanVienID=@NhanVienID and convert(date,NgayBatDau)=convert(date,@NgayDangKy)) and (select NgayKetThuc from NS_QTNghiPhep where NhanVienID=@NhanVienID and convert(date,NgayBatDau)=convert(date,@NgayDangKy))
		 or convert(date,concat(convert(date,@NgayDangKy),' ',@KTLamTruocCa)) between (select NgayBatDau from NS_QTNghiPhep where NhanVienID=@NhanVienID and convert(date,NgayBatDau)=convert(date,@NgayDangKy)) and (select NgayKetThuc from NS_QTNghiPhep where NhanVienID=@NhanVienID and convert(date,NgayBatDau)=convert(date,@NgayDangKy))
	begin
		select N'Bạn không thể đăng ký OT vào thời gian đã đăng ký nghỉ!', convert(bit,0), 1
	end
	ELSE IF @BDLamTruocCa < @GioKetThuc1_CLV AND @KTLamTruocCa > @GioBatDau1_CLV and @IsCaDem = 0 --AND @LaNgayLe = 0
	BEGIN
		SELECT N'Không đăng kí làm thêm trong giờ làm việc', CONVERT(bit, 0), 1
		RETURN
	END
	ELSE IF @BDLamTruocCa < @GioKetThuc2_CLV AND @KTLamTruocCa > @GioBatDau2_CLV and @IsCaDem = 0 --AND @LaNgayLe = 0
	BEGIN
		SELECT N'Không đăng kí làm thêm trong giờ làm việc', CONVERT(bit, 0), 1
		RETURN
	END

	--An them làm qua đêm
	ELSE IF @NgayGio_BDLamTruocCa < @NgayGioBatDau1_CLV AND @NgayGio_KTLamTruocCa > @NgayGioBatDau1_CLV and @IsCaDem = 1  --AND @LaNgayLe = 0
	BEGIN
		SELECT N'Không đăng kí làm thêm trong giờ làm việc', CONVERT(bit, 0), 1
		RETURN
	END
	ELSE IF @NgayGio_BDLamTruocCa < @NgayGioKetThuc2_CLV AND @NgayGio_KTLamTruocCa > @NgayGioBatDau2_CLV and @IsCaDem = 1  --AND @LaNgayLe = 0
	BEGIN
		SELECT N'Không đăng kí làm thêm trong giờ làm việc', CONVERT(bit, 0), 1
		RETURN
	END
	--
	else IF (@SoPhut > 240 AND @LaNgayNghi = 0 AND @LyDoTangCaID = 4 AND @LaNgayLe = 0 AND @LaNgayNghiBuLe = 0)
	begin
		select N'Thời gian OT tính tiền ngày làm việc không quá 4h trong 1 ngày', convert(bit,0), 1
	end
	else IF (@SoPhut > 720 and @LyDoTangCaID  = 4)
	begin
		select N'Thời gian OT không quá 12h trong 1 ngày', convert(bit,0), 1
	end
	ELSE IF (@SoPhutLamOT/60 > @SoGioOTToiDa and @LyDoTangCaID  = 4)
	begin
		select N'Thời gian OT tính tiền không quá ' + CONVERT(NVARCHAR,@SoGioOTToiDa) + N' giờ trong 1 tháng', convert(bit,0), 1
	end
	if (@SoPhutLamOTNam/60 > 200 and @LyDoTangCaID  = 4)
	begin
		select N'Thời gian OT không quá 200h trong 1 năm', convert(bit,0), 1
	END

END

