CREATE PROCEDURE [dbo].[ADD_BC_BangKeChuyenTien_ADCo]  
 @NgayChiLuong DATE,  
 @Thang INT,  
 @Nam INT  
AS  
BEGIN  

 --DECLARE @Thang INT = 4,  
 --        @Nam INT = 2025,  
 --        @DangNhapID INT,  
 --        @NgayChiLuong DATE = GETDATE();  
 SELECT NV.MaNhanVien AS MaNV,  
     'Salary ' + CASE WHEN @Thang <= 9 THEN '0'  
       ELSE '' END + CONVERT(NVARCHAR(10), @Thang) + '.' + CONVERT(NVARCHAR(10), @Nam) AS NoiDung,  
     dbo.fuChuyenCoDauThanhKhongDau(Ho+' '+NV.HoTen) AS NguoiThuHuong,  
     BangLuong.Tienluong + isnull(kbs.Khac, 0) as SoTien,  
     NV.TaiKhoanNganHang AS STK,  
     (select top 1 MaNganHang from dbo.NS_DsNganHang where TenNganHang = nv.TenNganHang) +' - ' + NV.TenNganHang AS TenNganHang,  
     '' AS GhiChu,  
     CONVERT(NVARCHAR(50),@NgayChiLuong,103) AS NgayChiLuong  
 FROM  
  (  
   SELECT BL.NhanVienID, bl.Thang, bl.Nam, SUM(CCT.TienLuong) AS Tienluong  
   FROM dbo.NS_TL_BangLuong BL  
    JOIN dbo.NS_TL_ChiTietLuong CCT ON CCT.BangLuongID = BL.BangLuongID  
    JOIN dbo.NS_TL_LoaiLuong LL ON LL.LoaiLuongID = CCT.LoaiLuongID  
           AND LL.MaSo = 'ThucLinh'  
   WHERE BL.Thang = @Thang  
   AND   BL.Nam = @Nam  
   GROUP BY BL.NhanVienID, bl.Thang, bl.Nam  
  ) BangLuong  
  JOIN dbo.NhanVien NV ON NV.NhanVienID = BangLuong.NhanVienID  
  left join ADD_KhoanBoSungNgoaiLuong kbs on BangLuong.NhanVienID = kbs.NhanVienID and BangLuong.Thang = kbs.Thang and BangLuong.Nam = kbs.Nam  
  WHERE nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
END;
GO
