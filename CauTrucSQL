CREATE PROCEDURE [dbo].[NS_DG_OnAfterSavingEvaluation]
	@DanhGiaID int

AS
BEGIN
	--DECLARE  @DanhGiaID INT = 8

	declare @NhanVienID int=(select NhanVIeniD from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)
	declare @NhomDanhGiaID int=(select NhomDanhGiaID from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)
	declare @Nam int = (select max(NS_DG_DotDanhGia.Nam) from NS_DG_DanhGia inner join NS_DG_DotDanhGia on NS_DG_DanhGia.DotDanhGiaID=NS_DG_DotDanhGia.DotDanhGiaID where NS_DG_DanhGia.DanhGiaID=@DanhGiaID)
	declare @DotDanhGiaCuID int=(select DotDanhGiaID from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)
	declare @QuyTrinhID int = isnull((select max(NS_DG_QuyTrinh_BuocThucHien.QuyTrinhID) from NS_DG_DanhGia
	inner join NS_DG_QuyTrinh_BuocThucHien on NS_DG_DanhGia.QuyTrinhBuocThucHienID=NS_DG_QuyTrinh_BuocThucHien.BuocThucHienID
	where NS_DG_DanhGia.DanhGiaID=@DanhGiaID),0)
	declare @DotDanhGiaID int
	declare @CongTyID int=(SELECT CongTyID FROM  nhanvien where NhanVienID=@NhanVienID)
	DECLARE @NoiDung nvarchar(250) = (select YKienPheDuyet from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)
	declare @NgayKetThuc datetime = (select max(NgayKetThuc) from NS_HopDong where NhanVienID = @NhanVienID )--and LoaiHopDongID=89)
	declare @LuaChonID int = (select max(XepLoaiDanhGiaID) from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)-- and QuyTrinhBuocThucHienID=9)
	declare @QuyTrinhBuocThucHIenID int = (select QuyTrinhBuocThucHienID from NS_DG_DanhGia where DanhGiaID=@DanhGiaID and XetDuyet=1)

	DECLARE @VongDanhGiaID int = (SELECT VongDanhGiaID FROM NS_DG_DotDanhGia WHERE DotDanhGiaID = @DotDanhGiaCuID)
	--Tích vào ô cho phép cập nhật tiến độ thì sẽ không tự sinh
	DECLARE @IsCapNhatLaiKPI INT = (SELECT ISNULL(IsChoPhepCheckIn,0) FROM dbo.NS_DG_DotDanhGia WHERE DotDanhGiaID = @DotDanhGiaCuID)

	
	--declare @NhanSuPhuTrach int = (select NhanVienID from ADD_NS_TD_NguoiPhuTrachOnBoarding where CongTyID=@CongTyID and NhomID=5)
	--declare @emailHR nvarchar(100) = (select Email from NhanVien where NhanVienID=@NhanSuPhuTrach)
	
	--Cấu hình động
	DECLARE @NhomDanhGiaCuoiNamID INT = (SELECT TOP 1 NhomDanhGiaID FROM dbo.NS_DG_NhomDanhGia WHERE MaNhomDanhGia = 'KPI_CN')
	DECLARE @NhomDanhGiaGiuaNamID INT = (SELECT TOP 1 NhomDanhGiaID FROM dbo.NS_DG_NhomDanhGia WHERE MaNhomDanhGia = 'KPI_GN')

	DECLARE @BoTieuChiCuoiNamID INT = (SELECT TOP 1 BoTieuChiID FROM dbo.NS_DG_BoTieuChi WHERE MaBoTieuChi = 'DGKPI_CN')
	-- thiết lập sau đối với trường hợp đặc biệt
	DECLARE @QuyTrinhDGCuoiNamID INT = @QuyTrinhID
	--(SELECT TOP 1 QuyTrinhID FROM dbo.NS_DG_QuyTrinh WHERE MaQuyTrinh = 'QTC')
	
	
	
	--(select XetDuyet from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)=1 and
	--KPI Cá nhân
	if(@NhomDanhGiaID=@NhomDanhGiaGiuaNamID AND @IsCapNhatLaiKPI != 1 and (select XetDuyet from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)=1 
	and (select QuyTrinhBuocThucHienID from NS_DG_DanhGia where DanhGiaID=@DanhGiaID)=
	(select max(BuocThucHIenID) from NS_DG_QuyTrinh_BuocThucHien where QuyTrinhID=@QuyTrinhID and IsBuocThietLapMucTieu=0)
	and @QuyTrinhID>0)
		BEGIN
			
			INSERT INTO [dbo].[NS_DG_DotDanhGia]
			([MaDotDanhGia],[TenDotDanhGia],[NhanVienID],[Thang],[Quy],[Nam],[NhomDanhGiaID],[HeSoDanhGia]
			,[TrangThai],[TongDiem],[XepLoaiDanhGiaID],[CreatedByID],[CreatedDate],[ModifyByID],[ModifyDate]
			,[BoTieuChiStrID],[QuyTrinhID],[BuocThucHienTiepTheoID],[NguoiXetDuyetTiepTheoID],[NhomXetDuyetTiepTheoID],[MaNhanVien]
			,[HoVaTen],[TenPhongBan],[TenChucVu],[NguoiXetDuyetMucTieuID],[NgayXetDuyetMucTieu],[IsThietLapMucTieu]
			,[IsTuDanhGia],[IsVongCuoiID],[NBD_DanhGia],[NKT_DanhGia],[NBD_NhapChiTieu],[NKT_NhapChiTieu]
			,[GhiChu],[PhongBanID],[ChucVuID],[QuanLyTrucTiepID],[BuocXetDuyetMucTieuTiepTheoID],[HoVaTen_NguoiDuyetMucTieu],[ChucVu_NguoiDuyetMucTieu]
