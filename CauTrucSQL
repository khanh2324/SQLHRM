CREATE PROCEDURE [dbo].[ADD_BC_Payslip_ADCo] 
	@Thang int, @Nam int

AS
BEGIN


--	 declare @PhongBanID int = 20, @Thang int = 3, @Nam int = 2025, @NhanVienID int = 0, @DangNhapID int = 3115
	declare @ThangLuong date = eomonth(convert(char(2), @thang) + '/1/' + convert(char(4), @nam) )
	declare @NgayQuyDoi date = convert(char(2), @thang) + '/26/' + convert(char(4), @nam) 
	declare @DauKy date = dateadd(month, -1, @NgayQuyDoi)
	 declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)   
	
	select bl.Thang,bl.Nam,
		   nv.MaNhanVien as MaNV, nv.Ho + ' ' + nv.HoTen as HoVaTen,
		   dbo.fuChuyenCoDauThanhKhongDau(nv.Ho + ' ' + nv.HoTen) AS HoVaTenKhongDau,
		   pb.PhongBanID as PhongBanID, cb.TenBac as CapBac
		   , cv.TenChucVu,cv.TenChucVuTA,pb.Ten AS TenPhongBan,pb.TenPhongBanTA AS TenPhongBanTA
		   ,nv.MaSoThue
		, (SELECT STUFF((
				SELECT ', ' + TenKhuVuc
				FROM NS_DsKhuVuc 
				WHERE KhuVucID IN (
					SELECT CAST(value AS INT)
					FROM STRING_SPLIT(LEFT(STUFF(nv.KhuVucStr, 1, 1, ''), LEN(STUFF(nv.KhuVucStr, 1, 1, '')) - 1), ',')
				)FOR XML PATH(''), TYPE
				).value('.', 'NVARCHAR(MAX)'), 1, 1, '') 
			) AS DiaDiemLamViec	  	 
		, kv.TenKhuVuc AS DiaDiemLamViec
		, CostCenter.Ten as CostCenter, nv.NgayBatDauLam as NgayVaoLam, nv.NgayNghiViec as NgayNghiViec
		, isnull(bl.CC_XN, 0) as CongLamViec, isnull(bl.CC_NghiPhep, 0) as CongNghiPhep
		, isnull(bl.[CC_TongCong], 0) as TongCong, isnull(bl.[TLNC_LCB], 0) as LuongCoBan
		, isnull(bl.[TLNC_PC_TrachNhiem], 0) as PCTrachNhiem, isnull(bl.[TLNC_PC_ViTri], 0) as PCViTri, isnull(bl.[TLNC_PC_DiLai], 0) as PCDiLai
		, isnull(bl.[TLNC_PC_DocHai], 0) as PCDocHai, isnull(bl.[TLNC_PC_Khac], 0) as PCKhac, isnull(bl.[TLNC_PC_BuaAn], 0) as PCTienAn
		, isnull(bl.[TLNC_ThuongThang], 0) as ThuongThang, isnull(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) as TongLuongVaPhuCap

		, isnull(bl.[TLOT_ChieuThue], 0) as OTChiuThue, isnull(bl.[TLOT_MienThue], 0) as OTKhongChiuThue, isnull(bl.[TLOT_LamCaDem], 0) as TienCaDem
		, isnull(bl.[TLOT_TongLuongOT_LamCaDem], 0) as TongOTVaCaDem, isnull(bl.[Thuong_KM], 0) as ThuongKM, isnull(bl.[Thuong_KPI], 0) as ThuongKPI
		, isnull(bl.[Thuong_LuongT13], 0) as LuongThang13, isnull(bl.[Thuong_Nam], 0) as ThuongNam, isnull(bl.[Thuong_ChenhLechT1], 0) as ChenhLechThang1
		, isnull(bl.[Thuong_CongTruocThue], 0) as CongTruocThue, isnull(bl.[Thuong_TruTruocThue], 0) as TruTruocThue
		, isnull(bl.[Thuong_TongThuong], 0) as TongThuongVaKhoanTruocThue, isnull(bl.[TongThuNhap], 0) as TongThuNhap

		, isnull(bl.[BH_LuongBHXH], 0) as MucLuongBHXH, isnull(bl.[BH_LuongBHTN], 0) as MucLuongBHTN, isnull(bl.[BH_Tong_NLD], 0) as BHNhanVien
		, isnull(bl.[BH_Tong_CTY], 0) as BHCongTy, isnull(bl.[BH_Tong], 0) as TongBHXH
		
		, isnull(bl.[Tax_ThuNhapChiuThue], 0) as ThuNhapChiuThue, isnull(bl.[Tax_GiamTru_BanThan], 0) as GiamTruBanThan
		, isnull(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) as GiamTruNguoiPhuThuoc, isnull(bl.[Tax_SoNguoiPhuThuoc], 0) as SoNguoiPhuThuoc
		, isnull(bl.[Tax_ThuNhapTinhThue], 0) as ThuNhapTinhThue, isnull(bl.[Tax_TongThue], 0) as ThueTNCN, isnull(bl.[Tax_ThuNhapSauThue], 0) as ThuNhapSauThue
		, isnull(bl.[PSSThue_CongDoan_NLD], 0) as CongDoanPhiNV, isnull(bl.[PSSThue_CongDoan_CTY], 0) as KinhPhiCongDoanCTY, isnull(bl.[PSSThue_TruSauTax], 0) as TruSauThue
		, isnull(bl.[PSSThue_CongSauTax], 0) as CongSauThue, isnull(bl.[ThucLinh], 0) as ThucLinh, isnull(bl.[ChiPhiCongTy], 0) as ChiPhiCongTy

	from NhanVien nv	
		 cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1      
		 left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
		 cross apply dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1  
		 left join dbo.NS_DsChucVu cv on cv.ChucVuID = cv1.ChucVuID
		 cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv  
	 	 left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId

	left join NS_DsCapBac cb on nv.CapBacID = cb.CapBacID
	left join ADD_CostCenter CostCenter on nv.CostCenterId = CostCenter.CostCenterId
	right join
	(select * from (
		select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong

		from NS_TL_BangLuong bl 
		left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID
		left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID

		Where (1=1)
		and bl.Thang = @Thang
		and bl.Nam = @Nam
		and bl.NhanVienID=40291
		) as A pivot ( sum(TienLuong) for MaSo in( [QD_LCB], [QD_LCB_New], [QD_PC_TrachNhiem], [QD_PC_TrachNhiem_New], [QD_PC_ViTri],
						 [QD_PC_ViTri_New], [QD_PC_DiLai], [QD_PC_DiLai_New], [QD_PC_DocHai], [QD_PC_DocHai_New],
						 [QD_PC_Khac], [QD_PC_Khac_New], [QD_PC_BuaAn], [QD_PC_BuaAn_New], [QD_ThuongThang],
						 [QD_ThuongThang_New], [QD_TongLuong_PhuCap], [QD_TongLuong_PhuCap_New], [CC_XN], [CC_XD],
						 [CC_NghiPhep], [CC_NghiLe], [CC_NghiBu], [CC_CongTac], [CC_NghiCheDo], [CC_NghiCoLuong],
						 [CC_TongCong], [CC_GCC], [TLNC_LuongGio], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri],
						 [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn], [TLNC_ThuongThang],
						 [TLNC_TongLuong_Thuong_PhuCap], [TLNC_TongLuong_Thuong_PhuCap_Gop], [CC_TongGioOT],
						 [CC_TongGioOT_NoneTax], [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem],
						 [TLOT_TongLuongOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem_Gop], [Thuong_KM_IP], [Thuong_KM],
						 [Thuong_KPI_IP], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam_IP], [Thuong_Nam],
						 [Thuong_ChenhLechT1_IP], [Thuong_ChenhLechT1], [Thuong_CongTruocThue_IP],
						 [Thuong_CongTruocThue], [Thuong_TruTruocThue_IP], [Thuong_TruTruocThue], [Thuong_TongThuong],
						 [TongThuNhap], [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],
						 [Tax_ThuNhapMienThue], [Tax_ThuNhapMienThue_Gop], [Tax_ThuNhapChiuThue],
						 [Tax_GiamTru_BanThan], [Tax_SoNguoiPhuThuoc], [Tax_GiamTru_NguoiPhuThuoc],
						 [Tax_ThuNhapTinhThue], [Tax_TongThue], [Tax_ThuNhapSauThue], [PSSThue_CongDoan_NLD],
						 [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax_IP], [PSSThue_TruSauTax], [PSSThue_CongSauTax_IP],
						 [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy]  ) ) as B
	) as bl on nv.NhanVienID = bl.NhanVienID	
end
GO
