CREATE  proc [dbo].[BHXH_DS_THAYDOI_QTBHXH] @DonViID int, @CongTyID int, @Fromdate DateTime, @Todate DateTime, @Type int AS      
      
BEGIN      
      
        ----DECLARE  @CongTyID int=1,@DonViID int =0,@FromDate datetime='2025-02-26 00:00:00',@ToDate datetime='2025-3-25 23:59:59',@Type int=0  
    
        SET NOCOUNT ON;      
        DECLARE @DonVi int, @CongTyID_ID int, @Fromdate1 DateTime, @Todate1 DateTime, @Type1 int, @Types int=-1  
        SET @DonVi= @DonViID set @CongTyID_ID = @CongTyID set @Fromdate1 = @Fromdate set @Todate1 = @Todate set @Type1 = @Type      
		declare @NgayDauKyCong datetime = (concat(convert(nvarchar,year(@Todate1)),'-',convert(nvarchar,month(@Todate1)),'-25'))
    begin    
        DECLARE  @ToiThang datetime = '12/31/2099'      
        
            DECLARE @tbl_BienDong TABLE (    ThangBaoCao DATE,    [type] INT,    NhanVienID INT,    MaNhanVien NVARCHAR(50),    MucLuongCu DECIMAL(18,2),    TyleCu DECIMAL(10,2),    Tyle DECIMAL(10,2),    SoSo NVARCHAR(50),    PhongBan NVARCHAR(250),    ChucVu NVARCHAR(250),
                HoVaTen NVARCHAR(100),    TuThang DATE,   ToiThang DATE,    MucLuong DECIMAL(18,2),    GhiChu NVARCHAR(50),    Nhom NVARCHAR(100),    TrangThai INT,    NgayTraTheBHYT DATE,    KhongTraTheBHYT BIT);

            --CREATE TABLE #dbl (    STTG INT,    NhanVienID INT,    NgayHuong DATE,    GiaTriMoi DECIMAL(18,2),
            --    PRIMARY KEY (NhanVienID, STTG) -- Thêm clustered index
            --);
            DECLARE @dbl TABLE (    STTG INT,    NhanVienID INT,    NgayHuong DATE,    GiaTriMoi DECIMAL(18,2),
                INDEX IX_dbl CLUSTERED (NhanVienID, STTG) -- SQL Server 2014+
            );

            DECLARE @pb TABLE (    PhongBanID INT,    MaPhongBan nvarchar(50),    TenPhongBan nvarchar(500),
                INDEX IX_pb CLUSTERED (PhongBanID) -- SQL Server 2014+
            );
            insert into @pb(PhongBanID, MaPhongBan,  TenPhongBan)
            SELECT         PhongBanID,        MaPhongBan,        Ten AS TenPhongBan
            FROM PhongBan    WHERE CongTyID=@CongTyID  

            -- Tạo bảng tạm thay cho CTE
            DECLARE @nv TABLE ( NgayKyHD DATE, NhanVienID INT, MaNhanVien NVARCHAR(50), HoVaTen NVARCHAR(100), SoBHXH NVARCHAR(50), PhongBanID INT, ChucDanhID INT, ChucVuID INT,
                NghiViec BIT, NgayNghiViec DATE, QuocTichID INT, INDEX IX_NhanVienTemp_NhanVienID NONCLUSTERED (NhanVienID));
            -- Điền dữ liệu vào bảng tạm
            INSERT INTO @nv
            SELECT 
                dbo.BHXH_LayHDDauTien(NhanVienID) AS NgayKyHD,
                NhanVienID,    MaNhanVien,    CONCAT(HO, ' ', HoTen) AS HoVaTen,    SoBHXH,    pb.PhongBanID,    ChucDanhID,    ChucVuID,    ISNULL(NghiViec, 0) AS NghiViec,    NgayNghiViec,    QuocTichID
            FROM NhanVien nv WITH (NOLOCK)
            INNER JOIN @PB pb ON pb.PhongBanID = nv.PhongBanID
            WHERE 
                NgayBatDauLam <= @Todate1     --AND (ISNULL(nv.NghiViec, 0) = 0 OR CONVERT(DATE, nv.NgayNghiViec) > @Todate1)  
				AND ISNULL(nv.IsDeleted, 0) = 0;

            drop table if exists  #BH
            SELECT TOP 1 WITH TIES NhanVienID, [Type], NgayBatDau, NgayKetthuc, SoNam, SoThang, MucLuong, NguoiThamGiaID, TyleDong, ThangBaoCao   
            INTO #BH FROM NS_QTDongBHXH   WHERE NgayBatDau <= @Todate1 and NhanVienID in (select NhanVienID from  @nv)  ORDER BY ROW_NUMBER() OVER (PARTITION BY  NhanVienID ORDER BY  NgayBatDau DESC)   

-- Insert dữ liệu vào temp table

    ;WITH LoaiLuongRelevant AS (    SELECT LoaiLuongID     FROM NS_TL_LoaiLuong WITH (NOLOCK)
        WHERE Maso IN ('QD_LCB', 'QD_PC_TrachNhiem', 'QD_PC_ViTri', 'QD_PC_DocHai')
        ),
        DienBienLuong AS (
            SELECT db.NhanVienID, ISNULL(db.NgayHuong, db.NgayQuyetDinh) AS NgayHuong, SUM(ct.GiaTri) AS GiaTri,
                ROW_NUMBER() OVER (PARTITION BY db.NhanVienID ORDER BY ISNULL(db.NgayHuong, db.NgayQuyetDinh) DESC) AS STTG
            FROM NS_QTDienBienLuong db WITH (NOLOCK)
            INNER JOIN NS_QTDienBienLuongChiTiet ct WITH (NOLOCK) 
                ON db.QTDienBienLuongID = ct.QTDienBienLuongID
            INNER JOIN LoaiLuongRelevant ll                 ON ct.LoaiLuongID = ll.LoaiLuongID
            WHERE CONVERT(DATE, ISNULL(db.NgayHuong, db.NgayQuyetDinh)) <= @ToDate1
            GROUP BY db.NhanVienID, ISNULL(db.NgayHuong, db.NgayQuyetDinh)
        )
        insert into @dbl (STTG, NhanVienID, NgayHuong, GiaTriMoi )
        SELECT STTG, NhanVienID, NgayHuong, GiaTri AS GiaTriMoi
        FROM DienBienLuong    WHERE STTG <= 2;      
    
/* @Type =1 TĂNG MỚI - Phiên bản tối ưu */
SET @Types = 1;

        INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT)
        SELECT 
            @Todate1 AS ThangBaoCao,    @Types AS type,    nv.NhanVienID,    nv.MaNhanVien,    NULL AS MucLuongCu,    NULL AS TyleCu,    dbo.BHXH_LayTyLe(nv.QuocTichID, @Todate1) AS Tyle ,    nv.SoBHXH AS SoSo 
            ,  pb.TenPhongBan AS PhongBan,    cv.TenChucVu AS ChucVu,    nv.HoVaTen,
            --CASE 
            --    WHEN DAY(nv.NgayKyHD) <= 15 
            --    THEN DATEADD(DAY, 1 - DAY(nv.NgayKyHD), nv.NgayKyHD)
            --    ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(nv.NgayKyHD), nv.NgayKyHD))
            --END AS TuThang, 
            CASE 
                WHEN dbo.BHXH_TinhSoNgayNghi_TheoThang(MONTH(@Todate1), YEAR(@Todate1), nv.NhanVienID) < 14
                THEN DATEADD(DAY, 1 - DAY(nv.NgayKyHD), nv.NgayKyHD)
                ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(nv.NgayKyHD), nv.NgayKyHD))
            END AS TuThang,   
			@ToiThang AS ToiThang,
            dbo.BHXH_LayMucLuongDongBHXH(nv.NhanVienID, nv.NgayKyHD) AS MucLuong,
            'tm' AS GhiChu,    N'Tăng mới BHXH' AS Nhom,

            @Types AS TrangThai,    NULL AS NgayTraTheBHYT,    CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM @nv nv
        INNER JOIN @pb pb ON nv.PhongBanID = pb.PhongBanID
        LEFT JOIN NS_DsChucVu cv ON nv.ChucVuID = cv.ChucVuID
        WHERE 
            nv.NgayKyHD IS NOT NULL 
            --AND nv.NgayKyHD <= @Todate1
            AND nv.NgayKyHD <= eomonth(@Todate1)
            AND (
                nv.NghiViec = 0 
                OR (
                    nv.NghiViec = 1 
                    AND (
                        CASE 
                            WHEN nv.NgayKyHD BETWEEN @Fromdate1 AND @Todate1 
                            THEN DATEADD(MONTH, 0, nv.NgayNghiViec)
                            ELSE DATEADD(MONTH, 1, nv.NgayNghiViec)
                        END
                    ) > @Todate1
                )
            )
            AND NhanVienID NOT IN (SELECT NhanVienID FROM NS_BH_NguoiThamGia)
            AND @Type1 IN (0, @Types)
            AND dbo.BHXH_LayMucLuongDongBHXH(nv.NhanVienID, nv.NgayKyHD) > 0

  /*@Type =4 TĂNG DO TĂNG LƯƠNG*/      
 SET @Types = 4  

        ;WITH NhanVienCTE  AS (
        SELECT nv.NhanVienID, nv.MaNhanVien, nv.HoVaTen, nv.SoBHXH, nv.PhongBanID,
            nv.ChucVuID,            nv.QuocTichID,            pb_list.TenPhongBan,            cv.TenChucVu
        FROM @nv nv 
        INNER JOIN @pb pb_list ON nv.PhongBanID = pb_list.PhongBanID
        LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID 
        ),
        NhanVienTangLuong AS (
        SELECT             ni.*,            db1.GiaTriMoi AS MucLuong,            db2.GiaTriMoi AS MucLuongCu,            db1.NgayHuong,
            CASE 
                WHEN DAY(db1.NgayHuong) <= 15 
                THEN DATEADD(DAY, 1 - DAY(db1.NgayHuong), db1.NgayHuong)
                ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(db1.NgayHuong), db1.NgayHuong))
            END AS TuThang
        FROM NhanVienCTE ni
        INNER JOIN @dbl db1 ON ni.NhanVienID = db1.NhanVienID AND db1.STTG = 1
        INNER JOIN @dbl db2 ON ni.NhanVienID = db2.NhanVienID AND db2.STTG = 2
        WHERE db1.GiaTriMoi > 0
    )
      INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
    SELECT 
        @ToDate1 AS ThangBaoCao, @Types AS type, nd.NhanVienID, nd.MaNhanVien, nd.MucLuongCu, NULL AS TyleCu, dbo.BHXH_LayTyLe(nd.QuocTichID, @ToDate1) AS Tyle, nd.SoBHXH AS SoSo
        , nd.TenPhongBan AS PhongBan, nd.TenChucVu AS ChucVu, nd.HoVaTen, nd.TuThang, @ToiThang AS ToiThang, nd.MucLuong, 'tmd' AS GhiChu,        N'Tăng mức đóng BHXH' AS Nhom
        , @Type1 AS TrangThai, NULL AS NgayTraTheBHYT, CONVERT(BIT, 0) AS KhongTraTheBHYT
    FROM NhanVienTangLuong nd
    WHERE 
        @Type1 IN (0, 4)
        AND nd.MucLuongCu < nd.MucLuong
        AND NOT EXISTS (
            SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
            WHERE NhanVienID = nd.NhanVienID
            AND nd.TuThang BETWEEN NgayBatDau AND NgayKetthuc
            AND type IN (5, 7, 8, 9)
        )
        AND NOT EXISTS (
            SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
            WHERE NhanVienID = nd.NhanVienID
            AND nd.TuThang = NgayBatDau
            AND type IN (4, 10)
        )
        AND EXISTS (
            SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
            WHERE NhanVienID = nd.NhanVienID
            AND nd.TuThang > NgayBatDau
        );

/* @Type = 10 GIẢM DO GIẢM LƯƠNG */
SET @Types = 10;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
        ;WITH NhanVienCTE AS (
            SELECT         nv.NhanVienID,        nv.MaNhanVien,        CONCAT(nv.HO, ' ', nv.HoTen) AS HoVaTen,        nv.SoBHXH,        nv.PhongBanID,        nv.ChucVuID,        nv.QuocTichID,        pb_list.TenPhongBan,        cv.TenChucVu
            FROM NhanVien nv WITH (NOLOCK)
            INNER JOIN @PB pb_list ON nv.PhongBanID = pb_list.PhongBanID
            LEFT JOIN NS_DsChucVu cv WITH (NOLOCK) ON nv.ChucVuID = cv.ChucVuID
        ),
        NhanVienGiamLuong AS (
            SELECT 
                nv.*,
                db1.GiaTriMoi AS MucLuongHienTai, db2.GiaTriMoi AS MucLuongCu,
                db1.NgayHuong,
                CASE 
                    WHEN DAY(db1.NgayHuong) <= 15 
                    THEN DATEADD(DAY, 1 - DAY(db1.NgayHuong), db1.NgayHuong)
                    ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(db1.NgayHuong), db1.NgayHuong))
                END AS TuThang
            FROM NhanVienCTE nv
            INNER JOIN @dbl db1 ON nv.NhanVienID = db1.NhanVienID AND db1.STTG = 1
            INNER JOIN @dbl db2 ON nv.NhanVienID = db2.NhanVienID AND db2.STTG = 2
            WHERE db1.GiaTriMoi > 0
            AND db2.GiaTriMoi > db1.GiaTriMoi -- Điều kiện giảm lương
        ),
        KiemTraDieuKienBHXH AS (
            SELECT 
                nv.*,
                CASE WHEN EXISTS (
                    SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
                    WHERE NhanVienID = nv.NhanVienID
                    AND nv.TuThang BETWEEN NgayBatDau AND NgayKetthuc
                    AND type IN (5,7,8,9)
                ) THEN 1 ELSE 0 END AS CoBienDongKhongHopLe,
                CASE WHEN EXISTS (
                    SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
                    WHERE NhanVienID = nv.NhanVienID
                    AND nv.TuThang = NgayBatDau
                    AND type IN (4,10)
                ) THEN 1 ELSE 0 END AS CoBienDongCungNgay,
                CASE WHEN EXISTS (
                    SELECT 1 FROM NS_QTDongBHXH WITH (NOLOCK)
                    WHERE NhanVienID = nv.NhanVienID
                    AND nv.TuThang > NgayBatDau
                ) THEN 1 ELSE 0 END AS CoBienDongTruocDo
            FROM NhanVienGiamLuong nv
        )

        -- Kết quả cuối cùng
          INSERT INTO @tbl_BienDong (
            ThangBaoCao, [type], NhanVienID, MaNhanVien, MucLuongCu, TyleCu, Tyle, SoSo, 
            PhongBan, ChucVu, HoVaTen, TuThang, ToiThang, MucLuong, GhiChu, Nhom, 
            TrangThai, NgayTraTheBHYT, KhongTraTheBHYT )
        SELECT 
            @Todate1 AS ThangBaoCao, @Types AS type, NhanVienID, MaNhanVien, MucLuongCu, NULL AS TyleCu, dbo.BHXH_LayTyLe(QuocTichID, @Todate1) AS Tyle, SoBHXH AS SoSo
            , TenPhongBan AS PhongBan, TenChucVu AS ChucVu, HoVaTen, TuThang, @ToiThang AS ToiThang, MucLuongHienTai AS MucLuong, 'gmd' AS GhiChu, N'Giảm mức đóng BHXH' AS Nhom
            , @Types AS TrangThai, NULL AS NgayTraTheBHYT, CONVERT(BIT, 0) AS KhongTraTheBHYT
        FROM KiemTraDieuKienBHXH
        WHERE 
            @Type1 IN (0, @Types)
            AND CoBienDongKhongHopLe = 0
            AND CoBienDongCungNgay = 0
            AND CoBienDongTruocDo = 1;



/* @Type = 5 GIẢM DO NGHỈ VIỆC */
SET @Types = 5;

        -- Sử dụng CTE để cải thiện hiệu năng và khả năng đọc
       ;WITH NhanVienCTE AS (
            SELECT                 nv.NhanVienID,                nv.MaNhanVien,                nv.HoVaTen,                nv.SoBHXH,                nv.PhongBanID,                nv.ChucVuID,                nv.QuocTichID,
                nvnv.NgayHieuLuc,                pb_list.TenPhongBan,                cv.TenChucVu,                CASE                     WHEN DAY(nvnv.NgayHieuLuc) >= 16 THEN 
                        CASE 
                            --WHEN dbo.BHXH_TinhSoNgayNghi(MONTH(nvnv.NgayHieuLuc), YEAR(nvnv.NgayHieuLuc), nv.NhanVienID) >= 14 
                            WHEN convert(date,nvnv.NgayHieuLuc) <= convert(date,@NgayDauKyCong)
                            THEN DATEADD(DAY, 1 - DAY(nvnv.NgayHieuLuc), nvnv.NgayHieuLuc)
                            ELSE DATEADD(MONTH, 1, DATEADD(DAY, 1 - DAY(nvnv.NgayHieuLuc), nvnv.NgayHieuLuc))
                        END
                    ELSE DATEADD(DAY, 1 - DAY(nvnv.NgayHieuLuc), nvnv.NgayHieuLuc)
