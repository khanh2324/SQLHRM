create proc [dbo].[LayThamSoDeXuat]
@ID int
as
begin

declare @DX nvarchar(max)=N''
declare @SQL nvarchar(max)=N''

  select @DX += coalesce('[DX_DT_BN_'+ case when TruongDuLieuID<9 then  convert( char(1), TruongDuLieuID) else convert( char(2), TruongDuLieuID) end+'],',null)
    from  DX_DeXuat_DuLieuDeXuat where DeXuatID=@ID 
    set  @DX = (case when len(isnull(@DX,''''))=0 then @DX else left(@DX,len(@DX)-1) end)
set @SQL=N'
select *,[DX_DT_BN_1]as A,[DX_DT_BN_2]as B,[DX_DT_BN_3]as C,[DX_DT_BN_4] as D,
case when [DX_DT_BN_5]=1 then ''Offline''
when [DX_DT_BN_5]=2 then ''Online''
when [DX_DT_BN_5]=3 then ''Kết hợp (on-off)''else N'''' end as N''F'',
[DX_DT_BN_6]as G,[DX_DT_BN_7]as K,
case when [DX_DT_BN_8]=1 then ''YES''
when [DX_DT_BN_8]=2 then ''NO''else N'''' end  as N''N'',
case when [DX_DT_BN_9]=1 then ''YES''
when [DX_DT_BN_9]=2 then ''NO''else N'''' end   as N''M'',
[DX_DT_BN_10]as O,[DX_DT_BN_11]as P
from (
	select DX_LoaiDeXuat.TenLoaiDeXuat,
	DX.TieuDe,
	NhanVien.Ho+'' ''+Nhanvien.HoTen as HoVaTen,
	NhanVien.MaNhanVien ,
	pbyc.Ten PhongBan,
	CVYC.TenChucVu,
	''DX_DT_BN_''+ case when TruongDuLieuID>9 then  convert( char(1), TruongDuLieuID) else convert( char(2), TruongDuLieuID) end TruongDuLieuID 
	,GiaTri

	from DX_DeXuat  DX
		inner join DX_LoaiDeXuat on DX_LoaiDeXuat.LoaiDeXuatID=DX.LoaiDeXuatID
		inner join DX_DeXuat_DuLieuDeXuat on DX_DeXuat_DuLieuDeXuat.DeXuatID=dx.DeXuatID
		inner join NhanVien on DX.NguoiDeXuatID = NhanVien.NhanVienID
		left join NS_DsChucVu CVYC on Nhanvien.ChucVuID = CVYC.ChucVuID
		left join PhongBan pbyc on NhanVien.PhongBanID = pbyc.PhongBanID

	where dx.DeXuatID = '+CONVERT(char(2), @ID)+'	
)a
	pivot (min(Giatri) for TruongDuLieuID in ('+@DX+'))b
	'

exec (@SQL)
end
