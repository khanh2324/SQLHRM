CREATE FUNCTION [dbo].[HS_TinhSoNgayPhepTheoQuyDinh_TĐ]
(
	@NhanVienID int,
	@Ngay date
)
RETURNS  decimal(10,2)
AS
BEGIN
	Declare @songay decimal(10,2)
	declare @ngaycuoinam date=convert(date,convert(nvarchar,year(@ngay))+'-12-31')
	declare @ngaydaunam date=(select case when year(@ngay)>2018 then convert(date,convert(nvarchar,year(@ngay))+'-1-1')
				else '2018-1-1' end)
	declare @sophepbandau decimal(10,2)=(select case when year(@ngay)>2018 then 0 else SoPhepBanDau end
				from nhanvien where NhanVienID=@NhanVienID)
	declare @ngaybatdaulam date=(select convert(date,NgayBatDauLam) from NhanVien where NhanVienID=@NhanVienID)
	declare @nghiviec int=isnull((select nghiviec from NhanVien where NhanVienID=@NhanVienID),0)
	declare @ngaynghiviec date=(select convert(date,NgayNghiViec) from NhanVien where NhanVienID=@NhanVienID)

	set @songay=12
	
	if (@ngaybatdaulam is null)
		begin
			 set @songay=0
		end
	else if (@nghiviec=0)
		begin
			if ((year(@ngaybatdaulam)<year(@Ngay) and @Ngay=@ngaycuoinam) or (year(@ngaybatdaulam)=year(@Ngay) and month(@ngaybatdaulam)=1 and day(@ngaybatdaulam)=1))
				begin
					set @songay=@songay
				end
			else
				begin
					set @songay=(datediff(day,@ngaydaunam,@ngay)+1)*@songay/365
				end
		end
	else
		begin
			if ((year(@ngaybatdaulam)<year(@ngaynghiviec) and @ngaynghiviec=@ngaycuoinam) or (year(@ngaybatdaulam)=year(@ngaynghiviec) and month(@ngaybatdaulam)=1 and day(@ngaybatdaulam)=1 and @ngaynghiviec=@ngaycuoinam))
				begin
					set @songay=@songay
				end
			else
				begin
					set @songay=(datediff(day,@ngaydaunam,@ngaynghiviec)+1)*@songay/365
				end
		end

	RETURN isnull(@songay,0)+isnull(@sophepbandau,0)+isnull(dbo.HS_TinhSoNgayDuocNghiTheoThamNien(@nhanvienid,@ngay),0)
END
