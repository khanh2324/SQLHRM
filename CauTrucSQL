CREATE PROCEDURE [dbo].[sp_BHXH_TinhTrichNopHangThang]     @Thang INT,     @Nam INT,     @PhongBanID INT AS
BEGIN
    SET NOCOUNT ON;

--DECLARE @Thang INT = 10,
--        @Nam INT   = 2025,
--        @PhongBanID INT = 147;
	
-- 1. Khai báo biến và bảng tạm cơ bản
DECLARE @fdate DATE = DATEFROMPARTS(@Nam, @Thang, 1);
DECLARE @tdate DATE = EOMONTH(@fdate);
DECLARE @tyle_CDP DECIMAL(10,3) = (CASE WHEN @fdate >= '2025-01-08' THEN 0.005 ELSE 0.01 END);

-- Bảng lưu phòng ban con
DECLARE @PhongBanCon TABLE (PhongBanID INT PRIMARY KEY);
INSERT INTO @PhongBanCon
SELECT PhongBanID FROM fn_LayPhongBanCon(@PhongBanID);

-- 2. Lấy thông tin lương tối thiểu
DECLARE @LuongToiThieu TABLE
(
    Vung1 DECIMAL(10,3),
    Vung2 DECIMAL(10,3),
    Vung3 DECIMAL(10,3),
    Vung4 DECIMAL(10,3),
    LuongToiThieuChung DECIMAL(10,3)
);

INSERT INTO @LuongToiThieu
SELECT TOP 1 Vung1, Vung2, Vung3, Vung4, LuongToiThieuChung 
FROM NS_BH_LuongToiThieu 
WHERE NgayBatDau < @fdate
ORDER BY NgayBatDau DESC;

DECLARE @LTTV1 DECIMAL(10,3) = ISNULL((SELECT Vung1 FROM @LuongToiThieu), 4680000);
DECLARE @LTTV2 DECIMAL(10,3) = ISNULL((SELECT Vung2 FROM @LuongToiThieu), 4160000);
DECLARE @LTTV3 DECIMAL(10,3) = ISNULL((SELECT Vung3 FROM @LuongToiThieu), 3640000);
DECLARE @LTTV4 DECIMAL(10,3) = ISNULL((SELECT Vung4 FROM @LuongToiThieu), 3250000);
DECLARE @LTTC  DECIMAL(10,3) = ISNULL((SELECT LuongToiThieuChung FROM @LuongToiThieu), 1800000);

-- 3. Lấy tỷ lệ đóng BHXH hiện hành
DECLARE @TyLeBH TABLE
(
    TyLeBHXH_CTY      DECIMAL(5,2),
    TyLeBHYT_CTY      DECIMAL(5,2),
    TyLeBHTN_CTY      DECIMAL(5,2),
    TyLeBHXH_NLD      DECIMAL(5,2),
    TyLeBHYT_NLD      DECIMAL(5,2),
    TyLeBHTN_NLD      DECIMAL(5,2),
    TyLeBHXH_CTY_NNG  DECIMAL(5,2),
    TyLeBHYT_CTY_NNG  DECIMAL(5,2),
    TyLeBHTN_CTY_NNG  DECIMAL(5,2),
    TyLeBHXH_NNG      DECIMAL(5,2),
    TyLeBHYT_NNG      DECIMAL(5,2),
    TyLeBHTN_NNG      DECIMAL(5,2)
);

INSERT INTO @TyLeBH
SELECT TOP 1 
    TyLe_BHXH_CTY, TyLe_BHYT_CTY, TyLe_BHTN_CTY,         
    TyLe_BHXH_NLD, TyLe_BHYT_NLD, TyLe_BHTN_NLD,
    TyLe_BHXH_CTY_NNG, TyLe_BHYT_CTY_NNG, TyLe_BHTN_CTY_NNG,        
    TyLe_BHXH_NNG, TyLe_BHYT_NNG, TyLe_BHTN_NNG
FROM dbo.NS_BH_TyLeThamGiaBHXH 
WHERE NgayBatDau <= @tdate 
ORDER BY NgayBatDau DESC;

-- 4. TÍNH LẠI DỮ LIỆU THÁNG @Thang/@Nam (CHƯA ĐỤNG TỚI NS_TL_BangTrichBHXH)

IF OBJECT_ID('tempdb..#TinhToanBH') IS NOT NULL DROP TABLE #TinhToanBH;

;WITH NhanVienTinh AS
(
    SELECT 
        nv.MaNhanVien,
        nv.NhanVienID,
        CONCAT(nv.HO, ' ', nv.HoTen) AS HoVaTen,
        ISNULL(CONVERT(BIT, nv.ThuNhapHaiNoi), 0) AS ThuNhapHaiNoi,
        pb.Ten AS TenPhongBan,
        pb.PhongBanID,
        ISNULL(pb.CongTyID, 0) AS CongTyID,
        pb.ThuTu,
        ISNULL(qt.TenNuoc, N'Việt Nam') AS QuocTich,
        ISNULL(nv.IsVeHuu, 0) AS IsVeHuu,
        ISNULL(
            (
                SELECT MAX(MucLuong) 
                FROM NS_QTDongBHXH 
                WHERE NhanVienID = nv.NhanVienID
                  AND NgayBatDau = 
                      (
                          SELECT MAX(NgayBatDau) 
                          FROM NS_QTDongBHXH 
                          WHERE NhanVienID = nv.NhanVienID
                            AND NgayBatDau < @tdate 
                            AND MucLuong > 0
                      )
            ),
            0
        ) AS MucLuong,
        ISNULL(
            (
                SELECT MAX(Type) 
                FROM NS_QTDongBHXH 
                WHERE NhanVienID = nv.NhanVienID
                  AND @fdate BETWEEN NgayBatDau AND NgayketThuc
            ),
            1
        ) AS [Type],
        CASE 
            WHEN ISNULL(
                     (
                         SELECT MAX(Type) 
                         FROM NS_QTDongBHXH 
                         WHERE NhanVienID = nv.NhanVienID
                           AND @fdate BETWEEN NgayBatDau AND NgayketThuc
                     ), 1
                 ) IN (5,7,8)
             AND ISNULL(
                     (
                         SELECT MAX(CONVERT(INT, ISNULL(KhongTraTheBHYT, 0))) 
                         FROM NS_QTDongBHXH 
                         WHERE NhanVienID = nv.NhanVienID
                           AND @fdate BETWEEN NgayBatDau AND NgayketThuc
                     ), 0
                 ) = 1 
            THEN 1 ELSE 0 
        END AS NhomNhanVienID,
        ISNULL(nv.TrangThaiTGCongDoan, 0) AS IsCD,
        @LTTV1 AS LTTV
    FROM NhanVien nv
    LEFT JOIN NS_DsQuocTich qt 
        ON nv.QuocTichID = qt.QuocTichID
    LEFT JOIN PhongBan pb 
        ON pb.PhongBanID = nv.PhongBanID 
       AND pb.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
    LEFT JOIN SYS_ThongTinCongTy cty 
        ON cty.ID = pb.CongTyID
    WHERE nv.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
      AND nv.NgayBatDauLam <= @tdate 
      AND (ISNULL(nv.NghiViec, 0) = 0 OR CONVERT(DATE, nv.NgayNghiViec) > @fdate)
      AND ISNULL(nv.IsDeleted, 0) = 0
      AND EXISTS 
      (
          SELECT 1 
          FROM NS_QTDongBHXH 
          WHERE NhanVienID = nv.NhanVienID 
            AND MucLuong > 0 
            AND NgayBatDau < @tdate
      )
),
TinhToanBH AS
(
    SELECT 
        nv.*,
        tl.*,
        @fdate AS Ngay,
        @Thang AS Thang,
        @Nam   AS Nam,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 
            THEN 0 ELSE 1 
        END AS IsTrichNop,

        CASE 
            WHEN nv.MucLuong >= 20 * @LTTC 
            THEN 20 * @LTTC 
            ELSE nv.MucLuong 
        END AS ML_BHXH,

        CASE 
            WHEN nv.MucLuong >= 20 * nv.LTTV 
            THEN 20 * nv.LTTV 
            ELSE nv.MucLuong 
        END AS ML_BHTN,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.IsCD = 1 OR nv.QuocTich <> N'Việt Nam' 
            THEN 0
            ELSE
                CASE 
                    WHEN (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * @tyle_CDP 
                         >= (@LTTC * 0.1) 
                    THEN (@LTTC * 0.1)
                    ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * @tyle_CDP
                END
        END AS DPCD_NLD,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.IsVeHuu = 1 OR nv.QuocTich <> N'Việt Nam' 
            THEN 0
            ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 0.02
        END AS KPCD_CTY,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.ThuNhapHaiNoi = 1 THEN 0.05  
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHXH_CTY 
                        ELSE tl.TyLeBHXH_CTY_NNG 
                    END
                ) / 100.0
        END AS BHXH_CTY_TMP,

        CASE 
            WHEN (nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1) AND nv.NhomNhanVienID <> 1 
            THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHYT_CTY 
                        ELSE tl.TyLeBHYT_CTY_NNG 
                    END
                ) / 100.0
        END AS BHYT_CTY_TMP,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 
            THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * nv.LTTV THEN 20 * nv.LTTV ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHTN_CTY 
                        ELSE tl.TyLeBHTN_CTY_NNG 
                    END
                ) / 100.0
        END AS BHTN_CTY_TMP,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 
            THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHXH_NLD 
                        ELSE tl.TyLeBHXH_NNG 
                    END
                ) / 100.0
        END AS BHXH_NLD_TMP,

        CASE 
            WHEN (nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1) AND nv.NhomNhanVienID <> 1 
            THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHYT_NLD 
                        ELSE tl.TyLeBHYT_NNG 
                    END
                ) / 100.0
        END AS BHYT_NLD_TMP,

        CASE 
            WHEN nv.[Type] IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 
            THEN 0
            ELSE 
                (CASE WHEN nv.MucLuong >= 20 * nv.LTTV THEN 20 * nv.LTTV ELSE nv.MucLuong END) * 
                (
                    CASE 
                        WHEN nv.IsVeHuu = 1 THEN 0 
                        WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHTN_NLD 
                        ELSE tl.TyLeBHTN_NNG 
                    END
                ) / 100.0
        END AS BHTN_NLD_TMP
    FROM NhanVienTinh nv
    CROSS JOIN @TyLeBH tl
)
SELECT *
INTO #TinhToanBH
FROM TinhToanBH;

---------------------------------------------------------------
-- 5. TÍNH CHÊNH LỆCH BACKDATE CHO CHÍNH THÁNG @Thang/@Nam
--    So sánh: #TinhToanBH (số mới)  VS  NS_TL_BangTrichBHXH (số cũ)
---------------------------------------------------------------

-- Xoá chênh lệch cũ của kỳ này (nếu đã chạy trước đó)
DELETE cl
FROM NS_TL_ChenhLechBHXH cl
WHERE cl.ThangBC = @Thang
  AND cl.NamBC   = @Nam
  AND cl.ThangPhatSinhBienDong = @tdate
  AND cl.NhanVienID IN (SELECT NhanVienID FROM #TinhToanBH);

;WITH BangMoi AS
(
    SELECT * FROM #TinhToanBH
),
BangCu AS
(
    SELECT 
        bt.NhanVienID,
        bt.BHXH_CTY,
        bt.BHYT_CTY,
        bt.BHTN_CTY,
        bt.BHXH_NLD,
        bt.BHYT_NLD,
        bt.BHTN_NLD,
        bt.TONGCONGDOAN,
        bt.KPCD_CTY
    FROM NS_TL_BangTrichBHXH bt
    WHERE bt.Thang      = @Thang
      AND bt.Nam        = @Nam
      AND bt.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
)
INSERT INTO [dbo].[NS_TL_ChenhLechBHXH]
(
    [ThangBC],[NamBC],[NhanVienID],[MucLuong],[HoVaTen],
    [MaNhanVien],[PhongBan],[IsVeHuu],[QuocTich],[TyGia],
    [MaDonVi],[IsCD],[Type],[NgayBatDau],[ThangBaoCao],
    [IsTrichBHXH],[IsTrichBHTNLD],[IsTrichBHYT],[IsTrichBHTN],
    [Ngay],[IsTrichNop],[ML_BHXH],[ML_BHTN],[TL_BHXHCTY],
    [TL_BHTNLDCTY],[TL_BHYTCTY],[TL_BHTNCTY],[TL_BHXHNLD],[TL_BHYTNLD],
    [TL_BHTNNLD],[CONGDOAN],[KPCD],[BHXH_CTY],[BHTNLD_CTY],[BHYT_CTY],[BHTN_CTY],
    [BHXH_NLD],[BHYT_NLD],[BHTN_NLD],
    [ChenhLechBHXH_CTY],[ChenhLechBHTNLD_CTY],[ChenhLechBHYT_CTY],[ChenhLechBHTN_CTY],
    [ChenhLechBHXH_NLD],[ChenhLechBHYT_NLD],[ChenhLechBHTN_NLD],
    [ChenhLechCONGDOAN],[ChenhLechKPCD],[ThangPhatSinhBienDong]
)
SELECT
    @Thang                               AS ThangBC,
    @Nam                                 AS NamBC,
    m.NhanVienID,
    m.MucLuong,
    m.HoVaTen,
    m.MaNhanVien,
    m.TenPhongBan                        AS PhongBan,
    m.IsVeHuu,
    m.QuocTich,
    1                                    AS TyGia,
    NULL                                 AS MaDonVi,
    m.IsCD,
    m.[Type],
    m.Ngay                                 AS NgayBatDau,
    DATEADD(MONTH,1,m.Ngay)                                 AS ThangBaoCao,

    CASE WHEN ROUND(m.BHXH_CTY_TMP,0) = 0 AND ROUND(m.BHXH_NLD_TMP,0) = 0 THEN 0 ELSE 1 END AS IsTrichBHXH,
    0                                    AS IsTrichBHTNLD,
    CASE WHEN ROUND(m.BHYT_CTY_TMP,0) = 0 AND ROUND(m.BHYT_NLD_TMP,0) = 0 THEN 0 ELSE 1 END AS IsTrichBHYT,
    CASE WHEN ROUND(m.BHTN_CTY_TMP,0) = 0 AND ROUND(m.BHTN_NLD_TMP,0) = 0 THEN 0 ELSE 1 END AS IsTrichBHTN,

    m.Ngay,
    m.IsTrichNop,
    m.ML_BHXH,
    m.ML_BHTN,

    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHXH_CTY ELSE m.TyLeBHXH_CTY_NNG END AS TL_BHXHCTY,
    0                                    AS TL_BHTNLDCTY,
    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHYT_CTY ELSE m.TyLeBHYT_CTY_NNG END AS TL_BHYTCTY,
    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHTN_CTY ELSE m.TyLeBHTN_CTY_NNG END AS TL_BHTNCTY,
    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHXH_NLD ELSE m.TyLeBHXH_NNG END AS TL_BHXHNLD,
    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHYT_NLD ELSE m.TyLeBHYT_NNG END AS TL_BHYTNLD,
    CASE WHEN m.IsVeHuu = 1 THEN 0 WHEN m.QuocTich = N'Việt Nam' THEN m.TyLeBHTN_NLD ELSE m.TyLeBHTN_NNG END AS TL_BHTNNLD,

    ROUND(m.KPCD_CTY + m.DPCD_NLD,0)     AS CONGDOAN,
    ROUND(m.KPCD_CTY,0)                  AS KPCD,

    ROUND(m.BHXH_CTY_TMP,0)             AS BHXH_CTY,
    0                                   AS BHTNLD_CTY,
    ROUND(m.BHYT_CTY_TMP,0)             AS BHYT_CTY,
    ROUND(m.BHTN_CTY_TMP,0)             AS BHTN_CTY,
    ROUND(m.BHXH_NLD_TMP,0)             AS BHXH_NLD,
    ROUND(m.BHYT_NLD_TMP,0)             AS BHYT_NLD,
    ROUND(m.BHTN_NLD_TMP,0)             AS BHTN_NLD,

    ROUND(m.BHXH_CTY_TMP,0) - ISNULL(ROUND(c.BHXH_CTY,0),0)   AS ChenhLechBHXH_CTY,
    0                                                          AS ChenhLechBHTNLD_CTY,
    ROUND(m.BHYT_CTY_TMP,0) - ISNULL(ROUND(c.BHYT_CTY,0),0)   AS ChenhLechBHYT_CTY,
    ROUND(m.BHTN_CTY_TMP,0) - ISNULL(ROUND(c.BHTN_CTY,0),0)   AS ChenhLechBHTN_CTY,

    ROUND(m.BHXH_NLD_TMP,0) - ISNULL(ROUND(c.BHXH_NLD,0),0)   AS ChenhLechBHXH_NLD,
    ROUND(m.BHYT_NLD_TMP,0) - ISNULL(ROUND(c.BHYT_NLD,0),0)   AS ChenhLechBHYT_NLD,
    ROUND(m.BHTN_NLD_TMP,0) - ISNULL(ROUND(c.BHTN_NLD,0),0)   AS ChenhLechBHTN_NLD,

    ROUND(m.KPCD_CTY + m.DPCD_NLD,0) - ISNULL(ROUND(c.TONGCONGDOAN,0),0) AS ChenhLechCONGDOAN,
    ROUND(m.KPCD_CTY,0)              - ISNULL(ROUND(c.KPCD_CTY,0),0)     AS ChenhLechKPCD,

    @tdate                               AS ThangPhatSinhBienDong
FROM BangMoi m
LEFT JOIN BangCu c
       ON c.NhanVienID = m.NhanVienID
WHERE 
    (ROUND(m.BHXH_CTY_TMP,0) - ISNULL(ROUND(c.BHXH_CTY,0),0)) <> 0 OR
    (ROUND(m.BHYT_CTY_TMP,0) - ISNULL(ROUND(c.BHYT_CTY,0),0)) <> 0 OR
    (ROUND(m.BHTN_CTY_TMP,0) - ISNULL(ROUND(c.BHTN_CTY,0),0)) <> 0 OR
    (ROUND(m.BHXH_NLD_TMP,0) - ISNULL(ROUND(c.BHXH_NLD,0),0)) <> 0 OR
    (ROUND(m.BHYT_NLD_TMP,0) - ISNULL(ROUND(c.BHYT_NLD,0),0)) <> 0 OR
    (ROUND(m.BHTN_NLD_TMP,0) - ISNULL(ROUND(c.BHTN_NLD,0),0)) <> 0 OR
    (ROUND(m.KPCD_CTY + m.DPCD_NLD,0) - ISNULL(ROUND(c.TONGCONGDOAN,0),0)) <> 0 OR
    (ROUND(m.KPCD_CTY,0) - ISNULL(ROUND(c.KPCD_CTY,0),0)) <> 0;


---------------------------------------------------------------
-- 6. SAU KHI CHÊNH LỆCH XONG MỚI CẬP NHẬT LẠI NS_TL_BangTrichBHXH
---------------------------------------------------------------

DELETE FROM NS_TL_BangTrichBHXH 
WHERE Thang = @Thang 
  AND Nam = @Nam 
  AND PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon);

INSERT INTO dbo.NS_TL_BangTrichBHXH
(
    MaNhanVien, NhanVienID, HoVaTen, ThuNhapHaiNoi, TenPhongBan,
    PhongBanID, CongTyID, ThuTu, QuocTich, IsVeHuu,
    MucLuong, [Type], TyGia, NhomNhanVienID, IsCD, 
    Ngay, IsTrichNop, ML_BHXH, ML_BHTN, 
    TL_BHXH_CTY, TL_BHYT_CTY, TL_BHTN_CTY,
    TL_BHXH_NLD, TL_BHYT_NLD, TL_BHTN_NLD, 
    Thang, Nam,
    TONGCONGDOAN, KPCD_CTY, DPCD_NLD, 
    BHXH_CTY,  BHYT_CTY, BHTN_CTY, BHXH_NLD,
    BHYT_NLD, BHTN_NLD, BH_NLD, BH_CTY, TONGBH
)
SELECT 
    MaNhanVien,
    NhanVienID,
    HoVaTen,
    ThuNhapHaiNoi,
    TenPhongBan,
    PhongBanID,
    CongTyID,
    ThuTu,
    QuocTich,
    IsVeHuu,
    MucLuong,
    [Type],
    1 AS TyGia,
    NhomNhanVienID,
    IsCD,
    Ngay,
    IsTrichNop,
    ML_BHXH,
    ML_BHTN,

    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHXH_CTY ELSE TyLeBHXH_CTY_NNG END AS TL_BHXH_CTY,
    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHYT_CTY ELSE TyLeBHYT_CTY_NNG END AS TL_BHYT_CTY,
    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHTN_CTY ELSE TyLeBHTN_CTY_NNG END AS TL_BHTN_CTY,

    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHXH_NLD ELSE TyLeBHXH_NNG END AS TL_BHXH_NLD,
    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHYT_NLD ELSE TyLeBHYT_NNG END AS TL_BHYT_NLD,
    CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHTN_NLD ELSE TyLeBHTN_NNG END AS TL_BHTN_NLD,

    Thang,
    Nam,

    ROUND(KPCD_CTY + DPCD_NLD, 0) AS TONGCONGDOAN,
    ROUND(KPCD_CTY, 0)            AS KPCD_CTY,
    ROUND(DPCD_NLD, 0)            AS DPCD_NLD,

    ROUND(BHXH_CTY_TMP, 0)        AS BHXH_CTY,
    ROUND(BHYT_CTY_TMP, 0)        AS BHYT_CTY,
    ROUND(BHTN_CTY_TMP, 0)        AS BHTN_CTY,
    ROUND(BHXH_NLD_TMP, 0)        AS BHXH_NLD,
    ROUND(BHYT_NLD_TMP, 0)        AS BHYT_NLD,
    ROUND(BHTN_NLD_TMP, 0)        AS BHTN_NLD,

    ROUND(BHXH_NLD_TMP + BHYT_NLD_TMP + BHTN_NLD_TMP, 0) AS BH_NLD,
    ROUND(BHXH_CTY_TMP  + BHYT_CTY_TMP + BHTN_CTY_TMP, 0) AS BH_CTY,
    ROUND(
        BHXH_NLD_TMP + BHYT_NLD_TMP + BHTN_NLD_TMP 
      + BHXH_CTY_TMP  + BHYT_CTY_TMP + BHTN_CTY_TMP,
        0
    ) AS TONGBH
FROM #TinhToanBH
ORDER BY ThuTu, MaNhanVien;

---------------------------------------------------------------
-- 7. TRẢ KẾT QUẢ BÁO CÁO THÁNG ĐÃ BACKDATE
---------------------------------------------------------------
SELECT 
    nv.MaNhanVien AS N'Mã nhân viên', 
    bh.HoVaTen    AS N'Họ và tên',
    cty.madonvi   AS N'Mã đơn vị', 
    pb.Ten        AS N'Phòng ban',
    cv.TenChucVu  AS N'Tên chức danh',
    bh.MucLuong   AS N'Mức lương',
    bh.BHXH_CTY,
    bh.BHYT_CTY,
    bh.BHTN_CTY,
    bh.KPCD_CTY   AS N'Kinh phí công đoàn',
    bh.BH_CTY     AS N'Bảo hiểm CTY',

    bh.BHXH_NLD,
    bh.BHYT_NLD,
    bh.BHTN_NLD,
    bh.DPCD_NLD   AS N'Đoàn phí công đoàn',
    bh.BH_NLD     AS N'Bảo hiểm NLD',
    bh.TONGBH     AS N'Tổng bảo hiểm',
    bh.TONGCONGDOAN AS N'Tổng công đoàn'
FROM NS_TL_BangTrichBHXH bh
LEFT JOIN NhanVien nv 
    ON nv.NhanVienID = bh.NhanVienID
LEFT JOIN PhongBan pb 
    ON pb.PhongBanID = nv.PhongBanID
LEFT JOIN SYS_ThongTinCongTy cty 
    ON cty.ID = pb.CongTyID
LEFT JOIN NS_DsChucVu cv 
    ON cv.ChucVuID = nv.ChucVuID
WHERE bh.Thang = @Thang 
  AND bh.Nam   = @Nam 
  AND bh.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
ORDER BY bh.ThuTu, bh.MaNhanVien;

END
GO
/****** Object:  StoredProcedure [dbo].[sp_BHXH_TinhTrichNopHangThang_Old]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[sp_BHXH_TinhTrichNopHangThang_Old]     @Thang INT,     @Nam INT,     @PhongBanID INT AS
BEGIN
    SET NOCOUNT ON;
    --declare @Thang int=3 ,@Nam int=2025,@PhongBanID int=20
    -- 1. Khai báo biến và bảng tạm
    DECLARE @fdate DATE = DATEFROMPARTS(@Nam, @Thang, 1);
    DECLARE @tdate DATE = EOMONTH(@fdate);
	declare @tyle_CDP decimal(10,3)=(case when @fdate>='2025-01-08' then 0.005 else 0.01 end)
    
    -- Bảng lưu phòng ban con
    DECLARE @PhongBanCon TABLE (PhongBanID INT PRIMARY KEY);
    INSERT INTO @PhongBanCon
    SELECT PhongBanID FROM fn_LayPhongBanCon(@PhongBanID);
    
    -- 2. Lấy thông tin lương tối thiểu
    DECLARE @LuongToiThieu TABLE (        Vung1 DECIMAL(10,3),         Vung2 DECIMAL(10,3),         Vung3 DECIMAL(10,3),         Vung4 DECIMAL(10,3),         LuongToiThieuChung DECIMAL(10,3)    );
    
    INSERT INTO @LuongToiThieu
    SELECT TOP 1 Vung1, Vung2, Vung3, Vung4, LuongToiThieuChung 
    FROM NS_BH_LuongToiThieu 
    WHERE NgayBatDau < @fdate
    ORDER BY NgayBatDau DESC;
    
    DECLARE @LTTV1 DECIMAL(10,3) = ISNULL((SELECT Vung1 FROM @LuongToiThieu), 4680000);
    DECLARE @LTTV2 DECIMAL(10,3) = ISNULL((SELECT Vung2 FROM @LuongToiThieu), 4160000);
    DECLARE @LTTV3 DECIMAL(10,3) = ISNULL((SELECT Vung3 FROM @LuongToiThieu), 3640000);
    DECLARE @LTTV4 DECIMAL(10,3) = ISNULL((SELECT Vung4 FROM @LuongToiThieu), 3250000);
    DECLARE @LTTC DECIMAL(10,3) = ISNULL((SELECT LuongToiThieuChung FROM @LuongToiThieu), 1800000);
    
    -- 3. Lấy tỷ lệ đóng BHXH hiện hành
    DECLARE @TyLeBH TABLE (        TyLeBHXH_CTY DECIMAL(5,2),        TyLeBHYT_CTY DECIMAL(5,2),        TyLeBHTN_CTY DECIMAL(5,2)
        , TyLeBHXH_NLD DECIMAL(5,2),        TyLeBHYT_NLD DECIMAL(5,2),        TyLeBHTN_NLD DECIMAL(5,2)
        , TyLeBHXH_CTY_NNG DECIMAL(5,2),        TyLeBHYT_CTY_NNG DECIMAL(5,2),        TyLeBHTN_CTY_NNG DECIMAL(5,2)
        , TyLeBHXH_NNG DECIMAL(5,2),        TyLeBHYT_NNG DECIMAL(5,2),        TyLeBHTN_NNG DECIMAL(5,2)
    );
    
    INSERT INTO @TyLeBH
    SELECT TOP 1 
        TyLe_BHXH_CTY, TyLe_BHYT_CTY, TyLe_BHTN_CTY,         TyLe_BHXH_NLD, TyLe_BHYT_NLD, TyLe_BHTN_NLD,
        TyLe_BHXH_CTY_NNG, TyLe_BHYT_CTY_NNG, TyLe_BHTN_CTY_NNG,        TyLe_BHXH_NNG, TyLe_BHYT_NNG, TyLe_BHTN_NNG
    FROM dbo.NS_BH_TyLeThamGiaBHXH 
    WHERE NgayBatDau <= @tdate 
    ORDER BY NgayBatDau DESC;
    
    -- 4. Xóa dữ liệu cũ
    DELETE FROM NS_TL_BangTrichBHXH 
    WHERE Thang = @Thang AND Nam = @Nam 
    AND PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon);

    
    -- 5. Tính toán dữ liệu mới sử dụng CTE
    ;WITH NhanVienTinh AS (
        -- Lấy danh sách nhân viên cần tính (giữ nguyên như trước)
        SELECT 
            nv.MaNhanVien, nv.NhanVienID, CONCAT(nv.HO, ' ', nv.HoTen) AS HoVaTen,
            ISNULL(CONVERT(BIT, nv.ThuNhapHaiNoi), 0) AS ThuNhapHaiNoi,
            pb.Ten AS TenPhongBan, pb.PhongBanID, ISNULL(pb.CongTyID, 0) AS CongTyID, pb.ThuTu,
            ISNULL(qt.TenNuoc, N'Việt Nam') AS QuocTich, ISNULL(nv.IsVeHuu, 0) AS IsVeHuu,
            --ISNULL((SELECT MAX(MucLuong) FROM NS_QTDongBHXH 
                  --WHERE NhanVienID = nv.NhanVienID
                  --AND NgayBatDau = (SELECT MAX(NgayBatDau) FROM NS_QTDongBHXH 
                  --                 WHERE NhanVienID = nv.NhanVienID
                  --                 AND NgayBatDau < @tdate AND ThangBaoCao < @tdate AND MucLuong > 0)), 0) AS MucLuong,
            ISNULL((SELECT MAX(MucLuong) FROM NS_QTDongBHXH 
                  WHERE NhanVienID = nv.NhanVienID
                  AND NgayBatDau = (SELECT MAX(NgayBatDau) FROM NS_QTDongBHXH 
                                   WHERE NhanVienID = nv.NhanVienID
                                   AND NgayBatDau < @tdate AND MucLuong > 0)), 0) AS MucLuong,
            ISNULL((SELECT MAX(Type) FROM NS_QTDongBHXH 
                  WHERE NhanVienID = nv.NhanVienID
                  AND @fdate BETWEEN NgayBatDau AND NgayketThuc), 1) AS Type,
            CASE WHEN ISNULL((SELECT MAX(Type) FROM NS_QTDongBHXH 
                            WHERE NhanVienID = nv.NhanVienID
                            AND @fdate BETWEEN NgayBatDau AND NgayketThuc), 1) IN (5,7,8)
                 AND ISNULL((SELECT MAX(CONVERT(INT, ISNULL(KhongTraTheBHYT, 0))) FROM NS_QTDongBHXH 
                            WHERE NhanVienID = nv.NhanVienID
                            AND @fdate BETWEEN NgayBatDau AND NgayketThuc), 0) = 1 
                 THEN 1 ELSE 0 END AS NhomNhanVienID,
            ISNULL(nv.TrangThaiTGCongDoan, 0) AS IsCD ,@LTTV1 AS LTTV
        FROM NhanVien nv
        LEFT JOIN NS_DsQuocTich qt ON nv.QuocTichID = qt.QuocTichID
        LEFT JOIN PhongBan pb ON pb.PhongBanID = nv.PhongBanID AND pb.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
        LEFT JOIN SYS_ThongTinCongTy cty ON cty.ID = pb.CongTyID
        WHERE nv.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
          AND nv.NgayBatDauLam <= @tdate 
          AND (ISNULL(nv.NghiViec, 0) = 0 OR CONVERT(DATE, nv.NgayNghiViec) > @fdate)
          AND ISNULL(nv.IsDeleted, 0) = 0
          AND EXISTS (SELECT 1 FROM NS_QTDongBHXH WHERE NhanVienID = nv.NhanVienID AND MucLuong > 0 AND NgayBatDau < @tdate)
    ),
    TinhToanBH AS (
        SELECT 
            nv.*,
            tl.*,
            @fdate AS Ngay,
            @Thang AS Thang,
            @Nam AS Nam,
            -- Các thông số cơ bản
            CASE WHEN nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 THEN 0 ELSE 1 END AS IsTrichNop,
            -- Mức lương đóng BHXH (tối đa 20 lần lương tối thiểu chung)
            CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END AS ML_BHXH,
            -- Mức lương đóng BHTN (tối đa 20 lần lương tối thiểu vùng)
            CASE WHEN nv.MucLuong >= 20 * nv.LTTV THEN 20 * nv.LTTV ELSE nv.MucLuong END AS ML_BHTN,
            
            -- Tính từng khoản đóng riêng biệt
            -- Công đoàn (1% lương, tối đa 10% lương tối thiểu chung)
            CASE 
                WHEN nv.Type IN (5,7,8,9) OR  nv.IsCD = 1 OR nv.QuocTich <> N'Việt Nam' THEN 0
                WHEN (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * @tyle_CDP >= (@LTTC * 0.1) 
                THEN (@LTTC * 0.1)
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * @tyle_CDP
            END AS DPCD_NLD,
            
            -- Kinh phí công đoàn (2% lương)
            CASE 
                WHEN nv.Type IN (5,7,8,9)  OR nv.IsVeHuu = 1 OR nv.QuocTich <> N'Việt Nam' THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 0.02
            END AS KPCD_CTY,
            
            -- BHXH công ty
            /*THU NHẬP 2 NƠI THÌ CHỈ ĐÓNG 5 BẢO HIỂM TNLD_BNN*/
            CASE 
                WHEN nv.Type IN (5,7,8,9) THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 
                                   WHEN   nv.ThuNhapHaiNoi = 1 THEN 0.05  WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHXH_CTY ELSE tl.TyLeBHXH_CTY_NNG END) / 100.0
            END AS BHXH_CTY_TMP,
            
          
            
            -- BHYT công ty
            CASE 
                WHEN (nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1) AND nv.NhomNhanVienID != 1 THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHYT_CTY ELSE tl.TyLeBHYT_CTY_NNG END) / 100.0
            END AS BHYT_CTY_TMP,
            
            -- BHTN công ty
            CASE 
                WHEN nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * nv.LTTV THEN 20 * nv.LTTV ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHTN_CTY ELSE tl.TyLeBHTN_CTY_NNG END) / 100.0
            END AS BHTN_CTY_TMP,
            
            -- BHXH nhân viên
            CASE 
                WHEN nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHXH_NLD ELSE tl.TyLeBHXH_NNG END) / 100.0
            END AS BHXH_NLD_TMP,
            
            -- BHYT nhân viên
            CASE 
                WHEN (nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1) AND nv.NhomNhanVienID != 1 THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * @LTTC THEN 20 * @LTTC ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHYT_NLD ELSE tl.TyLeBHYT_NNG END) / 100.0
            END AS BHYT_NLD_TMP,
            
            -- BHTN nhân viên
            CASE 
                WHEN nv.Type IN (5,7,8,9) OR nv.ThuNhapHaiNoi = 1 THEN 0
                ELSE (CASE WHEN nv.MucLuong >= 20 * nv.LTTV THEN 20 * nv.LTTV ELSE nv.MucLuong END) * 
                     (CASE WHEN nv.IsVeHuu = 1 THEN 0 WHEN nv.QuocTich = N'Việt Nam' THEN tl.TyLeBHTN_NLD ELSE tl.TyLeBHTN_NNG END) / 100.0
            END AS BHTN_NLD_TMP
        FROM NhanVienTinh nv
        CROSS JOIN @TyLeBH tl
    )
    INSERT INTO dbo.NS_TL_BangTrichBHXH (MaNhanVien, NhanVienID, HoVaTen, ThuNhapHaiNoi, TenPhongBan,
        PhongBanID, CongTyID, ThuTu, QuocTich, IsVeHuu,
        MucLuong, Type, TyGia, NhomNhanVienID, IsCD, 
        Ngay, IsTrichNop, ML_BHXH, ML_BHTN, TL_BHXH_CTY,          TL_BHYT_CTY, TL_BHTN_CTY
        , TL_BHXH_NLD, TL_BHYT_NLD,TL_BHTN_NLD, Thang, Nam,
        TONGCONGDOAN, KPCD_CTY, DPCD_NLD, BHXH_CTY,  BHYT_CTY, BHTN_CTY, BHXH_NLD,
        BHYT_NLD, BHTN_NLD, BH_NLD, BH_CTY, TONGBH  )

    SELECT 
        MaNhanVien,        NhanVienID,        HoVaTen,        ThuNhapHaiNoi,        TenPhongBan,        PhongBanID,        CongTyID,        ThuTu,        QuocTich,        IsVeHuu,        MucLuong,
        Type,        1 AS TyGia,        NhomNhanVienID,        IsCD,        Ngay,        IsTrichNop,        ML_BHXH,        ML_BHTN,
        -- Tỷ lệ đóng (giữ nguyên)
        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHXH_CTY ELSE TyLeBHXH_CTY_NNG END AS TL_BHXH_CTY,
        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHYT_CTY ELSE TyLeBHYT_CTY_NNG END AS TL_BHYT_CTY,
        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHTN_CTY ELSE TyLeBHTN_CTY_NNG END AS TL_BHTN_CTY,

        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHXH_NLD ELSE TyLeBHXH_NNG END AS TL_BHXH_NLD,
        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHYT_NLD ELSE TyLeBHYT_NNG END AS TL_BHYT_NLD,
        CASE WHEN IsVeHuu = 1 THEN 0 WHEN QuocTich = N'Việt Nam' THEN TyLeBHTN_NLD ELSE TyLeBHTN_NNG END AS TL_BHTN_NLD,
        Thang,        Nam,
        -- Làm tròn các giá trị đã tính
        ROUND(KPCD_CTY + DPCD_NLD, 0) AS TONGCONGDOAN,
        ROUND(KPCD_CTY, 0) AS KPCD_CTY,
        ROUND(DPCD_NLD, 0) AS DPCD_NLD,
        ROUND(BHXH_CTY_TMP, 0) AS BHXH_CTY,
        ROUND(BHYT_CTY_TMP, 0) AS BHYT_CTY,
        ROUND(BHTN_CTY_TMP, 0) AS BHTN_CTY,
        ROUND(BHXH_NLD_TMP, 0) AS BHXH_NLD,
        ROUND(BHYT_NLD_TMP, 0) AS BHYT_NLD,
        ROUND(BHTN_NLD_TMP, 0) AS BHTN_NLD,
        -- Tổng đóng của nhân viên
        ROUND(BHXH_NLD_TMP + BHYT_NLD_TMP + BHTN_NLD_TMP, 0) AS BH_NLD,
        -- Tổng đóng của công ty
        ROUND(BHXH_CTY_TMP  + BHYT_CTY_TMP + BHTN_CTY_TMP, 0) AS BH_CTY,
        -- Tổng cộng (công ty + nhân viên)
        ROUND(BHXH_NLD_TMP + BHYT_NLD_TMP + BHTN_NLD_TMP + BHXH_CTY_TMP  + BHYT_CTY_TMP + BHTN_CTY_TMP, 0) AS TONGBH
    FROM TinhToanBH
    ORDER BY ThuTu, MaNhanVien;
    

    
    -- 6. Trả kết quả (giữ nguyên như trước)
    SELECT 
        nv.MaNhanVien AS N'Mã nhân viên', 
        bh.HoVaTen AS N'Họ và tên',
        cty.madonvi AS N'Mã đơn vị', 
        pb.Ten AS N'Phòng ban',
        cv.TenChucVu AS N'Tên chức danh',
		bh.MucLuong as N'Mức lương',
        bh.BHXH_CTY,        bh.BHYT_CTY,        bh.BHTN_CTY,        bh.KPCD_CTY AS N'Kinh phí công đoàn', bh.BH_CTY as N'Bảo hiểm CTY',

        bh.BHXH_NLD,        bh.BHYT_NLD,        bh.BHTN_NLD,        bh.DPCD_NLD AS N'Đoàn phí công đoàn', bh.BH_NLD as N'Bảo hiểm NLD'
        ,bh.TONGBH as N'Tổng bảo hiểm', bh.TONGCONGDOAN as N'Tổng công đoàn'
    FROM NS_TL_BangTrichBHXH bh
    LEFT JOIN NhanVien nv ON nv.NhanVienID = bh.NhanVienID
    LEFT JOIN PhongBan pb ON pb.PhongBanID = nv.PhongBanID
    LEFT JOIN SYS_ThongTinCongTy cty ON cty.ID = pb.CongTyID
    LEFT JOIN NS_DsChucVu cv ON cv.ChucVuID = nv.ChucVuID
    WHERE bh.Thang = @Thang 
      AND bh.Nam = @Nam 
      AND bh.PhongBanID IN (SELECT PhongBanID FROM @PhongBanCon)
    ORDER BY bh.ThuTu, bh.MaNhanVien;
END
