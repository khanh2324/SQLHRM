/****** Object:  StoredProcedure [dbo].[proc_CopyBTC]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROC [dbo].[proc_CopyBTC]
(
    @ID INT,                -- BoTieuChiID đích
    @CopyTuBoTieuChi INT    -- BoTieuChiID nguồn
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRAN;

        --------------------------------------------------
        -- 1. Xóa toàn bộ tiêu chí cũ của bộ đích
        --------------------------------------------------
        DELETE dbo.NS_DG_TieuChi
        WHERE BoTieuChiID = @ID;

        --------------------------------------------------
        -- 2. Bảng mapping ID cũ -> ID mới
        --------------------------------------------------
        DECLARE @MapTieuChi TABLE
        (
            OldTieuChiID INT PRIMARY KEY,
            NewTieuChiID INT
        );

        --------------------------------------------------
        -- 3. Copy tiêu chí CHA gốc (TieuChiChaID = 0)
        --------------------------------------------------
        MERGE dbo.NS_DG_TieuChi AS target
        USING
        (
            SELECT *
            FROM dbo.NS_DG_TieuChi
            WHERE BoTieuChiID = @CopyTuBoTieuChi
              AND TieuChiChaID = 0
        ) AS source
        ON 1 = 0
        WHEN NOT MATCHED THEN
            INSERT
            (
                TieuChiChaID, BoTieuChiID, TenTieuChi, MaTieuChi,
                TrongSo, MucTieu, MoTa, IsUse, IsDeleted, IsGroup,
                IsNhapGiaTri, IsReadOnly, IsFixed, ThuTu,
                DiemTru, CongThuc, DonViTinh, ValueList
            )
            VALUES
            (
                0, @ID, source.TenTieuChi, source.MaTieuChi,
                source.TrongSo, source.MucTieu, source.MoTa,
                source.IsUse, source.IsDeleted, source.IsGroup,
                source.IsNhapGiaTri, source.IsReadOnly, source.IsFixed,
                source.ThuTu, source.DiemTru, source.CongThuc,
                source.DonViTinh, source.ValueList
            )
        OUTPUT
            source.TieuChiID,
            inserted.TieuChiID
        INTO @MapTieuChi (OldTieuChiID, NewTieuChiID);

        --------------------------------------------------
        -- 4. Copy các cấp CON (đệ quy bằng WHILE)
        --------------------------------------------------
        WHILE 1 = 1
        BEGIN
            MERGE dbo.NS_DG_TieuChi AS target
            USING
            (
                SELECT con.*
                     , map.NewTieuChiID AS NewChaID
                FROM dbo.NS_DG_TieuChi con
                INNER JOIN @MapTieuChi map
                    ON con.TieuChiChaID = map.OldTieuChiID
                WHERE con.BoTieuChiID = @CopyTuBoTieuChi
                  AND NOT EXISTS
                  (
                      SELECT 1
                      FROM @MapTieuChi m
                      WHERE m.OldTieuChiID = con.TieuChiID
                  )
            ) AS source
            ON 1 = 0
            WHEN NOT MATCHED THEN
                INSERT
                (
                    TieuChiChaID, BoTieuChiID, TenTieuChi, MaTieuChi,
                    TrongSo, MucTieu, MoTa, IsUse, IsDeleted, IsGroup,
                    IsNhapGiaTri, IsReadOnly, IsFixed, ThuTu,
                    DiemTru, CongThuc, DonViTinh, ValueList
                )
                VALUES
                (
                    source.NewChaID, @ID, source.TenTieuChi, source.MaTieuChi,
                    source.TrongSo, source.MucTieu, source.MoTa,
                    source.IsUse, source.IsDeleted, source.IsGroup,
                    source.IsNhapGiaTri, source.IsReadOnly, source.IsFixed,
                    source.ThuTu, source.DiemTru, source.CongThuc,
                    source.DonViTinh, source.ValueList
                )
            OUTPUT
                source.TieuChiID,
                inserted.TieuChiID
            INTO @MapTieuChi (OldTieuChiID, NewTieuChiID);

            IF @@ROWCOUNT = 0 BREAK;
        END

        COMMIT TRAN;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRAN;
        THROW;
    END CATCH
END
GO
