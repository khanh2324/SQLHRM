CREATE PROCEDURE [dbo].[EMAIL_NS_TD_OFFER]
(
      -- Add the parameters for the function here
	  @DotTuyenDungID int,
	  @StrThiSinhID nvarchar (1000),
	  @ThiSinhID int

)

AS
BEGIN

Select  NS_TD_ThiSinh.TenHo + ' '+ NS_TD_ThiSinh.Ten as HoTenUngVien, 
		NS_DsChucVu.TenChucVu as ViTriTuyenDung,  PhongBan.Ten as PhongBan,
		QLTT.Ho + ' '+ QLTT.Hoten as QuanLyTrucTiep,
		--NHD.Ho + ' '+ NHD.Hoten as NguoiHuongDan,
		Convert(nvarchar, NS_TD_ThiSinh_DotTuyenDung.NgaySanSangDiLam ,103) as NgaySanSangDiLam,
		NS_TD_ThiSinh_DotTuyenDung.ThoiGianThuViec,
		NS_DsKhuVuc.TenKhuVuc as NoiLamViec,
		Format(NS_TD_ThiSinh_DotTuyenDung.LuongCoBan, '#,###') as LuongCoBan ,
		 NS_TD_ThiSinh_DotTuyenDung.PhuCap,
		 NS_TD_ThiSinh_DotTuyenDung.LuongKhac ,
		 NS_TD_ThiSinh_DotTuyenDung.TyleHuongLuongTV,
		Day(Getdate()) as Ngay,
		Month(Getdate()) as Thang,
		Cast(Year (Getdate()) as nvarchar(4)) as Nam,
		NS_TD_ThiSinh.Email


from NS_TD_ThiSinh_DotTuyenDung   
	inner join NS_TD_DotTuyenDung on NS_TD_DotTuyenDung.DotTuyenDungID = NS_TD_ThiSinh_DotTuyenDung.DotTuyenDungID
	left join NS_DsChucVu on NS_TD_DotTuyenDung.ViTriTuyenDungID = NS_DsChucVu.ChucVuID
	left join PhongBan on NS_TD_ThiSinh_DotTuyenDung.PhongBanID = PhongBan.PhongBanID
	inner join NS_TD_ThiSinh on NS_TD_ThiSinh_DotTuyenDung.ThiSinhID = NS_TD_ThiSinh.ThiSinhID
	left join NS_DsKhuVuc on NS_TD_ThiSinh_DotTuyenDung.KhuVucID = NS_DsKhuVuc.KhuVucID
	left join NhanVien QLTT on NS_TD_ThiSinh_DotTuyenDung.QuanLyTrucTiepID = QLTT.NhanVienID
	--left join NhanVien NHD on NS_TD_ThiSinh_DotTuyenDung.NguoihuongDanID = NHD.NhanVienID
where NS_TD_ThiSinh_DotTuyenDung.TrangThai in (3)
and NS_TD_ThiSinh_DotTuyenDung.ThiSinhID in (select a from GHR_HamCatChuoi(@StrThiSinhID, ','))
and NS_TD_ThiSinh_DotTuyenDung.DotTuyenDungID = @DotTuyenDungID

END
