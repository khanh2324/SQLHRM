Create FUNCTION [dbo].[GetPublicFolderShare](@nhanvienid int, @phongbanid int)
RETURNS @tbl TABLE (id int, valu int, prID int)
WITH EXECUTE AS CALLER
AS
 begin
	   declare @tempCount int
	   declare @count int
	   declare @parentID int

	   set @count = 0
	   insert @tbl(id, valu, prID)
	   (SELECT DISTINCT ROW_NUMBER() over( order by FolderID), FolderID, ParentFolderID FROM NS_FM_Folder 
        WHERE FolderID IN (SELECT FolderID FROM NS_FM_FileShare WHERE (ShareToNhanVienID=@nhanvienid OR ShareToPhongBanID=@phongbanid) AND IsPublicFolder=1)
        AND ISNULL(IsDeleted,0)=0)

	   select @count = count(id) from @tbl
	   if(@count > 0)
	   begin
			declare @row int
			set @row = 1
			while @row <= @count
			begin
				 select @tempCount = count(id) from @tbl
				 select @parentID = valu from @tbl where id = @row
				 insert @tbl(id, valu, prID) select ROW_NUMBER() over( order by id) + @tempCount, valu, prID 
				 from dbo.GetFolderChilds(@parentID)
				 set @row = @row +1
			end
	   end
 return
end
