    update NS_TD_NhuCauTuyenDung set TrangThai=4 where NhuCauTuyenDungID=@ID
	UPDATE NS_TD_NhuCauTuyenDung set YKienPheDuyet=(select NguoiXetDuyet+' - '+LyDoTuChoi from WF_QuyTrinh_ThucHien 
