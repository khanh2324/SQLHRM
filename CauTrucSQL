sum(isnull(Bangluong.Thuong_Nam, 0)) - sum(isnull(Bangluong.Thuong_Nam_TT, 0)) AS Thuong_Nam,
sum(isnull(Bangluong.Thuong_LuongT13, 0)) - sum(isnull(Bangluong.Thuong_LuongT13_TT, 0)) AS Thuong_LuongT13,
