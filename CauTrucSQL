	set @phongbanid =
	(select 
	case when (select count(*) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)=0
	then 
		(select phongbanid from nhanvien where NhanVienID = @nhanvienid) 
	else
		(
			case when (select COUNT(*) from ns_qtchuyencanbo as qt where 
			NhanVienID = @NhanVienID and 
			@date between convert(date,qt.ngayhieuluc) and dateadd(dd,-1,isnull((select MIN(convert(date,ngayhieuluc)) from
			NS_QTChuyenCanBo where NhanVienID = @nhanvienid
			and NgayHieuLuc > qt.NgayHieuLuc),'1/1/2099')))>0
			then 
			(select max(PhongBanMoiID) from ns_qtchuyencanbo as qt where 
			NhanVienID = @NhanVienID and 
			@date between convert(date,qt.ngayhieuluc) and isnull((select dateadd(dd,-1,MIN(convert(date,ngayhieuluc))) from
			NS_QTChuyenCanBo where NhanVienID = @nhanvienid
			and NgayHieuLuc > qt.NgayHieuLuc),'1/1/2099'))
			else
			(
			select max(phongbancuid) from ns_qtchuyencanbo where nhanvienid = @nhanvienid
			and ngayhieuluc = (select min(ngayhieuluc) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)
			)
			end
		)
	end
	)
	-- xét chức vụ

	set @chucvuid =
	(select 
	case when (select count(*) from ns_qtchuyencanbo where nhanvienid = @nhanvienid)=0
	then 
