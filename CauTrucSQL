CREATE proc [dbo].[LayThamSoNhuCauDaoTao]
@ID int
as
begin
 DECLARE @chuoi NVARCHAR(max)
 SELECT
 @chuoi = COALESCE(@chuoi +'' + chuoi + '',''+chuoi+'') 
FROM (
select N'<tr><td>'+convert(nvarchar,STT)+N'</td><td>'+MaNhanVien+N'</td><td>'+HoVaTen+N'</td><td>'
+TenChucVu+N'</td><td>'+DoiTuong+N'</td><td>'+convert(nvarchar,NgayBatDauLam,103)+N'</td><tr>' as chuoi
