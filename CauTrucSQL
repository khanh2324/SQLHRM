CREATE PROCEDURE [dbo].[XuLyImportDotDG]
@IDD int
AS
BEGIN
	
	UPDATE ddg SET ddg.HeSoDanhGia = 1, ddg.TrangThai = 3, ddg.QuyTrinhID = 1027,
	ddg.HoVaTen = nv.Ho+' '+nv.HoTen, ddg.TenPhongBan = pb.Ten, ddg.TenChucVu = cv.TenChucVu,
	ddg.IsThietLapMucTieu = 1, ddg.IsTuDanhGia =  1,ddg.BoTieuChiStrID = N'2021',
	TrangThai_ThietLapMucTieu = 3
	FROM dbo.NS_DG_DotDanhGia ddg
	INNER JOIN dbo.NhanVien nv ON nv.NhanVienID = ddg.NhanVienID
	INNER JOIN dbo.PhongBan pb ON pb.PhongBanID = nv.PhongBanID
	INNER JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = nv.ChucVuID
	WHERE ddg.DotDanhGiaID = @IDD
	
	DELETE dbo.NS_DG_DanhGia WHERE DotDanhGiaID = @IDD

	INSERT INTO NS_DG_DanhGia(MaDotDanhGia,DotDanhGiaID,NhanVienID,BoTieuChiStrID,QuyTrinhBuocThucHienID,NhomDanhGiaID,TenBuocDanhGia
	,TongDiem,XepLoaiDanhGiaID,TenXepLoaiDanhGia,IsTuDanhGia,XetDuyet,VongDanhGiaID,ThuTu_BuocThucHien,TenNguoiDanhGia)
	SELECT ddg.MaDotDanhGia,ddg.DotDanhGiaID,ddg.NhanVienID,ddg.BoTieuChiStrID,2053,ddg.NhomDanhGiaID,N'Quản lý trực tiếp',
	ddg.TongDiem,ddg.XepLoaiDanhGiaID,xl.TenXepLoaiDanhGia,0,1,ddg.VongDanhGiaID,2,ADD_TenNguoiDanhGia
	FROM dbo.NS_DG_DotDanhGia ddg
	INNER JOIN dbo.NS_DG_XepLoaiDanhGia xl ON xl.XepLoaiDanhGiaID = ddg.XepLoaiDanhGiaID
	WHERE ddg.DotDanhGiaID = @IDD

END

GO
