CREATE PROCEDURE [dbo].[ESS_REQUEST_DXBG]
	@DeXuatID int, @LoaiDeXuatID int, @NgayDeXuat datetime , @NguoiDungID int,	
    @RF_2037 NVARCHAR(100) = NULL
AS
BEGIN
	
	DECLARE @NhanVienID INT  = (SELECT TOP 1 NhanVienID FROM SYS_NguoiDung WHERE NguoiDungID = @NguoiDungID)
	
	DECLARE @MaChucVu NVARCHAR(200) = (SELECT MaChucVu FROM dbo.NS_DsChucVu 
	WHERE ChucVuID = (SELECT ChucVuID FROM dbo.NhanVien WHERE NhanVienID = @NhanVienID))
	
	DECLARE @NgayNghiViec DATE;

	if (select top 1 NgayDiLamLai from ns_nhanvien_nghiviec where NhanVienID=@NhanVienID order by NgayHieuLuc desc) is null
	begin
		set @NgayNghiViec = (SELECT NgayHieuLuc FROM dbo.NS_NhanVien_NghiViec WHERE dbo.NS_NhanVien_NghiViec.NhanVienID = CONVERT(INT,ISNULL(@RF_2037,0)))
	end

	DECLARE @DaNghiViec BIT =   (CASE WHEN @NgayNghiViec IS NULL THEN 0 ELSE 1 END) 
	

	IF @RF_2037 IS NULL
	BEGIN
	    select N'Bạn phải nhập nhân viên nghỉ việc !', convert(bit, 0), 1	
	END
	ELSE IF @DaNghiViec = 0
	BEGIN
		SELECT N'Nhân viên bạn chọn chưa nghỉ việc !', CONVERT(BIT,0), 1
	END
	ELSE IF @MaChucVu NOT LIKE N'HR.HRSO'
	BEGIN
		SELECT N'Bạn không phải nhân viên HR không thể tạo đề xuất này !', CONVERT(BIT,0), 1
	END

	/*Luôn luôn phải có*/  
	ELSE
	BEGIN
		SELECT '', convert(bit, 1), 1    
	END

END

