CREATE proc [dbo].[sp_BC_BangCongNhaMay] @NgayThangID int, @PhongBanID int, @DangNhapID int, @NV_DangNhapID int,  @NV_DangNhapTen nvarchar(100) as  
  

--declare @NgayThangID int  =31473, @PhongBanID int = 20, @DangNhapID int = 3115,  @NV_DangNhapID int =8873,@NV_DangNhapTen nvarchar(50)=N'ADMIN'  
  
 declare @CongtyID int = (select CongTyID from  PhongBan where PhongBanID = @PhongBanID)  
 declare @NgayKyCong date  =IsNull( (select Ngay from  NS_BH_NgayThang where NgayThangID = @NgayThangID), getdate())  
  
 declare @NgayBatDau date, @NgayKetThuc date
  select @NgayBatDau = NgayBD_CongThang, @NgayKetThuc = NgayKT_CongThang from  dbo.fnt_GetNgayGioKyCong(@CongtyID, @NgayKycong) 

 drop table if exists  #pb, #ChamCong, #NgayThang, #nv  
 select PhongBanID into #PB from  fn_LayPhongBanCon_DuocCapQuyen(@PhongBanID, @DangNhapID)  
  
	declare @NhanSuVanPhong int = 1
 
  
select row_number() over (order by Ngay) as STT, Ngay, Case when Thu <> 1 then CONCAT('T',Thu) else 'CN' end Thu Into #NgayThang from  NS_BH_NgayThang where Ngay between @NgayBatDau and @NgayKetThuc    
select   
NhanVienID,  PhongBanID, MaNhanVien, concat(ho, ' ', hoten) HoVaTen, ChucDanhID,  ChucVuID, NghiViec, NgayNghiViec, TrangThaiID, NgayBatDauLam, LoaiLaoDongID
into #nv  from  nhanvien x  
where PhongBanID in (select PhongBanID from  #PB)   
and x.ngaybatdaulam <= @NgayKetThuc and (isnull(x.nghiviec,0) = 0 or convert(date, x.ngaynghiviec) > @NgayBatDau) and isnull(x.isdeleted,0) = 0  
and NhomNhanSuId <> @NhanSuVanPhong
and x.NhanVienID not in (40452,40462,40461)
 AND X.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
  
select row_number() over (order by ThuTu) as STT ,  GetDate() NgayBaoCao, @NgayKetThuc NgayKetThuc  

, MaNhanVien, HoVaTen, NgayBatDauLam, tbl_lld.Ten TenPhongBan, tbl_lld.ThuTu, ([XN])/8.0 + [CTL]  as TongCongTinhLuong
