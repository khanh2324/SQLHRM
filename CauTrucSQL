Create proc [dbo].[sp_KhoaLichCaLamViec] @NgayThangID int, @Khoa int  as      

BEGIN
	--declare @NgayThangID int =31687, @Khoa int = 0

	if(ISNULL(@NgayThangID ,0)= 0) 
	set @NgayThangID = (select NgayThangID from  NS_BH_NgayThang where Ngay = CONVERT(date, getdate()))

	declare @NgayBD_KyCong date = (select Ngay from  NS_BH_NgayThang where NgayThangID = @NgayThangID)
	set @NgayBD_KyCong = (select NgayBD_CongThang from  fnt_LayNgayGioKyCong(0, @NgayBD_KyCong))
	declare @NgayKT_KyCong date = (select NgayKT_CongThang from  fnt_LayNgayGioKyCong(0, @NgayBD_KyCong))
	declare @Thang int = month(@NgayKT_KyCong), @Nam int = year(@NgayKT_KyCong)

	if (select count(*) from NS_TL_KhoaLuong where Thang = month(@NgayKT_KyCong) and Nam = year(@NgayKT_KyCong) and Type = 1)=0
	begin
		select N'Bạn chưa khóa công tháng ' + convert(nvarchar,@Thang) + '/' + convert(nvarchar,@Nam)
	end
	else
	begin
		select * from NS_TL_DangKyCong where month(NgayChamCong) = @Thang and year(NgayChamCong) = @Nam 
		select 1
	end
END
