CREATE PROCEDURE [dbo].[HS_LayParameters_KhenThuong]
@QTKhenThuongID int
AS
BEGIN
	declare @nhanvienid int = (SELECT NhanVienID FROM NS_QTKhenThuong WHERE QTKhenThuongID=@QTKhenThuongID)

	select
	NS_DsHinhThucKhenThuong.Ten as HinhThucKhenThuong,LyDoKhenThuong ,
	CoQuanKhenThuong ,SoTienThuong ,
	nhanvien.MaNhanVien,
	nhanvien.ho+' '+nhanvien.hoten HoVaTen,
	convert(nvarchar,nhanvien.ngaysinh,103) NgaySinh,nhanvien.DiaChiThuongTru,
	nhanvien.DienThoai,phongban.ten PhongBan,NS_DsChucVu.TenChucVu,
	NS_DsChucDanh.TenChucDanh, NS_DsQuocTich.TenNuoc,
	NgayQuyetDinh as NgayKhenThuong,
	nk.ho+' '+nk.hoten as HoVaTenNguoiKy,cvnk.TenChucVu TenChucVuNguoiKy,cdnk.TenChucDanh TenChucDanhNguoiKy,
	qtnk.TenNuoc QuocTichNguoiKy,NS_QTKhenThuong.GhiChu,
	NhanVien.GioiTinh,case when NhanVien.GioiTinh = N'Nam' then N'Ông' else N'Bà' end as OngBa,
	NhanVien.DiaChi,NhanVien.Email,NhanVien.TaiKhoanNganHang,NhanVien.CMTND,
	NhanVien.NgayCapCMT,NhanVien.NoiCapCMT
	from NS_QTKhenThuong
	left join NS_DsHinhThucKhenThuong on NS_DsHinhThucKhenThuong.HinhThucKhenThuongID=NS_QTKhenThuong.HinhThucKhenThuongID
	inner join nhanvien on nhanvien.nhanvienid=NS_QTKhenThuong.NhanVienID
	inner join phongban on phongban.phongbanid=nhanvien.PhongBanID
	left join NS_DsChucVu on NS_DsChucVu.ChucVuID=nhanvien.ChucVuID
	left join NS_DsChucDanh on NS_DsChucDanh.ChucDanhID=nhanvien.ChucDanhID
	left join NS_DsQuocTich on NS_DsQuocTich.QuocTichID=nhanvien.QuocTichID
	inner join nhanvien nk on nk.nhanvienid=NS_QTKhenThuong.NguoiKyID
	inner join phongban pbnk on pbnk.phongbanid=nk.PhongBanID
	left join NS_DsChucVu cvnk on cvnk.ChucVuID=nk.ChucVuID
	left join NS_DsChucDanh cdnk on cdnk.ChucDanhID=nk.ChucDanhID
	left join NS_DsQuocTich qtnk on qtnk.QuocTichID=nk.QuocTichID
	WHERE QTKhenThuongID=@QTKhenThuongID
	
END

