/****** Object:  StoredProcedure [dbo].[ADD_BCDB_CoCauChiPhiLuong]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE proc [dbo].[ADD_BCDB_CoCauChiPhiLuong]  
as  
  
;WITH SalaryPivot AS (
    SELECT *
    FROM (
        SELECT 
            bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong
        FROM NS_TL_BangLuong bl
        LEFT JOIN NS_TL_ChiTietLuong ctl ON bl.BangLuongID = ctl.BangLuongID
        LEFT JOIN NS_TL_LoaiLuong   ll  ON ctl.LoaiLuongID = ll.LoaiLuongID
        WHERE (1=1)
        /* -- TÙY CHỌN: nếu muốn cố định 1 kỳ
           AND (@Thang IS NULL OR bl.Thang = @Thang)
           AND (@Nam   IS NULL OR bl.Nam   = @Nam)
        */
    ) AS A
    PIVOT (
        SUM(TienLuong) FOR MaSo IN (
            [CC_TongCong],
            [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac],
            [TLNC_PC_BuaAn], [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap],
            [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem],
            [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam], [Thuong_ChenhLechT1],
            [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap],
            [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],
            [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc], [Tax_SoNguoiPhuThuoc],
            [Tax_ThuNhapTinhThue], [Tax_TongThue], [Tax_ThuNhapSauThue],
            [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax], [PSSThue_CongSauTax],
            [ThucLinh], [ChiPhiCongTy]
        )
    ) AS B
)
SELECT
    pb.PhongBanID,
    UPPER(pb.Ten) AS TenPhongBan,
    sp.Nam,
    sp.Thang,

    -- Tổng hợp theo phòng ban (SUM các cột pivot)
    ISNULL(SUM(sp.[CC_TongCong])                    ,0) AS Tong_NgayCongThucTe,
    ISNULL(SUM(sp.[TLNC_LCB])                       ,0) AS Tong_LuongCoBan,
    ISNULL(SUM(sp.[TLNC_PC_TrachNhiem])             ,0) AS Tong_PC_TrachNhiem,
    ISNULL(SUM(sp.[TLNC_PC_ViTri])                  ,0) AS Tong_PC_ViTri,
    ISNULL(SUM(sp.[TLNC_PC_DiLai])                  ,0) AS Tong_PC_DiLai,
    ISNULL(SUM(sp.[TLNC_PC_DocHai])                 ,0) AS Tong_PC_DocHai,
    ISNULL(SUM(sp.[TLNC_PC_Khac])                   ,0) AS Tong_PC_Khac,
    ISNULL(SUM(sp.[TLNC_PC_BuaAn])                  ,0) AS Tong_PC_TienAn,
    ISNULL(SUM(sp.[TLNC_ThuongThang])               ,0) AS Tong_ThuongThang,
    ISNULL(SUM(sp.[TLNC_TongLuong_Thuong_PhuCap])   ,0) AS Tong_Luong_PhuCap,

    ISNULL(SUM(sp.[TLOT_ChieuThue])                 ,0) AS Tong_OT_ChiuThue,
    ISNULL(SUM(sp.[TLOT_MienThue])                  ,0) AS Tong_OT_KhongChiuThue,
    ISNULL(SUM(sp.[TLOT_LamCaDem])                  ,0) AS Tong_TienCaDem,
    ISNULL(SUM(sp.[TLOT_TongLuongOT_LamCaDem])      ,0) AS Tong_OT_Va_CaDem,

    ISNULL(SUM(sp.[Thuong_KM])                      ,0) AS Tong_ThuongKM,
    ISNULL(SUM(sp.[Thuong_KPI])                     ,0) AS Tong_ThuongKPI,
    ISNULL(SUM(sp.[Thuong_LuongT13])                ,0) AS Tong_LuongT13,
    ISNULL(SUM(sp.[Thuong_Nam])                     ,0) AS Tong_ThuongNam,
    ISNULL(SUM(sp.[Thuong_ChenhLechT1])             ,0) AS Tong_ChenhLechT1,
    ISNULL(SUM(sp.[Thuong_CongTruocThue])           ,0) AS Tong_CongTruocThue,
    ISNULL(SUM(sp.[Thuong_TruTruocThue])            ,0) AS Tong_TruTruocThue,
    ISNULL(SUM(sp.[Thuong_TongThuong])              ,0) AS Tong_Thuong_KhoanTruocThue,

    ISNULL(SUM(sp.[TongThuNhap])                    ,0) AS Tong_ThuNhap,

    ISNULL(SUM(sp.[BH_LuongBHXH])                   ,0) AS Tong_MucLuongBHXH,
    ISNULL(SUM(sp.[BH_LuongBHTN])                   ,0) AS Tong_MucLuongBHTN,
    ISNULL(SUM(sp.[BH_Tong_NLD])                    ,0) AS Tong_BH_NLD,
    ISNULL(SUM(sp.[BH_Tong_CTY])                    ,0) AS Tong_BH_CTY,
    ISNULL(SUM(sp.[BH_Tong])                        ,0) AS Tong_BHXH,

    ISNULL(SUM(sp.[Tax_ThuNhapChiuThue])            ,0) AS Tong_ThuNhapChiuThue,
    ISNULL(SUM(sp.[Tax_GiamTru_BanThan])            ,0) AS Tong_GiamTru_BanThan,
    ISNULL(SUM(sp.[Tax_GiamTru_NguoiPhuThuoc])      ,0) AS Tong_GiamTru_NPT,
    ISNULL(SUM(sp.[Tax_SoNguoiPhuThuoc])            ,0) AS Tong_SoNPT,
    ISNULL(SUM(sp.[Tax_ThuNhapTinhThue])            ,0) AS Tong_ThuNhapTinhThue,
    ISNULL(SUM(sp.[Tax_TongThue])                   ,0) AS Tong_ThueTNCN,
    ISNULL(SUM(sp.[Tax_ThuNhapSauThue])             ,0) AS Tong_ThuNhapSauThue,

    ISNULL(SUM(sp.[PSSThue_CongDoan_NLD])           ,0) AS Tong_CongDoanPhiNV,
    ISNULL(SUM(sp.[PSSThue_CongDoan_CTY])           ,0) AS Tong_KinhPhiCongDoanCTY,
    ISNULL(SUM(sp.[PSSThue_TruSauTax])              ,0) AS Tong_TruSauThue,
    ISNULL(SUM(sp.[PSSThue_CongSauTax])             ,0) AS Tong_CongSauThue,

    ISNULL(SUM(sp.[ThucLinh])                       ,0) AS Tong_ThucLinh,
    ISNULL(SUM(sp.[ChiPhiCongTy])                   ,0) AS Tong_ChiPhiCongTy
FROM SalaryPivot AS sp
INNER JOIN NhanVien AS nv ON nv.NhanVienID = sp.NhanVienID
LEFT  JOIN PhongBan AS pb ON pb.PhongBanID = nv.PhongBanID
WHERE 1=1
  AND nv.MaNhanVien <> '80090'
  AND nv.NhanVienID NOT IN (40452,40462,40461)
  AND nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
  /* -- TÙY CHỌN: nếu muốn lọc 1 kỳ
     AND (@Thang IS NULL OR sp.Thang = @Thang)
     AND (@Nam   IS NULL OR sp.Nam   = @Nam)
  */
GROUP BY
    pb.PhongBanID,
    pb.Ten,
    sp.Nam,
    sp.Thang

GO
/****** Object:  StoredProcedure [dbo].[ADD_BCDB_TongOT]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
