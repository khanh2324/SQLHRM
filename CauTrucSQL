CREATE FUNCTION [dbo].[fn_TinhThueTNCN_LuyTien] (@ThuNhapTinhThue DECIMAL(18,2))
RETURNS DECIMAL(18,2)
AS
BEGIN
    DECLARE @Thue DECIMAL(18,2);

    SET @Thue = CASE
        WHEN @ThuNhapTinhThue <= 0 
            THEN 0
        WHEN @ThuNhapTinhThue < 10000000
            THEN @ThuNhapTinhThue * 0.05
        WHEN @ThuNhapTinhThue < 30000000
            THEN 500000 + (@ThuNhapTinhThue - 10000000) * 0.10
        WHEN @ThuNhapTinhThue < 60000000
            THEN 3500000 + (@ThuNhapTinhThue - 30000000) * 0.20
        WHEN @ThuNhapTinhThue < 100000000
            THEN 15500000 + (@ThuNhapTinhThue - 60000000) * 0.30
        ELSE
            45500000 + (@ThuNhapTinhThue - 100000000) * 0.45
    END;

    RETURN @Thue;
END
GO
