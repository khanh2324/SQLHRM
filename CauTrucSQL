create FUNCTION [dbo].[GetNotSaturdayAndSunDayInAMonth](@Thang int,@Nam int)
RETURNS @tbl TABLE (a date,b nvarchar(50))
WITH EXECUTE AS CALLER
AS
 begin
  DECLARE @FirstDateOfYear DATETIME
	DECLARE @LastDateOfYear DATETIME
	SELECT @FirstDateOfYear = convert(nvarchar,convert(nvarchar,@Thang)+'/'+convert(nvarchar,1)+'/'+convert(nvarchar,@Nam))
	SELECT @LastDateOfYear = convert(nvarchar,convert(nvarchar,@Thang)+'/'+convert(nvarchar,[dbo].[udf_GetNumDaysInMonth] (@thang,@nam))+'/'+convert(nvarchar,@Nam))
	;WITH cte AS (
	SELECT 1 AS DayID,
	@FirstDateOfYear AS FromDate,
	DATENAME(dw, @FirstDateOfYear) AS Dayname
	UNION ALL
	SELECT cte.DayID + 1 AS DayID,
	DATEADD(d, 1 ,cte.FromDate),
	DATENAME(dw, DATEADD(d, 1 ,cte.FromDate)) AS Dayname
	FROM cte
	WHERE DATEADD(d,1,cte.FromDate) <= @LastDateOfYear
	)
	insert @tbl(a,b) 
	SELECT FromDate AS Date, Dayname
	FROM CTE
	WHERE DayName NOT IN ('Saturday','Sunday') 
 return
end
