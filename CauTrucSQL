	select NhanVien.Ho+' '+NhanVien.HoTen as HoVaTen,
	MaNhanVien,NS_DsChucDanh.TenChucDanh,NS_DsChucVu.TenChucVu,
	PhongBan.Ten as PhongBan,
	NgayChinhSua as NgayChinhSua,
	convert(nvarchar,NS_TL_CC_TongHopTheoNgay_ChinhSua.NgayChamCong,103) as NgayChamCong,GiaTriCu,
	GioDen,GioVe,
	NS_TL_CC_TongHopTheoNgay_ChinhSua.LyDoChinhSua as LyDo,
