  CONVERT(VARCHAR(30),FORMAT(NS_QTCongTac.NgayBatDau, 'HH:mm - dd/MM/yyyy')) AS BDCongTac,  
  CONVERT(VARCHAR(30),FORMAT(NS_QTCongTac.NgayKetThuc, 'HH:mm - dd/MM/yyyy')) AS KTCongTac,  
  DATEDIFF(DAY,NgayBatDau,NgayKetThuc) + 1 SoNgay,  
NS_QTCongTac.NoiCongTac,NS_QTCongTac.CongViecCuThe,  
DienGiai,NS_QTCongTac.GhiChu,ApprovedBy,  
NS_DsLyDoCongTac.MaLyDoCongTac,
--NS_DsLyDoCongTac.TenLyDoCongTac,
NS_DsLyDoCongTac.TenLyDoCongTac+'/'+NS_DsLyDoCongTac.TenLyDoCongTacTA as TenLyDoCongTac,
NS_QTCongTac.LyDoHuyDangKy,  
(select ND_HoVaTen from SYS_NguoiDung a where a.NguoiDungID = nhanvien.BaoCaoTrucTiepID) as QuanLyTT,  
 (select case when TrangThai=1 then N'- Ý kiến phê duyệt: '+GhiChu when  
TrangThai=-1 then N'- Lý do từ chối: '+GhiChu else '' end as Ykien_Duyet_Tuchoi  
 from SYS_XetDuyet where ObjectID=@ID and QuyTrinhID in (select QuyTrinhID from WF_QuyTrinh where MaQuyTrinh='XD_CONGTAC')) as Ykien_Duyet_TuChoi,  
CASE WHEN xd.NguoiDangChoDuyet = '' OR xd.NguoiDangChoDuyet IS NULL THEN xd.NguoiDuyetCuoi  
 ELSE xd.NguoiDangChoDuyet END AS NguoiDangChoDuyet  ,
 ISNULL(NS_QTCongTac.ADD_NguoiHoTro,'') NguoiHoTro ,
  ISNULL(lh.TenThongTinLienHe,'') ThongTinLienHe
from NS_QTCongTac  
inner join nhanvien on ns_qtcongtac.nhanvienid = nhanvien.nhanvienid  
inner join phongban on nhanvien.phongbanid = phongban.phongbanid  
inner join ns_dschucvu on nhanvien.chucvuid = ns_dschucvu.chucvuid  
left join NS_DsLyDoCongTac on NS_QTCongTac.LyDoCongTacID=NS_DsLyDoCongTac.LyDoCongTacID  
LEFT JOIN dbo.SYS_XetDuyet xd ON xd.ObjectID = NS_QTCongTac.QTCongTacID AND xd.ObjectCode = 'NS_QTCongTac' AND xd.QuyTrinhID = 5
LEFT JOIN dbo.ADD_ThongTinLienHeNghiPhep lh ON lh.ADD_ThongTinLienHeID = NS_QTCongTac.ADD_LienHeVoiToi  
where qtcongtacid = @ID   
  
END  

