CREATE PROCEDURE [dbo].[HS_LayParameters_HopDong]
@HopDongID INT
AS
BEGIN
    
--DECLARE @HopDongId INT = 770;

SELECT ISNULL(HD.MaHopDong, '') as MaHopDong, ISNULL(nv.MaNhanVien,'') MaNhanVien,
CASE when isnull(NV.GioiTinh, '') = N'Nữ' then N'Bà' when isnull(NV.GioiTinh, '') = N'Nam' then N'Ông' else '' end as OngBa,
CASE when isnull(NV.GioiTinh, '') = N'Nữ' then N'chị' when isnull(NV.GioiTinh, '') = N'Nam' then N'anh' else '' end as AnhChi,
case when isnull(NV.GioiTinh, '') = N'Nữ' then N'Ms' when isnull(NV.GioiTinh, '') = N'Nam' then N'Mr' else '' end as OngBaTA,
ISNULL(NV.Ho, '')+' '+isnull(NV.HoTen, '') as HoVaTen,
isnull(convert(nvarchar(10), NV.NgaySinh, 103), '') as NgaySinh,
LTRIM(RTRIM(
        REPLACE(
            REPLACE(ISNULL(NST.TenTinh, ''), N'Thành phố ', ''),
            N'Tỉnh ', ''
        )
    )) AS NoiSinh,
--ISNULL(NST.TenTinh, '') as NoiSinh,
--ISNULL(nv.NoiSinh, '') as NoiSinh,
dbo.fuChuyenCoDauThanhKhongDau(LTRIM(RTRIM(
        REPLACE(
            REPLACE(ISNULL(NST.TenTinh, ''), N'Thành phố ', ''),
            N'Tỉnh ', ''
        )
    ))) AS NoiSinhTA,
ISNULL(NV.CCCD, '') as CCCD, isnull(convert(nvarchar(10), NV.NgayCapCCCD, 103), '') as NgayCapCCCD,
isnull(NV.NoiCapCCCD, '') as NoiCapCCCD, dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NV.NoiCapCCCD, '')) as NoiCapCCCDTA,
ISNULL(QT.TenNuoc, '') as QuocTich, '' as NgheNghiep, 
ISNULL(NV.DiaChiThuongTru, '') as DiaChiThuongTru, isnull(NV.DiaChi, '') as DiaChiHienTai,
dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NV.DiaChiThuongTru, '')) as DiaChiThuongTruTA,
dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NV.DiaChi, '')) as DiaChiHienTaiTA,
isnull(LHD.TenLoaiHopDong, '') as TenLoaiHopDong, isnull(LHD.TenLoaiHopDongTA, '') as TenLoaiHopDongTA,
CASE when HD.NgayBatDau is null  then '' else isnull(convert(nvarchar(10), HD.NgayBatDau, 103), '') end as NgayBatDau,
CASE when HD.NgayBatDau is null  then '' else isnull(convert(nvarchar(10), DATEADD(MONTH,-2,HD.NgayBatDau), 103), '') end as NgayBatDauTV,
CASE when HD.NgayBatDau is null  then '' else isnull(convert(nvarchar(10), DATEADD(DAY,-1,HD.NgayBatDau), 103), '') end as NgayKetThucTV,
CASE when HD.NgayKetThuc is null  then '' else isnull(convert(nvarchar(10), HD.NgayKetThuc, 103), '') end as NgayKetThuc,
case when HD.NgayKyHD is null  then '' else isnull(convert(nvarchar(10), HD.NgayKyHD, 103), '') end as NgayKy,
upper(isnull(NV.Ho, '')+' '+isnull(NV.HoTen, '')) as HoVaTenVietHoa, HD.NgayBatDau NgayBatDauDate, 
ISNULL(CV.TenChucVu, '') as TenChucVu,ISNULL(CV.TenChucVuTA, '') as TenChucVuTA, 
ISNULL(DBLCT.GiaTri, 0) as LuongThoaThuan,
 FORMAT(ISNULL(DBLCT.GiaTri, 0), 'N0', 'vi-VN') LuongThoaThuanCham, 
dbo.Num2Text(ISNULL(DBLCT.GiaTri, 0)) AS LuongThoaThuanTV,
dbo.Num2Text_English(ISNULL(DBLCT.GiaTri, 0)) AS LuongThoaThuanTA,
ISNULL(DBL_PCDH.GiaTri, 0) as PhuCapDocHai,
 FORMAT(ISNULL(DBL_PCDH.GiaTri, 0), 'N0', 'vi-VN') PhuCapDocHaiCham, 
dbo.Num2Text(ISNULL(DBL_PCDH.GiaTri, 0)) AS PhuCapDocHaiTV,
dbo.Num2Text_English(ISNULL(DBL_PCDH.GiaTri, 0)) AS PhuCapDocHaiTA,
isnull(PB.Ten, '') as TenPhongBan, isnull(TD.TenTrinhDo, '') as TenTrinhDo,
--tạm thời để 85%
ISNULL(DBLCT.GiaTri, 0)*85/100 as LuongThuViec,
UPPER((select top 1 a.Ho+' '+a.HoTen from NhanVien a
join NS_DsChucVu b on a.chucvuid = b.chucvuid where tenchucvu like N'%Giám đốc điều hành%')) as ChuKy, CD.TenChucDanh,
CASE when isnull(NVK.GioiTinh, NKCTY.GioiTinh) = N'Nữ' then N'Bà' when isnull(NVK.GioiTinh, NKCTY.GioiTinh) = N'Nam' then N'Ông' else '' end as OngBaNK,
CASE when isnull(NVK.GioiTinh, NKCTY.GioiTinh) = N'Nữ' then N'Ms' when isnull(NVK.GioiTinh, NKCTY.GioiTinh) = N'Nam' then N'Mr' else '' end as OngBaNKTA,
ISNULL(NVK.Ho, NKCTY.Ho)+' '+isnull(NVK.HoTen, NKCTY.HoTen) as HoVaTenNK,
upper(isnull(NVK.Ho, NKCTY.Ho)+' '+isnull(NVK.HoTen, NKCTY.HoTen)) as HoVaTenNKVietHoa,
dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NVK.Ho, NKCTY.Ho)+' '+isnull(NVK.HoTen, NKCTY.HoTen)) HoTenNKTA,
isnull(CVK.TenChucVu, CVKCTY.TenChucVu) as TenChucVuNK,
isnull(CVK.TenChucVuTA, CVKCTY.TenChucVu) AS TenChucVuNKTA,
UPPER(ISNULL(CVK.TenChucVu, CVKCTY.TenChucVu)) as TenChucVuNKVietHoa,
ISNULL(CDK.TenChucDanh,CDKCTY.TenChucDanh) AS TenChucDanhNK,isnull(QTK.TenNuoc, QTKCTY.TenNuoc) as QuocTichNK,
--dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NST.TenTinh, '')) as NoiSinhTA,
dbo.fuChuyenCoDauThanhKhongDau(ISNULL(NV.Ho, '')+' '+isnull(NV.HoTen, '')) as HoVaTenTA,
PB.TenPhongBanTA,kv.TenKhuVuc DiaDiemLamViec,
dbo.fuChuyenCoDauThanhKhongDau(ISNULL(kv.TenKhuVuc, '')) as DiaDiemLamViecTA,
CASE 
        WHEN HD.NgayKetThuc IS NULL OR DATEDIFF(YEAR, HD.NgayBatDau, HD.NgayKetThuc) > 10 
            THEN '' 
        WHEN DATEDIFF(YEAR, HD.NgayBatDau, HD.NgayKetThuc) >= 1 
            THEN CAST(DATEDIFF(YEAR, HD.NgayBatDau, HD.NgayKetThuc) AS NVARCHAR) + N' năm ' 
                 + CAST(DATEDIFF(MONTH, HD.NgayBatDau, HD.NgayKetThuc) % 12 AS NVARCHAR) + N' tháng'
        ELSE CAST(DATEDIFF(MONTH, HD.NgayBatDau, HD.NgayKetThuc) AS NVARCHAR) + N' tháng'
    END AS ThoiGianHopDong,
isnull(convert(nvarchar(10), nvnv.NgayHieuLuc, 103), '') AS NgayNghiViec, 
isnull(convert(nvarchar(10), DATEADD(DAY,-1,nvnv.NgayHieuLuc), 103), '') AS NgayTruocNghiViec, 
isnull(convert(nvarchar(10), nvnv.NgayTao, 103), '') AS NgayTaoDonNghiViec,
lhd.Thang SoThangHD, dbo.Num2Text(ISNULL(lhd.Thang, 0)) AS SoThangHDTV
from NhanVien as NV
join NS_HopDong as HD on NV.NhanVienID = HD.NhanVienID
LEFT JOIN dbo.NS_NhanVien_NghiViec nvnv ON nvnv.NhanVienID = nv.NhanVienID
left join NS_DsQuocTich as QT on NV.QuocTichID = QT.QuocTichID
--LEFT JOIN dbo.NS_DsTinh nst ON nst.TinhID = nv.NoiSinh_TinhID
LEFT JOIN dbo.NS_DsKhuVuc kv ON kv.KhuVucID  = nv.KhuVucID
LEFT JOIN dbo.NS_DsTinh NST ON NST.TinhID = nv.NoiSinh_TinhID
inner join NS_DsLoaiHopDong as LHD on HD.LoaiHopDongID = LHD.LoaiHopDongID
LEFT JOIN dbo.NS_DsNhomLoaiHopDong NLHD ON NLHD.NhomLoaiHopDongID = LHD.NhomLoaiHopDongID
left join NS_DsChucVu as CV on NV.ChucVuID = CV.ChucVuID
left join NS_DsChucDanh as CD on NV.ChucDanhID = CD.ChucDanhID
left join PhongBan as PB on NV.PhongBanID = PB.PhongBanID
left join NS_DsTrinhDo as TD on NV.TrinhDoID = TD.TrinhDoID
left join NS_QTDienBienLuong as DBL on NV.NhanVienID = DBL.NhanVienID and DBL.NgayHuong = (select max(a.NgayHuong) from NS_QTDienBienLuong a where a.nhanvienid = DBL.nhanvienid)
left join NS_QTDienBienLuongChiTiet as DBLCT on DBL.QTDienBienLuongID = DBLCT.QTDienBienLuongID and DBLCT.LoaiLuongID = 1
--left join NS_QTDienBienLuongChiTiet as DBLCT_LTV on DBL.QTDienBienLuongID = DBLCT.QTDienBienLuongID and DBLCT.LoaiLuongID = 80
left join NS_QTDienBienLuongChiTiet as DBL_PCDH on DBL.QTDienBienLuongID = DBL_PCDH.QTDienBienLuongID and DBLCT.LoaiLuongID = 5
LEFT JOIN NhanVien NVK ON NVK.NhanVienID = HD.NguoiKyID
left join NS_DsQuocTich as QTK on NVK.QuocTichID = QTK.QuocTichID
left join NS_DsChucVu as CVK on NVK.ChucVuID = CVK.ChucVuID
left join NS_DsChucDanh as CDK on NVK.ChucDanhID = CDK.ChucDanhID

LEFT JOIN SYS_ThongTinCongTy cty ON cty.ID = Nv.CongTyID
LEFT JOIN NhanVien NKCTY ON NKCTY.NhanVienId = cty.NguoiKyHDLDID
left join NS_DsQuocTich as QTKCTY on NKCTY.QuocTichID = QTKCTY.QuocTichID
left join NS_DsChucVu as CVKCTY on NKCTY.ChucVuID = CVKCTY.ChucVuID
left join NS_DsChucDanh as CDKCTY on NKCTY.ChucDanhID = CDKCTY.ChucDanhID

Where HD.HopDongID = @HopDongID;


END


GO
