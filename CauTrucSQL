					 inner join NS_DsChucVu on NhanVien.ChucVuID=NS_DsChucVu.ChucVuID
			where Nhanvien.NhanVienID=@NhanVienID and NS_DG_DotDanhGia.Nam=@Nam 
			AND NS_DG_DotDanhGia.NhomDanhGiaID=@NhomDanhGiaGiuaNamID and NS_DG_DotDanhGia.DotDanhGiaID=@DotDanhGiaCuID

