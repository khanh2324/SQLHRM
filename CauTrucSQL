AS         
--declare @NgayGio_Vao datetime ='2020/04/19 04:00:00'      
--declare @NgayGio_Ra datetime ='2020/04/19 23:00:00'        
--declare @BatDauCaDem datetime ,@KetThucCaDem datetime       
BEGIN        
 -- Declare the return variable here      
  DECLARE @ResultVar nvarchar(600)      
 DECLARE @Cot_Thang NVARCHAR(MAX)    
 SET @ResultVar = N'';     
;WITH NgayTrongThang(Ngay) AS     
(    
  SELECT 0 UNION ALL     
  SELECT Ngay + 1 FROM NgayTrongThang    
  WHERE Ngay < DATEDIFF(DAY, @NgayBatDau , @NgayKetThuc)    
),    
NgayThangNam(NgayThang) AS     
(    
  SELECT DATEADD(DAY, Ngay, @NgayBatDau) FROM NgayTrongThang    
)       
SELECT @ResultVar += N', ' + quotename(NgayThang)                
  FROM (SELECT  DAY(NgayThang) NgayThang FROM  NgayThangNam  group by NgayThang ) AS x;     
	
	
	IF(CHARINDEX(', [29], [30], [31],', @ResultVar,0)=0)
	BEGIN
		IF(CHARINDEX(', [29], [30],', @ResultVar,0)=0)
		BEGIN
			IF(CHARINDEX(', [29],', @ResultVar,0)=0) -- THÁNG CHỈ CÓ 28 NGÀY-- KHÔNG CÓ NGÀY 29
			BEGIN
				SET @ResultVar = REPLACE(@ResultVar,', [28],',', [28], [29], [30], [31],')
			END 
