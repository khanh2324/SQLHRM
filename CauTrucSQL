sum(isnull(Bangluong.TLNC_LuongGio, 0)) - sum(isnull(Bangluong.TLNC_LuongGio_TT, 0)) AS TLNC_LuongGio,
sum(isnull(Bangluong.BH_LuongBHTN, 0)) - sum(isnull(Bangluong.BH_LuongBHTN_TT, 0)) AS BH_LuongBHTN,
sum(isnull(Bangluong.BH_LuongBHXH, 0)) - sum(isnull(Bangluong.BH_LuongBHXH_TT, 0)) AS BH_LuongBHXH,
sum(isnull(Bangluong.TongThuNhap, 0)) - sum(isnull(Bangluong.TongThuNhap_TT, 0)) AS TongThuNhap,
