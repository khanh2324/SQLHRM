CREATE proc [dbo].[ADD_BC_SocialInsurance_ADCo] (@Thang int, @Nam int, @NhomNhanSuID int)  
as  
  
--declare @Thang int = 3  
--declare @Nam int = 2025  
--declare @NhomNhanSuID int = 1  
  
  declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)    
declare @MucTranLuongCoSo decimal(18,2) = (select top 1 LuongToiThieuChung from NS_BH_LuongToiThieu where NgayBatDau <= convert(date,getdate())) * 20  
declare @MucTranLuongToiThieuVung decimal(18,2) = (select top 1 Vung1 from NS_BH_LuongToiThieu where NgayBatDau <= convert(date,getdate())) * 20  
  
select   
ROW_NUMBER() OVER (ORDER BY ThuTuPhongBan,ThuTuChucVu) STT,  
concat(N'SOCIAL-HEALTH-UNEMPLOYMENT INSURANCE ', Thang,'/',Nam,' DEPOTS ADCO') TieuDe,  
*,   
TranBHXH * 25.5 / 100 SI,   
--TranBHXH * 4.5 / 100 HI,   
case when BH_IsTruyThuBH=1 then 0 else TranBHXH * 4.5 / 100 end HI,   
--TranBHTN * 2 / 100 UP,  
case when BH_IsTruyThuBH=1 then 0 else TranBHTN * 2 / 100 end UP,  
--TranBHXH * 25.5 / 100 + TranBHXH * 4.5 / 100 + TranBHTN * 2 / 100 Total,  
--TranBHXH * 9.5 / 100 + TranBHTN * 1.0 / 100 Employee,  
--TranBHXH * 20.5 / 100 + TranBHTN * 1.0 / 100 Employer  
BH_Tong*(-1) as Total,  
BH_Tong_NLD*(-1) as Employee,  
BH_Tong_CTY*(-1) as Employer  
  
from (  
 select b.*,  
 --case when TongLCB_PC > @MucTranLuongCoSo then @MucTranLuongCoSo else TongLCB_PC end TranBHXH,  
 BH_LuongBHXH as TranBHXH,  
 --case when TongLCB_PC > @MucTranLuongToiThieuVung then @MucTranLuongToiThieuVung else TongLCB_PC end TranBHTN  
 BH_LuongBHTN as TranBHTN  
 ,bl_text.CostCenter  
 from (  
  select *, isnull(QD_LCB,0) + isnull(QD_PC_TrachNhiem,0) + isnull(QD_PC_ViTri,0) + isnull(QD_PC_DocHai,0) TongLCB_PC   
  from (  
   select bl.NhanVienID,Thang,Nam,nv.MaNhanVien MaNV, concat(nv.Ho,' ',nv.HoTen) TenNV,  
   isnull(sdtc.Lever2Ten,sdtc.Lever1Ten) PhongBan, pb.ThuTu ThuTuPhongBan, cv.TenChucVu ChucVu, cv.ThuTu ThuTuChucVu,  
   --STUFF(  
   -- (SELECT ', ' + kv.TenKhuVuc  
   --  FROM STRING_SPLIT(KhuVucStr, ',') AS s  
   --   JOIN dbo.NS_DsKhuVuc kv  
   --    ON kv.KhuVucID = TRY_CAST(s.value AS INT)  
   --  WHERE s.value <> ''  
   --  FOR XML PATH(''), TYPE  
   -- ).value('.', 'NVARCHAR(MAX)'),  
   -- 1,2,'') DiaDiemLamViec,  
   kv.TenKhuVuc DiaDiemLamViec,  
    ll.MaSo, ct.TienLuong   
   from NS_TL_BangLuong bl  
   left join NhanVien nv on bl.NhanVienID = nv.NhanVienID  
   left join PhongBan pb on nv.PhongBanID = pb.PhongBanID  
   left join v_SoDoToChucPhongBan sdtc on pb.PhongBanID = sdtc.PhongBanID  
   left join NS_DsChucVu cv on nv.ChucVuID = cv.ChucVuID  
   left join NS_TL_ChiTietLuong ct on bl.BangLuongID = ct.BangLuongID  
   left join NS_TL_LoaiLuong ll on ct.LoaiLuongID = ll.LoaiLuongID  
   left join ADD_CostCenter cc on nv.CostCenterId = cc.CostCenterId  
   left join ADD_CostCentral ctr on nv.CostCentral = ctr.CostCentralId  
     cross apply dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv    
     left join dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId  
   where nv.NhomNhanSuId = @NhomNhanSuID  
   AND nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
   and nv.NhanVienID not in (40452,40462)) pvt   
   pivot ( max(TienLuong) for MaSo in(QD_LCB, QD_PC_TrachNhiem, QD_PC_ViTri, QD_PC_DocHai,BH_LuongBHXH,BH_LuongBHTN, BH_Tong_NLD,  BH_Tong_CTY, BH_Tong, BH_IsTruyThuBH)  
  ) a  
 ) b  
   left join    
    (select CostCenter CostCenter,NhanVienID from (    
      select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuongStr    
      from NS_TL_BangLuong bl     
