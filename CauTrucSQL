	inner join NS_DsChucVu on NhanVien.ChucVuID=NS_DsChucVu.ChucVuID
	left join NS_DsHinhThucDaoTao on NS_QTDaoTao.HinhThucDaoTaoID=NS_DsHinhThucDaoTao.HinhThucDaoTaoID
	left join NS_DT_KhoaDaoTao on NS_QTDaoTao.KhoaDaoTaoID=NS_DT_KhoaDaoTao.KhoaDaoTaoID
	left join NS_DT_KetQuaDaoTao on NS_QTDaoTao.KetQuaDaoTaoID=NS_DT_KetQuaDaoTao.KetQuaDaoTaoID
	left join NS_DsQuocTich on NS_QTDaoTao.NuocDaoTaoID=NS_DsQuocTich.QuocTichID
	left join NS_DsTruongDaoTao on NS_QTDaoTao.TruongDaoTaoID=NS_DsTruongDaoTao.TruongDaoTaoID
	left join NS_DsHeDaoTao on NS_QTDaoTao.HeDaoTaoID=NS_DsHeDaoTao.HeDaoTaoID
	left join NS_DsNganhHoc on NS_QTDaoTao.NganhHocID=NS_DsNganhHoc.NganhHocID
	left join NS_DsChuyenNganh on NS_QTDaoTao.ChuyenNganhID=NS_DsChuyenNganh.ChuyenNganhID
	left join NS_DsVanBang on NS_QTDaoTao.VanBangID=NS_DsVanBang.VanBangID
	left join NS_DsChungChi on NS_QTDaoTao.ChungChiID=NS_DsChungChi.ChungChiID
	where NS_QTDaoTao.QTDaoTaoID = @ID	

end
