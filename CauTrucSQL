CREATE PROCEDURE [dbo].[QT_GetDSQuaTrinh_LamViec]
@TuNgay DateTime,
@ToiNgay DateTime,
@PhongBanID int,
@NhanVienID int	
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;

	SELECT 
		   NS_QTChuyenCanBo.NgayChuyen as 'Ngày chuyển',
  		   NhanVien.MaNhanVien as 'Mã nhân viên', NhanVien.CMTND,
		   NhanVien.Ho+' '+NhanVien.HoTen as 'Nhân viên', 
		   LyDoChuyen as 'Lý do chuyển',
		   TenPhongBanCu as 'Phòng ban cũ', TenPhongBanMoi as 'Phòng ban mới',
		   TenChucVuOLD as 'Chức vụ cũ', TenChucVuNew as 'Chức vụ mới'
	FROM NS_QTChuyenCanBo
			inner join NhanVien on NhanVien.NhanVienID = NS_QTChuyenCanBo.NhanVienID
	WHERE (1=1) 
			And ((NS_QTChuyenCanBo.NgayChuyen>=@TuNgay) Or (Year(@TuNgay)=1900))
			And ((NS_QTChuyenCanBo.NgayChuyen<=@ToiNgay) Or (Year(@ToiNgay)=1900))

			AND (NS_QTChuyenCanBo.NhanVienID = @NhanVienID Or @NhanVienID=0)

			And ((NS_QTChuyenCanBo.PhongBanMoiID = @PhongBanID Or @PhongBanID=0) OR
				 (NS_QTChuyenCanBo.PhongBanCuID  = @PhongBanID Or @PhongBanID=0))

	Order By NhanVien.MaNhanVien
END
