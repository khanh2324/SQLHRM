CREATE PROCEDURE [dbo].[ADD_XuLy_ImportTieuChi] 
	@IDD int, @CreatedByID int

as
begin
	
	-- update các dữ liệu cố định
    update tc set 
		  IsUse = 1, IsDeleted = 0, IsGroup = 0, IsNhapGiaTri = 1, IsReadOnly = 0, IsFixed = 0, TenTieuChiTA = '', MucTieu = 0, DiemTru = 0, tc.PIID = 0
		, TieuChiChaID = isnull((select top 1 tcc.TieuChiID from NS_DG_TieuChi tcc where tcc.MaTieuChi = tc.ADD_MaTieuChiCha ), 0)
		, BoTieuChiID = isnull((select top 1 tcc.BoTieuChiID from NS_DG_TieuChi tcc where tcc.MaTieuChi = tc.ADD_MaTieuChiCha), 0)
		, CongThuc = N'if ( [DiemNhap] > 5,5, [TrongSo]*[DiemNhap]/[MucTieu])'
		, CreatedByID = @CreatedByID
		, CreatedDate = getdate()
	from NS_DG_TieuChi tc
	where TieuChiID = @IDD

	-- xóa tiêu chí trùng Bộ tiêu chí, Tiêu chí cha, Mã tiêu chí, quý, năm
	delete NS_DG_TieuChi where TieuChiID not in (select min(TieuChiID) from NS_DG_TieuChi group by MaTieuChi, TieuChiChaID, BoTieuChiID)


END
