Create PROCEDURE [dbo].[Job_ADCo_GuiMailCCTuan]


AS
BEGIN

declare @numbermail int =(select count(*) from dbo.NhanVien WHERE NgayBatDauLam <= GETDATE() AND ISNULL(NgayNghiViec,'2099-01-01') >= GETDATE()
AND Email <> '' AND Email IS NOT NULL)

DECLARE @mail int = 1
DECLARE @Today DATE = GETDATE()

DECLARE @MondayThisWeek DATE = DATEADD(DAY, 1 - DATEPART(WEEKDAY, @Today), @Today)
SET DATEFIRST 2
-- Tuần trước
DECLARE @TuNgay DATE = DATEADD(DAY, -7, GETDATE())      
DECLARE @DenNgay DATE = DATEADD(DAY, -1, GETDATE())         

DECLARE @EmailCC NVARCHAR(1000) = dbo.LayEmailCC()

  
while @mail <= @numbermail
BEGIN
DECLARE @NhanVienID INT = (
    SELECT NhanVienID
    FROM (
        SELECT ROW_NUMBER() OVER (ORDER BY NhanVienID) AS STT, NhanVienID
        FROM dbo.NhanVien
        WHERE NgayBatDauLam <= GETDATE()
            AND ISNULL(NgayNghiViec, '2099-01-01') >= GETDATE()
            AND Email IS NOT NULL AND Email <> ''
			AND ChucVuID NOT IN (801,805)
    ) AS nv
    WHERE STT = @mail
)
	insert into EmailToSend(ContentID,Email,EmailProfileID,ParameterQuery,[Subject],[Status],CustomerID,CC)
	SELECT 2046,(select dbo.EmailNhanVien(@NhanVienID) )as Email,13,concat('LayTTChamCongTuan', ' ',CONVERT(NVARCHAR(50),@NhanVienID))
	,N'Bảng chấm công '+CONVERT(NVARCHAR(100),@TuNgay,103)+' - '+CONVERT(NVARCHAR(100),@DenNgay,103),0,0,@EmailCC

    set @mail = @mail+1
END

END


