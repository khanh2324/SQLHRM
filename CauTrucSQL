CREATE PROCEDURE [dbo].[DG_TongHopKetQuaDanhGia]
@NhanVienID int,
@KyDanhGia int,
@CongViecID int,
@NhomDanhGiaID int,
@Thang int,
@Quy int,
@Nam int	
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;
	IF (@KyDanhGia=2) 
	BEGIN
		SELECT Ma, Level, CongThuc, NS_DG_CongViec.CongViecID, LamTron, DiemSo 
		FROM   NS_DG_CongViec
		inner join 
		(
			SELECT AVG(DiemSo) as DiemSo, CongViecID FROM NS_DG_TongHopDanhGiaChiTiet 
			Where Quy=@Quy And Nam=@Nam And NhomDanhGiaID=@NhomDanhGiaID And Thang>0 And NhanVienID=@NhanVienID
			Group By CongViecID
		) as NS_DG_TongHopDanhGiaChiTiet
		on NS_DG_TongHopDanhGiaChiTiet.CongViecID = NS_DG_CongViec.CongViecID
		WHERE NS_DG_CongViec.CongViecID in (SELECT DISTINCT Valu FROM GetCongViecChilds(@CongViecID)) And IsUse=1
		And NS_DG_CongViec.CongViecID not in (SELECT CongViecID FROM NS_DG_TongHopDanhGiaChiTiet Where IsChinhSua=1 And Quy=@Quy And Nam=@Nam And Thang=0 
											  And NhanVienID=@NhanVienID And NhomDanhGiaID=@NhomDanhGiaID)
		Order By Level Desc
	END
	ELSE
	BEGIN
		IF (@KyDanhGia=3)
		BEGIN
			SELECT Ma, Level, CongThuc, NS_DG_CongViec.CongViecID, LamTron, DiemSo 
			FROM   NS_DG_CongViec
			inner join 
			(
				SELECT AVG(DiemSo) as DiemSo, CongViecID FROM NS_DG_TongHopDanhGiaChiTiet 
				Where Quy>0 And Nam=@Nam And NhomDanhGiaID=@NhomDanhGiaID And Thang=0 And NhanVienID=@NhanVienID
				Group By CongViecID
			) as NS_DG_TongHopDanhGiaChiTiet
			on NS_DG_TongHopDanhGiaChiTiet.CongViecID = NS_DG_CongViec.CongViecID
			WHERE NS_DG_CongViec.CongViecID in (SELECT DISTINCT Valu FROM GetCongViecChilds(@CongViecID)) And IsUse=1
			And NS_DG_CongViec.CongViecID not in (SELECT CongViecID FROM NS_DG_TongHopDanhGiaChiTiet Where IsChinhSua=1 And Quy=0 And Nam=@Nam And Thang=0 
												  And NhanVienID=@NhanVienID And NhomDanhGiaID=@NhomDanhGiaID)
			Order By Level Desc
		END
	END
END
