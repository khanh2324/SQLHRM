CREATE PROCEDURE [dbo].[ApDungChamCong]
@ID int
AS
BEGIN
if((select count(*) from NS_TL_CC_TongHopTheoNgay_ChinhSua where NhanVienID =
(select NhanVienID from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)
and month(NgayChamCong) =  month((select NgayChamCong from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID))
and year(NgayChamCong)=year((select NgayChamCong from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID))
and FieldName ='THEM_GIO' and XetDuyet = 1)<4)
begin
update NS_TL_CC_TongHopTheoNgay_ChinhSua set xetduyet = 1 where TongHopTheoNgay_ChinhSuaID = @ID

insert into dbo.NS_TL_CC_DuLieuChamCong(NhanVienID,MayChamCongID,
ThoiGian,VaoRa,NhapTay,MaChamCong,HoVaTen,PhongBanID,DuLieuKhongTongHop)
select NS_TL_CC_TongHopTheoNgay_ChinhSua.NhanVienID,4,
convert(datetime,convert(nvarchar,ngaychamcong,101)+' '+left(convert(nvarchar,right(GiaTriMoi,7)),5)),
0,0,NhanVien.MaTheChamCong,Ho+' '+HoTen,NhanVien.PhongBanID,0
from NS_TL_CC_TongHopTheoNgay_ChinhSua
inner join NhanVien on NS_TL_CC_TongHopTheoNgay_ChinhSua.NhanVienID = NhanVien.NhanVienID
where TongHopTheoNgay_ChinhSuaID = @ID
end
else
begin
update NS_TL_CC_TongHopTheoNgay_ChinhSua set xetduyet = -1 where TongHopTheoNgay_ChinhSuaID = @ID
end
END




