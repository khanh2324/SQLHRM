	@NguoiDungID INT,
	@NhanVienID INT,
	@SoNgayNghi DECIMAL(10,2),
	@ToDate DATETIME,
	@QTNghiPhepID INT
AS
BEGIN	

--DECLARE @FromDate DATETIME='2025-07-26 08:00:00',@KyHieuChamCongID INT =21,@NguoiDungID INT =3115,
--@NhanVienID INT =40452,@QTNghiPhepID INT =0,@SoNgayNghi DECIMAL(10,2) =2 ,@ToDate DATETIME='2025-07-28 17:00:00'

DECLARE  @ResulTable TABLE (SoPhepChuyenTuNamTruoc Decimal(10,3), SoPhepTheoQuyDinh Decimal(10,3), SoPhepDaNghi Decimal(10,3), SoPhepConLai Decimal(10,3),ThamNien Decimal(10,3),
							NghiBuTonNamTruoc  Decimal(10,3),NghiBuDuocHuong DECIMAL(10,3),NghiBuDaSuDung DECIMAL(10,3),NghiBuConLai DECIMAL(10,3),
