			BEGIN
				SET @ResultVar = REPLACE(@ResultVar,', [29],',', [29], [30], [31],')
			END
		END
		ELSE
		BEGIN
			SET @ResultVar = REPLACE(@ResultVar,', [30],',', [30], [31],')
		END
	END

 RETURN  STUFF(@ResultVar, 1, 2, '')      
        
