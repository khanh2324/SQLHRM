CREATE FUNCTION [dbo].[BHXH_LayTyLe](@QuocTichID int, @Todate1 date)    RETURNS   decimal(10,3)    
WITH EXECUTE AS CALLER    
AS    
BEGIN    
     
--DECLARE @Todate1 date ='01/01/2023'  
--DECLARE @QuocTichID int = 1  
  
		DECLARE  @TyLe decimal(10,3)=  
  
		(SELECT  TOP 1  
			CASE WHEN @QuocTichID =(SELECT QuocTichID FROM  NS_DsQuocTich Where MaNuoc = 'VN')   
			THEN     
			isnull(TyLe_BHXH_CTY,0)+isnull(TyLe_BHYT_CTY,0)+isnull(TyLe_BHTN_CTY,0)     
			+isnull(TyLe_BHXH_NLD,0)+isnull(TyLe_BHYT_NLD,0)+isnull(TyLe_BHTN_NLD,0)   
			ELSE  
				isnull(TyLe_BHXH_CTY_NNG,0)+isnull(TyLe_BHYT_CTY_NNG,0)+isnull(TyLe_BHTN_CTY_NNG,0) 
			+isnull(TyLe_BHXH_NNG,0)+isnull(TyLe_BHYT_NNG,0)+isnull(TyLe_BHTN_NNG,0)  
			END  
  
			FROM  NS_BH_TyLeThamGiaBHXH  WHERE NgayBatDau<=@Todate1 ORDER BY NgayBatDau DESC)  
  
		RETURN ISNULL(@TyLe, 0)  
END    
    
GO
