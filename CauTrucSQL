update NS_TL_CC_TongHopTheoNgay_ChinhSua set xetduyet = 1 where TongHopTheoNgay_ChinhSuaID = @ID

--An them cập nhập giờ giải trình ca đêm sang ngày hôm sau

;WITH CTE AS (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY CAST(ThoiGian AS DATE)
               ORDER BY ThoiGian
           ) AS rn
    FROM NS_TL_CC_DuLieuChamCong
    WHERE DuLieuKhongTongHop = 1 
	and convert(date,ThoiGian) = (select convert(date,ngayChamCong) from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)
	and NhanVienID = (select NhanVienID from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)
	and ((@CaLamViecID = 67 AND CONVERT(TIME, ThoiGian) = '07:00:00') or (@CaLamViecID = 71 AND CONVERT(TIME, ThoiGian) = '08:00:00'))
)
UPDATE CTE
SET ThoiGian = DATEADD(DAY, 1, ThoiGian), DuLieuKhongTongHop = 0 
WHERE rn = 1;

--

update NS_TL_CC_DuLieuChamCong set DuLieuKhongTongHop =  0 where DuLieuKhongTongHop = 1
and convert(date,ThoiGian)=
(select convert(date,ngayChamCong) from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)
and NhanVienID =
(select NhanVienID from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)

update NS_TL_CC_DuLieuChamCong set DuLieuKhongTongHop =  1 
where DuLieuKhongTongHop = 0 and convert(time,ThoiGian)='00:00:00' 
and convert(date,ThoiGian)=
(select convert(date,ngayChamCong) from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)
and NhanVienID =
(select NhanVienID from NS_TL_CC_TongHopTheoNgay_ChinhSua where TongHopTheoNgay_ChinhSuaID = @ID)


--gửi mail
DECLARE @XetDuyetId INT = (SELECT XetDuyetID FROM dbo.SYS_XetDuyet 
WHERE ObjectID = @ID AND ObjectCode = 'NS_TL_CC_TongHopTheoNgay_ChinhSua' AND QuyTrinhID = 17)
