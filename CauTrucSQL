	select QTID,rtrim(ltrim([1])),rtrim(ltrim([2])),rtrim(ltrim([3])),rtrim(ltrim([4])) from(
	select * from @tbltam)
	as a pivot(max(chuoi) for stt in([1],[2],[3],[4])) as pvt
 return
end



