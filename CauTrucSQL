			INSERT INTO [dbo].[NS_DG_NhanVien_MucTieu]
			([BoTieuChiID],[BoTieuChiStrID],[NhanVienID],[DotDanhGiaID],[TieuChiChaID],[TieuChiID],[TenTieuChi]
