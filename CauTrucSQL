CREATE PROCEDURE [dbo].[ADD_BC_ServeranceAllowance_ADCo]   
 @NgayBaoCao datetime, @PhongBanID int, @CostCenterID int, @NhanVienID int, @NhomNhanSuID int, @DangNhapID int  
  
AS  
BEGIN  
  
 --DECLARE @NgayBaoCao DATETIME = GETDATE(),  
 --@PhongBanId INT = 20, @CostCenterId INT = 0, @NhanVienID INT = 0,  
 --@NhomNhanSuId INT = 0, @DangNhapId INT =3115  
  
 select MaNhanVien MaNV, Ho+' '+HoTen HoVaTen, cv.TenChucVu ChucVu,  
 --pb.Ten PhongBan,  
 upper((case when cc.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.Ten else v.Lever2Ten end    
     else lld.Ten end     
   )) as TenPhongBan,  
 ccl.TenCostCentral CostCenter  
 ,CONVERT(NVARCHAR,nv.NgayBatDauLam,103) JoiningDate, DATEDIFF(day,nv.NgayBatDauLam,'2009-01-01') Before2009,  
 DATEDIFF(DAY,hdtv.NgayBatDau,hdtv.NgayKetThuc) Probation, DATEDIFF(DAY,bhts.NgayBatDau,bhts.NgayKetthuc) MaternityLeave,  
 DATEDIFF(DAY,bhno.NgayBatDau,bhno.NgayKetthuc) NghiOmDaiNgay,  
 ISNULL(nv.TotalforSA,0) TotalforSA_day,  
 ISNULL(nv.TotalforSA,0)/365.0 TotalforSA_year,ROUND(ISNULL(nv.TotalforSA,0)/365.0,0) Totalyears,  
 dbo.BHXH_TINHTRUNGBINHLUONG6T(nv.NhanVienID,MONTH(@NgayBaoCao),YEAR(@NgayBaoCao)) AS Everagesalary,   
 --ISNULL(nvnv.TroCapThoiViec,0) AS Total,  
 dbo.fns_TinhTroCapThoiViec(nvnv.NhanVienNghiViecID,1) Total,  
 ISNULL(kg.TenKhuVuc,'') KhoGoc  
 FROM dbo.NhanVien nv  
 LEFT JOIN dbo.NS_NhanVien_NghiViec nvnv ON nvnv.NhanVienID = nv.NhanVienId  
 and nvnv.NgayHieuLuc = (select MAX(NgayHieuLuc) from NS_NhanVien_NghiViec where NhanVienID = nv.NhanVienID   
 AND CONVERT(DATETIME,NgayHieuLuc) <= @NgayBaoCao)  
 LEFT JOIN dbo.NS_DsChucVu cv ON cv.ChucVuID = nv.ChucVuID  
 LEFT JOIN dbo.PhongBan pb ON pb.PhongBanID = nv.PhongBanID  
 left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID    
 left join dbo.NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID   
 left join dbo.NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID    
 LEFT JOIN dbo.NS_DsKhuVuc kg ON kg.KhuVucID = nv.KhoGocID  
 LEFT JOIN dbo.ADD_CostCenter cc ON cc.CostCenterId = nv.CostCenterId  
 LEFT JOIN dbo.ADD_CostCentral ccl ON ccl.CostCentralId = nv.CostCentral  
 LEFT JOIN dbo.NS_HopDong hdtv ON hdtv.NhanVienID = nv.NhanVienID  
 AND hdtv.NgayBatDau = (SELECT MAX(NgayBatDau) FROM dbo.NS_HopDong WHERE  
 LoaiHopDongID in (SELECT LoaiHopDongID FROM NS_DsLoaiHopDong  
 WHERE CHARINDEX ( CONCAT(',', MaLoaiHD,','), (SELECT CONCAT(',', GiaTri,',') FROM  SYS_ThongSo where MaSo ='HSNS_MA_HDTV')) > 0))  
 LEFT JOIN NS_QTDongBHXH bhts ON bhts.NhanVienID = nv.NhanVienID AND bhts.LoaiBienDongID = 9  
 LEFT JOIN NS_QTDongBHXH bhno ON bhno.NhanVienID = nv.NhanVienID AND bhno.LoaiBienDongID = 8  
 WHERE DATEDIFF(DAY,nv.NgayBatDauLam,@NgayBaoCao) >= 365  
 AND nv.PhongBanID  in (select valu  from dbo.GetPhongBanChild_WUser(@PhongbanId,@DangnhapID))  
 AND (nv.CostCentral = @CostCenterID or @CostCenterID = -1001 or @CostCenterID = 0)  
 --AND (dbo.nv.CostCenterId = @CostCenterID or @CostCenterID = -1001 or @CostCenterID = 0)  
 AND (nv.NhanVienID = @NhanVienID or @NhanVienID = -1001 or @NhanVienID = 0)  
 AND (nv.NhomNhanSuId = @NhomNhanSuID or @NhomNhanSuID = -1001 or @NhomNhanSuID = 0)  
  and nv.NhanVienID not in (40452,40462)  
  AND nv.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
  
END  
GO
/****** Object:  StoredProcedure [dbo].[ADD_BC_SocialInsurance_ADCo]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
