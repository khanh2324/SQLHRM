CREATE view [dbo].[v_CapBacPhongBan]                
as                        
WITH cteTree AS(                 
Select PhongBanID, MaPhongBan , Ten, TenPhongBanTA, PhongBanChaID, IsDeleted, CapPhongBanID,             
 0 AS Ranks, CAST(PhongBanID AS NVARCHAR(MAX))   AS TreeID,  CAST(Ten AS NVARCHAR(MAX))   AS TreeTen, CongTyID,
        CAST(ThuTuSapXep AS VARCHAR(MAX)) AS ThuTuSapXep
from PhongBan where PhongBanChaID =0 AND IsDeleted =0                
UNION ALL                  
Select child.PhongBanID, child.MaPhongBan, child.Ten, child.TenPhongBanTA, child.PhongBanChaID , child.IsDeleted  , child.CapPhongBanID,              
parent.Ranks + 1, CAST(CONCAT(parent.TreeID, ',', child.PhongBanID) AS NVARCHAR(MAX)) AS TreeID  , CAST(CONCAT(parent.TreeTen, '=>', child.Ten) AS NVARCHAR(MAX)) AS TreeTen, child.CongTyID          
,  CAST(parent.ThuTuSapXep + '.' + RIGHT('000' + CAST(ROW_NUMBER() OVER (PARTITION BY child.PhongBanChaID ORDER BY child.ThuTuSapXep ASC) AS VARCHAR), 2) AS VARCHAR(MAX)) AS ThuTuSapXep
from PhongBan  AS child                  
JOIN cteTree AS parent ON child.PhongBanChaID =parent.PhongBanID                 
WHERE child.IsDeleted = 0)     
  
  
SELECT cteTree.*, TenCapPhongBan ,[Level] CapCuaCapPhongBan   from cteTree           
left join NS_DsCapPhongBan on cteTree.CapPhongBanID = NS_DsCapPhongBan.CapPhongBanID   
