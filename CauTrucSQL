GO
CREATE PROCEDURE [dbo].[LayThongTinNghiPhep]    
@ID int    
AS    
BEGIN    
    
 --DECLARE @ID INT = 278    
    
 SELECT NhanVien.Ho+' '+NhanVien.HoTen AS HoVaTen,    
 NhanVien.MaNhanVien,NS_DsChucDanh.TenChucDanh,NS_DsChucVu.TenChucVu,    
 PhongBan.Ten AS PhongBan,    
 CONVERT(NVARCHAR,NS_QTNghiPhep.NgayBatDau,103) TuNgayDate,    
 CONVERT(NVARCHAR,NS_QTNghiPhep.NgayKetThuc,103) ToiNgayDate,    
 CONVERT(NVARCHAR,NS_QTNghiPhep.NgayBatDau,103)+' '+LEFT(CONVERT(NVARCHAR,CONVERT(TIME,NS_QTNghiPhep.NgayBatDau)),5) AS TuNgay,    
 CONVERT(NVARCHAR,NS_QTNghiPhep.NgayKetThuc,103)+' '+LEFT(CONVERT(NVARCHAR,CONVERT(TIME,NS_QTNghiPhep.NgayKetThuc)),5) AS ToiNgay,    
 NS_QTNghiPhep.songaynghi AS SoNgayNghi,    
 NS_QTNghiPhep.LyDoNghi AS LyDo,NS_QTNghiPhep.LyDoHuyDangKy,    
 NS_TL_KyHieuChamCong.MoTa,    
 CONVERT(INT,NhanVien.SoPhepTheoQuyDinh) SoPhepTheoQuyDinh,    
 CONVERT(INT,NhanVien.SoPhepDaNghi) SoPhepDaNghi,    
 CONVERT(INT,NhanVien.SoPhepConLai) - isnull((SELECT SUM(SoNgayNghi) FROM dbo.NS_QTNghiPhep WHERE NhanVienID = NhanVien.NhanVienID AND KyHieuChamCongID = 21 AND XetDuyet in (0,100)),0) SoPhepConLai,   
 CONVERT(INT,NhanVien.SoPhepConLai) + isnull((SELECT SUM(SoNgayNghi) FROM dbo.NS_QTNghiPhep WHERE QTNghiPhepID=@ID),0) SoPhepConLaiBefore,    
 CONVERT(DECIMAL(10,2),NhanVien.NghiBuDuocHuong) NghiBuDuocHuong,    
 CONVERT(DECIMAL(10,2),NhanVien.NghiBuDaSuDung) NghiBuDaSuDung,    
 CONVERT(DECIMAL(10,2),NhanVien.NghiBuConLai) NghiBuConLai,    
 CONVERT(NVARCHAR, NhanVien.NgayBatDauLam,103) AS NgayVaoLam, NhanVien.NhanVienID,    
 (SELECT ND_HoVaTen FROM SYS_NguoiDung a WHERE a.NguoiDungID = nhanvien.BaoCaoTrucTiepID) AS QuanLyTT,    
 (SELECT CASE WHEN TrangThai=1 THEN N'- Ý kiến phê duyệt: '+GhiChu WHEN    
TrangThai=-1 THEN N'- Lý do từ chối: '+GhiChu ELSE '' END AS Ykien_Duyet_Tuchoi    
 FROM SYS_XetDuyet WHERE ObjectID=@ID AND QuyTrinhID IN (SELECT QuyTrinhID FROM WF_QuyTrinh WHERE MaQuyTrinh='XD_NGHIPHEP')) AS Ykien_Duyet_TuChoi,    

 CASE WHEN xd.NguoiDangChoDuyet = '' OR xd.NguoiDangChoDuyet IS NULL THEN xd.NguoiDuyetCuoi    
 ELSE xd.NguoiDangChoDuyet END AS NguoiDangChoDuyet,  
 --An them
 QLTT.MaNhanVien+' - '+QLTT.Ho+' '+QLTT.HoTen HoTenQuanLyTT,	
 --

 ISNULL(lh.TenThongTinLienHe,'') ThongTinLienHe,ISNULL(NS_QTNghiPhep.Des,'') DiaDiem,    
 ISNULL(NS_QTNghiPhep.ADD_NguoiHoTro,'') NguoiHoTro    
     
 FROM NS_QTNghiPhep     
  INNER JOIN NhanVien ON NS_QTNghiPhep.NhanVienID = NhanVien.NhanVienID    
  left JOIN SYS_NguoiDung ON SYS_NguoiDung.NguoiDungID = NhanVien.BaoCaoTrucTiepID  
  left JOIN NhanVien QLTT ON SYS_NguoiDung.NhanVienID = QLTT.NhanVienID    
  left join PhongBan on NhanVien.PhongBanID = PhongBan.PhongBanID    
  left join NS_DsChucVu on NhanVien.ChucVuID = NS_DsChucVu.ChucVuID    
  left join NS_DsChucDanh on NhanVien.ChucDanhID = NS_DsChucDanh.ChucDanhID    
  left join NS_TL_KyHieuChamCong on NS_QTNghiPhep.kyhieuchamcongid=NS_TL_KyHieuChamCong.kyhieuchamcongid    
  LEFT JOIN dbo.SYS_XetDuyet xd ON xd.ObjectID = NS_QTNghiPhep.QTNghiPhepID AND xd.ObjectCode = 'NS_QTNghiPhep' AND xd.QuyTrinhID = 6  
  LEFT JOIN dbo.ADD_ThongTinLienHeNghiPhep lh ON lh.ADD_ThongTinLienHeID = NS_QTNghiPhep.ADD_LienHeVoiToi    
  --INNER JOIN (Select  top 1 with ties  * from  WF_QuyTrinh_ThucHien order by row_number() over (partition by XetDuyetID order by NgayBatDau desc)) bth on xd.XetDuyetID = bth.XetDuyetID    
 where QTNghiPhepID = @ID and NS_TL_KyHieuChamCong.HienThiDangKyNghi = 1    
     
END    
GO
