inner join SYS_XetDuyet on WF_QuyTrinh_ThucHien.XetDuyetID = SYS_XetDuyet.XetDuyetID
inner join SYS_NguoiDung on WF_QuyTrinh_ThucHien.NguoiDungXetDuyetID = SYS_NguoiDung.NguoiDungID
inner join NhanVien on SYS_NguoiDung.NhanVienID = nhanvien.NhanVienID
where SYS_XetDuyet.ObjectID = NS_QTNghiPhep.QTNghiPhepID
