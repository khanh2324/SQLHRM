CREATE PROCEDURE [dbo].[EMAIL_NS_TD_LICHPHONGVAN]
(
      -- Add the parameters for the function here

	  @VongThiID int,
	  @DotTuyenDungID int,
	  @StrThiSinhID nvarchar (1000)

)

AS
BEGIN

	select NS_TD_ThiSinh.ThiSinhID, NS_TD_ThiSinh.SoBaoDanh, NS_TD_ThiSinh.TenHo+' '+NS_TD_ThiSinh.Ten as TenUngVien, 
	case when NS_TD_ThiSinh.GioiTinh=N'Nam' then N'Anh' else N'Chị' end as DanhXung_UV,
	case when NS_TD_ThiSinh.GioiTinh=N'Nam' then N'Mr.' else N'Ms.' end as DanhXung_EN_UV,
	case when NguoiPhuTrach.GioiTinh=N'Nam' then N'Anh' else N'Chị' end as DanhXung_NguoiLienHe,
	case when NguoiPhuTrach.GioiTinh=N'Nam' then N'Mr.' else N'Ms.' end as DanhXung_EN_NguoiLienHe,
	NS_TD_ThiSinh.Email,
convert(nvarchar,NS_TD_VongThi_ThiSinh.LichPhongVan,103) as NgayPV,
case when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Monday' then N'Thứ 2' when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Tuesday' then N'Thứ 3'
when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Wednesday' then N'Thứ 4' when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Thursday' then N'Thứ 5'
when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Friday' then N'Thứ 6' when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Saturday' then N'Thứ 7'
when DATENAME(dw,NS_TD_VongThi_ThiSinh.LichPhongVan)='Sunday' then N'Chủ nhật' else '' end as ThuPV,
convert(nvarchar,NS_TD_VongThi_ThiSinh.LichPhongVan,108) as GioPV,
NguoiPhuTrach.ho +' '+NguoiPhuTrach.hoten as NguoiLienHe,NS_TD_NhuCauTuyenDung.TenViTri as ViTriTuyenDung,NS_DsChucVu.TenChucVu as ViTriUngTuyen
from NS_TD_VongThi_ThiSinh
inner join NS_TD_ThiSinh on NS_TD_VongThi_ThiSinh.ThiSinhID=NS_TD_ThiSinh.ThiSinhID
left join NS_TD_DotTuyenDung on NS_TD_VongThi_ThiSinh.DotTuyenDungID=NS_TD_DotTuyenDung.DotTuyenDungID
left join NhanVien NguoiPhuTrach on NS_TD_DotTuyenDung.NguoiPhuTrachID=NguoiPhuTrach.NhanVienID
left join NS_TD_NhuCauTuyenDung on NS_TD_DotTuyenDung.NhuCauTuyenDungID=NS_TD_NhuCauTuyenDung.NhuCauTuyenDungID
left join NS_DsChucVu on NS_TD_ThiSinh.ViTriDuTuyenID=NS_DsChucVu.ChucVuID
where NS_TD_VongThi_ThiSinh.ThiSinhID in (select a from GHR_HamCatChuoi(@StrThiSinhID, ',')) and NS_TD_VongThi_ThiSinh.DotTuyenDungID=@DotTuyenDungID and NS_TD_VongThi_ThiSinh.VongThiID=@VongThiID

END

GO
