DECLARE @NhanVienDuyet3 INT = (SELECT NhanVienID FROM dbo.SYS_NguoiDung WHERE NguoiDungID = 
(SELECT NguoiDungXetDuyetID FROM WF_QuyTrinh_ThucHien WHERE XetDuyetID = @XetDuyetId AND QuyTrinhBuocThucHienID = 1070))

-- Nếu Duyệt 2 trùng Duyệt 1, cho Duyệt 2 = 0
IF @NhanVienDuyet2 = @NhanVienDuyet1
    SET @NhanVienDuyet2 = 0

-- Nếu Duyệt 3 trùng Duyệt 1 hoặc Duyệt 2, cho Duyệt 3 = 0
IF @NhanVienDuyet3 = @NhanVienDuyet1 OR @NhanVienDuyet3 = @NhanVienDuyet2
