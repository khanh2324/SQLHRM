sum(isnull(Bangluong.CC_TongGioOT, 0)) - sum(isnull(Bangluong.CC_TongGioOT_TT, 0)) AS CC_TongGioOT,
sum(isnull(Bangluong.TLNC_TongLuong_Thuong_PhuCap_Gop, 0)) - sum(isnull(Bangluong.TLNC_TongLuong_Thuong_PhuCap_Gop_TT, 0)) AS TLNC_TongLuong_Thuong_PhuCap_Gop,
