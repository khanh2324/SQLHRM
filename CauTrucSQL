where NS_DT_NhuCau_NhanVien.NhuCauDaoTaoID = @ID) as a) as b

		select NhuCauID,TenNhuCauDaoTao,
		NhanVien.MaNhanVien, NhanVien.Ho + ' ' + NhanVien.HoTen as HoVaTen ,
		NC.PhongBanYeuCau as PhongBan, CVYC.TenChucVu,
		NC.SoLuongHocVien as SoLuong,
		NC.ThoiLuongDuKien, NC.ChiPhiDuKien,
		NC.NgayBatDau,NC.NgayKetThuc,
		NC.DiaDiemDaoTao,
		NS_DT_DotDaoTao.TenDotDaoTao as TenDotDaoTao,
		NC.DonViDaoTao,
		NC.GhiChu,
		convert(nvarchar,NC.NgayBatDau,103) as NgayBatDau,
		convert(nvarchar,NC.NgayKetThuc,103) as NgayKetThuc,
		@chuoi as chuoi,
