CREATE FUNCTION [dbo].[Num2Text_English] (@Number MONEY)
RETURNS NVARCHAR(4000)
AS
BEGIN
    DECLARE @ones TABLE (num INT, word NVARCHAR(20))
    INSERT INTO @ones VALUES 
    (0, 'zero'), (1, 'one'), (2, 'two'), (3, 'three'), (4, 'four'), 
    (5, 'five'), (6, 'six'), (7, 'seven'), (8, 'eight'), (9, 'nine'),
    (10, 'ten'), (11, 'eleven'), (12, 'twelve'), (13, 'thirteen'),
    (14, 'fourteen'), (15, 'fifteen'), (16, 'sixteen'), (17, 'seventeen'),
    (18, 'eighteen'), (19, 'nineteen')

    DECLARE @tens TABLE (num INT, word NVARCHAR(20))
    INSERT INTO @tens VALUES 
    (2, 'twenty'), (3, 'thirty'), (4, 'forty'), (5, 'fifty'), 
    (6, 'sixty'), (7, 'seventy'), (8, 'eighty'), (9, 'ninety')

    DECLARE @Result NVARCHAR(4000) = ''
    DECLARE @NumberInt BIGINT = FLOOR(@Number)
    DECLARE @NumberDec INT = ROUND((@Number - @NumberInt) * 100, 0)

    DECLARE @num INT, @part NVARCHAR(4000)
    DECLARE @hundreds INT, @remainder INT
    DECLARE @word NVARCHAR(50)
    DECLARE @tenPart INT, @unitPart INT
    DECLARE @tenWord NVARCHAR(20), @unitWord NVARCHAR(20)

    DECLARE @Segment TABLE (Position INT, Value BIGINT)
    DECLARE @pos INT = 0

    WHILE @NumberInt > 0
    BEGIN
        INSERT INTO @Segment(Position, Value)
        VALUES (@pos, @NumberInt % 1000)
        SET @NumberInt = @NumberInt / 1000
        SET @pos += 1
    END

    DECLARE @Scale TABLE (Position INT, Name NVARCHAR(20))
    INSERT INTO @Scale VALUES 
    (0, ''),
    (1, 'thousand'),
    (2, 'million'),
    (3, 'billion'),
    (4, 'trillion')

    DECLARE cur CURSOR FOR 
    SELECT Position, Value FROM @Segment ORDER BY Position DESC

    OPEN cur
    FETCH NEXT FROM cur INTO @pos, @num

    WHILE @@FETCH_STATUS = 0
    BEGIN
        SET @part = ''
        SET @hundreds = @num / 100
        SET @remainder = @num % 100

        IF @hundreds > 0
        BEGIN
            SELECT @word = word FROM @ones WHERE num = @hundreds
            SET @part = @part + @word + ' hundred'
            IF @remainder > 0
                SET @part = @part + ' and '
        END

        IF @remainder < 20 AND @remainder > 0
        BEGIN
            SELECT @word = word FROM @ones WHERE num = @remainder
            SET @part = @part + @word
        END
        ELSE IF @remainder >= 20
        BEGIN
            SET @tenPart = @remainder / 10
            SET @unitPart = @remainder % 10
            SET @unitWord = ''

            SELECT @tenWord = word FROM @tens WHERE num = @tenPart
            IF @unitPart > 0
                SELECT @unitWord = '-' + word FROM @ones WHERE num = @unitPart

            SET @part = @part + @tenWord + @unitWord
        END

        IF LEN(@part) > 0
        BEGIN
            DECLARE @scaleName NVARCHAR(20)
            SELECT @scaleName = Name FROM @Scale WHERE Position = @pos
            IF @scaleName <> ''
                SET @part = @part + ' ' + @scaleName

            IF LEN(@Result) > 0
                SET @Result = @Result + ', ' + @part
            ELSE
                SET @Result = @part
        END

        FETCH NEXT FROM cur INTO @pos, @num
    END

    CLOSE cur
    DEALLOCATE cur

    -- Xử lý phần xu (cents)
    IF @NumberDec > 0
    BEGIN
        DECLARE @centText NVARCHAR(100)
        SET @centText = ''
        IF @NumberDec < 20
            SELECT @centText = word FROM @ones WHERE num = @NumberDec
        ELSE
        BEGIN
            SET @tenPart = @NumberDec / 10
            SET @unitPart = @NumberDec % 10
            SET @unitWord = ''

            SELECT @tenWord = word FROM @tens WHERE num = @tenPart
            IF @unitPart > 0
                SELECT @unitWord = '-' + word FROM @ones WHERE num = @unitPart

            SET @centText = @tenWord + @unitWord
        END
        SET @Result = @Result + ' and ' + @centText + ' cents'
    END
    ELSE
    BEGIN
        SET @Result = @Result
        --SET @Result = @Result + ' only'
    END

	IF @Result = ''
	BEGIN
	    SET @Result = 'Zero'
	END


    -- Viết hoa chữ cái đầu
    SET @Result = UPPER(LEFT(@Result,1)) + SUBSTRING(@Result,2,LEN(@Result))

    RETURN @Result
END
GO
