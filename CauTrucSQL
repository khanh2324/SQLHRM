CREATE PROCEDURE [dbo].[HS_DSNhanVienNghiPhep]              
@PhongBanID int,            
@ToDate DATETIME,  
@Active_CongTyID INT  
AS              
BEGIN              
SET NOCOUNT ON;       
  
--DECLARE @PhongBanId INT = 44, @Todate DATETIME = GETDATE()  
  declare @date date=convert(date,getdate())
  declare @date_TT date=convert(date,dateadd(m,-1,@date))
select       
pvt.MaNhanVien as N'Mã nhân viên',        
