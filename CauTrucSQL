CREATE PROCEDURE [dbo].[ADD_BaoCaoTuyenDung]
		@PhongBanID INT ,
		@DangNhapID INT ,
		@Nam INT,
		@Thang int
AS
BEGIN


--DECLARE @PhongBanID INT = 191, @DangNhapID INT = 3115, @Nam INT = 2025, @Thang INT = 11

;WITH TongHopThiSinh AS
(
    SELECT 
        tstd.DotTuyenDungID,
        COUNT(*) AS SoUngVienDatYeuCau, -- tổng ứng viên theo đợt
        SUM(CASE WHEN tstd.TrangThai = 2 THEN 1 ELSE 0 END) AS SoUngVienQuaHR,
        SUM(CASE WHEN tstd.TrangThai = 3 THEN 1 ELSE 0 END) AS SoUngVienQuaLine,
        SUM(CASE WHEN tstd.TrangThai = 6 THEN 1 ELSE 0 END) AS SoUngVienThanhCong
    FROM dbo.NS_TD_ThiSinh_DotTuyenDung tstd
    GROUP BY tstd.DotTuyenDungID
)
SELECT 
    td.DotTuyenDungID,                                -- ID đợt tuyển
    ISNULL(td.MaDotTuyenDung,0) AS MaDotTuyenDung,    -- Mã đợt tuyển dụng
    STUFF(
        (
            SELECT ', ' + kv2.TenKhuVuc
            FROM STRING_SPLIT(td.KhuVucID, ',') AS s
                JOIN dbo.NS_DsKhuVuc kv2
                    ON kv2.KhuVucID = TRY_CAST(s.value AS INT)
            WHERE s.value <> ''
            FOR XML PATH(''), TYPE
        ).value('.', 'NVARCHAR(MAX)'),
        1,
        2,
        ''
    ) AS DiaDiemLamViec,

    td.TenDotTuyenDung AS TenDotTuyenDung,            -- Tên đợt tuyển dụng
    td.NgayBatDau AS NgayBatDauTuyen,                 -- Ngày bắt đầu tuyển dụng
    td.NgayKetThuc AS NgayKetThucTuyen,               -- Ngày kết thúc tuyển dụng
    CONVERT(NVARCHAR,ISNULL(xd.NgayDuyetCuoi,''),103) AS NgayPheDuyet, -- Ngày phê duyệt
    td.TrangThai AS TrangThaiTuyenDung,               -- Trạng thái tuyển dụng

    '' AS MaYeuCauTuyenDung,                          -- Mã yêu cầu tuyển dụng
    nc.LyDoTuyen AS LyDoTuyenDung,                    -- Lý do tuyển dụng
    nc.SoLuongYC AS SoLuongTuyen,                     -- Số lượng cần tuyển
  
    cv.TenChucVu AS ChucVuTuyen,                      -- Tên chức vụ cần tuyển
    ISNULL(cb.TenBac,'') TenCapBac,
    ISNULL(ncb.TenNhomCapBac,'') TenNhomCapBac,
    ISNULL(td.ADD_LoaiHinhTuyenDung,'') LoaiHinhTuyenDung,
    STUFF((
            SELECT ', ' + nv2.MaNhanVien + ' - ' + nv2.Ho + ' ' + nv2.HoTen
            FROM STRING_SPLIT(nc.ThayTheNhanVienIDStr, ',') AS s
                JOIN dbo.NhanVien nv2
                    ON nv2.NhanVienID = TRY_CAST(s.value AS INT)
            WHERE s.value <> ''
            FOR XML PATH(''), TYPE
        ).value('.', 'NVARCHAR(MAX)'),1,2,'') AS ThayTheNhanVien,

    pb.Ten AS PhongBan,                               -- Tên phòng ban
    
    cty.TenCongTy AS CongTy,                          -- Tên công ty
    N'Việt Nam' AS QuocGia,                           -- Quốc gia
    CASE WHEN nc.LyDoTuyen = N'Bổ sung theo định biên' THEN N'Trong ngân sách'
         ELSE N'Ngoài ngân sách' 
    END AS TrongNganSach,                             -- Có trong ngân sách không (bit)
   
    cd.TenChucDanh,                         
    CONVERT(NVARCHAR,ISNULL(nc.NgayLap,''),103) AS NgayLapDeXuat,            
    CONVERT(NVARCHAR,ISNULL(nc.NgayCan,''),103) AS NgayCanTuyen,       -- Ngày bắt đầu nhu cầu tuyển
    CONVERT(NVARCHAR,ISNULL(td.NgayKetThuc,''),103) AS NgayKetThuc,    -- Ngày kết thúc nhu cầu tuyển
    CONVERT(NVARCHAR,ISNULL(td.NgayKetThucThucTe,''),103) AS NgayKetThucThucTe,
	DATEDIFF(DAY,td.NgayKetThucThucTe,td.NgayKetThuc) ThoiGianLechKPI,
	DATEDIFF(DAY,td.NgayBatDau,td.NgayKetThuc) ThoiGianBanDau,
	DATEDIFF(DAY,td.NgayBatDau,td.NgayKetThucThucTe) ThoiGianHoanTat,
	
    ISNULL(td.SoLuong,0) AS SoHoSoNhan,               -- Số lượng hồ sơ ứng tuyển

    ISNULL(th.SoUngVienDatYeuCau,0)     AS SoUngVienDatYeuCau, 
    ISNULL(th.SoUngVienQuaHR,0)         AS SoUngVienQuaHR,          
    ISNULL(th.SoUngVienQuaLine,0)       AS SoUngVienQuaLine,  
    ISNULL(th.SoUngVienThanhCong,0)     AS SoUngVienThanhCong,  

    CONVERT(NVARCHAR,ISNULL(tstd.NgayChuyenOffer,''),103) AS NgayOffer,  -- Ngày gửi Offer
    CONVERT(NVARCHAR,ISNULL(tstd.NgayBatDauLam,''),103) AS NgayNhanViec,
    
	ISNULL(nvts.MaNhanVien,'') MaNhanVienMoi,
    ts.TenHo + ' ' + ts.Ten AS TenNhanVienMoi,        -- Họ tên nhân viên mới
    nhs.Ten AS TenNguonHoSo                           -- Nguồn tuyển thành công
FROM dbo.NS_TD_DotTuyenDung td
INNER JOIN dbo.NS_TD_NhuCauTuyenDung nc 
    ON td.DotTuyenDungID = nc.DotTuyenDungID

LEFT JOIN TongHopThiSinh th 
    ON th.DotTuyenDungID = td.DotTuyenDungID

LEFT JOIN dbo.SYS_XetDuyet xd 
    ON xd.ObjectID = nc.NhuCauTuyenDungID 
   AND xd.ObjectCode = 'NS_TD_NhuCauTuyenDung'
LEFT JOIN dbo.NS_DsChucVu cv 
    ON nc.ViTriTuyenDungID = cv.ChucVuID
LEFT JOIN dbo.PhongBan pb 
    ON nc.PhongBanYeuCauID = pb.PhongBanID
LEFT JOIN dbo.NS_DsChucDanh cd 
    ON cd.ChucDanhID = cv.ChucDanhID
LEFT JOIN dbo.SYS_ThongTinCongTy cty 
    ON nc.CongTyID = cty.ID
LEFT JOIN dbo.NS_TD_ThiSinh_DotTuyenDung tstd 
    ON tstd.DotTuyenDungID = td.DotTuyenDungID
LEFT JOIN dbo.NS_TD_ThiSinh ts 
    ON ts.ThiSinhID = tstd.ThiSinhID
LEFT JOIN NhanVien nvts ON nvts.ThiSinhID = ts.ThiSinhID
LEFT JOIN dbo.NS_DsNguonHoSo nhs 
    ON nhs.NguonHoSoID = ts.NguonHoSoID
LEFT JOIN dbo.NS_DsCapBac cb 
    ON cb.CapBacID = td.CapBacID 
LEFT JOIN dbo.NS_DsNhomCapBac ncb 
    ON ncb.NhomCapBacID = td.NhomCapBacID 
LEFT JOIN dbo.NS_DsKhuVuc kv 
    ON kv.KhuVucID = CONVERT(INT,td.KhuVucID)
WHERE pb.PhongBanID in (select valu from GetPhongBanChild_WUser(@PhongBanID,@DangNhapID ))
AND MONTH(td.NgayBatDau) = @Thang AND YEAR(td.NgayBatDau) = @Nam
ORDER BY td.NgayBatDau DESC;



END
GO
