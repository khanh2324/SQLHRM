when N'TrinhDoNGoaiNguID' then (select TenNgoaiNgu from NS_DsNgoaiNgu where NgoaiNguID = GiaTriCu)  
when N'HeDaoTaoID' then (select Ten from NS_DsHeDaoTao where HeDaoTaoID = GiaTriCu)  
when N'TrinhDoNgoaiNgu2ID' then (select TenNgoaiNgu from NS_DsNgoaiNgu where NgoaiNguID = GiaTriCu)  
when N'TruongDaoTaoID' then (select Ten from NS_DsTruongDaoTao where TruongDaoTaoID = GiaTriCu)  
when N'LoaiHopDongID' then (select tenloaihopdong from NS_DsLoaiHopDong where LoaiHopDongID = GiaTriCu)  
when N'TrangThaiID' then (select Ten from NS_DsTrangThai where TrangThaiID = GiaTriCu)  
when N'NganhHocID' then (select TenNganhHoc from NS_DsNganhHoc where NganhHocID = GiaTriCu)  
when N'TrinhDoID' then (select tentrinhdo from NS_DsTrinhDo where TrinhDoID = GiaTriCu)  
when N'DanTocID' then (select Ten from NS_DsDanToc where DanTocID = GiaTriCu)  
when N'TonGiaoID' then (select Ten from NS_DsTonGiao where TonGiaoID = GiaTriCu)  
when N'KhuVucID' then (select TenKhuVuc from NS_DsKhuVuc where KhuVucID = GiaTriCu)  
when N'BaoCaoTrucTiepID' then (select ND_MaNhanVien+' - '+ND_HoVaTen from Sys_nguoiDung where NguoiDungID = GiaTriCu)  
when N'BaoCaoGianTiepID' then (select ND_MaNhanVien+' - '+ND_HoVaTen from Sys_nguoiDung where NguoiDungID = GiaTriCu)  
when N'NoiKhamChuaBenhID' then (select MaNoiKhamChuaBenh+' - '+TenNoiKhamChuaBenh from NS_BH_NoiKhamChuaBenh where NoiKhamChuaBenhID = GiaTriCu)  
when N'CapBacID' then (select TenBac from NS_DsCapBac where CapBacID = GiaTriCu)  
when N'LoaiLaoDongID' then (select Ten from NS_DsLoaiLaoDong where LoaiLaoDongID = GiaTriCu)  
when N'HinhThucLaoDongID' then (select Ten from NS_DsHinhThucLaoDong where HinhThucLaoDongID = GiaTriCu)  
when N'TrangThai_GiayPhepLaoDongID' then (select Ten from NS_DsTrangThai_GiayPhepLaoDong where TrangThai_GiayPhepLaoDongID = GiaTriCu)  
else (case when KieuDuLieu = N'datetime' then substring(GiaTriCu,1,10) else GiaTriCu end)  
end as GiaTriCu_1,  
case truongthongtin   
when N'QuocTichID' then (select TenNuoc from NS_DsQuocTich where QuocTichID = GiaTriMoi)  
when N'tinhthanhid' then (select tentinh from NS_DsTinh where TinhID = GiaTriMoi)  
when N'QuanHuyenID' then (select tenquanhuyen from NS_DsQuanHuyen where QuanHuyenID = GiaTrimoi)  
when N'DiaChi_XaPhuongID' then (select TenXaPhuong from NS_DsXaPhuong where XaPhuongID = GiaTrimoi)  
when N'DiaChi_QuanHuyenID' then (select tenquanhuyen from NS_DsQuanHuyen where QuanHuyenID = GiaTrimoi)  
when N'DiaChi_TinhID' then (select tentinh from NS_DsTinh where TinhID = GiaTrimoi)  
when N'DiaChiTT_XaPhuongID' then (select TenXaPhuong from NS_DsXaPhuong where XaPhuongID = GiaTrimoi)  
when N'DiaChiTT_QuanHuyenID' then (select tenquanhuyen from NS_DsQuanHuyen where QuanHuyenID = GiaTrimoi)  
when N'DiaChiTT_TinhID' then (select tentinh from NS_DsTinh where TinhID = GiaTrimoi)  
when N'ChucVuID' then (select tenchucvu from NS_DsChucVu where ChucVuID = giatrimoi)   
when N'PhongBanID' then (select ten from phongban where PhongBanID = giatrimoi)  
when N'ChucDanhID' then (select tenchucdanh from NS_DsChucDanh where ChucDanhID = giatrimoi)  
when N'TrinhDoTinHocID' then (select Ten from NS_DsTinHoc where TinHocID = giatrimoi)  
when N'TrinhDoNGoaiNguID' then (select TenNgoaiNgu from NS_DsNgoaiNgu where NgoaiNguID = giatrimoi)  
when N'HeDaoTaoID' then (select Ten from NS_DsHeDaoTao where HeDaoTaoID = giatrimoi)  
when N'TrinhDoNgoaiNgu2ID' then (select TenNgoaiNgu from NS_DsNgoaiNgu where NgoaiNguID = giatrimoi)  
when N'TruongDaoTaoID' then (select Ten from NS_DsTruongDaoTao where TruongDaoTaoID = giatrimoi)  
when N'LoaiHopDongID' then (select tenloaihopdong from NS_DsLoaiHopDong where LoaiHopDongID = giatrimoi)  
when N'TrangThaiID' then (select Ten from NS_DsTrangThai where TrangThaiID = giatrimoi)  
when N'NganhHocID' then (select TenNganhHoc from NS_DsNganhHoc where NganhHocID = giatrimoi)  
when N'TrinhDoID' then (select tentrinhdo from NS_DsTrinhDo where TrinhDoID = giatrimoi)  
when N'DanTocID' then (select Ten from NS_DsDanToc where DanTocID = giatrimoi)  
when N'TonGiaoID' then (select Ten from NS_DsTonGiao where TonGiaoID = giatrimoi)  
when N'KhuVucID' then (select TenKhuVuc from NS_DsKhuVuc where KhuVucID = GiaTriCu)  
when N'BaoCaoTrucTiepID' then (select ND_MaNhanVien+' - '+ND_HoVaTen from Sys_nguoiDung where NguoiDungID = giatrimoi)  
when N'BaoCaoGianTiepID' then (select ND_MaNhanVien+' - '+ND_HoVaTen from Sys_nguoiDung where NguoiDungID = giatrimoi)  
when N'NoiKhamChuaBenhID' then (select MaNoiKhamChuaBenh+' - '+TenNoiKhamChuaBenh from NS_BH_NoiKhamChuaBenh where NoiKhamChuaBenhID = giatrimoi)  
when N'CapBacID' then (select TenBac from NS_DsCapBac where CapBacID = giatrimoi)  
when N'LoaiLaoDongID' then (select Ten from NS_DsLoaiLaoDong where LoaiLaoDongID = giatrimoi)  
when N'HinhThucLaoDongID' then (select Ten from NS_DsHinhThucLaoDong where HinhThucLaoDongID = giatrimoi)  
when N'TrangThai_GiayPhepLaoDongID' then (select Ten from NS_DsTrangThai_GiayPhepLaoDong where TrangThai_GiayPhepLaoDongID = giatrimoi)  
else (case when KieuDuLieu = N'datetime' then CONVERT(nvarchar,giatridatetime,103) else giatrimoi end)  
end as giatrimoi_1  
from SYS_LichSuThayDoiThongTinChiTiet   
where LichSuThayDoiThongTinID = @ID  
) as a where Thongtin is not null  
and ISNULL(giatrimoi_1,'')!=ISNULL(giatricu_1,'')) as b  
select NhanVienID, @Thongtin as Thongtin,MaNhanVien as MaNhanVien,NhanVien.Ho+' '+NhanVien.HoTen as HoTen,  
PhongBan.Ten as PhongBan, NS_DsChucVu.TenChucVu as ChucVu,  
 (select case when TrangThai=1 then N'- Ý kiến phê duyệt: '+GhiChu when  
TrangThai=-1 then N'- Lý do từ chối: '+GhiChu else '' end as Ykien_Duyet_Tuchoi  
 from SYS_XetDuyet where ObjectID=@ID and QuyTrinhID in (select QuyTrinhID from WF_QuyTrinh where MaQuyTrinh='XD_SUATTNHANVIEN')) as Ykien_Duyet_TuChoi  
from SYS_LichSuThayDoiThongTin inner join NhanVien  
on SYS_LichSuThayDoiThongTin.IDValue = NhanVien.NhanVienID  
inner join PhongBan on NhanVien.PhongBanID = PhongBan.PhongBanID  
left join NS_DsChucVu on NhanVien.ChucVuID = NS_DsChucVu.ChucVuID  
where NhanVienID = (select IDValue from SYS_LichSuThayDoiThongTin  
where LichSuThayDoiThongTinID = @ID)  
END  
  
