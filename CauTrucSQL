/****** Object:  StoredProcedure [dbo].[LayThamSoNhuCauTuyenDung]    Script Date: 03/04/2026 16:11:45 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROC [dbo].[LayThamSoNhuCauTuyenDung]  
    @ID INT  
AS  
BEGIN  
    SELECT   
        NC.NhuCauTuyenDungID,  
        nv.MaNhanVien,   
        nv.Ho + ' ' + nv.HoTen AS HoVaTen,  
        --NC.TenPhongBan AS PhongBan,   
		pb.Ten AS PhongBan,
        CVYC.TenChucVu,  
        NS_DsChucVu.TenChucVu AS ViTriTuyenDung,  
        NC.SoLuongYC AS SoLuong,  
        NC.DoTuoi,   
        NC.GioiTinh,  
        NC.SoNamKinhNghiem,  
        NS_DsTrinhDo.TenTrinhDo AS TrinhDo,  
        NC.LyDoTuyen AS LyDoTuyenDung,  
        --Ns_DsPhongLamViec.TenPhongLamViec as NoiLamViec,  
        NC.MoTaCongViec,  
        NC.GhiChu,  
        NC.DiaDiemLamViec,  
        NC.LyDoYeuCauHuyOrTamDung AS LyDoHuy_TamDung,  
  
        -- Tuyển dụng thay thế: gom danh sách nhân viên được thay thế  
        CASE   
            WHEN NC.LyDoTuyen = N'Thay thế cán bộ nghỉ việc' THEN  
                STUFF((  
                    SELECT N', ' + nv2.MaNhanVien + N' - ' + nv2.Ho + N' ' + nv2.HoTen  
                    FROM dbo.NhanVien nv2  
                    WHERE nv2.NhanVienID IN (  
                        SELECT TRY_CAST(value AS INT)  
                        FROM STRING_SPLIT(  
                                REPLACE(REPLACE(NC.ThayTheNhanVienIDStr,'[',''),']',''),  
                                ','  
                             )  
                    )  
                    FOR XML PATH(''), TYPE  
                ).value('.','nvarchar(max)'), 1, 2, N'')  
            ELSE N''  
        END AS TuyenDungThayThe,  
  
        -- Ý kiến duyệt / từ chối  
        (  
            SELECT CASE   
                       WHEN TrangThai = 1    
                           THEN N'- Ý kiến phê duyệt: ' + GhiChu  
                       WHEN TrangThai = -1   
                           THEN N'- Lý do từ chối: ' + GhiChu  
                       ELSE N''  
                   END  
            FROM SYS_XetDuyet xd  
            WHERE xd.ObjectID = @ID  
              AND xd.QuyTrinhID IN (  
                    SELECT QuyTrinhID   
                    FROM WF_QuyTrinh   
                    WHERE MaQuyTrinh = 'XD_TD_NHUCAU'  
              )  
        ) AS Ykien_Duyet_TuChoi  
  
    FROM NS_TD_NhuCauTuyenDung NC  
        INNER JOIN NhanVien nv   
            ON NC.NguoiYeuCauID = nv.NhanVienID  
        LEFT JOIN NS_DsChucVu CVYC   
            ON nv.ChucVuID = CVYC.ChucVuID  
		LEFT JOIN dbo.PhongBan pb ON nv.PhongBanID = pb.PhongBanID
        LEFT JOIN PhongBan pbyc   
            ON NC.PhongBanYeuCauID = pbyc.PhongBanID  
        LEFT JOIN NS_DsChucVu   
            ON NC.ViTriTuyenDungID = NS_DsChucVu.ChucVuID  
        LEFT JOIN NS_DsTrinhDo   
            ON NC.TrinhDoID = NS_DsTrinhDo.TrinhDoID  
        --LEFT JOIN Ns_DsPhongLamViec ON Nc.PhongLamViecID = Ns_DsPhongLamViec.PhongLamViecID  
    WHERE   
        NC.NhuCauTuyenDungID = @ID;  
END  
GO
