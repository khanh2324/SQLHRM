create FUNCTION [dbo].[TachChuoiQuanHeNhanThan]()
RETURNS @ketqua TABLE (QTID int,a1 nvarchar(100),a2 nvarchar(100),a3 nvarchar(100),a4 nvarchar(100))
WITH EXECUTE AS CALLER
AS
 begin
 declare @tbl table (QTID int)
declare @tbltam table (QTID int,stt int,chuoi nvarchar(100))
insert into @tbl 
select qtquanhegiadinhid from NS_QTQuanHeGiaDinh
declare @QTID int
declare @dem int
declare @stt int
declare @chuoi nvarchar(2000)
declare @chuoitg nvarchar(100)
set @dem = (select count(*) from @tbl)
declare @tg int
while (@dem!=0)
begin
	set @QTID = (select top 1 QTID from @tbl)
	set @chuoi = (select NoiDangKyGiayKhaiSinh from ns_qtquanhegiadinh where qtquanhegiadinhid = @QTID)
	set @tg = (select charindex(',',reverse(@chuoi)))
	if(@tg=0)
	begin
	insert into @tbltam(QTID,stt,chuoi)
		select @QTID,1,@chuoitg
	end
	else
	begin
	set @stt = 0
	while(@tg!=0)
	begin
		set @stt = @stt+1
		set @chuoitg = right(@chuoi,charindex(',',reverse(@chuoi))-1)
		insert into @tbltam(QTID,stt,chuoi)
		select @QTID,@stt,@chuoitg
		set @chuoi = left(@chuoi,len(@chuoi)-charindex(',',reverse(@chuoi)))
		set @tg = (select charindex(',',reverse(@chuoi)))
	end
	set @stt =@stt+1
	insert into @tbltam(QTID,stt,chuoi)
	select @QTID,@stt,ltrim(rtrim(@chuoi))
	end
	delete @tbl where QTID = @QTID
	set @dem = (select count(*) from @tbl)
	SET @chuoitg =''
end
