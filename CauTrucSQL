AS
 begin
  if @parentID > 0
  begin
   declare @tempCount int
   declare @count int
   set @count = 0
   insert @tbl(id, valu, prID) select  0,@parentID,0
   select @count = count(ID)from SYS_ThongTinCongTy where CongTyChaID = @parentID
   if(@count > 0)
   begin
        insert @tbl(id, valu, prID) select ROW_NUMBER() over( order by ID),ID, CongTyChaID 
        from SYS_ThongTinCongTy where CongTyChaID = @parentID
    declare @row int
    set @row = 1
    while @row <= @count
    begin
       select @tempCount = count(id) from @tbl
       select @parentID = valu from @tbl where id = @row
           insert @tbl(id, valu, prID) select ROW_NUMBER() over( order by id) + @tempCount, valu, prID 
           from dbo.GetCongTyChilds(@parentID)
       set @row = @row +1
    end
   end
  end
  else
	begin
		    insert @tbl(id, valu, prID) select ROW_NUMBER() over( order by ID),ID, CongTyChaID 
			from SYS_ThongTinCongTy
	end
  DELETE @tbl WHERE valu not in (SELECT DoiTuongID FROM SYS_NguoiDung_NhomQuyen WHERE NhomQuyen='CTYCON' And NguoiDungID=@userid)
 return
end
