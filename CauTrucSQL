CREATE procedure [dbo].[ADD_BangLuongVanHanh_ADCo] 
	@PhongBanID int, @Thang int, @Nam int, @LoaiLaoDongID int, @DangNhapID int

as
BEGIN

  --declare @PhongBanID int = 20, @Thang int = 3, @Nam int = 2025, @LoaiLaoDongID int = 0, @DangNhapID int = 3115  

	 declare @ThangLuong date = eomonth(convert(char(2), @thang) + '/1/' + convert(char(4), @nam) )  
	 declare @NgayQuyDoi date = convert(char(2), @thang) + '/26/' + convert(char(4), @nam)   
	 declare @DauKy date = dateadd(month, -1, @NgayQuyDoi)  
	 declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)   
   

	select ROW_NUMBER() OVER (ORDER BY STT, a.ThuTu) AS STT, * from (
	 select   
			 nv.MaNhanVien as MaNV, nv.Ho + ' ' + nv.HoTen as HoTen
  
		  , isnull(bl.[CC_TongCong], 0) as SoNgayLamViec, isnull(bl.[TLNC_LCB], 0) as LCB  
		  , isnull(bl.[TLNC_PC_TrachNhiem], 0) as PCTrachNhiem, isnull(bl.[TLNC_PC_DiLai], 0) as PCDiLai, isnull(bl.[TLNC_PC_DocHai], 0) as PCDocHai
		  , isnull(bl.[TLNC_PC_Khac], 0) as PCKhac, isnull(bl.[TLNC_PC_BuaAn], 0) as PCBuaAn, isnull(bl.[TLNC_ThuongThang], 0) as ThuongThang

		  , isnull(bl.[Thuong_KM], 0) as ThuongKM, isnull(bl.[TLOT_ChieuThue], 0) as LuongOTCoBan, isnull(bl.[TLOT_MienThue], 0) as LuongOTChenhLech
		  , isnull(bl.[TLOT_LamCaDem], 0) as LuongTraThemCaDem, 0 as PhepNam, isnull(bl.[Thuong_KPI], 0) as ThuongKPI
		  , isnull(bl.[Thuong_CongTruocThue], 0) as CongKhac, isnull(bl.[Thuong_TruTruocThue], 0) as TruTruocThue, isnull(bl.[TongThuNhap], 0) as TongPhaiTrai

		  , isnull(bl.[BH_Tong_NLD], 0) as KhauTruBH, isnull(bl.[Tax_GiamTru_BanThan], 0) as GiamTruBanThan, isnull(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) as GiamTruNguoiPhuThuoc
		  , isnull(bl.[Tax_SoNguoiPhuThuoc], 0) as SoNguoiPhuThuoc, isnull(bl.[Tax_ThuNhapTinhThue], 0) as ThuNhapChiuThue, isnull(bl.[Tax_TongThue], 0) as MucThuePhaiNop 
		  , isnull(bl.[PSSThue_CongDoan_NLD], 0) as PhiCongDoan, isnull(bl.[PSSThue_TruSauTax], 0) as TruSauThue, isnull(bl.[PSSThue_CongSauTax], 0) as CongSauThue
		  , isnull(bl.[ThucLinh], 0) as ThucLinh, dbo.fuChuyenCoDauThanhKhongDau (khogoc.TenKhuVuc) as TongKho, lld.LoaiLaoDongID as LoaiLaoDongID
		  , upper((case when Nhom.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.Ten else v.Lever2Ten end  
		   else lld.Ten end   
			)) as TenLoaiLaoDong  
		  , (case   
		    when Nhom.Ten = N'Văn phòng' then case when cappb.Level < 4 then pb.ThuTuSapXep else (select top 1 ThuTuSapXep from dbo.PhongBan where PhongBanID = v.Lever2ID) end  
	      else 100 + lld.ThuTu end   
		 ) as STT  
		 , cv.ThuTu		  
		--  , lld.Ten as TenLoaiLaoDong

		  --, isnull(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) as TongLuongVaPhuCap   	  
		  --, isnull(bl.[TLOT_TongLuongOT_LamCaDem], 0) as TongOTVaCaDem
		  --, isnull(bl.[Thuong_LuongT13], 0) as LuongThang13, isnull(bl.[Thuong_Nam], 0) as ThuongNam, isnull(bl.[Thuong_ChenhLechT1], 0) as ChenhLechThang1  	   
		  --, isnull(bl.[Thuong_TongThuong], 0) as TongThuongVaKhoanTruocThue 
		  --, isnull(bl.[BH_LuongBHXH], 0) as MucLuongBHXH, isnull(bl.[BH_LuongBHTN], 0) as MucLuongBHTN  
		  --, isnull(bl.[BH_Tong_CTY], 0) as BHCongTy, isnull(bl.[BH_Tong], 0) as TongBHXH    
		  --, isnull(bl.[Tax_ThuNhapChiuThue], 0) as ThuNhapChiuThue  	   
		  --, isnull(bl.[Tax_ThuNhapSauThue], 0) as ThuNhapSauThue  
		  --, isnull(bl.[PSSThue_CongDoan_CTY], 0) as KinhPhiCongDoanCTY 
		  --, isnull(bl.[ChiPhiCongTy], 0) as ChiPhiCongTy  
  
	 from NhanVien nv   
		 cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1      
		 left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
		 left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID  
		 cross apply dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1  
		 left join dbo.NS_DsChucVu cv on cv.ChucVuID = cv1.ChucVuID
		 --cross APPLY dbo.fnt_GetChucDanhNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cd1  
		 --left JOIN dbo.NS_DsChucDanh cd on cd.ChucDanhID = cd1.ChucDanhID
	 	 --cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv  
	 	 --left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId
		 --left join dbo.v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID  	
		 left join ADD_CostCenter Nhom on nv.CostCenterId = Nhom.CostCenterId  
		 left join dbo.NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID  		 
		 left join dbo.NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID  	
	 	 cross apply dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(nv.NhanVienID, @Date) ddlv  
		 --left join dbo.NS_DsKhuVuc khogoc on nv.KhoGocID = khogoc.KhuVucID
		 left join dbo.NS_DsKhuVuc khogoc on ddlv.KhuVucID = khogoc.KhuVucID
		 right join  
			 (select * from (  
				  select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuong  
				  from NS_TL_BangLuong bl   
					  left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID  
					  left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID   
				  Where (1=1)  
					  and bl.Thang = @Thang  
					  and bl.Nam = @Nam  				 
				  ) as A pivot ( sum(TienLuong) for MaSo in( [CC_TongCong], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac],   
															   [TLNC_PC_BuaAn], [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap], [TLOT_ChieuThue], [TLOT_MienThue],   
															   [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem], [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam],   
															   [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap],   
															   [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong],   
															   [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc], [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue],   
															   [Tax_TongThue], [Tax_ThuNhapSauThue], [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax],   
															   [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy]   ) ) as B  
				 ) as bl on nv.NhanVienID = bl.NhanVienID   
  
	 where pb.PhongBanID in (select valu from GetPhongBanChild_WUser(@PhongBanID, @DangNhapID) )  
		and (lld.LoaiLaoDongID = @LoaiLaoDongID or @LoaiLaoDongID = -1001 or @LoaiLaoDongID = 0)
		and nv.MaNhanVien <> '80090'
		and nv.NhanVienID not in (40452)
		AND pb.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
	) a
	 order by a.STT, a.ThuTu
        
END
