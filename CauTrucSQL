            JOIN dbo.NS_TL_ChiTietLuong Ctl
                ON Ctl.BangLuongID = Bl.BangLuongID
            JOIN dbo.NS_TL_LoaiLuong LL
                ON LL.LoaiLuongID = Ctl.LoaiLuongID
				cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(bl.NhanVienID, @Date_TT) pb1      
				left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
			    cross APPLY dbo.fnt_GetDiaDiemLamViecNhanVienTaiThoiDiem(bl.NhanVienID, @Date_TT) ddlv  
	 			left JOIN dbo.NS_DsKhuVuc kv on kv.KhuVucID = ddlv.KhuVucId

        WHERE (
                  Bl.Nam = year(@Date_TT)
                  AND Bl.Thang = month(@Date_TT)
              )
              AND pb.PhongBanID IN
                  (
                      SELECT valu FROM dbo.GetPhongBanChild_WUser(@PhongBanID, @DangNhapID)
                  )
              AND
                  (  kv.KhuVucID = @DiaDiemID
                  OR @DiaDiemID = 0
                  OR @DiaDiemID = -1001)
         
              AND Bl.NhanVienID IN
                   (
                       SELECT NhanVien.NhanVienID
                       FROM dbo.NhanVien
					   JOIN dbo.NS_NhanVien_NghiViec ON NS_NhanVien_NghiViec.NhanVienID = NhanVien.NhanVienID
                       WHERE (NhanVien.NhomNhanSuID = @NhomNhanSuID
                             OR ISNULL(@NhomNhanSuID,0) = 0
                             OR @NhomNhanSuID = -1001)
							 AND CONVERT(DATE,NgayHieuLuc) BETWEEN @NBD AND @NKT
                   )

    ) Bangluong
    PIVOT
    (
        SUM(TienLuong)
        FOR MaSo IN ([QD_LCB], [QD_LCB_New], [QD_PC_TrachNhiem], [QD_PC_TrachNhiem_New], [QD_PC_ViTri],
                     [QD_PC_ViTri_New], [QD_PC_DiLai], [QD_PC_DiLai_New], [QD_PC_DocHai], [QD_PC_DocHai_New],
                     [QD_PC_Khac], [QD_PC_Khac_New], [QD_PC_BuaAn], [QD_PC_BuaAn_New], [QD_ThuongThang],
                     [QD_ThuongThang_New], [QD_TongLuong_PhuCap], [QD_TongLuong_PhuCap_New], [CC_XN], [CC_XD],
                     [CC_NghiPhep], [CC_NghiLe], [CC_NghiBu], [CC_CongTac], [CC_NghiCheDo], [CC_NghiCoLuong],
                     [CC_TongCong], [CC_GCC], [TLNC_LuongGio], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri],
                     [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], [TLNC_PC_BuaAn], [TLNC_ThuongThang],
                     [TLNC_TongLuong_Thuong_PhuCap], [TLNC_TongLuong_Thuong_PhuCap_Gop], [CC_TongGioOT],
                     [CC_TongGioOT_NoneTax], [TLOT_ChieuThue], [TLOT_MienThue], [TLOT_LamCaDem],
                     [TLOT_TongLuongOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem_Gop], [Thuong_KM_IP], [Thuong_KM],
                     [Thuong_KPI_IP], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam_IP], [Thuong_Nam],
                     [Thuong_ChenhLechT1_IP], [Thuong_ChenhLechT1], [Thuong_CongTruocThue_IP], [Thuong_CongTruocThue],
                     [Thuong_TruTruocThue_IP], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap],
                     [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong], [Tax_ThuNhapMienThue],
                     [Tax_ThuNhapMienThue_Gop], [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_SoNguoiPhuThuoc],
                     [Tax_GiamTru_NguoiPhuThuoc], [Tax_ThuNhapTinhThue], [Tax_TongThue], [Tax_ThuNhapSauThue],
                     [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax_IP], [PSSThue_TruSauTax],
                     [PSSThue_CongSauTax_IP], [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy],

					 [QD_LCB_TT], [QD_LCB_New_TT], [QD_PC_TrachNhiem_TT], [QD_PC_TrachNhiem_New_TT], [QD_PC_ViTri_TT],
                     [QD_PC_ViTri_New_TT], [QD_PC_DiLai_TT], [QD_PC_DiLai_New_TT], [QD_PC_DocHai_TT], [QD_PC_DocHai_New_TT],
                     [QD_PC_Khac_TT], [QD_PC_Khac_New_TT], [QD_PC_BuaAn_TT], [QD_PC_BuaAn_New_TT], [QD_ThuongThang_TT],
                     [QD_ThuongThang_New_TT], [QD_TongLuong_PhuCap_TT], [QD_TongLuong_PhuCap_New_TT], [CC_XN_TT], [CC_XD_TT],
                     [CC_NghiPhep_TT], [CC_NghiLe_TT], [CC_NghiBu_TT], [CC_CongTac_TT], [CC_NghiCheDo_TT], [CC_NghiCoLuong_TT],
                     [CC_TongCong_TT], [CC_GCC_TT], [TLNC_LuongGio_TT], [TLNC_LCB_TT], [TLNC_PC_TrachNhiem_TT], [TLNC_PC_ViTri_TT],
                     [TLNC_PC_DiLai_TT], [TLNC_PC_DocHai_TT], [TLNC_PC_Khac_TT], [TLNC_PC_BuaAn_TT], [TLNC_ThuongThang_TT],
                     [TLNC_TongLuong_Thuong_PhuCap_TT], [TLNC_TongLuong_Thuong_PhuCap_Gop_TT], [CC_TongGioOT_TT],
                     [CC_TongGioOT_NoneTax_TT], [TLOT_ChieuThue_TT], [TLOT_MienThue_TT], [TLOT_LamCaDem_TT],
                     [TLOT_TongLuongOT_LamCaDem_TT], [TLOT_TongLuongOT_LamCaDem_Gop_TT], [Thuong_KM_IP_TT], [Thuong_KM_TT],
                     [Thuong_KPI_IP_TT], [Thuong_KPI_TT], [Thuong_LuongT13_TT], [Thuong_Nam_IP_TT], [Thuong_Nam_TT],
                     [Thuong_ChenhLechT1_IP_TT], [Thuong_ChenhLechT1_TT], [Thuong_CongTruocThue_IP_TT], [Thuong_CongTruocThue_TT],
                     [Thuong_TruTruocThue_IP_TT], [Thuong_TruTruocThue_TT], [Thuong_TongThuong_TT], [TongThuNhap_TT],
