CREATE PROCEDURE [dbo].[ADD_BC_DoiChieuTongHopLuong_SalaryAdjustment_ADCo]
    @PhongBanID INT,
    @Thang INT,
    @Nam INT,
    @DiaDiemID INT,
    @NhomNhanSuID INT,
    @DangNhapID INT
AS
BEGIN

	declare @Date date = convert(char(2), @thang) + '/25/' + convert(char(4), @nam)  
	declare @Date_TT date = dateadd(m,-1,@Date) 

    DECLARE @NKT DATE = CONVERT(NVARCHAR(10), @Nam) + '/' + CONVERT(NVARCHAR(10), @Thang) + '/26';
    DECLARE @NBD DATE = DATEADD(DAY, -1, DATEADD(MONTH, -1, @NKT));

    SELECT @Thang Thang, @Nam Nam,
