	DECLARE @ChucVuQLTT INT =  (SELECT ChucVuID FROM NhanVien WHERE NhanVienID=(SELECT NhanVienID FROM SYS_NguoiDung WHERE NguoiDungID=(SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienID = @NhanVienID)))
DECLARE @CapTrenQLTT INT = (SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienID = (SELECT NhanVienID FROM dbo.SYS_NguoiDung
							WHERE NguoiDungID = (SELECT BaoCaoTrucTiepID FROM NhanVien WHERE NhanVienId = @NhanVienID)))

