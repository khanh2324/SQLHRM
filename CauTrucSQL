CREATE PROCEDURE [dbo].[HS_LayParameters_NghiViec]  
@NhanVienNghiViecID int  
AS  
BEGIN  
 --DECLARE @NhanVienNghiViecID INT = 3483   
  
;WITH HD_MoiNhat AS (  
    SELECT hd.*  
    FROM dbo.NS_HopDong AS hd  
    WHERE hd.NhanVienID = (  
        SELECT nvnv.NhanVienID   
        FROM dbo.NS_NhanVien_NghiViec AS nvnv   
        WHERE nvnv.NhanVienNghiViecID = @NhanVienNghiViecID  
    )  
    AND hd.NgayBatDau = (  
        SELECT MAX(hd2.NgayBatDau)  
        FROM dbo.NS_HopDong AS hd2  
        WHERE hd2.NhanVienID = hd.NhanVienID  
    )  
)  
SELECT   
    ISNULL(hd.MaHopDong, '')                                      AS MaHopDong,   
    ISNULL(nv.MaNhanVien, '')                                     AS MaNhanVien,  
  
    CASE WHEN ISNULL(nv.GioiTinh,'') = N'Nữ'  THEN N'Bà'  
         WHEN ISNULL(nv.GioiTinh,'') = N'Nam' THEN N'Ông' ELSE '' END AS OngBa,  
    CASE WHEN ISNULL(nv.GioiTinh,'') = N'Nữ'  THEN N'chị'  
         WHEN ISNULL(nv.GioiTinh,'') = N'Nam' THEN N'anh' ELSE '' END AS AnhChi,  
    CASE WHEN ISNULL(nv.GioiTinh,'') = N'Nữ'  THEN N'Ms'  
         WHEN ISNULL(nv.GioiTinh,'') = N'Nam' THEN N'Mr' ELSE '' END AS OngBaTA,  
  
    ISNULL(nv.Ho,'') + ' ' + ISNULL(nv.HoTen,'')                  AS HoVaTen,  
    ISNULL(CONVERT(nvarchar(10), nv.NgaySinh, 103), '')           AS NgaySinh,  
 ISNULL(nv.DienThoai,'') DienThoai,  
 DATEDIFF(YEAR,nv.NgaySinh,GETDATE()) Tuoi,  
 CONCAT(  
  CASE   
   WHEN DATEDIFF(MONTH, nv.NgayBatDauLam, GETDATE()) / 12 > 0   
   THEN CONCAT(DATEDIFF(MONTH, nv.NgayBatDauLam, GETDATE()) / 12, N' năm ')  
   ELSE N''  
  END,  
  (DATEDIFF(MONTH, nv.NgayBatDauLam, GETDATE()) % 12),  
  N' tháng'  
 ) AS ThamNien,  
  
  
    LTRIM(RTRIM(REPLACE(REPLACE(ISNULL(nst.TenTinh,''), N'Thành phố ', ''), N'Tỉnh ', ''))) AS NoiSinh,  
    dbo.fuChuyenCoDauThanhKhongDau(  
        LTRIM(RTRIM(REPLACE(REPLACE(ISNULL(nst.TenTinh,''), N'Thành phố ', ''), N'Tỉnh ', '')))  
    )                                                             AS NoiSinhTA,  
  
    ISNULL(nv.CCCD,'')                                            AS CCCD,  
    ISNULL(CONVERT(nvarchar(10), nv.NgayCapCCCD, 103), '')        AS NgayCapCCCD,  
    ISNULL(nv.NoiCapCCCD,'')                                      AS NoiCapCCCD,  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(nv.NoiCapCCCD,''))      AS NoiCapCCCDTA,  
  
    ISNULL(qt.TenNuoc,'')                                         AS QuocTich,  
    ''                                                            AS NgheNghiep,  
  
    ISNULL(nv.DiaChiThuongTru,'')                                 AS DiaChiThuongTru,  
    ISNULL(nv.DiaChi,'')                                          AS DiaChiHienTai,  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(nv.DiaChiThuongTru,'')) AS DiaChiThuongTruTA,  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(nv.DiaChi,''))          AS DiaChiHienTaiTA,  
  
    ISNULL(lhd.TenLoaiHopDong,'')                                 AS TenLoaiHopDong,  
    ISNULL(lhd.TenLoaiHopDongTA,'')                               AS TenLoaiHopDongTA,  
  
 --Quản lý trực tiếp  
 ISNULL(nvql.Ho,'') + ' ' + ISNULL(nvql.HoTen,'')                  AS HoVaTenQL,  
  
    -- NGỮ CẢNH NGHỈ VIỆC:  
    -- Có thể giữ ngày HĐ (nếu còn) để tham chiếu, nhưng ưu tiên hiển thị mốc nghỉ việc từ nvnv  
    CASE WHEN hd.NgayBatDau IS NULL THEN '' ELSE CONVERT(nvarchar(10), hd.NgayBatDau, 103) END AS NgayBatDau,  
    CASE WHEN hd.NgayBatDau IS NULL THEN '' ELSE CONVERT(nvarchar(10), DATEADD(MONTH,-2, hd.NgayBatDau), 103) END AS NgayBatDauTV,  
    CASE WHEN hd.NgayBatDau IS NULL THEN '' ELSE CONVERT(nvarchar(10), DATEADD(DAY,-1, hd.NgayBatDau), 103)   END AS NgayKetThucTV,  
    CASE WHEN hd.NgayKetThuc IS NULL THEN '' ELSE CONVERT(nvarchar(10), hd.NgayKetThuc, 103) END AS NgayKetThuc,  
    CASE WHEN hd.NgayKyHD    IS NULL THEN '' ELSE CONVERT(nvarchar(10), hd.NgayKyHD, 103)    END AS NgayKy,  
  
    UPPER(ISNULL(nv.Ho,'') + ' ' + ISNULL(nv.HoTen,''))           AS HoVaTenVietHoa,  
    hd.NgayBatDau                                                AS NgayBatDauDate,  
  
    ISNULL(cv.TenChucVu,'')                                       AS TenChucVu,  
    ISNULL(cv.TenChucVuTA,'')                                     AS TenChucVuTA,  
  
    ISNULL(dblct.GiaTri,0)                                        AS LuongThoaThuan,  
    FORMAT(ISNULL(dblct.GiaTri,0), 'N0', 'vi-VN')                 AS LuongThoaThuanCham,  
    dbo.Num2Text(ISNULL(dblct.GiaTri,0))                          AS LuongThoaThuanTV,  
    dbo.Num2Text_English(ISNULL(dblct.GiaTri,0))                  AS LuongThoaThuanTA,  
  
    ISNULL(dbl_pcdh.GiaTri,0)                                     AS PhuCapDocHai,  
    FORMAT(ISNULL(dbl_pcdh.GiaTri,0), 'N0', 'vi-VN')              AS PhuCapDocHaiCham,  
    dbo.Num2Text(ISNULL(dbl_pcdh.GiaTri,0))                       AS PhuCapDocHaiTV,  
    dbo.Num2Text_English(ISNULL(dbl_pcdh.GiaTri,0))               AS PhuCapDocHaiTA,  
  
    ISNULL(pb.Ten,'')                                             AS TenPhongBan,  
    ISNULL(td.TenTrinhDo,'')                                      AS TenTrinhDo,  
  
    -- tạm tính 85%  
    ISNULL(dblct.GiaTri,0) * 85 / 100                             AS LuongThuViec,  
  
    UPPER((  
        SELECT TOP 1 nv2.Ho + ' ' + nv2.HoTen  
        FROM dbo.NhanVien AS nv2  
        JOIN dbo.NS_DsChucVu AS cv2 ON nv2.ChucVuID = cv2.ChucVuID  
        WHERE cv2.TenChucVu LIKE N'%Giám đốc điều hành%'  
    ))                                                            AS ChuKy,  
    cd.TenChucDanh,  
  
    CASE WHEN ISNULL(nvk.GioiTinh, nkcty.GioiTinh) = N'Nữ'  THEN N'Bà'  
         WHEN ISNULL(nvk.GioiTinh, nkcty.GioiTinh) = N'Nam' THEN N'Ông' ELSE '' END AS OngBaNK,  
    CASE WHEN ISNULL(nvk.GioiTinh, nkcty.GioiTinh) = N'Nữ'  THEN N'Ms'  
         WHEN ISNULL(nvk.GioiTinh, nkcty.GioiTinh) = N'Nam' THEN N'Mr' ELSE '' END AS OngBaNKTA,  
  
    ISNULL(nvk.Ho, nkcty.Ho) + ' ' + ISNULL(nvk.HoTen, nkcty.HoTen)                        AS HoVaTenNK,  
    UPPER(ISNULL(nvk.Ho, nkcty.Ho) + ' ' + ISNULL(nvk.HoTen, nkcty.HoTen))                 AS HoVaTenNKVietHoa,  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(nvk.Ho, nkcty.Ho) + ' ' + ISNULL(nvk.HoTen, nkcty.HoTen)) AS HoTenNKTA,  
  
    ISNULL(cvk.TenChucVu,    cvkcty.TenChucVu)                                             AS TenChucVuNK,  
    ISNULL(cvk.TenChucVuTA,  cvkcty.TenChucVu)                                             AS TenChucVuNKTA,  
    UPPER(ISNULL(cvk.TenChucVu, cvkcty.TenChucVu))                                         AS TenChucVuNKVietHoa,  
  
    ISNULL(cdk.TenChucDanh, cdkcty.TenChucDanh)                                            AS TenChucDanhNK,  
    ISNULL(qtk.TenNuoc, qtkcty.TenNuoc)                                                    AS QuocTichNK,  
  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(nv.Ho,'') + ' ' + ISNULL(nv.HoTen,''))          AS HoVaTenTA,  
  
    pb.TenPhongBanTA,  
    kv.TenKhuVuc                                                                               AS DiaDiemLamViec,  
    dbo.fuChuyenCoDauThanhKhongDau(ISNULL(kv.TenKhuVuc,''))                                   AS DiaDiemLamViecTA,  
  
    CASE   
        WHEN hd.NgayKetThuc IS NULL OR DATEDIFF(YEAR, hd.NgayBatDau, hd.NgayKetThuc) > 10 THEN ''  
        WHEN DATEDIFF(YEAR, hd.NgayBatDau, hd.NgayKetThuc) >= 1  
            THEN CAST(DATEDIFF(YEAR, hd.NgayBatDau, hd.NgayKetThuc) AS nvarchar) + N' năm '   
               + CAST(DATEDIFF(MONTH, hd.NgayBatDau, hd.NgayKetThuc) % 12 AS nvarchar) + N' tháng'  
        ELSE CAST(DATEDIFF(MONTH, hd.NgayBatDau, hd.NgayKetThuc) AS nvarchar) + N' tháng'  
    END AS ThoiGianHopDong,  
  
    -- Các mốc NGHỈ VIỆC (đã có sẵn trong câu gốc, giữ nguyên và làm nguồn chính):  
    ISNULL(CONVERT(nvarchar(10), nvnv.NgayHieuLuc, 103), '')                   AS NgayNghiViec,   
    ISNULL(nvnv.NgayHieuLuc, '')                   AS NgayNghiViecDate,   
    ISNULL(CONVERT(nvarchar(10), nvnv.NgayHieuLuc-1, 103), '')                   AS NgayLamViecCuoi,   
    ISNULL(nvnv.NgayQuyetDinh, '')                      AS NgayTaoDonNghiViec,  
 ISNULL(nvnv.SoQuyetDinh,'') SoQuyetDinh,  
 ISNULL(ldnv.Ten,'') LyDoNghiViec,  
 ISNULL(htnv.TenHinhThucNghiViec,'') HinhThucNghiViec,  
  
    lhd.Thang                                                                  AS SoThangHD,  
    dbo.Num2Text(ISNULL(lhd.Thang, 0))                                         AS SoThangHDTV  
FROM dbo.NS_NhanVien_NghiViec AS nvnv       -- << chuyển sang bảng nghỉ việc làm gốc  
JOIN dbo.NhanVien              AS nv   ON nv.NhanVienID = nvnv.NhanVienID  
LEFT JOIN dbo.SYS_NguoiDung qltt ON qltt.NguoiDungID = nv.BaoCaoTrucTiepID  
LEFT JOIN NhanVien nvql ON nvql.NhanVienID = qltt.NhanVienID  
LEFT JOIN dbo.NS_DsQuocTich    AS qt   ON nv.QuocTichID = qt.QuocTichID  
LEFT JOIN dbo.NS_DsKhuVuc      AS kv   ON kv.KhuVucID  = nv.KhuVucID  
LEFT JOIN dbo.NS_DsTinh        AS nst  ON nst.TinhID   = nv.NoiSinh_TinhID  
  
LEFT JOIN dbo.NS_DsLyDoNghiViec ldnv ON ldnv.LyDoNghiViecID = nvnv.LyDoNghiViecID  
LEFT JOIN dbo.NS_DsHinhThucNghiViec htnv ON htnv.HinhThucNghiViecID = nvnv.HinhThucNghiViecID  
  
-- HĐ mới nhất (nếu cần dữ liệu HĐ trong mẫu):  
LEFT JOIN HD_MoiNhat           AS hd   ON 1 = 1  
LEFT JOIN dbo.NS_DsLoaiHopDong AS lhd ON hd.LoaiHopDongID = lhd.LoaiHopDongID  
LEFT JOIN dbo.NS_DsNhomLoaiHopDong AS nlhd ON nlhd.NhomLoaiHopDongID = lhd.NhomLoaiHopDongID  
  
LEFT JOIN dbo.NS_DsChucVu      AS cv   ON nv.ChucVuID   = cv.ChucVuID  
LEFT JOIN dbo.NS_DsChucDanh    AS cd   ON nv.ChucDanhID = cd.ChucDanhID  
LEFT JOIN dbo.PhongBan         AS pb   ON nv.PhongBanID = pb.PhongBanID  
LEFT JOIN dbo.NS_DsTrinhDo     AS td   ON nv.TrinhDoID  = td.TrinhDoID  
  
LEFT JOIN dbo.NS_QTDienBienLuong AS dbl   
       ON nv.NhanVienID = dbl.NhanVienID   
      AND dbl.NgayHuong = (SELECT MAX(a.NgayHuong) FROM dbo.NS_QTDienBienLuong AS a WHERE a.NhanVienID = dbl.NhanVienID)  
  
LEFT JOIN dbo.NS_QTDienBienLuongChiTiet AS dblct   
       ON dbl.QTDienBienLuongID = dblct.QTDienBienLuongID AND dblct.LoaiLuongID = 1  
LEFT JOIN dbo.NS_QTDienBienLuongChiTiet AS dbl_pcdh   
       ON dbl.QTDienBienLuongID = dbl_pcdh.QTDienBienLuongID AND dbl_pcdh.LoaiLuongID = 5  -- fix alias  
  
LEFT JOIN dbo.NhanVien         AS nvk    ON nvk.NhanVienID = hd.NguoiKyID  
LEFT JOIN dbo.NS_DsQuocTich    AS qtk    ON nvk.QuocTichID = qtk.QuocTichID  
LEFT JOIN dbo.NS_DsChucVu      AS cvk    ON nvk.ChucVuID   = cvk.ChucVuID  
LEFT JOIN dbo.NS_DsChucDanh    AS cdk    ON nvk.ChucDanhID = cdk.ChucDanhID  
  
LEFT JOIN dbo.SYS_ThongTinCongTy AS cty   ON cty.ID = nv.CongTyID  
LEFT JOIN dbo.NhanVien           AS nkcty ON nkcty.NhanVienId = cty.NguoiKyHDLDID  
LEFT JOIN dbo.NS_DsQuocTich      AS qtkcty ON nkcty.QuocTichID = qtkcty.QuocTichID  
LEFT JOIN dbo.NS_DsChucVu        AS cvkcty ON nkcty.ChucVuID   = cvkcty.ChucVuID  
LEFT JOIN dbo.NS_DsChucDanh      AS cdkcty ON nkcty.ChucDanhID = cdkcty.ChucDanhID  
  
WHERE nvnv.NhanVienNghiViecID = @NhanVienNghiViecID;  
  
   
END  
  
GO
