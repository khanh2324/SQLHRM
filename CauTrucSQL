CREATE PROCEDURE [dbo].[ADD_BC_TongHopLuongTheoThang_ADCo] 
	@CostID int, @TuNgay datetime, @DenNgay datetime , @DangNhapID int

AS
BEGIN

	 --declare @CostID int = 0, @TuNgay datetime = '2025/8/01', @DenNgay datetime = '2025/08/31', @DangNhapID int = 3115
	set @TuNgay = DATEFROMPARTS(year(@TuNgay), month(@TuNgay), 1)
	set @DenNgay = DATEFROMPARTS(year(@DenNgay), month(@DenNgay), 1)
	declare @Date date = convert(char(2), month(@DenNgay)) + '/25/' + convert(char(4), year(@DenNgay))
	

	select 
		  a.NhomCostCentral, a.CostCentral
		, count(a.MaNV) as SoLuong, sum(a.LuongGop) as LuongGop, sum(a.PCTrachNhiem) as PCTrachNhiem, sum(a.PCViTri) as PCViTri
		, sum(a.PCDiLai) as PCDiLai, sum(a.PCDocHai) as PCDocHai, sum(a.PCKhac) as PCKhac, sum (a.PCBuaAn) as PCBuaAn
		, sum(a.ThuongThang) as ThuongThang, sum(a.ThuongKM) as ThuongKM, sum(a.LuongLamThemCoBan) as LuongLamThemCoBan
		, sum (a.LuongLamThemChenhLech) as LuongLamThemChenhLech, sum(a.LuongTraThemCaDem) as LuongTraThemCaDem
		, sum(a.ChenhLechThang1) as ChenhLechThang1, sum(a.ThuongKPI) as ThuongKPI, sum (a.LuongThang13) as LuongThang13
		, sum(a.ThuongNam) as ThuongNam, sum(a.CongKhac) as CongKhac, sum(a.TruTruocThue) as TruTruocThue, sum (a.TongPhaiTra) as TongPhaiTra

		, sum(a.TongBHNV) as TongBHNV, sum(a.TongBHCTY) as TongBHCTY, sum(a.TongBHNV_CTY) as TongBHNV_CTY
		--, 11000000 as MucGiamTruGiaCanh, 4400000 as MucGiamTruNguoiPhuThuoc
		, sum(a.MucGiamTruGiaCanh) as MucGiamTruGiaCanh
		, sum(a.MucGiamTruNguoiPhuThuoc) as MucGiamTruNguoiPhuThuoc
		, sum(a.SoNguoiPhuThuoc) as SoNguoiPhuThuoc
		, sum(a.ThuNhapChiuThue) as ThuNhapChiuThue, sum(a.MucThuePhaiNop) as MucThuePhaiNop, sum(a.ThuNhapSauThue) as ThuNhapSauThue
		, sum (a.PhiCongDoanCaNhan) as PhiCongDoanCaNhan, sum(a.PhiCongDoanCTY) as PhiCongDoanCTY, sum(a.TienTruSauThue) as TienTruSauThue
		, sum(a.CongKhacSauThue) as CongKhacSauThue, sum (a.ThanhToan) as ThanhToan, sum(Final) as Final

	from (
		select 
			  nv.MaNhanVien as MaNV, nv.Ho + ' ' + nv.HoTen as TenNhanVien, bl_text.NhomCostCenter as NhomCostCentral, bl_text.CostCenter as CostCentral

			, isnull(bl.[TLNC_LCB], 0) as LuongGop
			, isnull(bl.[TLNC_PC_TrachNhiem], 0) as PCTrachNhiem, isnull(bl.[TLNC_PC_ViTri], 0) as PCViTri, isnull(bl.[TLNC_PC_DiLai], 0) as PCDiLai
			, isnull(bl.[TLNC_PC_DocHai], 0) as PCDocHai, isnull(bl.[TLNC_PC_Khac], 0) as PCKhac, isnull(bl.[TLNC_PC_BuaAn], 0) as PCBuaAn
			, isnull(bl.[TLNC_ThuongThang], 0) as ThuongThang, isnull(bl.[Thuong_KM], 0) as ThuongKM
		
			, isnull(bl.[TLOT_ChieuThue], 0) as LuongLamThemCoBan, isnull(bl.[TLOT_MienThue], 0) as LuongLamThemChenhLech, isnull(bl.[TLOT_LamCaDem], 0) as LuongTraThemCaDem
			, isnull(bl.[Thuong_ChenhLechT1], 0) as ChenhLechThang1, isnull(bl.[Thuong_KPI], 0) as ThuongKPI, isnull(bl.[Thuong_LuongT13], 0) as LuongThang13
			, isnull(bl.[Thuong_Nam], 0) as ThuongNam, isnull(bl.[Thuong_CongTruocThue], 0) as CongKhac, isnull(bl.[Thuong_TruTruocThue], 0) as TruTruocThue
			, isnull(bl.[TongThuNhap], 0) as TongPhaiTra, isnull(bl.[BH_Tong_NLD], 0) as TongBHNV, isnull(bl.[BH_Tong_CTY], 0) as TongBHCTY

			, isnull(bl.[BH_Tong], 0) as TongBHNV_CTY, isnull(bl.[Tax_GiamTru_BanThan], 0) as MucGiamTruGiaCanh, isnull(bl.[Tax_GiamTru_NguoiPhuThuoc], 0) as MucGiamTruNguoiPhuThuoc
			, isnull(bl.[Tax_SoNguoiPhuThuoc], 0) as SoNguoiPhuThuoc, isnull(bl.[Tax_ThuNhapChiuThue], 0) as ThuNhapChiuThue, isnull(bl.[Tax_TongThue], 0) as MucThuePhaiNop
			, isnull(bl.[Tax_ThuNhapSauThue], 0) as ThuNhapSauThue, isnull(bl.[PSSThue_CongDoan_NLD], 0) as PhiCongDoanCaNhan
			, isnull(bl.[PSSThue_CongDoan_CTY], 0) as PhiCongDoanCTY, isnull(bl.[PSSThue_TruSauTax], 0) as TienTruSauThue
			, isnull(bl.[PSSThue_CongSauTax], 0) as CongKhacSauThue, isnull(bl.[ThucLinh], 0) as ThanhToan, isnull(bl.[ChiPhiCongTy], 0) as Final

			--, isnull(bl.[TLNC_TongLuong_Thuong_PhuCap], 0) as TongLuongVaPhuCap
			--, isnull(bl.[TLOT_TongLuongOT_LamCaDem], 0) as TongOTVaCaDem, isnull(bl.[Thuong_KM], 0) as ThuongKM			
			--, isnull(bl.[Thuong_TongThuong], 0) as TongThuongVaKhoanTruocThue
			--, isnull(bl.[BH_LuongBHXH], 0) as MucLuongBHXH, isnull(bl.[BH_LuongBHTN], 0) as MucLuongBHTN	
			--, isnull(bl.[Tax_ThuNhapTinhThue], 0) as ThuNhapTinhThue

		from NhanVien nv	
		cross apply dbo.fnt_GetPhongBanNhanVienTaiThoiDiem(nv.NhanVienID, @Date) pb1      
		left join dbo.PhongBan pb on pb.PhongBanID = pb1.PhongBanID
		left join v_SoDoToChucPhongBan v on pb.PhongBanID = v.PhongBanID
		left join NS_DsCapPhongBan cappb on pb.CapPhongBanID = cappb.CapPhongBanID
		cross apply dbo.fnt_GetChucVuNhanVienTaiThoiDiem(nv.NhanVienID, @Date) cv1  
		left join dbo.NS_DsChucVu cv on cv.ChucVuID = cv1.ChucVuID
		left join ADD_CostCenter Nhom on nv.CostCenterId = Nhom.CostCenterId
		left join ADD_CostCentral cost on nv.CostCentral = cost.CostCentralId
		left join NS_DsLoaiLaoDong lld on nv.LoaiLaoDongID = lld.LoaiLaoDongID
		right join -- Tổng lương của nhân viên từ tháng đến tháng theo bộ lọc
		(select * from (
			select bl.NhanVienID, ll.MaSo, ctl.TienLuong
			from NS_TL_BangLuong bl 
				left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID
				left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID
			where DATEFROMPARTS(ctl.NamTL, ctl.ThangTL, 1) between convert(date, @TuNgay) and convert(date, @DenNgay)
			) as A pivot ( sum(TienLuong) for MaSo in( [CC_TongCong], [TLNC_LCB], [TLNC_PC_TrachNhiem], [TLNC_PC_ViTri], [TLNC_PC_DiLai], [TLNC_PC_DocHai], [TLNC_PC_Khac], 
													   [TLNC_PC_BuaAn], [TLNC_ThuongThang], [TLNC_TongLuong_Thuong_PhuCap], [TLOT_ChieuThue], [TLOT_MienThue], 
													   [TLOT_LamCaDem], [TLOT_TongLuongOT_LamCaDem], [Thuong_KM], [Thuong_KPI], [Thuong_LuongT13], [Thuong_Nam], 
													   [Thuong_ChenhLechT1], [Thuong_CongTruocThue], [Thuong_TruTruocThue], [Thuong_TongThuong], [TongThuNhap], 
													   [BH_LuongBHXH], [BH_LuongBHTN], [BH_Tong_NLD], [BH_Tong_CTY], [BH_Tong], 
													   [Tax_ThuNhapChiuThue], [Tax_GiamTru_BanThan], [Tax_GiamTru_NguoiPhuThuoc], [Tax_SoNguoiPhuThuoc], [Tax_ThuNhapTinhThue], 
													   [Tax_TongThue], [Tax_ThuNhapSauThue], [PSSThue_CongDoan_NLD], [PSSThue_CongDoan_CTY], [PSSThue_TruSauTax], 
													   [PSSThue_CongSauTax], [ThucLinh], [ChiPhiCongTy]   ) ) as B
		) as bl on nv.NhanVienID = bl.NhanVienID	
		 left join  
			 (select b.*,ADD_CostCenter.CostCenterId CostCenterId,ADD_CostCentral.CostCentralId CostCentralId from (  
				  select bl.NhanVienID, bl.Thang, bl.Nam, ll.MaSo, ctl.TienLuongStr  
				  from NS_TL_BangLuong bl   
					  left join NS_TL_ChiTietLuong ctl on bl.BangLuongID = ctl.BangLuongID  
					  left join NS_TL_LoaiLuong ll on ctl.LoaiLuongID = ll.LoaiLuongID   
				  Where (1=1)  and DATEFROMPARTS(ctl.NamTL, ctl.ThangTL, 1) between convert(date, @TuNgay) and convert(date, @DenNgay)
				  ) as A pivot ( max(TienLuongStr) for MaSo in( [CapBac], [NhomCostCenter], [CostCenter] ) ) as B  
				  left join ADD_CostCentral on ADD_CostCentral.TenCostCentral=b.CostCenter
				  left join ADD_CostCenter on ADD_CostCenter.Ten=b.NhomCostCenter
				 ) as bl_text on nv.NhanVienID = bl_text.NhanVienID  

		where (1=1)
		and (bl_text.CostCentralId = @CostID or @CostID = -1001 or @CostID = 0)
		AND pb.PhongBanID NOT IN (SELECT valu FROM dbo.GetPhongBanChilds(191))
	--	and pb.PhongBanID in (select valu from GetPhongBanChild_WUser(@PhongBanID, @DangNhapID) )

	) a
	group by a.NhomCostCentral, a.CostCentral
	order by a.NhomCostCentral, a.CostCentral



END

